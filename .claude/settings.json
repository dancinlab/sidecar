{
  "_note": "self-dogfooding GUARDS only — inject(prefs/recommend/easy/commons/architecture) 는 전역 ~/.harness/cli 1벌로 단일화(중복주입 방지). repo-전용 load 줄만 잔존.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "CLAUDE_TOOL_INPUT=\"$CLAUDE_TOOL_INPUT\" bash bin/harness pre bash"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "CLAUDE_TOOL_INPUT=\"$CLAUDE_TOOL_INPUT\" bash bin/harness pre write"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash bin/harness post edit \"$CLAUDE_FILE_PATH\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash bin/harness load inject"
          }
        ]
      }
    ]
  }
}