// @allow-bare-exec
// wilson-hexa-first-warn :: session_start.hexa
//
// SessionStart hook. The PreToolUse deny is silently dropped under
// defaultMode:bypassPermissions (Claude Code design — bypass is a user-
// owned trust toggle). For bypass users the only effective block is
// managed-settings.json — which lives in a root-owned dir and takes
// precedence over bypassPermissions. This hook nudges the user toward
// /wilson-hexa-first-warn:enforce when that file is absent.
//
// Output schema (only when nudge is warranted):
//   { "hookSpecificOutput": { "hookEventName": "SessionStart",
//                             "additionalContext": "<one line>" } }
//
// Silent (exit 0, no stdout) when:
//   - SIDECAR_NO_HEXA_FIRST_WARN_SESSION_HINT=1 (or WILSON_ variant)
//   - SIDECAR_NO_HEXA_FIRST_WARN=1 (master opt-out, respected here too)
//   - managed-settings.json exists AND already contains a deny entry
//     for at least one protected ext (heuristic: substring "Write(**/*."
//     present anywhere in the file)
//
// No file is written; this hook only reads and reports.

fn protected_substring() -> string {
    // any deny entry the user installed via /enforce begins with this.
    return "\"Write(**/*."
}

fn managed_path() -> string {
    let raw = exec("uname -s 2>/dev/null").trim()
    if raw == "Darwin" { return "/Library/Application Support/ClaudeCode/managed-settings.json" }
    if raw == "Linux"  { return "/etc/claude-code/managed-settings.json" }
    return ""
}

fn file_exists(path: string) -> bool {
    if path.len() == 0 { return false }
    let out = exec("[ -f " + shell_q(path) + " ] && echo 1 || echo 0").trim()
    return out == "1"
}

fn file_contains(path: string, needle: string) -> bool {
    if path.len() == 0 { return false }
    let out = exec("grep -F " + shell_q(needle) + " " + shell_q(path) + " 2>/dev/null | head -1").trim()
    return out.len() > 0
}

fn main() {
    // Master opt-outs.
    if env("SIDECAR_NO_HEXA_FIRST_WARN").len() > 0 { return }
    if env("WILSON_NO_HEXA_FIRST_WARN").len() > 0 { return }
    if env("SIDECAR_NO_HEXA_FIRST_WARN_SESSION_HINT").len() > 0 { return }
    if env("WILSON_NO_HEXA_FIRST_WARN_SESSION_HINT").len() > 0 { return }

    let mgr = managed_path()
    if mgr.len() == 0 { return }   // unsupported platform — stay silent

    // Already enforced? Stay silent.
    if file_exists(mgr) && file_contains(mgr, protected_substring()) { return }

    // Nudge — one line of additionalContext.
    let msg = "HEXA_FIRST_WARN_SESSION_HINT { managed_settings_absent: "
        + mgr
        + ", note: PreToolUse deny is silently ignored under defaultMode:bypassPermissions; OS-level enforce via /wilson-hexa-first-warn:enforce (one-time sudo install), optout: SIDECAR_NO_HEXA_FIRST_WARN_SESSION_HINT=1 }"

    println("{")
    println("  \"hookSpecificOutput\": {")
    println("    \"hookEventName\": \"SessionStart\",")
    println("    \"additionalContext\": " + json_quote(msg))
    println("  }")
    println("}")
}

// ── helpers ─────────────────────────────────────────────────────────

fn shell_q(s: string) -> string {
    let mut out = []
    out.push("'")
    let mut i = 0
    while i < s.len() {
        let c = s[i]
        if c == '\'' {
            out.push("'\"'\"'")
        } else {
            out.push(s.substring(i, i + 1))
        }
        i = i + 1
    }
    out.push("'")
    return out.join("")
}

// Minimal JSON string quoter — escapes ", \ and control chars; the
// message we emit contains only ASCII printable, so this is sufficient.
fn json_quote(s: string) -> string {
    let mut out = []
    out.push("\"")
    let mut i = 0
    while i < s.len() {
        let c = s[i]
        if c == '"' { out.push("\\\"") }
        else if c == '\\' { out.push("\\\\") }
        else if c == '\n' { out.push("\\n") }
        else if c == '\r' { out.push("\\r") }
        else if c == '\t' { out.push("\\t") }
        else { out.push(s.substring(i, i + 1)) }
        i = i + 1
    }
    out.push("\"")
    return out.join("")
}
