#!/bin/sh
# sidecar — CLI for the sidecar Claude Code marketplace.
#
# usage:
#   sidecar init      Scaffold project.tape + CLAUDE.md symlink + LATTICE_POLICY.md here.
#   sidecar sync      Pull latest marketplace + cache copy + patch installed_plugins.json.
#   sidecar --help    Show this help.

set -eu

show_help() {
  sed -n '2,7p' "$0" | sed 's/^#\{0,1\} \{0,1\}//'
}

# Absolute path of the sidecar repo root (this script lives in <root>/bin/sidecar,
# follow symlinks so it works when `sidecar` is symlinked onto PATH).
sidecar_root() {
  self="$0"
  while [ -L "$self" ]; do
    link=$(readlink "$self")
    case "$link" in
      /*) self="$link" ;;
      *)  self="$(dirname "$self")/$link" ;;
    esac
  done
  CDPATH='' cd -- "$(dirname "$self")/.." && pwd
}

case "${1:-}" in
  ""|-h|--help)
    show_help
    exit 0
    ;;
esac

VERB="$1"; shift

case "$VERB" in
  init)
    if [ -e project.tape ]; then
      echo "sidecar: project.tape already exists — refusing to overwrite" >&2
      exit 1
    fi
    NAME=$(basename "$PWD")
    cat > project.tape <<TAPE
@V := "tape" :: spec [active]
  version = "1.2"

@I := "$NAME" :: identity [active]
  kind   = "<one line — what this project is>"
  brief  = "<2-4 sentences — purpose · scope · why it exists>"
  parent = "<org / parent project>"
  ssot   = "<canonical location>"
  layout = "
    $NAME/
    ├── ...
    └── ...
  "

@D := "$NAME" :: governance [active]
  do   = "..."
  dont = "..."
TAPE
    if [ -e CLAUDE.md ] && [ ! -L CLAUDE.md ]; then
      mv CLAUDE.md CLAUDE.md.bak
      echo "sidecar: existing CLAUDE.md backed up to CLAUDE.md.bak"
    elif [ -L CLAUDE.md ]; then
      rm CLAUDE.md
    fi
    ln -s project.tape CLAUDE.md
    echo "sidecar: created project.tape · CLAUDE.md → project.tape (symlink)"
    # LATTICE_POLICY.md — cross-project real-limits-first policy, carried by sidecar.
    if [ -e LATTICE_POLICY.md ]; then
      echo "sidecar: LATTICE_POLICY.md already exists — left untouched"
    else
      LATTICE_SRC="$(sidecar_root)/LATTICE_POLICY.md" || LATTICE_SRC=""
      if [ -n "$LATTICE_SRC" ] && [ -f "$LATTICE_SRC" ]; then
        cp "$LATTICE_SRC" LATTICE_POLICY.md
        echo "sidecar: created LATTICE_POLICY.md (real-limits-first policy)"
      else
        echo "sidecar: warning — LATTICE_POLICY.md source not found; skipped" >&2
      fi
    fi
    echo "sidecar: edit project.tape to fill in @I and @D blocks"
    ;;
  sync)
    MP="${HOME}/.claude/plugins/marketplaces/sidecar"
    CACHE="${HOME}/.claude/plugins/cache/sidecar"
    JSON="${HOME}/.claude/plugins/installed_plugins.json"
    if [ ! -d "$MP/.git" ]; then
      echo "sidecar sync: marketplace not installed at $MP" >&2
      exit 1
    fi
    git -C "$MP" pull origin main >/dev/null 2>&1 || { echo "sidecar sync: marketplace pull failed" >&2; exit 1; }
    SHA=$(git -C "$MP" rev-parse HEAD)
    python3 - "$MP" "$CACHE" "$JSON" "$SHA" <<'PY'
import json, pathlib, shutil, sys, datetime
mp, cache, json_p, sha = (pathlib.Path(a) if i < 3 else a for i, a in enumerate(sys.argv[1:5]))
shutil.copy2(json_p, str(json_p) + ".bak")
manifest = json.loads((mp / ".claude-plugin/marketplace.json").read_text())
installed = json.loads(json_p.read_text())
now = datetime.datetime.now(datetime.timezone.utc).strftime("%Y-%m-%dT%H:%M:%S.%fZ")
synced = []
for p in manifest["plugins"]:
    name, ver = p["name"], p["version"]
    src = None
    for sub in ("hooks", "skills", "commands"):
        cand = mp / sub / name
        if cand.exists():
            src = cand; break
    if src is None:
        continue
    dest = cache / name / ver
    if not dest.exists():
        dest.mkdir(parents=True, exist_ok=True)
        for item in src.iterdir():
            if item.is_dir():
                shutil.copytree(item, dest / item.name, dirs_exist_ok=True)
            else:
                shutil.copy2(item, dest / item.name)
    key = f"{name}@sidecar"
    cur = installed["plugins"].get(key, [{}])[0] if installed["plugins"].get(key) else {}
    if cur.get("version") != ver or cur.get("gitCommitSha") != sha:
        installed["plugins"][key] = [{
            "scope": "user",
            "installPath": str(dest),
            "version": ver,
            "installedAt": cur.get("installedAt", now),
            "lastUpdated": now,
            "gitCommitSha": sha,
        }]
        synced.append(f"{name}@{ver}")
json_p.write_text(json.dumps(installed, indent=2) + "\n")
print(f"sidecar sync: {len(synced)} plugin(s) updated · HEAD={sha[:7]}")
for s in synced:
    print(f"  ✓ {s}")
PY
    ;;
  *)
    echo "sidecar: unknown verb '$VERB'" >&2
    echo "  valid verbs: init · sync" >&2
    exit 1
    ;;
esac
