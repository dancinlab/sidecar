#!/bin/sh
# sidecar — CLI for the sidecar Claude Code marketplace.
#
# usage:
#   sidecar init        Scaffold project.tape + CLAUDE.md symlink + LATTICE_POLICY.md here.
#   sidecar sync        Pull marketplace + refresh cache + installed_plugins.json + enable plugins.
#   sidecar sign <key>  Mint a user sign-off token unlocking agent edits to a sign-gated file (commons · project · gitignore · paths) for 5 min.
#   sidecar profile [<name>]  Show, or set, the enable profile (minimal · hexa · full). Set re-applies the install.
#   sidecar enable <plugin>   Force-enable one plugin regardless of profile (per-plugin override). Re-applies.
#   sidecar disable <plugin>  Force-disable one plugin regardless of profile (per-plugin override). Re-applies.
#   sidecar reset <plugin>    Drop a plugin's override so it follows the profile again. Re-applies.
#   sidecar mirror      Refresh ~/.claude/commands/ mirrors so plugin commands are bare-invocable (`Skill("imagine")` instead of `Skill("imagine:imagine")`). Auto-runs at the tail of `sync`.
#   sidecar shadow [plan]  Drop the forced `plugin:command` namespace (#15882): mirror+disable every command/skill plugin (hook/mcp kept), splicing SKILL.md triggers into the bare command so it stays lossless. `plan` = dry-run. Re-asserted at the tail of `sync`.
#   sidecar unshadow    Revert shadow — re-enable the shadowed plugins (namespaced again) + remove created skill mirrors.
#   sidecar paths       Show / add / remove path prefixes in the LOCAL-EXECUTION WHITELIST (~/.sidecar/local-paths). pool-route forces any Bash cmd whose argv contains a `/`-prefix matching a registered prefix to run LOCAL (skip pool routing). Sub-forms: `paths` = list · `paths add` = register cwd · `paths add <dir>` = register an absolute-resolved dir · `paths rm <prefix>` = remove. add/rm are SIGN-GATED (key `paths`: `! sidecar sign paths` first) since the list overrides pool-route. Seeded on first use with sidecar's own cache + repo paths.
#   sidecar reap        Reap stale `hexa-lsp` servers (idle > 2h) — fork-storm hygiene. Dry-run by default; `reap --kill` terminates them. Never touches claude (@D s9) or active hexa runs.
#   sidecar handoff     Cross-project handoff registry (~/.sidecar/handoff/handoff.jsonl) — the single SSOT for cross-repo gap/patch/bug/RFC handoffs (commons g11·g36·g48·g59·g60; retires the per-repo INBOX domain). Sub-forms: `handoff add <repo> <text...>` = append an open entry · `handoff ls [<repo>]` = table (filter by repo) · `handoff done <id>` = flip status → done · `handoff` = counts summary. JSONL store, repo-external, portable via $HOME.
#   sidecar mount       Code-tier sshfs manager — edit a remote repo locally, build on the remote's LOCAL fs. Config ~/.sidecar/codetier.conf. Sub-forms: `mount` = list+status · `mount add <name> <host>:<dir> [<mnt>]` · `mount rm <name>` · `mount up [name]` · `mount down [name]` (alias `sidecar unmount`) · `mount build <name> <cmd...>` = run on remote via ssh (mount-path build = slow). Generic: any host:repo, not project-bound.
#   sidecar --help      Show this help.

set -eu

show_help() {
  sed -n '2,19p' "$0" | sed 's/^#\{0,1\} \{0,1\}//'
}

# Mirror plugin commands to ~/.claude/commands/ so they're bare-invocable
# without the `plugin:` namespace. Refreshed on every `sidecar sync` tail so
# mirrors track plugin updates. Overwrites: the mirror IS the plugin command —
# customize the plugin source, not the user-level mirror.
do_mirror() {
  DST="$HOME/.claude/commands"
  SRC="$HOME/.claude/plugins/cache/sidecar"
  if [ ! -d "$SRC" ]; then
    echo "sidecar mirror: no cache at $SRC — skipped" >&2
    return 0
  fi
  mkdir -p "$DST"
  n=0
  for d in "$SRC"/*/; do
    [ -d "$d" ] || continue
    V=$(ls -1 "$d" 2>/dev/null | sort -V | tail -1)
    [ -z "$V" ] && continue
    cdir="$d$V/commands"
    [ -d "$cdir" ] || continue
    for cmd in "$cdir"/*.md; do
      [ -f "$cmd" ] || continue
      cp "$cmd" "$DST/$(basename "$cmd")"
      n=$((n+1))
    done
  done
  echo "sidecar mirror: $n command(s) → $DST"
}

# Sign-off token store: `sidecar sign <key>` mints ~/.sidecar/signs/<key>.sign
# (current epoch); the sign-guard hook denies agent edits to a gated governance
# file unless a token < SIGN_TTL seconds old exists. Keep SIGN_TTL in lockstep
# with `TTL` in hooks/sign-guard/bin/_sign_guard.hexa.
SIGN_DIR="$HOME/.sidecar/signs"
SIGN_TTL=300
# The `local` key is a SEPARATE concern: it is pool-route's runtime force-local
# token (`! sidecar sign local`), whose TTL is enforced by `_local_signed()` in
# hooks/pool-route/bin/_pool_route.hexa (LOCAL_SIGN_TTL). 0.9.3 raised it to
# 30min (build-covering — a local corpus build runs 10-20min). The governance
# SIGN_TTL above is unaffected. `sign_ttl_for <key>` returns the right TTL so
# the mint message + `--list` remaining-time display match the gate that
# actually enforces the token. Keep LOCAL_SIGN_TTL in lockstep with pool-route.
LOCAL_SIGN_TTL=1800
sign_ttl_for() { if [ "$1" = "local" ]; then echo "$LOCAL_SIGN_TTL"; else echo "$SIGN_TTL"; fi; }

# Fresh, valid sign token for <key>? Mirrors `_signed()` in the sign-guard hook
# (hooks/sign-guard/bin/_sign_guard.hexa). Used to gate state-mutating verbs
# (e.g. `paths add/rm`) on a real USER sign-off — the agent cannot self-mint
# (the sign-guard hook hard-denies the agent's own `sidecar sign`).
sign_fresh() {
  _sf="$SIGN_DIR/$1.sign"
  [ -f "$_sf" ] || return 1
  _sm=$(cat "$_sf" 2>/dev/null || echo 0); : "${_sm:=0}"
  [ "$(( $(date +%s) - _sm ))" -le "$(sign_ttl_for "$1")" ]
}

# Absolute path of the sidecar repo root (this script lives in <root>/bin/sidecar,
# follow symlinks so it works when `sidecar` is symlinked onto PATH).
sidecar_root() {
  self="$0"
  while [ -L "$self" ]; do
    link=$(readlink "$self")
    case "$link" in
      /*) self="$link" ;;
      *)  self="$(dirname "$self")/$link" ;;
    esac
  done
  CDPATH='' cd -- "$(dirname "$self")/.." && pwd
}

# re-apply the local install (recomputes enabledPlugins from the active profile
# + per-plugin overrides). Used by the profile / enable / disable / reset verbs.
apply_install() {
  _root=$(sidecar_root)
  if ! command -v hexa >/dev/null 2>&1; then
    echo "sidecar: hexa not on PATH — choice saved; run 'sidecar sync' to apply it" >&2
    exit 1
  fi
  [ -f "$_root/install.hexa" ] || { echo "sidecar: install.hexa not found at $_root" >&2; exit 1; }
  exec hexa run "$_root/install.hexa"
}

case "${1:-}" in
  ""|-h|--help)
    show_help
    exit 0
    ;;
esac

VERB="$1"; shift

case "$VERB" in
  init)
    if [ -e project.tape ]; then
      echo "sidecar: project.tape already exists — refusing to overwrite" >&2
      exit 1
    fi
    NAME=$(basename "$PWD")
    cat > project.tape <<TAPE
@V := "tape" :: spec [active]
  version = "1.2"

@I := "$NAME" :: identity [active]
  kind   = "<one line — what this project is>"
  brief  = "<2-4 sentences — purpose · scope · why it exists>"
  parent = "<org / parent project>"
  ssot   = "<canonical location>"
  layout = "
    $NAME/
    ├── ...
    └── ...
  "

@D := "$NAME" :: governance [active]
  do   = "..."
  dont = "..."
TAPE
    if [ -e CLAUDE.md ] && [ ! -L CLAUDE.md ]; then
      mv CLAUDE.md CLAUDE.md.bak
      echo "sidecar: existing CLAUDE.md backed up to CLAUDE.md.bak"
    elif [ -L CLAUDE.md ]; then
      rm CLAUDE.md
    fi
    ln -s project.tape CLAUDE.md
    echo "sidecar: created project.tape · CLAUDE.md → project.tape (symlink)"
    # LATTICE_POLICY.md — cross-project real-limits-first policy, carried by sidecar.
    if [ -e LATTICE_POLICY.md ]; then
      echo "sidecar: LATTICE_POLICY.md already exists — left untouched"
    else
      LATTICE_SRC="$(sidecar_root)/LATTICE_POLICY.md" || LATTICE_SRC=""
      if [ -n "$LATTICE_SRC" ] && [ -f "$LATTICE_SRC" ]; then
        cp "$LATTICE_SRC" LATTICE_POLICY.md
        echo "sidecar: created LATTICE_POLICY.md (real-limits-first policy)"
      else
        echo "sidecar: warning — LATTICE_POLICY.md source not found; skipped" >&2
      fi
    fi
    echo "sidecar: edit project.tape to fill in @I and @D blocks"
    ;;
  mount|unmount|umount)
    # CODE-TIER mount manager — edit a remote repo over sshfs on THIS
    # workstation while builds/measurements run on the remote's LOCAL fs
    # (mount-path build = slow, so `mount build` routes over ssh). Generic:
    # any host:repo, not tied to one project. Config = ~/.sidecar/codetier.conf
    # (line-based `name|host:remote_dir|mountpoint`; `#`/blank tolerated).
    CT_CONF="$HOME/.sidecar/codetier.conf"
    mkdir -p "$HOME/.sidecar"
    [ -e "$CT_CONF" ] || : > "$CT_CONF"
    CT_OPTS="reconnect,defer_permissions,noappledouble,ServerAliveInterval=15,ServerAliveCountMax=3"
    ct_lookup() { # $1=name → echoes "host:remote_dir|mountpoint"
      while IFS= read -r line || [ -n "$line" ]; do
        case "$line" in ""|\#*) continue ;; esac
        n=${line%%|*}; rest=${line#*|}
        [ "$n" = "$1" ] && { printf '%s\n' "$rest"; return 0; }
      done < "$CT_CONF"
      return 1
    }
    ct_is_mounted() { mount | grep -q " on $1 (macfuse"; }  # $1=mountpoint
    ct_up() { # $1=name $2=src(host:dir) $3=mnt
      if ct_is_mounted "$3"; then echo "✅ $1: already mounted ($3)"; return 0; fi
      mkdir -p "$3"
      umount -f "$3" 2>/dev/null || true
      diskutil unmount force "$3" 2>/dev/null || true   # clear ghost mount
      sshfs "$2" "$3" -o "$CT_OPTS,volname=$1" || { echo "❌ $1: sshfs failed" >&2; return 1; }
      sleep 1
      ct_is_mounted "$3" && echo "✅ $1: mounted → $3" || { echo "❌ $1: not mounted after sshfs" >&2; return 1; }
    }
    ct_down() { # $1=mnt
      umount "$1" 2>/dev/null || diskutil unmount force "$1" 2>/dev/null || umount -f "$1" 2>/dev/null || true
      ct_is_mounted "$1" && { echo "❌ still mounted: $1" >&2; return 1; } || echo "✅ unmounted: $1"
    }
    # `unmount`/`umount` are shorthand for `mount down`
    if [ "$VERB" != "mount" ]; then set -- down "$@"; fi
    SUB="${1:-list}"; [ $# -gt 0 ] && shift
    case "$SUB" in
      ""|list|status)
        n=0
        while IFS= read -r line || [ -n "$line" ]; do
          case "$line" in ""|\#*) continue ;; esac
          name=${line%%|*}; rest=${line#*|}; src=${rest%%|*}; mnt=${rest#*|}
          if ct_is_mounted "$mnt"; then st="✅ mounted"; else st="·  down"; fi
          printf '%-14s %-28s %-22s %s\n' "$name" "$src" "$mnt" "$st"
          n=$((n+1))
        done < "$CT_CONF"
        if [ "$n" -eq 0 ]; then
          echo "sidecar mount: no code-tiers configured — add one:"
          echo "  sidecar mount add <name> <host>:<remote_dir> [<mountpoint>]"
        fi
        ;;
      add)
        NAME="${1:-}"; SRC="${2:-}"; MNT="${3:-$HOME/mnt/$NAME}"
        [ -n "$NAME" ] && [ -n "$SRC" ] || { echo "usage: sidecar mount add <name> <host>:<remote_dir> [<mountpoint>]" >&2; exit 2; }
        case "$SRC" in *:*) : ;; *) echo "sidecar mount: <src> must be host:remote_dir" >&2; exit 2 ;; esac
        if ct_lookup "$NAME" >/dev/null; then echo "sidecar mount: '$NAME' already configured (rm first)" >&2; exit 1; fi
        printf '%s|%s|%s\n' "$NAME" "$SRC" "$MNT" >> "$CT_CONF"
        echo "sidecar mount: added '$NAME' → $SRC at $MNT"
        echo "  bring up:  sidecar mount up $NAME"
        ;;
      rm|remove)
        NAME="${1:-}"; [ -n "$NAME" ] || { echo "usage: sidecar mount rm <name>" >&2; exit 2; }
        tmp="${CT_CONF}.tmp.$$"; : > "$tmp"
        while IFS= read -r line || [ -n "$line" ]; do
          case "$line" in ""|\#*) printf '%s\n' "$line" >> "$tmp"; continue ;; esac
          [ "${line%%|*}" = "$NAME" ] || printf '%s\n' "$line" >> "$tmp"
        done < "$CT_CONF"
        mv -f "$tmp" "$CT_CONF"; echo "sidecar mount: removed '$NAME' (mountpoint left as-is)"
        ;;
      up)
        TARGET="${1:-}"; rc=0
        while IFS= read -r line || [ -n "$line" ]; do
          case "$line" in ""|\#*) continue ;; esac
          name=${line%%|*}; rest=${line#*|}; src=${rest%%|*}; mnt=${rest#*|}
          [ -n "$TARGET" ] && [ "$TARGET" != "$name" ] && continue
          ct_up "$name" "$src" "$mnt" || rc=1
        done < "$CT_CONF"
        exit $rc
        ;;
      down)
        TARGET="${1:-}"; rc=0
        while IFS= read -r line || [ -n "$line" ]; do
          case "$line" in ""|\#*) continue ;; esac
          name=${line%%|*}; rest=${line#*|}; mnt=${rest#*|}
          [ -n "$TARGET" ] && [ "$TARGET" != "$name" ] && continue
          ct_down "$mnt" || rc=1
        done < "$CT_CONF"
        exit $rc
        ;;
      build)
        NAME="${1:-}"; [ -n "$NAME" ] || { echo "usage: sidecar mount build <name> <cmd...>" >&2; exit 2; }
        shift
        REST=$(ct_lookup "$NAME") || { echo "sidecar mount: unknown tier '$NAME'" >&2; exit 1; }
        SRC=${REST%%|*}; HOST=${SRC%%:*}; RDIR=${SRC#*:}
        [ $# -gt 0 ] || { echo "usage: sidecar mount build <name> <cmd...>" >&2; exit 2; }
        exec ssh "$HOST" "cd ~/$RDIR && $*"
        ;;
      *)
        echo "sidecar mount: unknown subcommand '$SUB'" >&2
        echo "  verbs: list | add <name> <host>:<dir> [<mnt>] | rm <name> | up [name] | down [name] | build <name> <cmd...>" >&2
        exit 2
        ;;
    esac
    ;;
  sync)
    # Delegate to install.hexa — the single source of truth for local-install
    # setup: marketplace pull + version cache + installed_plugins.json AND
    # enabledPlugins. Patching installed_plugins.json alone left every synced
    # plugin installed-but-disabled (no command/hook/skill loaded); the enable
    # step is what makes `sidecar sync` a complete ship-cycle tail.
    ROOT=$(sidecar_root)
    # Self-update (PR#9): keep the hx-managed package in lockstep with
    # origin/main BEFORE delegating to install.hexa. Without this, the user's
    # `sidecar sync` runs whatever install.hexa landed in $ROOT at the last
    # `hx install sidecar` — meaning improvements to install.hexa (e.g. the
    # marketplace-clone branch-guard and the PR#9 force-reset itself) never
    # take effect on its own user base until they manually reinstall.
    #
    # Skipped only on real preconditions (no opt-out variable — project.tape
    # @D s11: a disable switch gets auto-flipped to silence the behavior):
    #   - $ROOT is not a git clone (e.g. dev tree without origin)
    #   - the working tree has dirty changes (preserve the dev's edits)
    if [ -d "$ROOT/.git" ]; then
      if [ -z "$(git -C "$ROOT" status --porcelain 2>/dev/null)" ]; then
        cur=$(git -C "$ROOT" branch --show-current 2>/dev/null || echo "")
        if [ "$cur" != "main" ] && [ -n "$cur" ]; then
          git -C "$ROOT" fetch origin main >/dev/null 2>&1 || true
          git -C "$ROOT" checkout main >/dev/null 2>&1 \
            || git -C "$ROOT" checkout -B main origin/main >/dev/null 2>&1 \
            || true
          echo "sidecar sync: hx-package realigned $cur → main"
        fi
        git -C "$ROOT" fetch origin main >/dev/null 2>&1 || true
        git -C "$ROOT" reset --hard origin/main >/dev/null 2>&1 || true
      fi
    fi
    if [ ! -f "$ROOT/install.hexa" ]; then
      echo "sidecar sync: install.hexa not found at $ROOT" >&2
      exit 1
    fi
    if ! command -v hexa >/dev/null 2>&1; then
      echo "sidecar sync: hexa not on PATH (install.hexa is a hexa-lang script)" >&2
      exit 1
    fi
    hexa run "$ROOT/install.hexa"
    do_mirror
    # Re-assert shadow if active: do_mirror overwrote spliced command mirrors
    # with the plain plugin copy, so re-splice + re-confirm the disable overrides
    # (idempotent; overrides already persisted so install.hexa above already
    # applied the disables). No-op when ~/.sidecar/shadowed.json is absent.
    if [ -f "$HOME/.sidecar/shadowed.json" ] && command -v hexa >/dev/null 2>&1; then
      hexa run "$ROOT/bin/_shadow.hexa" shadow >/dev/null 2>&1 || true
      echo "sidecar shadow: re-asserted (bare-only · namespace suppressed)"
    fi
    ;;
  mirror)
    do_mirror
    ;;
  shadow)
    _root=$(sidecar_root)
    command -v hexa >/dev/null 2>&1 || { echo "sidecar: hexa not on PATH" >&2; exit 1; }
    if [ "${1:-}" = plan ]; then
      exec hexa run "$_root/bin/_shadow.hexa" plan
    fi
    hexa run "$_root/bin/_shadow.hexa" shadow || exit 1
    echo "sidecar shadow: applying (disabling namespaced plugins)…"
    apply_install
    ;;
  unshadow)
    _root=$(sidecar_root)
    command -v hexa >/dev/null 2>&1 || { echo "sidecar: hexa not on PATH" >&2; exit 1; }
    hexa run "$_root/bin/_shadow.hexa" unshadow || exit 1
    echo "sidecar unshadow: applying (re-enabling plugins)…"
    apply_install
    ;;
  sign)
    # User sign-off gate. The sign-guard hook hard-denies agent edits to a
    # gated file (commons.tape · project.tape · .gitignore) unless a fresh
    # token exists. This mints / lists / clears those tokens.
    #
    #   sidecar sign <key>          mint a 5-min token for <key>  (commons · project · gitignore · paths)
    #   sidecar sign  | --list      show active tokens + remaining validity
    #   sidecar sign clear [<key>]  remove one / all tokens
    SUB="${1:-}"
    case "$SUB" in
      ""|--list|list|status)
        echo "sidecar sign — gated governance files need YOUR sign-off before the agent may edit them."
        echo "  mint:   sidecar sign <key>       (keys: commons · project · gitignore · paths)"
        echo "  clear:  sidecar sign clear [<key>]"
        now=$(date +%s)
        found=0
        if [ -d "$SIGN_DIR" ]; then
          for f in "$SIGN_DIR"/*.sign; do
            [ -e "$f" ] || continue
            found=1
            k=$(basename "$f" .sign)
            mint=$(cat "$f" 2>/dev/null || echo 0)
            : "${mint:=0}"
            left=$(( $(sign_ttl_for "$k") - (now - mint) ))
            if [ "$left" -gt 0 ]; then
              echo "  active: $k — valid ${left}s"
            else
              echo "  active: $k — EXPIRED"
            fi
          done
        fi
        [ "$found" -eq 0 ] && echo "  active: (none)"
        ;;
      clear)
        KEY="${2:-}"
        if [ -n "$KEY" ]; then
          rm -f "$SIGN_DIR/$KEY.sign"
          echo "sidecar sign: cleared token '$KEY'"
        else
          rm -f "$SIGN_DIR"/*.sign 2>/dev/null || true
          echo "sidecar sign: cleared all tokens"
        fi
        ;;
      *)
        KEY="$SUB"
        # ── Layer B · OPT-IN human-terminal gate (default OFF) ──────────────
        # A sign token is the ROOT OF TRUST for the whole governance gate, so
        # the mint must come from a real human at a terminal — never the agent.
        #
        # ACTIVE enforcement lives in the sign-guard PreToolUse hook, which
        # hard-denies `sidecar sign <key>` AND any write under ~/.sidecar/signs/
        # across every Claude Code tool surface (Bash tool · slash command's
        # `!`backtick` · interactive `!` bang all route through the Bash tool).
        #
        # This is the stronger SECOND layer: require a controlling terminal
        # (/dev/tty) for the mint. Empirically the agent's Bash tool runs with
        # NO controlling TTY (verified: /dev/tty not openable, `[ -t 0 ]` false),
        # while a human's real shell has one — so this catches even an
        # OBFUSCATED mint that slips past the hook's command parser (e.g.
        # `s=sign; sidecar $s project`, `eval`, a wrapper script): any agent
        # tool execution lacks /dev/tty regardless of how the string is shaped.
        #
        # OPT-IN (export SIDECAR_SIGN_REQUIRE_TTY=1) to keep the user's own sign
        # frictionless by default. This is ADDITIVE strictness, NOT an opt-OUT
        # that disables a guard (project.tape @D s11 forbids the latter): when
        # unset it falls back to the hook, never below it.
        if [ -n "${SIDECAR_SIGN_REQUIRE_TTY:-}" ]; then
          if ( exec </dev/tty ) 2>/dev/null; then
            printf 'sidecar sign: confirm you are the human user — retype the key (%s): ' "$KEY" >/dev/tty
            IFS= read -r _confirm </dev/tty || _confirm=""
            if [ "$_confirm" != "$KEY" ]; then
              echo "sidecar sign: ✗ confirmation mismatch — mint of '$KEY' aborted." >&2
              exit 1
            fi
          else
            echo "sidecar sign: ✗ no controlling terminal — refusing to mint '$KEY'." >&2
            echo "  Minting requires a real interactive terminal (a human shell)." >&2
            echo "  An agent tool / pipe / \`!\` bang has no /dev/tty — that is why you see this." >&2
            exit 1
          fi
        fi
        mkdir -p "$SIGN_DIR"
        date +%s > "$SIGN_DIR/$KEY.sign"
        _ttl_min=$(( $(sign_ttl_for "$KEY") / 60 ))
        if [ "$KEY" = "local" ]; then
          echo "sidecar sign: ✅ signed 'local' — pool-route will force EVERY command local (no pool routing) for the next ${_ttl_min} minutes."
          echo "  (build-covering window since 0.9.3; clear early with: sidecar sign clear local)"
        else
          echo "sidecar sign: ✅ signed '$KEY' — the agent may edit the file gated under '$KEY' for the next ${_ttl_min} minutes."
          echo "  (sign-guard will allow it until the token expires; clear early with: sidecar sign clear $KEY)"
        fi
        ;;
    esac
    ;;
  profile)
    # multi-user enable profile. install.hexa reads ~/.sidecar/profile (default
    # full = everything) and enables a plugin iff its tier is in the profile.
    PROF_FILE="$HOME/.sidecar/profile"
    SUB="${1:-}"
    if [ -z "$SUB" ]; then
      cur=$(cat "$PROF_FILE" 2>/dev/null || echo "full")
      echo "sidecar profile: ${cur:-full}"
      echo "  available: minimal (core only) · hexa (core + hexa-lang) · full (everything) · master (full + creator-only · needs ~/.sidecar/master)"
      echo "  set: sidecar profile <name>   ·   per-plugin: sidecar enable|disable|reset <plugin>"
      _root=$(sidecar_root)
      if command -v hexa >/dev/null 2>&1 && [ -f "$_root/bin/_overrides.hexa" ]; then
        echo "  per-plugin overrides:"
        hexa run "$_root/bin/_overrides.hexa" show 2>/dev/null
      fi
      exit 0
    fi
    case "$SUB" in
      minimal|hexa|full|master) ;;
      *) echo "sidecar profile: unknown '$SUB' — pick: minimal · hexa · full · master" >&2; exit 1 ;;
    esac
    mkdir -p "$HOME/.sidecar"
    printf '%s\n' "$SUB" > "$PROF_FILE"
    echo "sidecar profile → $SUB · applying…"
    apply_install
    ;;
  enable|disable)
    PLUG="${1:-}"
    [ -n "$PLUG" ] || { echo "usage: sidecar $VERB <plugin>" >&2; exit 1; }
    _root=$(sidecar_root)
    command -v hexa >/dev/null 2>&1 || { echo "sidecar: hexa not on PATH" >&2; exit 1; }
    val=true; [ "$VERB" = disable ] && val=false
    hexa run "$_root/bin/_overrides.hexa" set "$PLUG" "$val" || exit 1
    echo "sidecar $VERB: $PLUG (per-plugin override) · applying…"
    apply_install
    ;;
  reset)
    PLUG="${1:-}"
    [ -n "$PLUG" ] || { echo "usage: sidecar reset <plugin>" >&2; exit 1; }
    _root=$(sidecar_root)
    command -v hexa >/dev/null 2>&1 || { echo "sidecar: hexa not on PATH" >&2; exit 1; }
    hexa run "$_root/bin/_overrides.hexa" clear "$PLUG" || exit 1
    echo "sidecar reset: $PLUG → follows the profile · applying…"
    apply_install
    ;;
  paths)
    # LOCAL-EXECUTION WHITELIST — path-prefix list. pool-route reads
    # ~/.sidecar/local-paths and forces any Bash cmd whose argv contains a
    # `/`-prefixed token starting with a registered prefix to run LOCAL
    # (skip pool routing). The whitelist is ITSELF the opt-in — no env
    # opt-out exists (project.tape @D s11).
    #
    # State file: ~/.sidecar/local-paths (line-based; `#` comments + blank
    # lines tolerated and preserved on rm). Atomic writes via tmp + mv.
    # Seeded on first call with sidecar's own cache + repo so the router
    # never bounces sidecar's own hexa invocations.
    PATHS_FILE="$HOME/.sidecar/local-paths"
    mkdir -p "$HOME/.sidecar"
    # Seed default prefixes when the file is ABSENT (not when empty — an
    # explicit empty file means the user cleared it on purpose).
    if [ ! -e "$PATHS_FILE" ]; then
      tmp="${PATHS_FILE}.tmp.$$"
      {
        printf '%s\n' "$HOME/.claude/plugins/cache/sidecar/"
        printf '%s\n' "$HOME/core/sidecar/"
      } > "$tmp" && mv -f "$tmp" "$PATHS_FILE"
    fi
    SUB="${1:-}"
    # Mutating the LOCAL-EXECUTION WHITELIST is SIGN-GATED (key: `paths`). This
    # list OVERRIDES pool-route — any registered prefix forces a command LOCAL,
    # skipping the pool — so add/rm need a fresh USER sign-off. Listing stays
    # open. The agent cannot self-mint (sign-guard hook); the human runs
    # `! sidecar sign paths`. No env opt-out (project.tape @D s11). Direct
    # edits to ~/.sidecar/local-paths are gated by the sign-guard hook too.
    case "$SUB" in
      add|rm|remove|del|delete)
        if ! sign_fresh paths; then
          echo "sidecar paths: refused — add/rm is SIGN-GATED (key: paths)." >&2
          echo "  This list overrides pool-route (a registered prefix forces commands LOCAL)," >&2
          echo "  so changing it needs YOUR sign-off — the agent cannot self-mint." >&2
          echo "  Run  ! sidecar sign paths   in your terminal, then retry within 5 min." >&2
          exit 1
        fi
        ;;
    esac
    case "$SUB" in
      ""|list|show)
        n=0
        while IFS= read -r line || [ -n "$line" ]; do
          case "$line" in
            ""|\#*) continue ;;
          esac
          printf '%s\n' "$line"
          n=$((n+1))
        done < "$PATHS_FILE"
        echo "sidecar paths: $n prefix(es) registered at $PATHS_FILE"
        ;;
      add)
        ARG="${2:-}"
        if [ -z "$ARG" ]; then
          DIR="$(pwd)"
        else
          if [ ! -d "$ARG" ]; then
            echo "sidecar paths: refused — '$ARG' is not an existing directory" >&2
            exit 1
          fi
          DIR=$(CDPATH='' cd -- "$ARG" && pwd) || { echo "sidecar paths: refused — cannot resolve '$ARG' to an absolute path" >&2; exit 1; }
        fi
        # Canonical form: trailing slash so prefix-match is unambiguous.
        case "$DIR" in
          */) PREFIX="$DIR" ;;
          *)  PREFIX="$DIR/" ;;
        esac
        # refuse if already present (exact-line match, comments/blanks skipped)
        while IFS= read -r line || [ -n "$line" ]; do
          case "$line" in
            ""|\#*) continue ;;
          esac
          if [ "$line" = "$PREFIX" ]; then
            echo "sidecar paths: refused — '$PREFIX' already registered" >&2
            exit 1
          fi
        done < "$PATHS_FILE"
        tmp="${PATHS_FILE}.tmp.$$"
        cp "$PATHS_FILE" "$tmp" && printf '%s\n' "$PREFIX" >> "$tmp" && mv -f "$tmp" "$PATHS_FILE"
        echo "sidecar paths: + $PREFIX"
        ;;
      rm|remove|del|delete)
        ARG="${2:-}"
        if [ -z "$ARG" ]; then
          echo "usage: sidecar paths rm <prefix>" >&2
          exit 1
        fi
        # exact-line match (skip comments/blanks for the find — but preserve them on write)
        found=0
        while IFS= read -r line || [ -n "$line" ]; do
          case "$line" in
            ""|\#*) continue ;;
          esac
          if [ "$line" = "$ARG" ]; then
            found=1
            break
          fi
        done < "$PATHS_FILE"
        if [ "$found" -eq 0 ]; then
          echo "sidecar paths: refused — '$ARG' not registered (use 'sidecar paths' to list)" >&2
          exit 1
        fi
        tmp="${PATHS_FILE}.tmp.$$"
        : > "$tmp"
        while IFS= read -r line || [ -n "$line" ]; do
          if [ "$line" = "$ARG" ]; then continue; fi
          printf '%s\n' "$line" >> "$tmp"
        done < "$PATHS_FILE"
        mv -f "$tmp" "$PATHS_FILE"
        echo "sidecar paths: - $ARG"
        ;;
      *)
        echo "usage: sidecar paths [list | add [<dir>] | rm <prefix>]" >&2
        exit 1
        ;;
    esac
    ;;
  reap)
    # Stale-process reaper — fork-storm hygiene. A `hexa-lsp` language server
    # orphaned by a closed editor lingers idle for hours; it is not a fork-storm
    # by itself but these accumulate. `reap` lists stale ones (a `hexa-lsp` idle
    # longer than REAP_AGE_SECS); `reap --kill` (or `reap kill`) terminates them.
    # claude is NEVER touched (project.tape @D s9); ACTIVE hexa runs are never
    # touched (the pool-route fork-storm cap throttles those preventively, so the
    # reaper only sweeps leftover LSP cruft). Dry-run by default — look first.
    REAP_AGE_SECS=7200
    DO_KILL=0
    case "${1:-}" in --kill|kill) DO_KILL=1 ;; esac
    CANDS=$(ps -Ao pid,etime,pcpu,comm | awk -v thresh="$REAP_AGE_SECS" '
      /hexa-lsp/ && !/claude/ && !/awk/ {
        n=split($2,a,"[-:]"); s=0;
        if(n==2)s=a[1]*60+a[2];
        else if(n==3)s=a[1]*3600+a[2]*60+a[3];
        else if(n==4)s=a[1]*86400+a[2]*3600+a[3]*60+a[4];
        if(s>=thresh) printf "%s\t%s\t%s\t%s\n", $1, $2, $3, $4
      }')
    _hrs=$(( REAP_AGE_SECS / 3600 ))
    if [ -z "$CANDS" ]; then
      echo "sidecar reap: no stale hexa-lsp (idle > ${_hrs}h) — nothing to reap."
      exit 0
    fi
    n=$(printf '%s\n' "$CANDS" | grep -c .)
    echo "sidecar reap: ${n} stale hexa-lsp (idle > ${_hrs}h · claude excluded · active hexa runs untouched):"
    printf '  %-8s %-12s %-5s %s\n' PID ELAPSED %CPU COMM
    printf '%s\n' "$CANDS" | while IFS="$(printf '\t')" read -r pid et cpu comm; do
      [ -n "$pid" ] || continue
      printf '  %-8s %-12s %-5s %s\n' "$pid" "$et" "$cpu" "$comm"
    done
    if [ "$DO_KILL" -eq 1 ]; then
      printf '%s\n' "$CANDS" | while IFS="$(printf '\t')" read -r pid et cpu comm; do
        [ -n "$pid" ] || continue
        if kill "$pid" 2>/dev/null; then echo "  ✓ killed $pid"; else echo "  ✗ could not kill $pid (already gone?)"; fi
      done
      echo "sidecar reap: reaped ${n} stale hexa-lsp."
    else
      echo "sidecar reap: DRY RUN — run 'sidecar reap --kill' to terminate the ${n} above."
    fi
    ;;
  handoff)
    # Cross-project handoff registry — the single SSOT for cross-repo gap /
    # patch / bug / RFC handoffs (commons.tape g11 · g36 · g48 · g59 · g60).
    # Retires the per-repo INBOX domain: one JSONL store under $HOME/.sidecar
    # (repo-external runtime state · portable via $HOME · structured carrier per
    # project.tape s2 — JSONL, not markdown). One line per entry:
    #   {id, ts, from, to, kind, text, status}
    # Sub-forms:
    #   sidecar handoff add <repo> <text...>  append an open entry to <repo>
    #   sidecar handoff ls [<repo>]           table of entries (filtered by repo)
    #   sidecar handoff done <id>             flip an entry's status → done
    #   sidecar handoff                       counts summary (open / done / total)
    HANDOFF_DIR="$HOME/.sidecar/handoff"
    HANDOFF_FILE="$HANDOFF_DIR/handoff.jsonl"
    SUB="${1:-}"
    [ "$#" -gt 0 ] && shift
    command -v python3 >/dev/null 2>&1 || { echo "sidecar handoff: python3 not on PATH" >&2; exit 1; }
    case "$SUB" in
      add)
        TO="${1:-}"
        [ "$#" -gt 0 ] && shift
        if [ -z "$TO" ] || [ "$#" -eq 0 ]; then
          echo "usage: sidecar handoff add <repo> <text...>" >&2
          exit 1
        fi
        FROM=$(basename "$PWD")
        mkdir -p "$HANDOFF_DIR"
        HANDOFF_FILE="$HANDOFF_FILE" HF_TO="$TO" HF_FROM="$FROM" HF_TEXT="$*" \
          python3 - <<'PY'
import json, os, sys, time, uuid, tempfile
path = os.environ["HANDOFF_FILE"]
entry = {
    "id": uuid.uuid4().hex[:8],
    "ts": int(time.time()),
    "from": os.environ["HF_FROM"],
    "to": os.environ["HF_TO"],
    "kind": "handoff",
    "text": os.environ["HF_TEXT"],
    "status": "open",
}
line = json.dumps(entry, ensure_ascii=False) + "\n"
# Atomic append: read existing, rewrite via tmp + os.replace (no torn line).
prev = ""
if os.path.exists(path):
    with open(path, encoding="utf-8") as fh:
        prev = fh.read()
d = os.path.dirname(path)
fd, tmp = tempfile.mkstemp(dir=d)
try:
    with os.fdopen(fd, "w", encoding="utf-8") as fh:
        fh.write(prev)
        fh.write(line)
    os.replace(tmp, path)
except Exception:
    os.path.exists(tmp) and os.unlink(tmp)
    raise
print("sidecar handoff: added %s → %s  [%s]" % (entry["from"], entry["to"], entry["id"]))
print("  " + entry["text"])
PY
        ;;
      ls|list)
        FILTER="${1:-}"
        if [ ! -f "$HANDOFF_FILE" ]; then
          echo "sidecar handoff: registry empty (no entries yet)."
          exit 0
        fi
        HANDOFF_FILE="$HANDOFF_FILE" HF_FILTER="$FILTER" python3 - <<'PY'
import json, os, time
path = os.environ["HANDOFF_FILE"]
flt = os.environ.get("HF_FILTER", "")
rows = []
with open(path, encoding="utf-8") as fh:
    for ln in fh:
        ln = ln.strip()
        if not ln:
            continue
        try:
            e = json.loads(ln)
        except Exception:
            continue
        if flt and e.get("to") != flt:
            continue
        rows.append(e)
if not rows:
    print("sidecar handoff: no entries%s." % (" for '%s'" % flt if flt else ""))
    raise SystemExit(0)
def age(ts):
    d = int(time.time()) - int(ts)
    if d < 3600: return "%dm" % (d // 60)
    if d < 86400: return "%dh" % (d // 3600)
    return "%dd" % (d // 86400)
print("  %-8s %-6s %-12s %-12s %-4s %s" % ("ID", "STATUS", "FROM", "TO", "AGE", "TEXT"))
for e in rows:
    txt = e.get("text", "")
    if len(txt) > 50:
        txt = txt[:47] + "..."
    print("  %-8s %-6s %-12s %-12s %-4s %s" % (
        e.get("id", "?"), e.get("status", "?"),
        e.get("from", "?")[:12], e.get("to", "?")[:12],
        age(e.get("ts", 0)), txt))
op = sum(1 for e in rows if e.get("status") == "open")
print("  — %d entr%s (%d open · %d done)" % (
    len(rows), "y" if len(rows) == 1 else "ies", op, len(rows) - op))
PY
        ;;
      done)
        ID="${1:-}"
        if [ -z "$ID" ]; then
          echo "usage: sidecar handoff done <id>" >&2
          exit 1
        fi
        if [ ! -f "$HANDOFF_FILE" ]; then
          echo "sidecar handoff: registry empty — no '$ID' to close." >&2
          exit 1
        fi
        HANDOFF_FILE="$HANDOFF_FILE" HF_ID="$ID" python3 - <<'PY'
import json, os, sys, tempfile
path = os.environ["HANDOFF_FILE"]
target = os.environ["HF_ID"]
out, hit = [], False
with open(path, encoding="utf-8") as fh:
    for ln in fh:
        s = ln.strip()
        if not s:
            continue
        try:
            e = json.loads(s)
        except Exception:
            out.append(s)
            continue
        if e.get("id") == target:
            e["status"] = "done"
            hit = True
        out.append(json.dumps(e, ensure_ascii=False))
if not hit:
    sys.stderr.write("sidecar handoff: no entry with id '%s'\n" % target)
    raise SystemExit(1)
d = os.path.dirname(path)
fd, tmp = tempfile.mkstemp(dir=d)
try:
    with os.fdopen(fd, "w", encoding="utf-8") as fh:
        fh.write("\n".join(out) + "\n")
    os.replace(tmp, path)
except Exception:
    os.path.exists(tmp) and os.unlink(tmp)
    raise
print("sidecar handoff: closed [%s] → done" % target)
PY
        ;;
      ""|status)
        if [ ! -f "$HANDOFF_FILE" ]; then
          echo "sidecar handoff — cross-project handoff registry ($HANDOFF_FILE)"
          echo "  registry empty. add one: sidecar handoff add <repo> <text...>"
          exit 0
        fi
        HANDOFF_FILE="$HANDOFF_FILE" python3 - <<'PY'
import json, os
from collections import Counter
path = os.environ["HANDOFF_FILE"]
total = op = 0
by_repo = Counter()
with open(path, encoding="utf-8") as fh:
    for ln in fh:
        s = ln.strip()
        if not s:
            continue
        try:
            e = json.loads(s)
        except Exception:
            continue
        total += 1
        if e.get("status") == "open":
            op += 1
            by_repo[e.get("to", "?")] += 1
print("sidecar handoff — cross-project handoff registry")
print("  %d total · %d open · %d done" % (total, op, total - op))
if by_repo:
    print("  open by repo:")
    for repo, n in sorted(by_repo.items(), key=lambda kv: -kv[1]):
        print("    %-16s %d" % (repo, n))
print("  verbs: add <repo> <text...> · ls [<repo>] · done <id>")
PY
        ;;
      *)
        echo "usage: sidecar handoff [add <repo> <text...> | ls [<repo>] | done <id>]" >&2
        exit 1
        ;;
    esac
    ;;
  master)
    # creator-only marker. master-tier plugins enable ONLY while ~/.sidecar/master
    # exists (install.hexa gate). on = mint marker · off = remove · status = show.
    MK="$HOME/.sidecar/master"
    SUB="${1:-status}"
    case "$SUB" in
      on)  mkdir -p "$HOME/.sidecar"; printf '1\n' > "$MK"; echo "sidecar master: ON — ~/.sidecar/master minted · master-tier plugins now enable · applying…"; apply_install ;;
      off) rm -f "$MK"; echo "sidecar master: OFF — marker removed · master-tier plugins disabled · applying…"; apply_install ;;
      status|"") if [ -f "$MK" ]; then echo "sidecar master: ON (~/.sidecar/master present)"; else echo "sidecar master: OFF (no ~/.sidecar/master — master-tier plugins disabled)"; fi ;;
      *) echo "usage: sidecar master [on|off|status]" >&2; exit 1 ;;
    esac
    ;;
  *)
    echo "sidecar: unknown verb '$VERB'" >&2
    echo "  valid verbs: init · sync · mirror · shadow · unshadow · sign · profile · enable · disable · reset · paths · reap · handoff · master" >&2
    exit 1
    ;;
esac
