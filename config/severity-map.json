{
  "_doc": "Error signal → severity (block/defer/warn). block=fix now, defer=queue in errors.jsonl, warn=report only. Override per-repo via harness.config.json severityMapFile.",
  "fallback": "defer",
  "unknown_threshold": 30,
  "rules": {
    "lint_rule": {
      "L0-LOCKDOWN": "warn",
      "STALE": "warn",
      "CONVERGENCE-MISSING": "block",
      "CHANGELOG-MISSING": "block",
      "DOC-SCATTER": "warn",
      "DOC-NO-QUICKREF": "warn",
      "CLAUDE-MD-MISSING": "warn",
      "CLAUDE-MD-NO-DESC": "warn",
      "CLAUDE-MD-NO-TREE": "warn",
      "CLAUDE-MD-TREE-NO-DESC": "warn"
    },
    "build_kind": {
      "bash_nonzero": "defer",
      "tsc_error": "block",
      "test_fail": "block",
      "lint_error": "block",
      "build_fail": "block"
    },
    "runtime_signal": {
      "unknown": "defer"
    }
  }
}
