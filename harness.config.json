{
  "project": "sidecar",
  "_note": "self-dogfooding — 엔진=repo 자신(submodule 없음). protectedBranches 미설정으로 자기 개발 흐름(main 직접 push) 보존. 번들 config/*.json 을 직접 규칙으로 사용.",
  "lockdown": {
    "files": [
      "cli/index.ts",
      "lib/paths.ts",
      "lib/config.ts",
      "lib/lockdown.ts",
      "modules/pre.ts"
    ],
    "fromMarkdown": "README.md",
    "onEditReminder": "sidecar 코어 편집 — CHANGELOG.md 동시 갱신 + 임시 repo 스모크 테스트."
  },
  "enforcementFile": "config/enforcement.json",
  "keywordsFile": "config/keywords.json",
  "severityMapFile": "config/severity-map.json",
  "verify": {
    "checks": [
      {
        "id": "typecheck",
        "cmd": "npx tsc --noEmit",
        "timeoutMs": 240000
      }
    ]
  },
  "lint": {
    "freshnessFiles": [],
    "injectCaps": {
      "config/commons.md": 13000,
      "config/recommend.md": 6500
    },
    "injectBudgetBytes": 22883,
    "injectBudgetExtra": [
      "CLAUDE.md"
    ],
    "changelog": {
      "file": "CHANGELOG.jsonl",
      "keep": 30,
      "triggerPattern": "\\.(ts)$",
      "ignore": [
        "(^|/)styles/",
        "(^|/)templates/",
        "(^|/)config/"
      ]
    }
  },
  "docs": {
    "scopeDirs": [
      "docs"
    ]
  },
  "guides": [
    "README.md",
    "CHANGELOG.md",
    "ARCHITECTURE.md",
    "docs/install.md",
    "docs/extending.md",
    "docs/languages.md"
  ],
  "ledger": {
    "staleSec": 3600
  }
}
