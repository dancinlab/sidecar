// _ai_api_guard.hexa — PreToolUse(Bash) hard block for raw AI-API
// calls when a sidecar CLI wraps the same operation.
//
// commons @D g50: AI features (image / search / transcript / …) route
// through the CLI wrapper first (/imagine, /research, …). Raw API/SDK
// is allowed only when no wrapper exists. This hook enforces that at
// the Bash layer.
//
// Detection (two patterns):
//
// (1) HTTP CLIs to an AI hostname:
//     first-token ∈ {curl, wget, http, httpie} AND command contains
//     one of the AI API hostnames (api.openai.com, api.anthropic.com,
//     fal.run, api.replicate.com, generativelanguage.googleapis.com).
//
// (2) inline-Python/JS verification probe:
//     first-token ∈ {python, python3, node, deno, bun} AND command
//     contains ` -c ` (python/node) OR ` -e ` (node/deno/bun) AND one
//     of the AI-SDK import substrings (`import openai`,
//     `import anthropic`, `import fal_client`, `import replicate`,
//     `import google.generativeai`, `require("openai"`, etc.).
//
// General SDK usage in committed code files (no -c/-e) passes through.
//
// (3) s14 capacity-relief detector (project.tape @D s14):
//     flag when a Bash command OR Write/Edit content SETS / EXPORTS /
//     WRITES an Anthropic API key as a Claude rate-limit / capacity
//     workaround — `ANTHROPIC_API_KEY=`, `export ANTHROPIC_API_KEY`,
//     `--api-key` wired for an anthropic invocation, or an
//     `ANTHROPIC_API_KEY` assignment written into a config / env file.
//     This is an ADVISORY (non-blocking additionalContext), NOT a deny:
//     setting ANTHROPIC_API_KEY can be legitimate outside a capacity
//     context, and repo philosophy is advisory > deny (only force-push
//     hard-denies). The advisory points to the SANCTIONED CLI routes —
//     account swap via /quota, CLI routers, Bedrock/Vertex backends.
//
// No opt-out by design (project.tape @D s11).

fn _read_stdin() -> string {
    return to_string(exec("cat"))
}

fn _allow() {
    exit(0)
}

fn _json_escape(s: string) -> string {
    let n = len(s)
    let mut i = 0
    let mut parts = []
    parts.push("\"")
    while i < n {
        let c = s[i]
        if c == "\"" { parts.push("\\\"") }
        else if c == "\\" { parts.push("\\\\") }
        else if c == "\n" { parts.push("\\n") }
        else if c == "\r" { parts.push("\\r") }
        else if c == "\t" { parts.push("\\t") }
        else {
            let k = char_code(c, 0)
            if k < 32 { parts.push(" ") }
            else { parts.push(c) }
        }
        i = i + 1
    }
    parts.push("\"")
    return parts.join("")
}

fn _deny(reason: string) {
    let payload = "{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"deny\",\"permissionDecisionReason\":" + _json_escape(reason) + "}}"
    println(payload)
    exit(0)
}

// _advise — non-blocking additionalContext (does NOT deny the tool call).
fn _advise(body: string) {
    let payload = "{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"additionalContext\":" + _json_escape(body) + "}}"
    println(payload)
    exit(0)
}

fn _tokens(s: string) -> array {
    let mut out = []
    let n = len(s)
    let mut i = 0
    let mut cur = ""
    while i < n {
        let c = s[i]
        if c == " " || c == "\t" || c == "\n" || c == "\r" {
            if len(cur) > 0 { out.push(cur); cur = "" }
        } else {
            cur = cur + c
        }
        i = i + 1
    }
    if len(cur) > 0 { out.push(cur) }
    return out
}

fn _is_http_cli(t: string) -> bool {
    if t == "curl" { return true }
    if t == "wget" { return true }
    if t == "http" { return true }
    if t == "httpie" { return true }
    return false
}

fn _has_ai_hostname(cmd: string) -> bool {
    if cmd.contains("api.openai.com") { return true }
    if cmd.contains("api.anthropic.com") { return true }
    if cmd.contains("fal.run") { return true }
    if cmd.contains("api.replicate.com") { return true }
    if cmd.contains("generativelanguage.googleapis.com") { return true }
    return false
}

fn _is_inline_runtime(t: string) -> bool {
    if t == "python" { return true }
    if t == "python3" { return true }
    if t == "node" { return true }
    if t == "deno" { return true }
    if t == "bun" { return true }
    return false
}

fn _has_inline_flag(cmd: string) -> bool {
    if cmd.contains(" -c ") { return true }
    if cmd.contains(" -e ") { return true }
    return false
}

// collapse whitespace + line-continuations (\n \r \t \) to single spaces so a
// split import (e.g. `import\` <newline> `openai`) still matches. Static-only —
// dynamic imports (`exec(x+' openai')`, base64) are NOT detectable, out of scope.
fn _norm(s: string) -> string {
    let mut out = []
    let n = len(s)
    let mut i = 0
    let mut prev_sp = false
    while i < n {
        let c = s[i]
        if c == " " || c == "\n" || c == "\r" || c == "\t" || c == "\\" {
            if !prev_sp { out.push(" "); prev_sp = true }
        } else {
            out.push(c); prev_sp = false
        }
        i = i + 1
    }
    return out.join("")
}

fn _has_ai_sdk_import(cmd: string) -> bool {
    if cmd.contains("import openai") { return true }
    if cmd.contains("from openai") { return true }
    if cmd.contains("import anthropic") { return true }
    if cmd.contains("from anthropic") { return true }
    if cmd.contains("import fal_client") { return true }
    if cmd.contains("from fal_client") { return true }
    if cmd.contains("import replicate") { return true }
    if cmd.contains("from replicate") { return true }
    if cmd.contains("import google.generativeai") { return true }
    if cmd.contains("from google.generativeai") { return true }
    if cmd.contains("require(\"openai\"") { return true }
    if cmd.contains("require('openai'") { return true }
    if cmd.contains("require(\"@anthropic-ai/") { return true }
    if cmd.contains("require('@anthropic-ai/") { return true }
    return false
}

// s14 (project.tape): detect an Anthropic API key being SET / EXPORTED /
// WRITTEN as a Claude capacity / rate-limit workaround. Operates on the
// whitespace-normalized text (Bash command OR Write/Edit content). Matches:
//   - `ANTHROPIC_API_KEY=` assignment / inline env-prefix
//   - `export ANTHROPIC_API_KEY`
//   - any other mention of `ANTHROPIC_API_KEY` (config / .env writes,
//     `setenv`, JSON key, etc.)
//   - `--api-key` wired alongside an anthropic invocation
// Pure-substring (static) scan — env-indirection / base64 is out of scope.
fn _is_s14_apikey(cmd: string) -> bool {
    if cmd.contains("ANTHROPIC_API_KEY") { return true }
    // `--api-key` flag wired for an anthropic call (claude CLI / SDK / host)
    if cmd.contains("--api-key") && cmd.contains("anthropic") { return true }
    return false
}

// _s14_advisory — the SANCTIONED capacity-relief routes (never API keys).
fn _s14_advisory() -> string {
    return "ai-api-guard (project.tape @D s14): wiring an `ANTHROPIC_API_KEY` (set / export / write to a config or env file) as a Claude rate-limit / capacity workaround is forbidden — API keys are pay-per-token and bypass the subscription.\n  Relieve capacity via the SANCTIONED CLI routes instead:\n    quota / account swap → `/quota:quota switch <account>` (5h/7d limits + live credential swap)\n    CLI routers         → route through a CLI-level Claude router\n    managed backends     → Bedrock / Vertex Claude backends (subscription-cap relief, CLI-routed)\n  This is an advisory, not a block — but s14 is `required active`. No opt-out by design (project.tape @D s11)."
}

// _ti_string — pull a string field out of tool_input, "" if absent / wrong type.
fn _ti_string(ti: map, key: string) -> string {
    if !has_key(ti, key) { return "" }
    let v = ti[key]
    if type_of(v) != "string" { return "" }
    return v
}

fn main() {
    let raw = _read_stdin()
    let mut payload = json_parse("{}")
    try { payload = json_parse(raw) } catch e { _allow() }
    if type_of(payload) != "map" { _allow() }

    if !has_key(payload, "tool_name") { _allow() }
    let tool = payload["tool_name"]
    if !has_key(payload, "tool_input") { _allow() }
    let ti = payload["tool_input"]
    if type_of(ti) != "map" { _allow() }

    // ---- Write / Edit path: s14 advisory only (content-string scan) ----
    if tool == "Write" || tool == "Edit" {
        // Write → content ; Edit → new_string ; MultiEdit / fallback → both.
        let body = _ti_string(ti, "content") + " " + _ti_string(ti, "new_string")
        let body_norm = _norm(body)
        if _is_s14_apikey(body_norm) {
            _advise(_s14_advisory())
        }
        _allow()
    }

    // ---- Bash path ----
    if tool != "Bash" { _allow() }
    let cmd0 = _ti_string(ti, "command")
    let cmd = cmd0.trim()
    if cmd == "" { _allow() }

    let toks = _tokens(cmd)
    if len(toks) < 1 { _allow() }
    let first = toks[0]
    let cmd_norm = _norm(cmd)   // line-continuation / whitespace-split evasion

    // (1) HTTP CLI to AI hostname
    if _is_http_cli(first) && _has_ai_hostname(cmd_norm) {
        let reason = "ai-api-guard (commons @D g50): `" + first + " … <AI hostname>` is a raw HTTP call to an AI provider — refused.\n  Use the sidecar CLI wrapper instead:\n    image generation → `/imagine <prompt-file> <out.png>` (g44 pinned gpt-image-2)\n    arxiv / YouTube → `/research:arxiv` / `/research:yt` (g43)\n    text/correctness → `hexa verify` (g5)\n  Raw API/SDK is allowed only when no wrapper exists. No opt-out by design."
        _deny(reason)
    }

    // (2) inline-runtime AI-SDK probe
    if _is_inline_runtime(first) && _has_inline_flag(cmd_norm) && _has_ai_sdk_import(cmd_norm) {
        let reason = "ai-api-guard (commons @D g50): inline `" + first + " -c/-e '… import <AI SDK> …'` is a raw AI-SDK probe — refused.\n  Use the sidecar CLI wrapper instead (/imagine · /research · /verify · …). Raw SDK is allowed only when no wrapper exists, and only when committed to a code file (no inline `-c`/`-e`). No opt-out by design."
        _deny(reason)
    }

    // (3) s14 capacity-relief — ANTHROPIC_API_KEY set/export/wired (ADVISORY)
    if _is_s14_apikey(cmd_norm) {
        _advise(_s14_advisory())
    }

    _allow()
}
