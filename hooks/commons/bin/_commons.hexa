// _commons.hexa — UserPromptSubmit + SessionStart + PreCompact + PostCompact
// hook. Emits commons.tape as additionalContext.
//
// The event name is read from the stdin payload's `hook_event_name` field
// (Claude Code sends it snake_case) and echoed back verbatim in
// `hookSpecificOutput.hookEventName` — the harness rejects a mismatch.

fn _read_stdin() -> string {
    return to_string(exec("cat"))
}

fn _read_file_safe(path: string) -> string {
    let mut out = ""
    try { out = to_string(read_file(path)) }
    catch e { out = "" }
    return out
}

fn _json_escape(s: string) -> string {
    let n = len(s)
    let mut i = 0
    let mut parts = []
    parts.push("\"")
    while i < n {
        let c = s[i]
        if c == "\"" { parts.push("\\\"") }
        else if c == "\\" { parts.push("\\\\") }
        else if c == "\n" { parts.push("\\n") }
        else if c == "\r" { parts.push("\\r") }
        else if c == "\t" { parts.push("\\t") }
        else {
            let k = char_code(c, 0)
            if k < 32 { parts.push(" ") }
            else { parts.push(c) }
        }
        i = i + 1
    }
    parts.push("\"")
    return parts.join("")
}

// Read the firing event from the payload — snake_case `hook_event_name` is
// the Claude Code input field; tolerate a camelCase variant too.
// hexa `println` truncates a single call at 4096 bytes; emit in <4096
// chunks via repeated `print` (chunks accumulate past the cap).
fn _emit(s: string) {
    let n = len(s)
    let mut i = 0
    while i < n {
        let mut e = i + 3000
        if e > n { e = n }
        print(s.substring(i, e))
        i = e
    }
    print("\n")
}

fn _event_of(payload: map) -> string {
    if has_key(payload, "hook_event_name") { return payload["hook_event_name"] }
    if has_key(payload, "hookEventName") { return payload["hookEventName"] }
    return ""
}

// Append a live `pool` roster snapshot to the injected context — host /
// os, one line each — so the model sees the host lineup without running
// `pool list` first. Roster source of truth is the `pool` CLI's
// `~/.pool/pool.json`. Every listed host is always-on (no enable toggle);
// pi5-akida exclusion is handled downstream in pool-route via name match.
// Empty / missing / unreadable → "".
fn _roster_snapshot() -> string {
    let home = env_var("HOME")
    if home == "" { return "" }
    let raw = _read_file_safe(home + "/.pool/pool.json")
    if raw == "" { return "" }
    let mut cfg = json_parse("{}")
    try { cfg = json_parse(raw) } catch e { return "" }
    if type_of(cfg) != "map" { return "" }
    if !has_key(cfg, "hosts") { return "" }
    let hosts = cfg["hosts"]
    if type_of(hosts) != "array" { return "" }
    if len(hosts) == 0 { return "" }

    // single-line CSV-ish form keeps the prepend small (hexa stdout caps at
    // 4095 B/fire; saving bytes here saves commons.tape tail rules from
    // truncation). Format: name[os] separated by " · ".
    let mut parts = []
    let mut i = 0
    while i < len(hosts) {
        let h = hosts[i]
        if type_of(h) == "map" {
            let mut name = ""
            if has_key(h, "name") { if type_of(h["name"]) == "string" { name = h["name"] } }
            if name != "" {
                let mut os = "linux"
                if has_key(h, "os") { if type_of(h["os"]) == "string" { os = h["os"] } }
                parts.push(name + "[" + os + "]")
            }
        }
        i = i + 1
    }
    if len(parts) == 0 { return "" }
    return "# pool (~/.pool/pool.json · `sidecar pool on <host> <cmd>` · g9): " + parts.join(" · ") + "\n\n"
}

// Append a live cwd `./pods.json` snapshot to the injected context — one
// line per active job, so the agent ALWAYS sees the per-project pod/job
// manifest without running `hexa cloud pods` first. The manifest is the
// /system control-tower SSOT (per-project, cwd-local; distinct from the
// global $HOME/.hexa-cloud/pods.jsonl billing/orphan registry). Without
// this snapshot the agent has historically been blind to the manifest
// and forgotten to register pods on launch — see Layer 2 (`pods-route`
// hook) for the matching auto-`--register` enforcement.
//
// 0.13.0 (CLOUD M10) — reads the GLOBAL M5 registry `~/.hx/cloud/active-pods.json`
// (cwd-independent · cost-bearing · always-relevant) instead of the cwd-local
// `./pods.json`. The M5 registry (hexa-lang `pod_registry.hexa`) is the canonical
// "what pods are alive + billing right now" SSOT — populated by `cloud rent`/`rm`.
// Schema: {"version":N,"pods":[{id,provider,status,ttl_sec,max_cost_usd,
// cumulative_cost_usd,...}]}. Absent/empty → "" (no rented pods = normal idle,
// no clutter). Present → `<id>[<provider>,<status>]` + `$<cost>` when cumulative
// spend > 0, so the agent always sees live billing without `hexa cloud list`.
fn _pods_snapshot() -> string {
    let home = env_var("HOME")
    if home == "" { return "" }
    let raw = _read_file_safe(home + "/.hx/cloud/active-pods.json")
    if raw == "" { return "" }
    let mut cfg = json_parse("{}")
    try { cfg = json_parse(raw) } catch e { return "" }
    if type_of(cfg) != "map" { return "" }
    if !has_key(cfg, "pods") { return "" }
    let pods = cfg["pods"]
    if type_of(pods) != "array" { return "" }
    if len(pods) == 0 { return "" }

    let mut parts = []
    let mut i = 0
    while i < len(pods) {
        let p = pods[i]
        if type_of(p) == "map" {
            let mut id = "?"
            if has_key(p, "id") { if type_of(p["id"]) == "string" { id = p["id"] } }
            let mut prov = "?"
            if has_key(p, "provider") { if type_of(p["provider"]) == "string" { prov = p["provider"] } }
            let mut status = "?"
            if has_key(p, "status") { if type_of(p["status"]) == "string" { status = p["status"] } }
            let mut tail = ""
            // cost flag — surface cumulative spend so a forgotten billing pod is visible
            if has_key(p, "cumulative_cost_usd") {
                let c = p["cumulative_cost_usd"]
                if type_of(c) == "float" { if c > 0.0 { tail = tail + ",$" + to_string(c) } }
                if type_of(c) == "int" { if c > 0 { tail = tail + ",$" + to_string(c) } }
            }
            // project attribution (cross-project down-guard SSOT) — empty/absent
            // project surfaces as ⚠unattributed so an unowned billing pod is loud.
            let mut project = ""
            if has_key(p, "project") { if type_of(p["project"]) == "string" { project = p["project"] } }
            let mut proj_tag = " @⚠unattributed"
            if project != "" { proj_tag = " @" + project }
            // purpose (free-form) — only rendered when present.
            let mut purpose_tag = ""
            if has_key(p, "purpose") {
                if type_of(p["purpose"]) == "string" {
                    if p["purpose"] != "" { purpose_tag = " · \"" + p["purpose"] + "\"" }
                }
            }
            parts.push(id + "[" + prov + "," + status + tail + "]" + proj_tag + purpose_tag)
        }
        i = i + 1
    }
    if len(parts) == 0 { return "" }
    return "# pods (~/.hx/cloud/active-pods.json · /system M5 registry · rented): " + parts.join(" · ") + "\n\n"
}

// 0.13.0 (CLOUD M10) — providers catalog one-liner from the M8 SSOT
// `~/.hx/cloud/providers.json` (the `cloud providers` decision reference).
// Present → `NN providers · cloud providers list`. Absent → "" (no clutter).
fn _providers_snapshot() -> string {
    let home = env_var("HOME")
    if home == "" { return "" }
    let raw = _read_file_safe(home + "/.hx/cloud/providers.json")
    if raw == "" { return "" }
    let mut cfg = json_parse("{}")
    try { cfg = json_parse(raw) } catch e { return "" }
    if type_of(cfg) != "map" { return "" }
    if !has_key(cfg, "providers") { return "" }
    let provs = cfg["providers"]
    if type_of(provs) != "map" { return "" }
    let tiers = keys(provs)
    let mut total = 0
    let mut ti = 0
    while ti < len(tiers) {
        let arr = provs[tiers[ti]]
        if type_of(arr) == "array" { total = total + len(arr) }
        ti = ti + 1
    }
    if total == 0 { return "" }
    return "# providers (~/.hx/cloud/providers.json · M8 카탈로그 · " + to_string(total) + "): `cloud providers list|fit|recommend`\n\n"
}

fn main() {
    let raw = _read_stdin()
    let mut payload = json_parse("{}")
    try { payload = json_parse(raw) } catch e { exit(0) }
    if type_of(payload) != "map" { exit(0) }

    let event = _event_of(payload)
    // No event name → cannot label the output safely; skip the injection.
    if event == "" { exit(0) }

    let root = env_var("CLAUDE_PLUGIN_ROOT")
    let body = _read_file_safe(root + "/commons.tape")
    // Snapshots are PREPENDED so the live state leads the payload:
    //   1. pool roster    (~/.pool/pool.json)              — host lineup
    //   2. pods registry  (~/.hx/cloud/active-pods.json)   — rented pods (M5 · billing)
    //   3. providers      (~/.hx/cloud/providers.json)     — catalog (M8 · decision ref)
    // On SessionStart only, the COMMANDS.md catalog is appended (once per
    // session, not every turn) so the agent sees the full cross-project
    // slash-command surface and can use it autonomously.
    let preamble = "# ⬇ BINDING governance layer — cross-project hard rules (commons.tape). MUST FOLLOW every reply · re-injected every turn so it never fades · NOT background context.\n\n"
    let mut full = _roster_snapshot() + _pods_snapshot() + _providers_snapshot() + preamble + body
    if event == "SessionStart" {
        let cat = _read_file_safe(root + "/COMMANDS.md")
        if cat != "" { full = full + "\n\n" + cat }
    }
    _emit("{\"hookSpecificOutput\":{\"hookEventName\":" + _json_escape(event) + ",\"additionalContext\":" + _json_escape(full) + "}}")
}
