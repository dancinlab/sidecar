@V := "tape" :: spec [active]
  version = "1.2"

@D g1 := "ai-native + canonical first" :: governance [required active]
  do   = "ai-native В· hexa-native first В· native + canonical patterns first when implementing (per language / framework)"

@D g3 := "minimal authoring + tables + ASCII" :: governance [required active]
  do   = "write & implement minimally В· use markdown tables actively В· use ASCII structure diagrams (tree В· box В· arrow) when shape/flow matters"
  dont = "prose-only В· verbose В· over-engineered"

@D g4 := "stacked PRs" :: governance [required active]
  do   = "stacked PRs (<200 lines В· 1 logical thing В· gh pr create --base previous-layer)"
  dont = "large multi-purpose PRs В· long-lived feature branches"

@D g5 := "verify via hexa CLI only" :: governance [required active]
  do   = "use `hexa verify` for correctness В· purity В· grade В· identity claims (paste the verdict VERBATIM)"
  dont = "LLM self-judge correctness without `hexa verify` В· cite sympy / PyPhi / Wolfram / Mathematica as primary evidence"

@D g6 := "hexa kick for gap discovery" :: governance [active]
  do   = "use `hexa kick --seed \"<expr>\" [--rounds N]` for gap breakthroughs В· discovery"

@D g7 := "consult hexa --help for unfamiliar verbs" :: governance [active]
  do   = "consult `hexa --help` for unfamiliar hexa CLI verbs"

@D g8 := "runpod dispatch via hexa-cloud (separate binary, NOT `hexa cloud`)" :: governance [required active]
  do   = "for runpod dispatch use `hexa-cloud {run|nohup|poll|copy-to|copy-from}` вЂ” SEPARATE BINARY at `hexa-lang/bin/hexa-cloud`, structured argv"
  dont = "raw `ssh` / `scp` for runpod dispatch В· `hexa cloud` invocation (no such subcommand; commons-pre-0.9.2 had this wrong)"

@D g9 := "pool + /inbox CLIs available" :: governance [active]
  do   = "know that `pool` (host roster + remote exec вЂ” pool list / add / on / status / install tailscale) and `/inbox` (cross-project handoff вЂ” list В· new <kind> <slug>) are available CLIs"

@D g10 := "Monitor tool for streaming" :: governance [active]
  do   = "use Claude Code's `Monitor` tool for streaming events from a background process (per-line stdout = notification)"
  dont = "`tail -f` / `sleep`-poll loops for background-event streaming"

@D g11 := "no gap workarounds вЂ” fix at source" :: governance [required active]
  do   = "file hexa-lang upstream gaps as `<hexa-lang-repo>/inbox/patches/<slug>.md` immediately on discovery"
  dont = "implement workarounds for known gaps (file an upstream inbox patch instead вЂ” fix at source, never paper over)"

@D g12 := "fan out parallel pods" :: governance [active]
  do   = "fan out up to 8 parallel pods when total wall time shrinks (compute / variants disjoint)"

@D g13 := "portable paths only" :: governance [required active]
  dont = "hardcoded absolute paths (use `$HOME` В· `${HOME}` В· relative paths В· `<repo-name>/<relpath>` notation)"

@D g14 := "5-count emoji for major events" :: governance [active]
  do   = "mark major events with 5-count emoji (рџ›ё*5 transcend / в­ђпёЏ*5 win / рџ”Ґ*5 breakthrough) вЂ” never on routine OK"

@D g15 := "current-state docs В· history in dedicated surfaces" :: governance [required active]
  do   = "write docs in completed-form (describe current state) вЂ” history goes in `CHANGELOG.md` (chronological) / `git log` (full audit trail)"
  dont = "mix migration history into living docs (no inline `replaces X` / `migrated from Y` / `archived YYYY-MM-DD`)"

@D g16 := "AGENTS.tape dormant В· don't touch" :: governance [required active]
  dont = "touch AGENTS.tape (kept dormant carry вЂ” user-request override only)"

@D g17 := "project.tape user-request only" :: governance [required active]
  dont = "touch project.tape unprompted (active project SSOT вЂ” read freely, but modify only on explicit user request)"

@D g18 := "bypass вЂ” auto-execute, don't punt" :: governance [required active]
  dont = "punt to user on clearly-OK agent-executable work (catalog: `next user action:` blocks В· `Should I proceed?` В· `Want me to check?` deferrals В· option-trees with obvious default В· over-clarification В· defer-by-waiting В· excessive recap) вЂ” self-check: interactive human input В· unauthorized destructive В· external visible В· explicit user-review request в†’ if all NO, just execute"

@D g19 := "project.tape вЂ” granular B form" :: governance [required active]
  do   = "when editing any `<project-root>/project.tape` (or commons-style multi-rule `.tape` carrier), use granular @D blocks вЂ” one rule per entry В· single concept В· do/dont only В· no `tool` / `usage` keys on multi-rule carriers (the v4 Sonnet bench showed they net-negative); single-rule isolated blocks like `@D ship` MAY use `tool` per tape v1.4 spec"
  dont = "monolithic `@D := \"<name>\" :: governance` block mashing many concepts into one do/dont string вЂ” that exceeds v1.2's 500-char/entry cap and dilutes LLM attention (v4 bench: granular 33/36 vs single-block 31/36)"

@D g20 := "no hardcoding В· implement generically" :: governance [required active]
  do   = "implement once, parameterize over instances В· code in one canonical home (single stdlib В· single dispatcher) В· manifest-driven extension (new instance = manifest only, no code change) В· universal generic path"
  dont = "hard-code per-instance / per-domain / per-tenant branches В· duplicate implementation across topical folders В· per-instance Producer / Dispatcher / Handler class family В· branch on instance name in the generic layer"

@D g21 := "no workaround / temp-fix as user choice вЂ” go straight to the proper fix" :: governance [required active]
  do   = "when the proper fix is identifiable, just implement it (the proper fix is THE action, not one option among many)"
  dont = "offer the user a menu like `quick patch vs proper refactor vs workaround` when the proper path is clear В· present workaround / temp-fix / band-aid as alternatives to be picked between"

@D g22 := "version discipline вЂ” bump SemVer + lockstep all version surfaces" :: governance [required active]
  do   = "any user-visible behavior change в†’ bump SemVer (patch = fix / new entry В· minor = new feature / format В· major = breaking) + update ALL version-bearing surfaces in the SAME commit (manifest В· README plugin row В· CHANGELOG В· marketplace В· cache В· etc.) + ship per project's ship cycle"
  dont = "ship behavior change without a version bump В· update some version surfaces but skip others (drift between files) В· skip the CHANGELOG entry"

@D g23 := "sidecar slash commands вЂ” use when applicable" :: governance [active]
  do   = "use sidecar slash commands when the situation fits вЂ” discovery: `/brainstorm` (depletion ideation) В· `/gap` (42-lens audit) В· `/kick` (hexa kick wrapper) В· `/verify` (hexa verify wrapper) В· workflow: `/inbox` (cross-project handoff) В· `/all-bg-go` (parallel fan-out) В· `/domain <NAME>` (UPPERCASE snapshot + log sister) В· `/inject` (mid-session sidecar refresh) В· `/prefs` (language settings) В· style: `/easy` (friendly response) В· research: `/research:arxiv` В· `/research:yt`"
