@D commons := "cross-project common" :: governance [required active]
  do   = "ai-native · english artifacts · korean response · write & implement minimally · use AGENTS.tape over CLAUDE.md · modify AGENTS.tape only on user request · stacked PRs (<200 lines · 1 logical thing · gh pr create --base previous-layer)"
  dont = "prose-only · non-english artifacts · verbose · over-engineered · create/edit CLAUDE.md directly · touch AGENTS.tape unprompted · large multi-purpose PRs · long-lived feature branches"
