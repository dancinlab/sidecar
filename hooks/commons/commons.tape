@D commons := "cross-project common" :: governance [required active]
  do   = "ai-native · english artifacts · korean response · use markdown tables actively in responses · write & implement minimally · treat .specify/memory/constitution.md as the substantive SSOT (CLAUDE.md is a Spec Kit wrapper) · use the Spec Kit pipeline (constitution → specify → plan → tasks → implement) for feature work · stacked PRs (<200 lines · 1 logical thing · gh pr create --base previous-layer) · use the hexa CLI `hexa verify` command for correctness · purity · grade · identity claims and paste the verdict verbatim · use `hexa kick` for gap breakthroughs · discovery exploration"
  dont = "prose-only · non-english artifacts · verbose · over-engineered · touch AGENTS.tape (kept dormant carry — user-request override only) · skip Spec Kit pipeline for >200-line features · large multi-purpose PRs · long-lived feature branches · LLM self-judge correctness without `hexa verify` · cite sympy / PyPhi / Wolfram / Mathematica as primary evidence"
