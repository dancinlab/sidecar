// _easy_auto.hexa — SessionStart + UserPromptSubmit + PreCompact + PostCompact
// auto-injector for the `easy` (friendly) response style.
//
// Reads ${CLAUDE_PLUGIN_ROOT}/styles/easy.<lang>.md per the user's response
// language (env EASY_LANG override, default `ko`) and emits the body as
// additionalContext so the 7-element friendly pattern is active from turn 0
// without the user having to call `/easy`. Falls back to easy.md (English
// base) when the lang variant is missing. No opt-out by design —
// emergency escape: EASY_LANG=off env to suppress this turn's inject.

fn _read_stdin() -> string {
    return to_string(exec("cat"))
}

fn _allow() {
    exit(0)
}

fn _json_str(s: string) -> string {
    let n = len(s)
    let mut i = 0
    let mut parts = []
    parts.push("\"")
    while i < n {
        let c = s[i]
        if c == "\"" { parts.push("\\\"") }
        else if c == "\\" { parts.push("\\\\") }
        else if c == "\n" { parts.push("\\n") }
        else if c == "\r" { parts.push("\\r") }
        else if c == "\t" { parts.push("\\t") }
        else {
            let k = char_code(c, 0)
            if k < 32 { parts.push(" ") }
            else { parts.push(c) }
        }
        i = i + 1
    }
    parts.push("\"")
    return parts.join("")
}

fn _event_of(payload: map) -> string {
    if has_key(payload, "hook_event_name") { return payload["hook_event_name"] }
    if has_key(payload, "hookEventName") { return payload["hookEventName"] }
    return ""
}

fn _env(name: string) -> string {
    let r = exec_with_status("printenv " + name)
    if r[1] != 0 { return "" }
    return r[0].trim()
}

fn main() {
    let raw = _read_stdin()
    let mut payload = json_parse("{}")
    try { payload = json_parse(raw) } catch e { _allow() }
    if type_of(payload) != "map" { _allow() }

    let event = _event_of(payload)
    if event == "" { _allow() }

    // emergency escape — EASY_LANG=off suppresses inject for this turn
    let lang_env = _env("EASY_LANG")
    if lang_env == "off" { _allow() }

    let plugin_root = _env("CLAUDE_PLUGIN_ROOT")
    if plugin_root == "" { _allow() }

    // resolve language: env override > default ko (sidecar prefs default)
    let mut lang = "ko"
    if lang_env != "" { lang = lang_env }

    // try styles/easy.<lang>.md; fall back to easy.md (English base)
    let primary = plugin_root + "/styles/easy." + lang + ".md"
    let fallback = plugin_root + "/styles/easy.md"
    let mut body = ""
    let mut src = ""
    try { body = read_file(primary); src = primary } catch e1 {
        try { body = read_file(fallback); src = fallback } catch e2 { _allow() }
    }
    if body == "" { _allow() }

    let header = "# response style: easy (auto-injected by easy-auto · " + src + ")\n\n"
                + "Apply the 7-element friendly pattern below to user-facing prose "
                + "this turn — icon · name · alias · plain-line · analogy · ASCII · "
                + "compare. Scope/exclusions per the canonical reference.\n\n"
                + "---\n\n"
    let context = header + body

    let out = "{\"hookSpecificOutput\":{\"hookEventName\":" + _json_str(event)
            + ",\"additionalContext\":" + _json_str(context) + "}}"
    println(out)
    exit(0)
}
