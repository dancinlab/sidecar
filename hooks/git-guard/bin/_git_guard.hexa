// _git_guard.hexa — PreToolUse(Bash) git-push safety guard.
//
// (1) DENY — force-type push (rewrites / bypasses shared history):
//   git push --force / -f
//   git push --force-with-lease
//   git push <remote> +<refspec>   (refspec-level force)
//
// (2) ADVISORY (non-blocking) — stale-base push. For a non-force
// `git push`, compute the current branch's divergence from the remote
// default branch (origin/HEAD, else origin/main). When the branch is
// >= STALE_BEHIND commits BEHIND that base, emit additionalContext: the
// base is stale, so files changed on the base since the cut may be
// silently reverted by this PR — and in a shared working dir this is
// the fingerprint of a concurrent agent swapping HEAD out from under
// you. Push still proceeds; this only surfaces the risk.
//
// (3) ADVISORY (non-blocking) — stale-base MERGE (anima #1105). The
// push-time check (2) is a backstop, but a `gh pr merge` (squash)
// reached main with a 35190-file revert-delete because no merge-time
// check existed. So when the command contains `gh pr merge` (and no
// `git push`), run the same divergence probe and warn before the merge
// lands. Stays advisory (guards-narrow-scope) — the real deny on mass
// deletion lives in pr-cycle-hook's deletion-sanity gate. Cross-repo
// (`--repo X`) merges are skipped (cwd HEAD is unrelated to that base).
//
// NO opt-out by design — no env var, no config file, no exception
// list. A guard you can switch off is a guard you will switch off;
// a mis-firing guard is fixed at the guard.

// Branch is flagged stale when it trails the remote default base by at
// least this many commits. Short-lived stacked PRs (the family norm)
// are cut fresh from main, so a branch this far behind is anomalous —
// the 37-behind/1-ahead branch-swap incident sits well above it.
let STALE_BEHIND = 20

fn _read_stdin() -> string {
    return to_string(exec("cat"))
}

fn _allow() {
    exit(0)
}

fn _json_escape(s: string) -> string {
    let n = len(s)
    let mut i = 0
    let mut parts = []
    parts.push("\"")
    while i < n {
        let c = s[i]
        if c == "\"" { parts.push("\\\"") }
        else if c == "\\" { parts.push("\\\\") }
        else if c == "\n" { parts.push("\\n") }
        else if c == "\r" { parts.push("\\r") }
        else if c == "\t" { parts.push("\\t") }
        else {
            let k = char_code(c, 0)
            if k < 32 { parts.push(" ") }
            else { parts.push(c) }
        }
        i = i + 1
    }
    parts.push("\"")
    return parts.join("")
}

fn _deny(reason: string) {
    let payload = "{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"deny\",\"permissionDecisionReason\":" + _json_escape(reason) + "}}"
    println(payload)
    exit(0)
}

// Non-blocking advisory — additionalContext only, NO permissionDecision,
// so the push still flows through its normal permission path.
fn _emit_advisory(text: string) {
    let payload = "{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"additionalContext\":" + _json_escape(text) + "}}"
    println(payload)
    exit(0)
}

fn _starts_with(s: string, prefix: string) -> bool {
    if len(prefix) > len(s) { return false }
    return s.substring(0, len(prefix)) == prefix
}

// strip ' and " so a quoted flag (e.g. `'--force-with-lease=x'` or `+"refspec"`)
// still tokenizes to its bare form and the force-push matcher can see it.
// Quoted whitespace then splits into separate tokens — harmless for flag /
// refspec detection (we only key off `--force*` tokens and a leading `+`).
fn _strip_quotes(s: string) -> string {
    let mut out = []
    let n = len(s)
    let mut i = 0
    while i < n {
        let c = s[i]
        if c != "'" && c != "\"" { out.push(c) }
        i = i + 1
    }
    return out.join("")
}

// whitespace-split into tokens
fn _tokens(s: string) -> array {
    let mut out = []
    let n = len(s)
    let mut i = 0
    let mut cur = ""
    while i < n {
        let c = s[i]
        if c == " " || c == "\t" || c == "\n" || c == "\r" {
            if len(cur) > 0 { out.push(cur); cur = "" }
        } else {
            cur = cur + c
        }
        i = i + 1
    }
    if len(cur) > 0 { out.push(cur) }
    return out
}

// Last `cd <dir>` target appearing before the `git push` token, so the
// divergence probe runs in the repo the push will actually target
// (e.g. `cd ~/core/demiurge && git push`). Empty when the push has no
// leading cd — the probe then runs in the hook's own cwd.
fn _cd_dir_before(toks: array, gp: int) -> string {
    let mut dir = ""
    let mut i = 0
    while i + 1 < gp {
        if toks[i] == "cd" { dir = toks[i + 1] }
        i = i + 1
    }
    return dir
}

// Non-blocking stale-base check for a non-force `git push`. Probes the
// target repo for branch + remote-default base + behind/ahead counts in
// a single shell round-trip; emits an advisory when behind >= STALE_BEHIND.
fn _stale_base_advisory(toks: array, gp: int) {
    let dir = _cd_dir_before(toks, gp)
    let mut prefix = ""
    if dir != "" { prefix = "cd " + dir + " 2>/dev/null && " }
    let body = "{ b=$(git rev-parse --abbrev-ref HEAD 2>/dev/null); d=$(git symbolic-ref -q --short refs/remotes/origin/HEAD 2>/dev/null || echo origin/main); c=$(git rev-list --left-right --count \"$d\"...HEAD 2>/dev/null); printf '%s\\n%s\\n%s\\n' \"$b\" \"$d\" \"$c\"; }"

    let mut out = ""
    try { out = to_string(exec(prefix + body)) } catch e { return }
    let lines = out.split("\n")
    if len(lines) < 3 { return }

    let branch = lines[0].trim()
    let base = lines[1].trim()       // e.g. "origin/main"
    let counts = lines[2].trim()     // "<behind>\t<ahead>"
    if branch == "" || branch == "HEAD" { return }   // no repo / detached
    if counts == "" { return }

    // remote-default short name — skip when we're pushing the base itself
    let mut base_name = base
    let slash = base.index_of("/")
    if slash >= 0 { base_name = base.substring(slash + 1, len(base)) }
    if branch == base_name { return }

    let parts = _tokens(counts)
    if len(parts) < 2 { return }
    let mut behind = 0
    let mut ahead = 0
    try { behind = to_int(parts[0]) } catch e { return }
    try { ahead = to_int(parts[1]) } catch e { ahead = 0 }
    if behind < STALE_BEHIND { return }

    let msg = "⚠ STALE-BASE PUSH — 현재 브랜치 '" + branch + "'는 " + base + "보다 " + to_string(behind) + "커밋 뒤처짐 (ahead " + to_string(ahead) + "). 베이스가 stale — " + base + "에서 그 이후 바뀐 파일은 이 PR 머지 시 옛 버전으로 덮여(silent revert) 되돌아갈 수 있음. 공유 워킹트리에서 동시 에이전트가 HEAD를 바꿔치기한 정황일 수 있으니 의도한 브랜치가 맞는지 확인하고 — 맞다면 " + base + "에서 격리 worktree로 새로 잘라 작업하세요. (non-blocking · push는 진행됨)"
    _emit_advisory(msg)
}

// first `gh pr merge` token adjacency in the command, -1 when absent.
fn _gh_pr_merge_idx(toks: array) -> int {
    let n = len(toks)
    let mut i = 0
    while i + 2 < n {
        if toks[i] == "gh" && toks[i + 1] == "pr" && toks[i + 2] == "merge" {
            return i
        }
        i = i + 1
    }
    return -1
}

// Non-blocking stale-base advisory for the MERGE path (anima #1105): the
// push-time stale-base check is a backstop, but a `gh pr merge` (squash)
// reached main with a 35190-file revert-delete because no merge-time check
// existed. Here we probe the same divergence (current branch behind the
// remote default base) and warn before the merge lands. The merge-time
// deny on mass deletion lives in pr-cycle-hook's deletion-sanity gate;
// this guard stays advisory (guards-narrow-scope). Cross-repo (`--repo X`)
// merges are skipped — the cwd branch is unrelated to that PR's base.
fn _stale_base_merge_advisory(toks: array) {
    // skip cross-repo merges (cwd HEAD ≠ the --repo X PR's branch)
    let mut k = 0
    while k + 1 < len(toks) {
        if toks[k] == "--repo" { return }
        k = k + 1
    }
    let body = "{ b=$(git rev-parse --abbrev-ref HEAD 2>/dev/null); d=$(git symbolic-ref -q --short refs/remotes/origin/HEAD 2>/dev/null || echo origin/main); c=$(git rev-list --left-right --count \"$d\"...HEAD 2>/dev/null); printf '%s\\n%s\\n%s\\n' \"$b\" \"$d\" \"$c\"; }"

    let mut out = ""
    try { out = to_string(exec(body)) } catch e { return }
    let lines = out.split("\n")
    if len(lines) < 3 { return }

    let branch = lines[0].trim()
    let base = lines[1].trim()
    let counts = lines[2].trim()
    if branch == "" || branch == "HEAD" { return }
    if counts == "" { return }

    let mut base_name = base
    let slash = base.index_of("/")
    if slash >= 0 { base_name = base.substring(slash + 1, len(base)) }
    if branch == base_name { return }

    let parts = _tokens(counts)
    if len(parts) < 2 { return }
    let mut behind = 0
    let mut ahead = 0
    try { behind = to_int(parts[0]) } catch e { return }
    try { ahead = to_int(parts[1]) } catch e { ahead = 0 }
    if behind < STALE_BEHIND { return }

    let msg = "⚠ STALE-BASE MERGE — 머지하려는 브랜치 '" + branch + "'는 " + base + "보다 " + to_string(behind) + "커밋 뒤처짐 (ahead " + to_string(ahead) + "). stale base 에서 분기한 PR 의 squash-merge 는 " + base + "에서 그 이후 바뀐/추가된 파일을 대량 회귀삭제할 수 있음 (anima #1105: 35190 파일 삭제). 머지 전 `gh pr diff --name-status` 의 D(삭제) 라인 수를 확인하고, 의도치 않은 대량 삭제면 origin/main 최신에서 fresh 분기해 다시 PR 하세요. (non-blocking · 실질 차단은 pr-cycle deletion-sanity gate 담당)"
    _emit_advisory(msg)
}

fn main() {
    let raw = _read_stdin()
    let mut payload = json_parse("{}")
    try { payload = json_parse(raw) } catch e { _allow() }

    if type_of(payload) != "map" { _allow() }
    if !has_key(payload, "tool_name") { _allow() }
    if payload["tool_name"] != "Bash" { _allow() }
    if !has_key(payload, "tool_input") { _allow() }
    let ti = payload["tool_input"]
    if type_of(ti) != "map" { _allow() }
    if !has_key(ti, "command") { _allow() }
    let cmd = ti["command"]
    if cmd == "" { _allow() }

    let toks = _tokens(_strip_quotes(cmd))
    let n = len(toks)

    // first `git push` token adjacency
    let mut gp = -1
    let mut i = 0
    while i + 1 < n {
        if toks[i] == "git" && toks[i + 1] == "push" {
            gp = i
            break
        }
        i = i + 1
    }
    if gp < 0 {
        // No `git push` — but a `gh pr merge` reaches main via a path the
        // push-time stale-base check never saw (anima #1105). Surface the
        // merge-time stale-base advisory, then allow.
        if _gh_pr_merge_idx(toks) >= 0 { _stale_base_merge_advisory(toks) }
        _allow()
    }

    let mut label = ""
    let mut j = gp + 2
    while j < n {
        let t = toks[j]
        if t == "-f" || t == "--force" {
            label = "git push --force / -f"
        }
        if t == "--force-with-lease" || _starts_with(t, "--force-with-lease=") {
            label = "git push --force-with-lease"
        }
        j = j + 1
    }
    // refspec-level force — `git push <remote> +<refspec>`
    if label == "" {
        if gp + 3 < n {
            let remote = toks[gp + 2]
            let ref_t = toks[gp + 3]
            if len(remote) > 0 && len(ref_t) > 1 && ref_t[0] == "+" {
                label = "git push <remote> +<refspec> (refspec-level force)"
            }
        }
    }

    if label != "" {
        let mut snippet = cmd
        if len(cmd) > 180 { snippet = cmd.substring(0, 177) + "..." }
        _deny("GIT_GUARD_BLOCK { pattern: " + label + ", command: " + snippet + ", action: blocked — this operation rewrites or bypasses safety. No override; if a force-push is genuinely required, do it outside Claude Code. }")
    }

    // Not a force push — non-blocking stale-base advisory, then allow.
    _stale_base_advisory(toks, gp)
    _allow()
}
