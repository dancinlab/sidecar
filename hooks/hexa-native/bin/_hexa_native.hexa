// _hexa_native.hexa — PreToolUse(Write|Edit|NotebookEdit|Bash) hard block.
//
// If the target file's enclosing project (any ancestor dir holding a
// `project.tape` marker) exists AND the target ends in `.py` / `.sh` / `.c` /
// `.cc` / `.cpp` / `.cxx` / `.h` / `.hpp` / `.hh` / `.inl` / `.ipp` / `.tcc` /
// `.s` / `.S` / `.asm` / `.o`, deny the write with a fixed message redirecting
// to `.hexa`.
//
// Three write channels are covered:
//   1. Structured file tools — Write / Edit / NotebookEdit (file_path).
//   2. Bash redirect channel — `> X.py`, `>> X.sh`, heredoc-to-redirect
//      (`cat > X.py << EOF`), and `tee [-a] X.py`. Relative targets are
//      resolved against the payload `cwd`. `python X.py` / `cat X.py` /
//      `chmod X.sh` (non-write commands) pass through untouched.
//   3. python-write channel — `python3 -c "open('x.py','w').write(…)"` and
//      `python3 - <<EOF … open('y.sh','w') … EOF`. These write from inside the
//      interpreter (not a shell redirect), so the whole command string is
//      scanned for an `open(…,'w'|'a')` / `.write_text` / `.write` whose path
//      literal ends in `.py` / `.sh`. Read mode (`open('x.py')`,
//      `open('x.py','r')`) and data writes (`.json` / `.txt` / `.csv` / `.md`)
//      pass through.
//
// DESIGN NOTE — explicitly no opt-out: no env-var bypass, no
// ~/.claude/sidecar/disabled.json honoring, no per-project exception
// list. Enforcement stands or the plugin is uninstalled.

fn _read_stdin() -> string {
    return to_string(exec("cat"))
}

fn _allow() {
    exit(0)
}

fn _json_escape(s: string) -> string {
    let n = len(s)
    let mut i = 0
    let mut parts = []
    parts.push("\"")
    while i < n {
        let c = s[i]
        if c == "\"" { parts.push("\\\"") }
        else if c == "\\" { parts.push("\\\\") }
        else if c == "\n" { parts.push("\\n") }
        else if c == "\r" { parts.push("\\r") }
        else if c == "\t" { parts.push("\\t") }
        else {
            let k = char_code(c, 0)
            if k < 32 { parts.push(" ") }
            else { parts.push(c) }
        }
        i = i + 1
    }
    parts.push("\"")
    return parts.join("")
}

fn _deny(reason: string) {
    let payload = "{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"deny\",\"permissionDecisionReason\":" + _json_escape(reason) + "}}"
    println(payload)
    exit(0)
}

fn _ends_with(s: string, suffix: string) -> bool {
    let ns = len(s)
    let ne = len(suffix)
    if ne > ns { return false }
    return s.substring(ns - ne, ns) == suffix
}

fn _starts_with(s: string, prefix: string) -> bool {
    if len(prefix) > len(s) { return false }
    return s.substring(0, len(prefix)) == prefix
}

fn _dirname(path: string) -> string {
    let i = path.last_index_of("/")
    if i < 0 { return "" }
    if i == 0 { return "/" }
    return path.substring(0, i)
}

fn _basename(path: string) -> string {
    let i = path.last_index_of("/")
    if i < 0 { return path }
    return path.substring(i + 1, len(path))
}

// Walk up parent dirs from the target's enclosing dir; return the first
// ancestor that holds a `project.tape` marker, or "" if none.
fn _find_project_root(target: string) -> string {
    let home = env_var("HOME")
    let mut cur = _dirname(target)
    let mut guard = 0
    while guard < 256 {
        if cur == "" { return "" }
        if cur == "/" { return "" }
        if cur == home { return "" }
        if file_exists(cur + "/project.tape") { return cur }
        let parent = _dirname(cur)
        if parent == cur { return "" }
        cur = parent
        guard = guard + 1
    }
    return ""
}

fn _ext_of(path: string) -> string {
    let base = _basename(path)
    let i = base.last_index_of(".")
    if i < 0 { return "" }
    return base.substring(i + 1, len(base))
}

fn _relpath(target: string, root: string) -> string {
    let prefix = root + "/"
    if _starts_with(target, prefix) {
        return target.substring(len(prefix), len(target))
    }
    return _basename(target)
}

// Same relative path but with the `.py` / `.sh` extension swapped to `.hexa`.
fn _swap_ext_hexa(rel: string) -> string {
    let i = rel.last_index_of(".")
    if i < 0 { return rel + ".hexa" }
    return rel.substring(0, i) + ".hexa"
}

// Shared deny body. `channel` names the write path. The message leads with
// the ACTION (re-issue as `.hexa`) so the reader reroutes instead of reading
// "blocked" and punting; the refusal reason is demoted below the fix.
fn _deny_for(root: string, target: string, channel: string) {
    let ext = _ext_of(target)
    let rel = _relpath(target, root)
    let proj = _basename(root)
    let rel_hexa = _swap_ext_hexa(rel)
    let reason = "hexa-native: re-issue this write as `" + rel_hexa + "` — same logic, just `.hexa`.\n"
        + "  ✅ ACTION (do this NOW — do NOT punt): author `" + rel_hexa + "` with the identical content. hexa is project `" + proj + "`'s native source language and runs here exactly like a `." + ext + "` would elsewhere. This is a one-token fix (swap the extension), NOT a dead-end — do NOT fall back to writing a doc / runbook, and do NOT hand it back to the user.\n"
        + "  WHY (a reroute, not a wall): `" + rel + "` (." + ext + ") was refused via " + channel + " only because the project root holds a `project.tape` marker. `.py` / `.sh` / `.c` / `.cc` / `.cpp` / `.cxx` / `.h` / `.hpp` / `.hh` / `.inl` / `.ipp` / `.tcc` / `.s` / `.S` / `.asm` / `.o` stay supported in OTHER projects; this one takes `.hexa` ONLY (C / C++ / header / inline / asm / object are compiler outputs here — `hexa cc --regen`, never hand-written).\n"
        + "  NO env-var / flag override — `.hexa` is the only path forward, so take it."
    _deny(reason)
}

// whitespace-split into tokens
fn _tokens(s: string) -> array {
    let mut out = []
    let n = len(s)
    let mut i = 0
    let mut cur = ""
    while i < n {
        let c = s[i]
        if c == " " || c == "\t" || c == "\n" || c == "\r" {
            if len(cur) > 0 { out.push(cur); cur = "" }
        } else {
            cur = cur + c
        }
        i = i + 1
    }
    if len(cur) > 0 { out.push(cur) }
    return out
}

fn _is_meta(c: string) -> bool {
    return c == " " || c == "\t" || c == "\n" || c == "\r" || c == ";" || c == "|" || c == "&" || c == "<" || c == ">" || c == "(" || c == ")"
}

// Quote-aware scan for `>` / `>>` redirect targets. fd-dup (`>&1`) yields
// no file target. Quotes around the target are stripped.
fn _redirect_targets(cmd: string) -> array {
    let n = len(cmd)
    let mut i = 0
    let mut out = []
    let mut q = ""
    while i < n {
        let c = cmd[i]
        if q != "" {
            if c == q { q = "" }
            i = i + 1
            continue
        }
        if c == "\"" || c == "'" {
            q = c
            i = i + 1
            continue
        }
        if c == ">" {
            i = i + 1
            while i < n && (cmd[i] == ">" || cmd[i] == "|") { i = i + 1 }
            while i < n && (cmd[i] == " " || cmd[i] == "\t") { i = i + 1 }
            if i < n && cmd[i] == "&" { continue }
            let mut tok = ""
            let mut tq = ""
            while i < n {
                let d = cmd[i]
                if tq != "" {
                    if d == tq { tq = "" } else { tok = tok + d }
                    i = i + 1
                    continue
                }
                if d == "\"" || d == "'" { tq = d; i = i + 1; continue }
                if _is_meta(d) { break }
                tok = tok + d
                i = i + 1
            }
            if len(tok) > 0 { out.push(tok) }
            continue
        }
        i = i + 1
    }
    return out
}

// `tee [-flags] FILE...` — file args until a pipe / terminator token.
fn _tee_targets(toks: array) -> array {
    let n = len(toks)
    let mut out = []
    let mut i = 0
    while i < n {
        if toks[i] == "tee" {
            let mut j = i + 1
            while j < n {
                let t = toks[j]
                if t == "|" || t == ";" || t == "&" || t == "&&" || t == "||" { break }
                if !_starts_with(t, "-") { out.push(t) }
                j = j + 1
            }
        }
        i = i + 1
    }
    return out
}

// `dd ... of=<file>` — explicit, no false-positive (of= names the write target).
fn _dd_targets(toks: array) -> array {
    let mut out = []
    let mut i = 0
    while i < len(toks) {
        let t = toks[i]
        if _starts_with(t, "of=") { out.push(t.substring(3, len(t))) }
        i = i + 1
    }
    return out
}

// `cp`/`mv` DEST — last non-flag arg is the destination. Conservative: only the
// destination is collected, and the caller's .py/.sh gate lets a non-gated dest
// pass, so the only denials are real .py/.sh creations. `install -t` / `ln` are
// intentionally out of scope (dest position varies); other write channels
// (`python -c open(...)`, `sed -i`, `perl -e`, …) are unbounded and NOT covered —
// this hook narrows the common channels, not a sandbox.
fn _cp_mv_dest(toks: array) -> array {
    let mut out = []
    if len(toks) < 3 { return out }
    let c0 = toks[0]
    if c0 != "cp" && c0 != "mv" { return out }
    let mut i = len(toks) - 1
    while i > 0 {
        let t = toks[i]
        if !_starts_with(t, "-") { out.push(t); return out }
        i = i - 1
    }
    return out
}

// ── python-write channel ────────────────────────────────────────────────
// `python3 -c "open('x.py','w').write(...)"` and `python3 - <<EOF … EOF`
// write files from INSIDE the interpreter, so they are not shell redirects and
// the redirect/tee/dd/cp scan never sees them. We scan the WHOLE command
// string (same approach as the heredoc-redirect scan) for write-mode file
// creations whose path literal ends in `.py` / `.sh`. Read-mode `open('x.py')`
// / `open('x.py','r')`, data writes (`.json` / `.txt` / `.csv` / `.md`), and
// `python x.py` (executing a script) all pass through.

// Is this a python interpreter invocation? First non-flag token is python /
// python3 / a path ending in `/python` or `/python3` (e.g. `/usr/bin/python3`).
fn _is_python_cmd(toks: array) -> bool {
    let n = len(toks)
    let mut i = 0
    while i < n {
        let t = toks[i]
        if t == "python" || t == "python3"
            || _ends_with(t, "/python") || _ends_with(t, "/python3") {
            return true
        }
        i = i + 1
    }
    return false
}

// Does `s` end in a .py/.sh source extension (for python-write gating)?
fn _is_py_sh(s: string) -> bool {
    return _ends_with(s, ".py") || _ends_with(s, ".sh")
}

// Read the quoted python string literal that begins at index `i` (cmd[i] must
// be `'` or `"`). Returns the inner value (quotes stripped). `end_box` is a
// 1-element array the caller passes to receive the index just past the closing
// quote. Returns "" if cmd[i] is not a quote.
fn _read_py_literal(cmd: string, i: int, end_box: array) -> string {
    let n = len(cmd)
    if i >= n { end_box[0] = i; return "" }
    let q = cmd[i]
    if q != "'" && q != "\"" { end_box[0] = i; return "" }
    let mut j = i + 1
    let mut val = ""
    while j < n {
        let c = cmd[j]
        // honor python backslash escape so `\'` inside a literal does not end it
        if c == "\\" && j + 1 < n {
            val = val + c + cmd[j + 1]
            j = j + 2
            continue
        }
        if c == q { j = j + 1; break }
        val = val + c
        j = j + 1
    }
    end_box[0] = j
    return val
}

// Skip spaces/tabs/newlines from index i; return new index.
fn _skip_ws(cmd: string, i: int) -> int {
    let n = len(cmd)
    let mut j = i
    while j < n && (cmd[j] == " " || cmd[j] == "\t" || cmd[j] == "\n" || cmd[j] == "\r") { j = j + 1 }
    return j
}

// Does `cmd` contain `needle` at index i (substring match)?
fn _has_at(cmd: string, i: int, needle: string) -> bool {
    let nn = len(needle)
    if i + nn > len(cmd) { return false }
    return cmd.substring(i, i + nn) == needle
}

// Scan `cmd` for write-mode file creations targeting `.py` / `.sh`. Heuristic,
// not a parser; anchored on `open(` and `write_text` so SHELL-level quoting of
// the whole `-c "<code>"` arg does not hide the PYTHON-level literals inside.
// Covers the canonical channels:
//   • open('x.py','w')            open("y.sh", 'a+')   open('x.py','wb')
//   • Path('p.py').write_text(…)  'p.sh'.write_text? (receiver literal)
//   • open('x.py','w').write(…)
// Read mode (`open('x.py')` / `open('x.py','r')`) and data writes
// (`.json` / `.txt` / `.csv` / `.md`) are NOT collected.
fn _python_write_targets(cmd: string) -> array {
    let n = len(cmd)
    let mut out = []
    let mut i = 0
    while i < n {
        // ── open( … ) anchor ──────────────────────────────────────────────
        if _has_at(cmd, i, "open(") {
            let mut p = _skip_ws(cmd, i + 5)
            let box = [0]
            let path = _read_py_literal(cmd, p, box)
            p = box[0]
            if _is_py_sh(path) {
                // advance to the comma, then read the mode literal (if any)
                let mut q = _skip_ws(cmd, p)
                if q < n && cmd[q] == "," {
                    q = _skip_ws(cmd, q + 1)
                    let box2 = [0]
                    // mode may be `mode=` kw — skip a leading `mode=`
                    if _has_at(cmd, q, "mode=") { q = _skip_ws(cmd, q + 5) }
                    let mode = _read_py_literal(cmd, q, box2)
                    let q0 = q
                    // reconstruct quoted form to reuse _is_write_mode_literal:
                    // mode value first char is enough (w/a → write).
                    if len(mode) > 0 {
                        let m = mode[0]
                        if m == "w" || m == "a" { out.push(path) }
                    }
                }
                // NOTE: `open('x.py')` with no mode arg = read default → skip.
            }
            i = i + 5
            continue
        }
        // ── write_text anchor — receiver literal ends in .py/.sh ───────────
        // pattern: <quote>x.py<quote> ... .write_text(   OR   Path('x.py').write_text
        if _has_at(cmd, i, ".write_text") || _has_at(cmd, i, ".write(") || _has_at(cmd, i, ".writelines") {
            // walk backwards to find the nearest preceding string literal
            let mut b = i - 1
            // skip a trailing `)` from Path('x.py').write_text
            while b >= 0 && (cmd[b] == ")" || cmd[b] == " " || cmd[b] == "\t") { b = b - 1 }
            if b >= 0 && (cmd[b] == "'" || cmd[b] == "\"") {
                let q = cmd[b]
                let mut s = b - 1
                let mut val = ""
                while s >= 0 && cmd[s] != q {
                    val = cmd[s] + val
                    s = s - 1
                }
                if _is_py_sh(val) { out.push(val) }
            }
            i = i + 6
            continue
        }
        i = i + 1
    }
    return out
}

// Resolve a redirect target to an absolute path using the payload `cwd`.
fn _resolve(cwd: string, target: string) -> string {
    if _starts_with(target, "/") { return target }
    if _starts_with(target, "~") {
        return env_var("HOME") + target.substring(1, len(target))
    }
    let mut t = target
    if _starts_with(t, "./") { t = t.substring(2, len(t)) }
    if cwd == "" { return t }
    return cwd + "/" + t
}

fn _handle_bash(payload: map, ti: map) {
    if !has_key(ti, "command") { _allow() }
    let cmd = ti["command"]
    if cmd == "" { _allow() }
    let mut cwd = ""
    if has_key(payload, "cwd") { cwd = payload["cwd"] }

    let toks = _tokens(cmd)
    let mut cands = _redirect_targets(cmd)
    let tees = _tee_targets(toks)
    let mut b = 0
    while b < len(tees) { cands.push(tees[b]); b = b + 1 }
    let dds = _dd_targets(toks)
    let mut d = 0
    while d < len(dds) { cands.push(dds[d]); d = d + 1 }
    let cps = _cp_mv_dest(toks)
    let mut e = 0
    while e < len(cps) { cands.push(cps[e]); e = e + 1 }

    let mut k = 0
    while k < len(cands) {
        let tgt = cands[k]
        if _ends_with(tgt, ".py") || _ends_with(tgt, ".sh") || _ends_with(tgt, ".c") || _ends_with(tgt, ".cc") || _ends_with(tgt, ".cpp") || _ends_with(tgt, ".cxx") || _ends_with(tgt, ".h") || _ends_with(tgt, ".hpp") || _ends_with(tgt, ".hh") || _ends_with(tgt, ".inl") || _ends_with(tgt, ".ipp") || _ends_with(tgt, ".tcc") || _ends_with(tgt, ".s") || _ends_with(tgt, ".S") || _ends_with(tgt, ".asm") || _ends_with(tgt, ".o") {
            let abs = _resolve(cwd, tgt)
            let root = _find_project_root(abs)
            if root != "" { _deny_for(root, abs, "a Bash write channel (>, >>, tee, dd of=, cp/mv)") }
        }
        k = k + 1
    }

    // python-write channel — `python3 -c "open('x.py','w')…"` / heredoc python.
    // The whole command string is scanned (incl. heredoc body) so both `-c` and
    // `python3 - <<EOF … EOF` are covered. Gate is already .py/.sh + write-mode.
    if _is_python_cmd(toks) {
        let pys = _python_write_targets(cmd)
        let mut p = 0
        while p < len(pys) {
            let abs = _resolve(cwd, pys[p])
            let root = _find_project_root(abs)
            if root != "" { _deny_for(root, abs, "python-write") }
            p = p + 1
        }
    }

    _allow()
}

fn main() {
    let raw = _read_stdin()
    let mut payload = json_parse("{}")
    try { payload = json_parse(raw) } catch e { _allow() }

    if type_of(payload) != "map" { _allow() }
    if !has_key(payload, "tool_name") { _allow() }
    let tool = payload["tool_name"]
    if tool != "Write" && tool != "Edit" && tool != "NotebookEdit" && tool != "Bash" { _allow() }

    if !has_key(payload, "tool_input") { _allow() }
    let ti = payload["tool_input"]
    if type_of(ti) != "map" { _allow() }

    if tool == "Bash" { _handle_bash(payload, ti) }

    let mut target = ""
    if has_key(ti, "file_path") { target = ti["file_path"] }
    if target == "" {
        if has_key(ti, "notebook_path") { target = ti["notebook_path"] }
    }
    if target == "" { _allow() }

    if !_ends_with(target, ".py") && !_ends_with(target, ".sh") && !_ends_with(target, ".c") && !_ends_with(target, ".cc") && !_ends_with(target, ".cpp") && !_ends_with(target, ".cxx") && !_ends_with(target, ".h") && !_ends_with(target, ".hpp") && !_ends_with(target, ".hh") && !_ends_with(target, ".inl") && !_ends_with(target, ".ipp") && !_ends_with(target, ".tcc") && !_ends_with(target, ".s") && !_ends_with(target, ".S") && !_ends_with(target, ".asm") && !_ends_with(target, ".o") { _allow() }

    let root = _find_project_root(target)
    if root == "" { _allow() }

    _deny_for(root, target, "the Write/Edit tool")
}
