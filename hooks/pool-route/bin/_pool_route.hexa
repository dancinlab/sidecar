// _pool_route.hexa — PreToolUse(Bash) pool auto-router.
//
// When pool routing is armed (`~/.pool/pool.json` has ≥1 enabled host) and
// a Bash command matches the heavy classifier, the command is rewritten via
// the hook `updatedInput` field so it runs on a pool host over ssh:
//     ssh <host> 'cd <workdir> && <cmd>'
//
// Host selection: a command that needs a specific OS (macOS-only /
// Linux-only) is restricted to hosts tagged with that platform; among the
// eligible hosts a round-robin counter spreads load. No eligible host ->
// runs local. A preflight `test -d` confirms the workdir exists on the
// host before routing — pool-route does NOT sync it; the project workdir
// is kept on pool hosts by the user.
//
// Roster source of truth: the `pool` CLI's `~/.pool/pool.json`.
// NO opt-out by design — no env var, no config file, no exception list.
//
// 0.6.1 — zero macOS offload (project.tape @D s12 / pool @D p3): macOS hosts
// are excluded from the auto-dispatch candidate set entirely. macOS-capable
// commands (swift build · xcodebuild) run local on the workstation Mac; only
// Linux hosts receive routed work. Explicit `pool on <macos-host>` is the
// pool CLI, not this hook, so it is unaffected.

let MARK = "__SIDECAR_POOL__"

fn _read_stdin() -> string {
    return to_string(exec("cat"))
}

fn _allow() {
    exit(0)
}

// `_deny(reason)` — block the Bash invocation entirely via the PreToolUse
// permission-decision channel. Used when a command was classified heavy
// (must go to the pool) but every routing path failed — running locally
// would silently violate the "pool-only resources" contract.
fn _deny(reason: string) {
    let out = "{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"deny\",\"permissionDecisionReason\":" + _json_str(reason) + "}}"
    println(out)
    exit(0)
}

// JSON-escape a string and wrap it in double quotes.
fn _json_str(s: string) -> string {
    let n = len(s)
    let mut i = 0
    let mut parts = []
    parts.push("\"")
    while i < n {
        let c = s[i]
        if c == "\"" { parts.push("\\\"") }
        else if c == "\\" { parts.push("\\\\") }
        else if c == "\n" { parts.push("\\n") }
        else if c == "\r" { parts.push("\\r") }
        else if c == "\t" { parts.push("\\t") }
        else {
            let k = char_code(c, 0)
            if k < 32 { parts.push(" ") }
            else { parts.push(c) }
        }
        i = i + 1
    }
    parts.push("\"")
    return parts.join("")
}

fn _is_word_char(c: string) -> bool {
    let k = char_code(c, 0)
    if k >= 48 && k <= 57 { return true }
    if k >= 65 && k <= 90 { return true }
    if k >= 97 && k <= 122 { return true }
    if k == 95 { return true }
    return false
}

// `\bword\b` — substring match bounded by non-word chars / string ends.
fn _has_word(hay: string, word: string) -> bool {
    let hn = len(hay)
    let wn = len(word)
    if wn == 0 { return false }
    let mut i = 0
    while i + wn <= hn {
        if hay.substring(i, i + wn) == word {
            let mut ok = true
            if i > 0 {
                if _is_word_char(hay[i - 1]) { ok = false }
            }
            if i + wn < hn {
                if _is_word_char(hay[i + wn]) { ok = false }
            }
            if ok { return true }
        }
        i = i + 1
    }
    return false
}

// whitespace-split into tokens
fn _tokens(s: string) -> array {
    let mut out = []
    let n = len(s)
    let mut i = 0
    let mut cur = ""
    while i < n {
        let c = s[i]
        if c == " " || c == "\t" || c == "\n" || c == "\r" {
            if len(cur) > 0 { out.push(cur); cur = "" }
        } else {
            cur = cur + c
        }
        i = i + 1
    }
    if len(cur) > 0 { out.push(cur) }
    return out
}

// strip ' and " so a quoted heavy subverb (e.g. `hexa 'kick'`) tokenizes to its
// bare form for the adjacency / pair-substring classifier. Classification only —
// the rewrite (ssh) always uses the original command verbatim.
fn _strip_quotes(s: string) -> string {
    let mut out = []
    let n = len(s)
    let mut i = 0
    while i < n {
        let c = s[i]
        if c != "'" && c != "\"" { out.push(c) }
        i = i + 1
    }
    return out.join("")
}

// adjacency: token a immediately followed by token b
fn _has_adjacent(toks: array, a: string, b: string) -> bool {
    let n = len(toks)
    let mut i = 0
    while i + 1 < n {
        if toks[i] == a && toks[i + 1] == b { return true }
        i = i + 1
    }
    return false
}

fn _any_word(cmd: string, words: array) -> bool {
    let mut i = 0
    while i < len(words) {
        if _has_word(cmd, words[i]) { return true }
        i = i + 1
    }
    return false
}

fn _any_contains(cmd: string, subs: array) -> bool {
    let mut i = 0
    while i < len(subs) {
        if cmd.contains(subs[i]) { return true }
        i = i + 1
    }
    return false
}

// pairs is a flat array [a0,b0, a1,b1, ...]
fn _any_adjacent(toks: array, pairs: array) -> bool {
    let mut i = 0
    while i + 1 < len(pairs) {
        if _has_adjacent(toks, pairs[i], pairs[i + 1]) { return true }
        i = i + 2
    }
    return false
}

// Substring-pair fallback — token-adjacency fails when claude-code wraps
// the user command in a zsh shell-snapshot envelope
// (`/bin/zsh -c 'source <snap>; ... eval ''<cmd>'''`) where the inner cmd
// becomes a single quoted argument; `hexa kick` then appears as token
// `'hexa` followed by `kick;` rather than two clean tokens. The `_any_word`
// path (heavy_words) survives this because `cmd.contains(word)` is
// substring-based; the pair path needs the same robustness. False-positive
// risk is bounded: pairs are 2-token compound verbs (`hexa kick`,
// `go build`) unlikely to appear coincidentally in unrelated cmds.
fn _any_pair_substring(cmd: string, pairs: array) -> bool {
    let mut i = 0
    while i + 1 < len(pairs) {
        let needle = pairs[i] + " " + pairs[i + 1]
        if cmd.contains(needle) { return true }
        i = i + 2
    }
    return false
}

// shell single-quote: wrap in '...', embedded ' becomes '\''
fn _shq(s: string) -> string {
    return "'" + s.split("'").join("'\\''") + "'"
}

// quote a workdir for a remote `cd`, keep a leading ~ unquoted so the
// remote shell expands it to that host's own home.
fn _cd_target(wd: string) -> string {
    if wd == "~" { return "~" }
    if wd.starts_with("~/") {
        return "~/" + _shq(wd.substring(2, len(wd)))
    }
    return _shq(wd)
}

// `tailscale ssh` opens a non-login shell — force a login shell so the
// remote PATH (Homebrew etc.) is sourced. Harmless for plain ssh too.
fn _login_wrap(remote: string) -> string {
    return "bash -lc " + _shq(remote)
}

// run a probe command, return only its exit code (255 = ssh/transport).
fn _exec_rc(cmd: string) -> int {
    let r = exec_with_status(cmd)
    return r[1]
}

// read an environment variable — "" when unset.
fn _env(name: string) -> string {
    let r = exec_with_status("printenv " + name)
    if r[1] != 0 { return "" }
    return r[0].trim()
}

// `_local_signed` — fresh `local` sign token (5min). Mirrors sign-guard's
// TTL contract: the user mints with `! sidecar sign local` in the TUI
// prompt; the file `~/.sidecar/signs/local.sign` holds the mint epoch.
// pool-route's local-bound heavy gate (0.6.4) reads it to decide whether
// to allow hexa/python/sh script invocations through the absolute-path
// exemption.
fn _local_signed() -> bool {
    let path = _env("HOME") + "/.sidecar/signs/local.sign"
    if !file_exists(path) { return false }
    let mut raw = ""
    try { raw = to_string(read_file(path)) } catch e { return false }
    let mint = to_int(raw.trim())
    if mint <= 0 { return false }
    let age = timestamp() - mint
    if age < 0 { return false }
    return age <= 300
}

// `_local_heavy_interp` — heavy interpreter/compiler invocation? These are
// the canonical mac fork-storm sources when forced local-bound: hexa CLI
// (any verb), direct hexa.real, python/python3/py, and `bash`/`sh
// <script>` (positional script arg, not `bash -c "..."` which is the
// shell wrapper convention). Bare reads (ls/cat/grep/find/...) stay free.
fn _local_heavy_interp(cmd: string, toks: array) -> bool {
    if _has_word(cmd, "hexa") { return true }
    if cmd.contains("hexa.real") { return true }
    if _any_word(cmd, ["python", "python3", "py"]) { return true }
    if len(toks) >= 2 {
        let t0 = toks[0]
        if t0 == "bash" || t0 == "sh" {
            let t1 = toks[1]
            // skip `bash -c "..."` / `sh -c "..."` — those are shell wrappers
            if len(t1) > 0 && t1.substring(0, 1) != "-" { return true }
        }
    }
    return false
}

// emit the updatedInput rewrite — rebuild tool_input with command swapped.
fn _emit(ti: map, new_cmd: string, note: string) {
    let ks = keys(ti)
    let mut parts = []
    let mut i = 0
    while i < len(ks) {
        let k = ks[i]
        if k == "command" {
            parts.push(_json_str(k) + ":" + _json_str(new_cmd))
        } else {
            parts.push(_json_str(k) + ":" + json_stringify(ti[k]))
        }
        i = i + 1
    }
    let updated = "{" + parts.join(",") + "}"
    let out = "{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"allow\",\"updatedInput\":" + updated + ",\"additionalContext\":" + _json_str(note) + "}}"
    println(out)
    exit(0)
}

// Event-name reader — hook payload carries `hook_event_name` (snake_case).
fn _event_of(payload: map) -> string {
    if has_key(payload, "hook_event_name") { return payload["hook_event_name"] }
    if has_key(payload, "hookEventName") { return payload["hookEventName"] }
    return ""
}

// Append a routing log entry — ~/.pool/route-log.jsonl, capped at 100 lines.
// Each line: {"t":"<iso>","host":"<name>","cmd":"<first 40 chars, sanitized>"}.
fn _log_route(host: string, cmd: string) {
    let home = _env("HOME")
    if home == "" { return }
    let path = home + "/.pool/route-log.jsonl"
    // sanitize: drop newlines/tabs, first 40 chars
    let mut head = cmd
    head = head.split("\n").join(" ")
    head = head.split("\t").join(" ")
    if len(head) > 40 { head = head.substring(0, 40) }
    let t = exec_with_status("date -u +%Y-%m-%dT%H:%M:%SZ")[0].trim()
    let line = "{\"t\":" + _json_str(t) + ",\"host\":" + _json_str(host) + ",\"cmd\":" + _json_str(head) + "}\n"
    // read existing, append, trim to last 100 lines
    let mut prior = ""
    try { prior = read_file(path) } catch e { prior = "" }
    let combined = prior + line
    let lines = combined.split("\n")
    let n = len(lines)
    let start = if n > 101 { n - 101 } else { 0 }
    let mut kept = []
    let mut i = start
    while i < n {
        if lines[i] != "" { kept.push(lines[i]) }
        i = i + 1
    }
    try { write_file(path, kept.join("\n") + "\n") } catch e { }
}

// SessionStart snapshot — emit recent routing log as additionalContext.
// Skips quietly when the log is empty or unreadable.
fn _emit_session_start() {
    let home = _env("HOME")
    if home == "" { exit(0) }
    let path = home + "/.pool/route-log.jsonl"
    let mut raw = ""
    try { raw = read_file(path) } catch e { exit(0) }
    if raw == "" { exit(0) }
    let lines = raw.split("\n")
    let n = len(lines)
    let take = 5
    let start = if n > take + 1 { n - take - 1 } else { 0 }
    let mut bullets = []
    let mut i = start
    while i < n {
        let ln = lines[i].trim()
        if ln != "" {
            let mut obj = json_parse("{}")
            try { obj = json_parse(ln) } catch e { obj = json_parse("{}") }
            if type_of(obj) == "map" {
                let mut t = ""
                let mut host = ""
                let mut cmd = ""
                if has_key(obj, "t") { if type_of(obj["t"]) == "string" { t = obj["t"] } }
                if has_key(obj, "host") { if type_of(obj["host"]) == "string" { host = obj["host"] } }
                if has_key(obj, "cmd") { if type_of(obj["cmd"]) == "string" { cmd = obj["cmd"] } }
                if host != "" {
                    bullets.push("- " + t + " → " + host + " : " + cmd)
                }
            }
        }
        i = i + 1
    }
    if len(bullets) == 0 { exit(0) }
    let body = "# recent pool-route (~/.pool/route-log.jsonl · last " + to_string(len(bullets)) + ")\n" + bullets.join("\n") + "\n"
    let out = "{\"hookSpecificOutput\":{\"hookEventName\":\"SessionStart\",\"additionalContext\":" + _json_str(body) + "}}"
    println(out)
    exit(0)
}

fn main() {
    let raw = _read_stdin()
    let mut payload = json_parse("{}")
    try { payload = json_parse(raw) } catch e { _allow() }
    if type_of(payload) != "map" { _allow() }

    // SessionStart — emit recent routing log snapshot, then exit.
    let event = _event_of(payload)
    if event == "SessionStart" { _emit_session_start() }

    // Bash tool only — Read/Write/Edit operate on the local fs.
    if !has_key(payload, "tool_name") { _allow() }
    if payload["tool_name"] != "Bash" { _allow() }
    if !has_key(payload, "tool_input") { _allow() }
    let ti = payload["tool_input"]
    if type_of(ti) != "map" { _allow() }
    if !has_key(ti, "command") { _allow() }
    let cmd0 = ti["command"]
    if type_of(cmd0) != "string" { _allow() }
    let cmd = cmd0.trim()
    if cmd == "" { _allow() }

    // skip — already routed / heredoc / background / already ssh
    if cmd.contains(MARK) { _allow() }
    if cmd.contains("<<") { _allow() }
    if cmd.ends_with("&") { _allow() }
    if cmd.starts_with("ssh ") { _allow() }

    // local-bound guard (pool-route 0.6.0): commands inherently tied to THIS
    // host's filesystem / repo state must NEVER route — they break on a remote
    // where the path / repo / binary doesn't exist. The recurring failure mode:
    // `git push` / `hexa run /Users/.../x.hexa` / a `/Users/`-absolute smoke
    // shipped to a Linux pool host where that path resolves to nothing.
    //   - git / gh : operate on the local working tree + remotes (cwd repo)
    //   - /Users/ or /home/ literal : host-specific absolute path
    // These are read/version-control/local-fs ops, never the heavy compute the
    // pool exists for, so an early _allow() is always correct.
    if _has_word(cmd, "git") || _has_word(cmd, "gh") { _allow() }
    if cmd.contains("/Users/") || cmd.contains("/home/") {
        // Sign gate (0.6.4): local-bound HEAVY invocations (hexa · python ·
        // bash/sh <script>) on absolute host paths are the canonical mac
        // fork-storm trigger — multiple sessions racing dispatch caches +
        // re-fork on every env-hash miss. Require a fresh user sign-off
        // (`! sidecar sign local`, 5min token, mints freely from the TUI
        // bang) before honoring the absolute-path exemption. Bare reads
        // (ls/cat/grep/find/...) on absolute paths stay free — the gate
        // narrows to interpreters/compilers only.
        let toks = _tokens(cmd)
        if _local_heavy_interp(cmd, toks) {
            if !_local_signed() {
                _deny("local-bound heavy invocation (hexa/python/sh <script>) on an absolute host path needs a fresh sign-off — the canonical mac fork-storm trigger. USER: run  `! sidecar sign local`  in the TUI prompt (5min token), then retry. Bare absolute-path reads (ls/cat/grep/find/...) are unaffected; this gate narrows to interpreters/compilers only.")
            }
        }
        _allow()
    }

    let home = _env("HOME")

    // roster — the `pool` CLI's single source of truth, ~/.pool/pool.json
    // (schema: hosts[] of {name, ssh, enabled, sudo, os}).
    let dd = home + "/.pool"
    let mut cfg = json_parse("{}")
    try {
        let parsed = json_parse(read_file(dd + "/pool.json"))
        if type_of(parsed) == "map" { cfg = parsed }
    } catch e { _allow() }

    // ARM check — at least one enabled roster host.
    if !has_key(cfg, "hosts") { _allow() }
    let hosts = cfg["hosts"]
    if type_of(hosts) != "array" { _allow() }

    let mut h_name = []
    let mut h_plat = []
    let mut h_sudo = []
    let mut hi = 0
    while hi < len(hosts) {
        let h = hosts[hi]
        if type_of(h) == "map" {
            let mut enabled = true
            if has_key(h, "enabled") { if type_of(h["enabled"]) == "bool" { enabled = h["enabled"] } }
            if enabled {
                // ssh target — the `ssh` field, falling back to `name`
                let mut tgt = ""
                if has_key(h, "ssh") { if type_of(h["ssh"]) == "string" { tgt = h["ssh"] } }
                if tgt == "" {
                    if has_key(h, "name") { if type_of(h["name"]) == "string" { tgt = h["name"] } }
                }
                let mut pl = "linux"
                if has_key(h, "os") { if type_of(h["os"]) == "string" { pl = h["os"] } }
                // macOS hosts are NEVER auto-dispatch candidates (project.tape
                // @D s12 / pool @D p3 — goal: zero macOS offload). The Mac is
                // the workstation, not a pool worker; macOS-capable commands
                // run local on it, never routed to a separate macOS box. An
                // explicit `pool on <macos-host>` still works (that path is the
                // pool CLI, not this auto-router).
                if tgt != "" && pl != "macos" {
                    h_name.push(tgt)
                    h_plat.push(pl)
                    let mut su = false
                    if has_key(h, "sudo") { if type_of(h["sudo"]) == "bool" { su = h["sudo"] } }
                    h_sudo.push(su)
                }
            }
        }
        hi = hi + 1
    }
    if len(h_name) == 0 { _allow() }

    // pool.json is roster-only — workdir mirrors the local cwd by default.
    let workdir = "auto"

    let stripped = _strip_quotes(cmd)
    let toks = _tokens(stripped)   // classifier tokens are quote-stripped

    // heavy classifier — build / test / package / train commands
    let heavy_words = ["make", "cargo", "npm", "pnpm", "yarn", "gradle", "mvn", "bazel", "cmake", "ctest", "tox", "pytest", "jest", "vitest", "webpack", "xcodebuild", "xcrun", "swiftc", "nvidia-smi", "train"]
    // hexa-native heavy subverbs (kick-storm 2026-05-23 Mac kill: /kick = `hexa kick --seed`,
    // multi-agent local fire drove load 80+. drill = kick alias. loop = RFC 080 DFS+LLM cycle.
    // cc = full transpiler bootstrap.)
    let heavy_pairs = ["go", "test", "go", "build", "swift", "build", "swift", "test", "docker", "build", "hexa", "kick", "hexa", "drill", "hexa", "loop", "hexa", "cc"]
    // big-tree find substring — multi-session `find $HOME/core/anima` (~458GB tree)
    // is the documented Mac-kill pattern (267% CPU from 3× concurrent bfs). Route
    // when the cmd contains `find <user>/core/anima`; preflight test -d gates the
    // host so non-mirrored hosts fall through to local. $HOME-relative so other
    // installs that lack the tree never match (substring is empty).
    let mut heavy_find_subs = []
    if home != "" { heavy_find_subs.push("find " + home + "/core/anima") }
    let heavy = _any_word(stripped, heavy_words) || _any_adjacent(toks, heavy_pairs) || _any_pair_substring(stripped, heavy_pairs) || _any_contains(cmd, heavy_find_subs)

    // NOTE (pool-route 0.6.0): the load-aware escalation gate (0.5.7 #96) was
    // REMOVED. It promoted any non-trivial cmd to "heavy" when non-claude CPU
    // summed > 150% — but on an 8-core Mac WindowServer + browser + build
    // daemons routinely exceed 150%, so nearly every git / hexa-run / smoke got
    // shipped to a Linux pool host and broke (Mac-local paths absent there).
    // "system busy" ≠ "this command should move" — that conflation was the bug.
    // Storm protection still holds: kick/drill/loop/cc + `find ~/core/anima` are
    // in the EXPLICIT classifier above, so the real meltdown patterns route on
    // their own merits, not on a noisy load signal.

    // root-needing commands — always routable, and `sudo`-prefixed on a
    // host tagged sudo:true.
    let sudo_words = ["apt", "apt-get", "dpkg", "dpkg-deb", "add-apt-repository", "yum", "dnf", "rpm", "pacman", "systemctl", "ldconfig", "setcap", "update-alternatives"]
    let needs_sudo = _any_word(cmd, sudo_words)

    if !heavy && !needs_sudo { _allow() }

    // capability filter — restrict to a platform when the command demands one
    let macos_words = ["xcodebuild", "xcrun", "xcode-select", "codesign", "notarytool", "stapler", "pkgbuild", "productbuild", "hdiutil", "lipo", "otool", "install_name_tool", "vtool", "swiftc", "sw_vers", "osascript", "launchctl", "diskutil", "caffeinate", "sips", "plutil"]
    let macos_pairs = ["swift", "build", "swift", "test", "swift", "run", "swift", "package"]
    let macos_subs = ["apple-darwin", "apple-macos", "apple-ios", "Mach-O", ".dylib", ".dmg"]
    let is_macos = _any_word(stripped, macos_words) || _any_adjacent(toks, macos_pairs) || _any_contains(cmd, macos_subs)

    let linux_words = ["apt", "apt-get", "dpkg", "dpkg-deb", "add-apt-repository", "yum", "dnf", "rpm", "pacman", "systemctl", "journalctl", "ldconfig", "setcap", "update-alternatives"]
    let linux_subs = ["linux-gnu", "linux-musl", ".deb", ".rpm"]
    let is_linux = _any_word(cmd, linux_words) || _any_contains(cmd, linux_subs)

    let mut why = "load-balanced"
    let mut elig = []
    let mut ei = 0
    if is_macos {
        why = "macOS-only command"
        while ei < len(h_name) {
            if h_plat[ei] == "macos" { elig.push(ei) }
            ei = ei + 1
        }
    } else if is_linux {
        why = "Linux-only command"
        while ei < len(h_name) {
            if h_plat[ei] == "linux" { elig.push(ei) }
            ei = ei + 1
        }
    } else {
        while ei < len(h_name) {
            elig.push(ei)
            ei = ei + 1
        }
    }
    if len(elig) == 0 { _allow() }

    // round-robin across the eligible hosts
    let rr_path = dd + "/.pool-route.rr"
    let mut n = 0
    try {
        let rr = read_file(rr_path).trim()
        if rr != "" { n = to_int(rr) }
    } catch e { n = 0 }
    if n < 0 { n = 0 }
    let start_pick = elig[n % len(elig)]
    try { write_file(rr_path, to_string((n + 1) % 1000000)) } catch e { }

    // ── workdir + transport (host-independent — pull above the host loop) ─

    // resolve the remote workdir — `auto` mirrors the local cwd under $HOME
    let mut wd_remote = workdir
    if wd_remote.to_lower() == "auto" {
        let mut cwd = ""
        if has_key(payload, "cwd") { if type_of(payload["cwd"]) == "string" { cwd = payload["cwd"] } }
        if cwd == "" { cwd = exec_with_status("pwd")[0].trim() }
        if cwd == home {
            wd_remote = "~"
        } else if cwd.starts_with(home + "/") {
            wd_remote = "~/" + cwd.substring(len(home) + 1, len(cwd))
        } else {
            _deny("pool-route: cwd outside $HOME cannot be mirrored to any pool host — heavy command refused (move into $HOME or rerun without the heavy-classifier trigger).")
        }
    }
    if wd_remote == "" { _deny("pool-route: empty remote workdir — heavy command refused.") }
    let wd_sh = _cd_target(wd_remote)

    // transport — tailscale if a local daemon is up, else plain ssh
    let mut tx = "auto"
    if tx == "auto" {
        tx = "ssh"
        if _exec_rc("command -v tailscale >/dev/null 2>&1") == 0 {
            if _exec_rc("tailscale status --peers=false >/dev/null 2>&1") == 0 { tx = "tailscale" }
        }
    }

    // hexa subverb (kick/drill/loop/cc) gate — script-backed verbs need the
    // hexa-lang repo + build/hexa_interp on the remote. Cmd-independent of
    // the picked host, so we compute the subverb (if any) once.
    let toks_pre = _tokens(cmd)
    let mut hexa_subverb = ""
    if len(toks_pre) >= 2 && toks_pre[0] == "hexa" {
        let sv0 = toks_pre[1]
        if sv0 == "kick" || sv0 == "drill" || sv0 == "loop" || sv0 == "cc" {
            hexa_subverb = sv0
        }
    }

    // ── iterate eligible hosts (round-robin start; wrap once) ────────────
    //
    // The user contract is "pool resources only" for heavy-classified cmds
    // — never silently fall back to local. So probe each eligible host in
    // turn; first one that passes (workdir present, hexa subverb works if
    // applicable) gets the route. If ALL fail, emit a `_deny` with a
    // per-host failure breakdown so the operator can fix the missing host.
    let mut tried = []
    let mut reasons = []
    let mut routed = false
    let mut li = 0
    while li < len(elig) {
        let pick = elig[(n + li) % len(elig)]
        let host_i = h_name[pick]

        // per-host rcmd (sudo prefix), hexa_env (HEXA_LANG choice), remote
        let mut rcmd = cmd
        let mut sudo_note = ""
        if h_sudo[pick] && needs_sudo && !rcmd.starts_with("sudo ") {
            rcmd = "sudo " + rcmd
            sudo_note = ", sudo-prefixed"
        }
        let mut hexa_env = ""
        if _has_word(rcmd, "hexa") || rcmd.contains("hexa ") {
            let mut hexa_lang = "$PWD"
            if hexa_subverb != "" { hexa_lang = "$HOME/core/hexa-lang" }
            hexa_env = "export PATH=\"$HOME/.hx/bin:$HOME/bin:$PATH\" HEXA_MODULE_LOADER=\"$PWD/build/hexa_module_loader\" HEXA_LANG=\"" + hexa_lang + "\" && "
        }
        let remote = "cd " + wd_sh + " && " + hexa_env + rcmd

        // preflight — workdir + hexa-subverb dispatchability check
        let mut probe_inner = "test -d " + wd_sh
        if hexa_subverb != "" {
            probe_inner = probe_inner + " && PATH=\"$HOME/.hx/bin:$HOME/bin:$PATH\" HEXA_LANG=\"$HOME/core/hexa-lang\" hexa " + hexa_subverb + " --help >/dev/null 2>&1"
        }
        let mut probe = ""
        if tx == "tailscale" {
            probe = "tailscale ssh " + _shq(host_i) + " " + _shq(probe_inner)
        } else {
            probe = "ssh -o BatchMode=yes -o ConnectTimeout=6 " + _shq(host_i) + " " + _shq(probe_inner)
        }
        let rc = _exec_rc(probe)
        if rc == 0 {
            // SUCCESS — emit the rewrite and finish
            let mut new_cmd = ""
            let sshc = "ssh"
            if tx == "tailscale" { let sshc2 = "tailscale ssh"; new_cmd = sshc2 + " " + _shq(host_i) + " " + _shq(_login_wrap(remote)) + "  # " + MARK }
            else { new_cmd = sshc + " " + _shq(host_i) + " " + _shq(_login_wrap(remote)) + "  # " + MARK }
            let mut note = "pool-route: routed to " + host_i + ":" + wd_remote + " via " + tx + " (workdir is user-synced)"
            note = note + " (" + why + sudo_note + "; " + to_string(len(h_name)) + "-host roster)."
            if li > 0 { note = note + " [skipped " + to_string(li) + " host(s) on preflight: " + tried.join(", ") + "]" }
            _log_route(host_i, cmd)
            _emit(ti, new_cmd, note)
            routed = true
        }
        // record failure reason for the deny trailer
        tried.push(host_i)
        let mut why_fail = "preflight rc=" + to_string(rc) + " (workdir missing"
        if hexa_subverb != "" { why_fail = why_fail + " or `hexa " + hexa_subverb + "` not dispatchable" }
        why_fail = why_fail + ")"
        reasons.push(host_i + ": " + why_fail)
        li = li + 1
    }
    // exhausted — every eligible host failed preflight
    if !routed {
        let body = "pool-route: heavy command refused — no eligible pool host passed preflight.\n"
                 + "  cmd     : " + cmd + "\n"
                 + "  why     : " + why + " (heavy-classified, must use pool resources)\n"
                 + "  tried   : " + tried.join(", ") + "\n"
                 + "  failures:\n    " + reasons.join("\n    ") + "\n"
                 + "  fix     : ensure each pool host has the hexa-lang repo at ~/core/hexa-lang "
                 + "+ a built build/hexa_interp (`cd ~/core/hexa-lang && hexa cc --regen`); "
                 + "for non-hexa commands, ensure the workdir (" + wd_remote + ") exists on at least one host."
        _deny(body)
    }
}
