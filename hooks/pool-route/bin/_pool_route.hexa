// _pool_route.hexa — PreToolUse(Bash) pool auto-router.
//
// When pool routing is armed (`~/.pool/pool.json` has ≥1 enabled host) and
// a Bash command matches the heavy classifier, the command is rewritten via
// the hook `updatedInput` field so it runs on a pool host over ssh:
//     ssh <host> 'cd <workdir> && <cmd>'
//
// Host selection: a command that needs a specific OS (macOS-only /
// Linux-only) is restricted to hosts tagged with that platform; among the
// eligible hosts a round-robin counter spreads load. No eligible host ->
// runs local. A preflight `test -d` confirms the workdir exists on the
// host before routing — pool-route does NOT sync it; the project workdir
// is kept on pool hosts by the user.
//
// Roster source of truth: the `pool` CLI's `~/.pool/pool.json`.
// NO opt-out by design — no env var, no config file, no exception list.
//
// 0.6.1 — zero macOS offload (project.tape @D s12 / pool @D p3): macOS hosts
// are excluded from the auto-dispatch candidate set entirely. macOS-capable
// commands (swift build · xcodebuild) run local on the workstation Mac; only
// Linux hosts receive routed work. Explicit `pool on <macos-host>` is the
// pool CLI, not this hook, so it is unaffected.
//
// Sidecar plugin pin: cmds carrying `$CLAUDE_PLUGIN_ROOT` or
// `$CLAUDE_PLUGIN_DATA` (literals expanded by the local bash on dispatch)
// resolve to LOCAL plugin cache paths — routing them to a pool host breaks
// because the cache lives only on the workstation. Treat the literals as
// local-bound, alongside `/Users/`/`/home/`. No sign gate: sidecar slash
// commands are a trusted, single-shot surface (not the multi-session
// dispatch-cache race the sign gate was designed to catch).

let MARK = "__SIDECAR_POOL__"

// 0.11.0 — fork-storm cap. A whitelist-forced-LOCAL hexa run (a /tmp script, a
// ~/core/sidecar tool, …) escapes the default hexa->pool offload and runs on
// the Mac. When N background agents each fire one at once the Mac forks into a
// multi-process CPU storm. FORK_STORM_CAP bounds how many USER hexa runs may be
// in flight locally before a NEW whitelist-local hexa is DENIED (with a
// runbook). sidecar's own hooks + claude are never counted (s9). A real
// precondition (a live process count), not an opt-out switch (s11); the count
// fails OPEN (a count error never blocks) so it can never break the build.
let FORK_STORM_CAP = 8

// `_pool_advisory_text()` — canonical advisory shown when a useless env-prefix
// is detected (0.7.11 — POOL-OFFLOAD m7 prep · agent education). Emitted via
// `additionalContext` on the eventual exit so the agent learns these are no-op
// without a counterfactual silent allow. ASCII-only to survive JSON escaping.
fn _pool_advisory_text() -> string {
    return "pool-route advisory: SIDECAR_NO_POOL / SIDECAR_NO_POOL_ROUTE / POOL_DISABLE / SIDECAR_POOL_DISABLE env-prefix are NO-OP since 0.7.3 (POSIX env-prefix stripped before the classifier reads the real verb). For genuine local-force, the USER must run `! sidecar sign local` in the TUI prompt (30-min token since 0.9.3 — build-covering, agent-self-mint forbidden). This cmd proceeds per actual classification; the env-prefix had zero effect on routing."
}

// `_is_useless_pool_env(name)` — name (without `=`) matches one of the canonical
// useless prefixes? Listed by name, NOT recognition of behavior (we don't honor
// these vars — they're no-ops); the list exists ONLY to identify when to emit
// the educational advisory. Adding a name here does not change routing.
fn _is_useless_pool_env(name: string) -> bool {
    if name == "SIDECAR_NO_POOL" { return true }
    if name == "SIDECAR_NO_POOL_ROUTE" { return true }
    if name == "POOL_DISABLE" { return true }
    if name == "SIDECAR_POOL_DISABLE" { return true }
    return false
}

// `_has_useless_pool_env_prefix(toks)` — scan POSIX env-var prefix tokens
// (`IDENT=value`) at the head of toks for any of the useless pool-disable
// names. Returns true if found — caller decides to emit advisory.
fn _has_useless_pool_env_prefix(toks: array) -> bool {
    let mut i = 0
    while i < len(toks) && _is_env_assign(toks[i]) {
        let t = toks[i]
        let eq = t.index_of("=")
        if eq > 0 {
            let name = t.substring(0, eq)
            if _is_useless_pool_env(name) { return true }
        }
        i = i + 1
    }
    return false
}

// Module-level mutable holding the advisory string for THIS invocation. Set
// once at main entry when a useless env-prefix is detected; consumed by every
// exit fn (_allow_count · _deny_count · _emit) which appends it to the JSON
// `additionalContext` field. NULL → no advisory.
let mut _ADVISORY = ""

fn _read_stdin() -> string {
    return to_string(exec("cat"))
}

fn _allow() {
    exit(0)
}

// `_deny(reason)` — block the Bash invocation entirely via the PreToolUse
// permission-decision channel. Used when a command was classified heavy
// (must go to the pool) but every routing path failed — running locally
// would silently violate the "pool-only resources" contract.
fn _deny(reason: string) {
    let mut body = "\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"deny\",\"permissionDecisionReason\":" + _json_str(reason)
    if _ADVISORY != "" { body = body + ",\"additionalContext\":" + _json_str(_ADVISORY) }
    let out = "{\"hookSpecificOutput\":{" + body + "}}"
    println(out)
    exit(0)
}

// `_tally(category)` — increment a single category counter in
// ~/.pool/route-counters.tally. Categories: "routed" (heavy → pool host)
// · "local_bound" (early-exit local-only path: git/gh/pool/npm/~/.X) ·
// "light_allowed" (passed classifier but not heavy → stayed local) ·
// "heavy_failed" (heavy but every eligible host failed preflight). Counts
// the MEANINGFUL classifier verdicts only — early-exit noise (non-Bash,
// empty cmd, MARK, heredoc, ssh-already, sign-local) is NOT counted, so
// the ratio reflects real routing decisions. Format: one `KEY=N` per line.
// Race-tolerant: lossy under concurrent Claude sessions but adequate for
// baseline-rate measurement (POOL-OFFLOAD m1).
fn _tally(category: string) {
    let home = _env("HOME")
    if home == "" { return }
    let path = home + "/.pool/route-counters.tally"
    let mut routed = 0
    let mut local_bound = 0
    let mut light_allowed = 0
    let mut heavy_failed = 0
    let mut raw = ""
    try { raw = read_file(path) } catch e { raw = "" }
    let lines = raw.split("\n")
    let mut i = 0
    while i < len(lines) {
        let ln = lines[i].trim()
        if ln != "" {
            let eq = ln.index_of("=")
            if eq > 0 {
                let k = ln.substring(0, eq)
                let v = to_int(ln.substring(eq + 1, len(ln)).trim())
                if k == "routed" { routed = v }
                else if k == "local_bound" { local_bound = v }
                else if k == "light_allowed" { light_allowed = v }
                else if k == "heavy_failed" { heavy_failed = v }
            }
        }
        i = i + 1
    }
    if category == "routed" { routed = routed + 1 }
    else if category == "local_bound" { local_bound = local_bound + 1 }
    else if category == "light_allowed" { light_allowed = light_allowed + 1 }
    else if category == "heavy_failed" { heavy_failed = heavy_failed + 1 }
    let total = routed + local_bound + light_allowed + heavy_failed
    let body = "routed=" + to_string(routed) + "\n"
             + "local_bound=" + to_string(local_bound) + "\n"
             + "light_allowed=" + to_string(light_allowed) + "\n"
             + "heavy_failed=" + to_string(heavy_failed) + "\n"
             + "total=" + to_string(total) + "\n"
    try { write_file(path, body) } catch e { }
}

// `_allow_count(cat)` / `_deny_count(reason, cat)` — counted exits. Use
// at meaningful classifier-decision sites only; plain _allow/_deny stays
// for non-classifier noise (non-Bash · empty · MARK · etc). When _ADVISORY
// is set (e.g. useless env-prefix detected), emits permissionDecision:allow
// + additionalContext so the agent sees the advisory inline on this cmd.
fn _allow_count(cat: string) {
    _tally(cat)
    if _ADVISORY != "" {
        let out = "{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"allow\",\"additionalContext\":" + _json_str(_ADVISORY) + "}}"
        println(out)
    }
    exit(0)
}
fn _deny_count(reason: string, cat: string) {
    _tally(cat)
    _deny(reason)
}

// JSON-escape a string and wrap it in double quotes.
fn _json_str(s: string) -> string {
    let n = len(s)
    let mut i = 0
    let mut parts = []
    parts.push("\"")
    while i < n {
        let c = s[i]
        if c == "\"" { parts.push("\\\"") }
        else if c == "\\" { parts.push("\\\\") }
        else if c == "\n" { parts.push("\\n") }
        else if c == "\r" { parts.push("\\r") }
        else if c == "\t" { parts.push("\\t") }
        else {
            let k = char_code(c, 0)
            if k < 32 { parts.push(" ") }
            else { parts.push(c) }
        }
        i = i + 1
    }
    parts.push("\"")
    return parts.join("")
}

fn _is_word_char(c: string) -> bool {
    let k = char_code(c, 0)
    if k >= 48 && k <= 57 { return true }
    if k >= 65 && k <= 90 { return true }
    if k >= 97 && k <= 122 { return true }
    if k == 95 { return true }
    return false
}

// `\bword\b` — substring match bounded by non-word chars / string ends.
fn _has_word(hay: string, word: string) -> bool {
    let hn = len(hay)
    let wn = len(word)
    if wn == 0 { return false }
    let mut i = 0
    while i + wn <= hn {
        if hay.substring(i, i + wn) == word {
            let mut ok = true
            if i > 0 {
                if _is_word_char(hay[i - 1]) { ok = false }
            }
            if i + wn < hn {
                if _is_word_char(hay[i + wn]) { ok = false }
            }
            if ok { return true }
        }
        i = i + 1
    }
    return false
}

// whitespace-split into tokens
fn _tokens(s: string) -> array {
    let mut out = []
    let n = len(s)
    let mut i = 0
    let mut cur = ""
    while i < n {
        let c = s[i]
        if c == " " || c == "\t" || c == "\n" || c == "\r" {
            if len(cur) > 0 { out.push(cur); cur = "" }
        } else {
            cur = cur + c
        }
        i = i + 1
    }
    if len(cur) > 0 { out.push(cur) }
    return out
}

// strip ' and " so a quoted heavy subverb (e.g. `hexa 'kick'`) tokenizes to its
// bare form for the adjacency / pair-substring classifier. Classification only —
// the rewrite (ssh) always uses the original command verbatim.
fn _strip_quotes(s: string) -> string {
    let mut out = []
    let n = len(s)
    let mut i = 0
    while i < n {
        let c = s[i]
        if c != "'" && c != "\"" { out.push(c) }
        i = i + 1
    }
    return out.join("")
}

// adjacency: token a immediately followed by token b
fn _has_adjacent(toks: array, a: string, b: string) -> bool {
    let n = len(toks)
    let mut i = 0
    while i + 1 < n {
        if toks[i] == a && toks[i + 1] == b { return true }
        i = i + 1
    }
    return false
}

fn _any_word(cmd: string, words: array) -> bool {
    let mut i = 0
    while i < len(words) {
        if _has_word(cmd, words[i]) { return true }
        i = i + 1
    }
    return false
}

fn _any_contains(cmd: string, subs: array) -> bool {
    let mut i = 0
    while i < len(subs) {
        if cmd.contains(subs[i]) { return true }
        i = i + 1
    }
    return false
}

// pairs is a flat array [a0,b0, a1,b1, ...]
fn _any_adjacent(toks: array, pairs: array) -> bool {
    let mut i = 0
    while i + 1 < len(pairs) {
        if _has_adjacent(toks, pairs[i], pairs[i + 1]) { return true }
        i = i + 2
    }
    return false
}

// Substring-pair fallback — token-adjacency fails when claude-code wraps
// the user command in a zsh shell-snapshot envelope
// (`/bin/zsh -c 'source <snap>; ... eval ''<cmd>'''`) where the inner cmd
// becomes a single quoted argument; `hexa kick` then appears as token
// `'hexa` followed by `kick;` rather than two clean tokens. The `_any_word`
// path (heavy_words) survives this because `cmd.contains(word)` is
// substring-based; the pair path needs the same robustness. False-positive
// risk is bounded: pairs are 2-token compound verbs (`hexa kick`,
// `go build`) unlikely to appear coincidentally in unrelated cmds.
fn _any_pair_substring(cmd: string, pairs: array) -> bool {
    let mut i = 0
    while i + 1 < len(pairs) {
        let needle = pairs[i] + " " + pairs[i + 1]
        if cmd.contains(needle) { return true }
        i = i + 2
    }
    return false
}

// shell single-quote: wrap in '...', embedded ' becomes '\''
fn _shq(s: string) -> string {
    return "'" + s.split("'").join("'\\''") + "'"
}

// quote a workdir for a remote `cd`, keep a leading ~ unquoted so the
// remote shell expands it to that host's own home.
fn _cd_target(wd: string) -> string {
    if wd == "~" { return "~" }
    if wd.starts_with("~/") {
        return "~/" + _shq(wd.substring(2, len(wd)))
    }
    return _shq(wd)
}

// `tailscale ssh` opens a non-login shell — force a login shell so the
// remote PATH (Homebrew etc.) is sourced. Harmless for plain ssh too.
fn _login_wrap(remote: string) -> string {
    return "bash -lc " + _shq(remote)
}

// run a probe command, return only its exit code (255 = ssh/transport).
fn _exec_rc(cmd: string) -> int {
    let r = exec_with_status(cmd)
    return r[1]
}

// read an environment variable — "" when unset.
fn _env(name: string) -> string {
    let r = exec_with_status("printenv " + name)
    if r[1] != 0 { return "" }
    return r[0].trim()
}

// `LOCAL_SIGN_TTL` — `local` sign token validity (seconds). 0.9.3: raised from
// 300 (5min) to 1800 (30min) — anima PURE F-CURRICULA-1 showed a single
// legitimate local build (corpus regen + compile) runs 10-20min, exceeding the
// old 5min window, so a mid-build `hexa run` re-tripped the fork-storm gate when
// the token expired (the user had to re-sign every 5min — unworkable friction).
// 30min covers a realistic build with margin while staying a finite, user-minted
// window. TRADE-OFF: the fork-storm protection window (sign-local SUPPRESSES the
// abs-path heavy gate) is now 6× longer — during it, a multi-session
// dispatch-cache race could re-fork the Mac unguarded. Accepted: the token is
// explicit, user-minted (no agent self-mint path), single-key, and clearable
// early (`sidecar sign clear local`); a build-covering window is the Occam fix
// (commons g0) vs a sliding-window/session-marker mechanism. This TTL is the
// `local` token ONLY (pool-route force-local) — it is INDEPENDENT of the
// governance sign TTL (`SIGN_TTL=300` in bin/sidecar + hooks/sign-guard, which
// gates agent EDITS to commons.tape/project.tape/.gitignore and stays at 5min).
let LOCAL_SIGN_TTL = 1800

// `_local_signed` — fresh `local` sign token (30min · LOCAL_SIGN_TTL). The user
// mints with `! sidecar sign local` in the TUI prompt; the file
// `~/.sidecar/signs/local.sign` holds the mint epoch. pool-route's local-bound
// heavy gate (0.6.4) + the single force-local gate (0.7.2) read it to decide
// whether to allow hexa/python/sh invocations through the absolute-path
// exemption (resp. suppress routing for every command in the window).
fn _local_signed() -> bool {
    let path = _env("HOME") + "/.sidecar/signs/local.sign"
    if !file_exists(path) { return false }
    let mut raw = ""
    try { raw = to_string(read_file(path)) } catch e { return false }
    let mint = to_int(raw.trim())
    if mint <= 0 { return false }
    let age = timestamp() - mint
    if age < 0 { return false }
    return age <= LOCAL_SIGN_TTL
}

// `_local_heavy_interp` — heavy interpreter/compiler invocation? These are
// the canonical mac fork-storm sources when forced local-bound: hexa CLI
// (any verb), direct hexa.real, python/python3/py, the C/C++ compiler
// drivers (gcc/g++/clang/clang++/cc/c++ — 0.6.12), and `bash`/`sh
// <script>` (positional script arg, not `bash -c "..."` which is the
// shell wrapper convention). Bare reads (ls/cat/grep/find/...) stay free.
//
// HOTFIX 0.6.5: detect interp invocation by FIRST-TOKEN basename only —
// 0.6.4 used `_has_word(cmd, "hexa")` which `cat /Users/.../hexa-lang/foo`
// also matched (the `-` in `hexa-lang` is a word boundary), gating bare
// reads. The first token IS the invoked verb; matching there is sound.
// POSIX env-var prefix detection. `IDENT=value` is a leading assignment, not
// a command; several `IDENT=val cmd args` may stack. The sign-gate MUST skip
// these before reading the real command — otherwise ANY env-var prefix
// (POOL_DISABLE, SIDECAR_POOL_DISABLE, FOO=bar, …) shifts toks[0] off the
// real interpreter and silently bypasses the gate. This is parser
// correctness, NOT recognition of any specific var — there is nothing to
// opt out of (s11); the prefix is simply not the command.
fn _is_env_assign(t: string) -> bool {
    let n = len(t)
    if n < 2 { return false }
    let c0 = char_code(t[0], 0)
    let is_id_start = (c0 >= 65 && c0 <= 90) || (c0 >= 97 && c0 <= 122) || c0 == 95
    if !is_id_start { return false }
    let mut i = 1
    while i < n {
        let c = t[i]
        if c == "=" { return true }
        let k = char_code(c, 0)
        let is_id_cont = (k >= 48 && k <= 57) || (k >= 65 && k <= 90) || (k >= 97 && k <= 122) || k == 95
        if !is_id_cont { return false }
        i = i + 1
    }
    return false
}

fn _strip_env_prefix(toks: array) -> array {
    let mut i = 0
    while i < len(toks) && _is_env_assign(toks[i]) { i = i + 1 }
    if i == 0 { return toks }
    let mut out = []
    let mut j = i
    while j < len(toks) { out.push(toks[j]); j = j + 1 }
    return out
}

// Known leading-position wrappers that exec a "real" command after their own
// args. The sign-gate skips them so `env`/`exec`/`nice`/`timeout`/`command`/
// `sudo`/`nohup`/`stdbuf`/`ionice` wrapping cannot disguise a heavy
// interpreter (audit found 8 realistic wrapper vectors silently ALLOW'd
// pre-0.7.3 on abs-path heavy invocations). NOT recognition of specific
// behavior — these are well-known POSIX/shell helpers whose argv ends in the
// real command. `eval` is out of scope (its arg is a quoted shell string
// requiring a real parser).
fn _is_wrapper(b: string) -> bool {
    return b == "env" || b == "exec" || b == "nice" || b == "timeout"
        || b == "command" || b == "sudo" || b == "nohup" || b == "stdbuf"
        || b == "ionice"
}

// Short options that consume the NEXT argv token as their value, per wrapper.
// Anything not listed is treated as a self-contained flag (no following arg).
// Long options use `--name=value` form and are handled by the bare `--` token
// terminator (we just skip the option token itself).
fn _opt_takes_arg(wrap: string, opt: string) -> bool {
    if wrap == "nice"    && opt == "-n" { return true }
    if wrap == "env"     && (opt == "-u" || opt == "-S") { return true }
    if wrap == "ionice"  && (opt == "-c" || opt == "-n" || opt == "-p" || opt == "-P" || opt == "-u") { return true }
    if wrap == "stdbuf"  && (opt == "-i" || opt == "-o" || opt == "-e" || opt == "-I" || opt == "-O" || opt == "-E") { return true }
    if wrap == "sudo"    && (opt == "-u" || opt == "-g" || opt == "-h" || opt == "-p" || opt == "-D" || opt == "-r" || opt == "-t" || opt == "-T") { return true }
    if wrap == "timeout" && (opt == "-s" || opt == "-k") { return true }
    return false
}

// Skip the wrapper word + its options + (for `timeout`) the positional
// DURATION, returning the index of the first token of the real command.
fn _strip_wrapper_args(toks: array, start: int) -> int {
    let wrap = _basename(toks[start])
    let mut k = start + 1
    while k < len(toks) {
        let t = toks[k]
        if len(t) == 0 { k = k + 1; continue }
        if t == "--" { k = k + 1; break }
        if t.substring(0, 1) == "-" {
            // long --name / --name=value → skip the token itself
            if len(t) >= 2 && t.substring(1, 2) == "-" { k = k + 1; continue }
            // short -X: skip, and consume one following arg if this option
            // takes one AND the value isn't already attached (`-oL` vs `-o L`).
            let opt2 = if len(t) >= 2 { t.substring(0, 2) } else { t }
            k = k + 1
            if _opt_takes_arg(wrap, opt2) && len(t) == 2 && k < len(toks) {
                let n = toks[k]
                if len(n) > 0 && n.substring(0, 1) != "-" && !_is_env_assign(n) {
                    k = k + 1
                }
            }
            continue
        }
        break
    }
    // `timeout DURATION cmd` — DURATION is a positional non-flag arg before cmd
    if wrap == "timeout" && k < len(toks) { k = k + 1 }
    return k
}

// Strip POSIX env-prefix + recognized wrappers + a single leading backslash
// (POSIX literal/alias-bypass, e.g. `\hexa`) so the heavy classifier reads
// the REAL command verb. Bounded recursion (depth 8) guards against
// pathological stacking.
fn _unwrap_to_real(toks0: array) -> array {
    let mut toks = _strip_env_prefix(toks0)
    let mut depth = 0
    while depth < 8 && len(toks) > 0 {
        let first = _basename(toks[0])
        let mut first_clean = first
        while len(first_clean) > 1 && first_clean.substring(0, 1) == "\\" {
            first_clean = first_clean.substring(1, len(first_clean))
        }
        if !_is_wrapper(first_clean) {
            if first_clean != first {
                // rewrite leading token with the unescaped basename so the caller's
                // basename match (already done via _basename(real[0])) sees `hexa`
                // instead of `\hexa`.
                let mut out = [first_clean]
                let mut k = 1
                while k < len(toks) { out.push(toks[k]); k = k + 1 }
                return out
            }
            return toks
        }
        let next = _strip_wrapper_args(toks, 0)
        if next >= len(toks) { return [] }
        let mut tail = []
        let mut p = next
        while p < len(toks) { tail.push(toks[p]); p = p + 1 }
        toks = _strip_env_prefix(tail)
        depth = depth + 1
    }
    return toks
}

fn _local_heavy_interp(cmd: string, toks: array) -> bool {
    // 0.7.3 — unwrap POSIX env-var prefix + known wrappers (env · exec · nice ·
    // timeout · command · sudo · nohup · stdbuf · ionice) + leading backslash
    // so the classifier reads the REAL verb. Pre-0.7.3 any IDENT=val prefix
    // OR any of those wrappers silently bypassed the sign-gate on abs-path
    // heavy invocations. `eval 'cmd'` remains out of scope (quoted shell
    // string requires a real parser).
    let real = _unwrap_to_real(toks)
    if len(real) == 0 { return false }
    let t0_basename = _basename(real[0])
    if t0_basename == "hexa" { return true }
    if t0_basename == "hexa.real" { return true }
    if t0_basename == "hexac" { return true }
    if t0_basename == "hexadrv" { return true }
    if t0_basename == "hxv2" { return true }
    if t0_basename == "python" || t0_basename == "python3" || t0_basename == "py" { return true }
    // 0.7.7 — Node/JS interpreters (POOL-OFFLOAD m2): node/deno/bun/ts-node are
    // the canonical JS/TS fork-storm sources on abs-path invocation, mirroring
    // python/hexa. `tsx` would belong here too (it's a real heavy interpreter
    // for `.ts/.tsx` execution) and is SAFE at the first-token-basename layer —
    // false-positive only exists in the substring-matched heavy_words layer
    // (where it collides with the `.tsx` file extension). Including it here.
    if t0_basename == "node" || t0_basename == "deno" || t0_basename == "bun" { return true }
    if t0_basename == "tsx" || t0_basename == "ts-node" { return true }
    // 0.7.8 — JVM 계열 (POOL-OFFLOAD m3): `java`/`javac`/`kotlinc`/`scalac`/`sbt`
    // first-token basename match — abs-path `/usr/bin/java -jar /Users/.../app.jar`
    // is the canonical JVM fork-storm trigger (each invocation forks the JVM).
    // Safe at first-token layer regardless of name length (`java`/`sbt` 4/3-char
    // substring-collide in heavy_words; first-token is precise EXEC-only match).
    if t0_basename == "java" || t0_basename == "javac" { return true }
    if t0_basename == "kotlinc" || t0_basename == "scalac" || t0_basename == "sbt" { return true }
    // 0.7.9 — 미디어 도구 (POOL-OFFLOAD m4): ffmpeg/magick/convert/sox first-token
    // basename — abs-path media transform on /Users path is canonical fork-storm
    // (video encode · image batch convert · audio process). convert/sox are
    // first-token-only (substring-collide as English words at heavy_words layer).
    if t0_basename == "ffmpeg" || t0_basename == "magick" { return true }
    if t0_basename == "convert" || t0_basename == "sox" { return true }
    // 0.6.12 — C/C++ compiler drivers: an absolute-path compile (e.g.
    // `/usr/bin/gcc /Users/…/x.c`) is the same fork-storm trigger as a heavy
    // interpreter — multi-session re-fork of the compiler on the workstation.
    // First-token basename keeps it precise: only a real compiler invocation
    // matches, never a bare read that merely mentions `cc` inside a path.
    if t0_basename == "gcc" || t0_basename == "g++" { return true }
    if t0_basename == "clang" || t0_basename == "clang++" { return true }
    if t0_basename == "cc" || t0_basename == "c++" { return true }
    if t0_basename == "bash" || t0_basename == "sh" {
        if len(real) >= 2 {
            let t1 = real[1]
            // skip `bash -c "..."` / `sh -c "..."` — those are shell wrappers
            if len(t1) > 0 && t1.substring(0, 1) != "-" { return true }
        }
    }
    return false
}

// `_is_hexa_exec(toks)` — WHITELIST core (0.8.0 — POOL-OFFLOAD m8, user
// directive "모든 hexa 실행 pool 로"): is the REAL invoked verb a hexa binary?
// This flips pool-route from a heavy-VERB blacklist (which leaked verify ·
// atlas · parse · honesty · … → multi-hundred-process Mac fork-storm) to a
// WHITELIST: ANY hexa execution routes to the pool, full stop. Unwraps the
// POSIX env-prefix + wrappers + backslash first (same hardening as the sign
// gate) so `POOL_DISABLE=1 nice hexa verify …` is still caught. The 3
// STRUCTURAL exemptions that must stay local are handled EARLIER in main and
// never reach here: (1) `$CLAUDE_PLUGIN_ROOT`/`$CLAUDE_PLUGIN_DATA` (sidecar's
// own hexa hooks/commands — routing the router is incoherent + the plugin
// cache only exists on the workstation); (2) `hexa cloud` (itself a remote
// dispatcher — double-dispatch is incoherent); (3) any `/Users/`·`/home/`·
// `~/.` absolute-path hexa (sign-gated — the path may not exist on the peer).
// Everything else hexa — verify · parse · run · build · kick · drill · loop ·
// cc · test · bench · atlas (lookup/register/…) · smash · honesty · … — routes.
fn _is_hexa_exec(toks: array) -> bool {
    let real = _unwrap_to_real(toks)
    if len(real) == 0 { return false }
    let b = _basename(real[0])
    if b == "hexa" { return true }
    if b == "hexa.real" { return true }
    if b == "hexac" { return true }
    if b == "hexadrv" { return true }
    if b == "hxv2" { return true }
    return false
}

// `_is_synced_workdir_path(p)` — does the path live inside a user-synced
// `~/core/<repo>/` workdir (mirrored to every pool host)? Both the tilde form
// (`~/core/…`) and the $HOME-expanded form (`<HOME>/core/…`) count. These are
// the ONLY paths a peer host is guaranteed to also hold, so a data input there
// can route; anything else (abs `/Users/`·`/home/` outside core, `/tmp`, a
// bare relative file that resolves against a non-synced cwd) is local-only.
fn _is_synced_workdir_path(p: string) -> bool {
    if p.starts_with("~/core/") { return true }
    let home = _env("HOME")
    if home != "" && p.starts_with(home + "/core/") { return true }
    return false
}

// `_has_whitelisted_local_path(av)` — 0.10.0 sidecar path-prefix whitelist
// (~/.sidecar/local-paths · USER-managed via `sidecar paths {bare|add|rm}`):
// scan ALL argv tokens for any `/`-prefixed absolute path that STARTS WITH
// a registered prefix line. Hit → force LOCAL (skip routing). This is the
// permanent counterpart to the runtime `sign-local` token: the user
// declares "anything under these prefixes runs HERE, never the pool",
// which fixes sidecar's own hexa hooks/commands bouncing into the pool +
// any user-declared local-only workspace. The whitelist itself IS the
// opt-in — there is no env opt-out (project.tape @D s11). Missing file =
// empty whitelist (no-op, no fail-closed). Blank + `#` comment lines are
// skipped. Read once per invocation (typically 2-10 lines, no cache).
// Returns the matched prefix for the routing-decision log, or "" on miss.
fn _whitelisted_path_match(av: array) -> string {
    let home = _env("HOME")
    if home == "" { return "" }
    let path = home + "/.sidecar/local-paths"
    if !file_exists(path) { return "" }
    let mut raw = ""
    try { raw = read_file(path) } catch e { return "" }
    if raw == "" { return "" }
    let lines = raw.split("\n")
    let mut i = 0
    while i < len(av) {
        let t = av[i]
        if len(t) > 0 && t.substring(0, 1) == "/" {
            let mut j = 0
            while j < len(lines) {
                let ln = lines[j].trim()
                if ln != "" {
                    if ln.substring(0, 1) != "#" {
                        if t.starts_with(ln) { return ln }
                    }
                }
                j = j + 1
            }
        }
        i = i + 1
    }
    return ""
}

// `_local_hexa_count()` — how many USER hexa interpreter runs are live on this
// host right now? Reads `ps -Ao args` and counts lines whose first token's
// basename is `hexa` (one line per run — the dispatch binary `hexa_run.<hash>`
// and the `sh -c` shim have a different basename, so a single run counts once).
// Excludes sidecar's OWN hooks (argv under `cache/sidecar`, incl. THIS router)
// and anything mentioning `claude` (s9 — never attribute load to claude). Only
// LOCAL hexa appear in `ps` here (pool-routed runs execute on a peer), so the
// count is exactly the local fork-storm pressure. Returns -1 on any error so
// the caller fails OPEN (never block on a count bug · s11 spirit).
fn _local_hexa_count() -> int {
    let mut raw = ""
    try { raw = to_string(exec("ps -Ao args")) } catch e { return -1 }
    if raw == "" { return -1 }
    let lines = raw.split("\n")
    let mut c = 0
    let mut i = 0
    while i < len(lines) {
        let ln = lines[i].trim()
        i = i + 1
        if ln == "" { continue }
        let sp = ln.index_of(" ")
        let mut first = ln
        if sp > 0 { first = ln.substring(0, sp) }
        if _basename(first) != "hexa" { continue }
        if ln.contains("cache/sidecar") { continue }
        if ln.contains("claude") { continue }
        c = c + 1
    }
    return c
}

// `_is_data_input_flag(name)` — is `name` one of the canonical data-INPUT flags
// whose VALUE is a path to local-only training/eval/corpus/weights data? A hexa
// command carrying one of these, pointing at a NON-synced path, depends on data
// that does NOT exist on a pool peer — routing it there reproduces the anima
// PURE F-CURRICULA-1 failure (`source not found`, which is actually data-
// absence misread as a compile error). Listed by NAME, the same data-locality
// logic as the host-introspection whitelist (semantic necessity, not
// convenience). Caller matches both `--flag value` and `--flag=value`.
fn _is_data_input_flag(name: string) -> bool {
    if name == "--corpus-path" { return true }
    if name == "--corpus" { return true }
    if name == "--data" { return true }
    if name == "--data-path" { return true }
    if name == "--dataset" { return true }
    if name == "--input" { return true }
    if name == "--train-data" { return true }
    if name == "--eval-data" { return true }
    if name == "--weights" { return true }
    if name == "--ckpt" { return true }
    if name == "--checkpoint" { return true }
    return false
}

// `_has_local_data_input(toks)` — does a hexa command depend on a data-input
// flag whose value is a LOCAL-ONLY path (not a synced `~/core/` workdir)? If so
// it must stay local — the peer has no copy of that data (data-locality, the
// same necessity as the host-introspection whitelist). Scans for each data-
// input flag (both `--flag value` and `--flag=value`): the value is the next
// token (space form) or the post-`=` substring (attached form). A value that is
// a synced `~/core/` path is SAFE (the peer mirrors it) → keeps routing; a value
// that is anything else (abs `/Users/`, `/tmp`, a bare relative path resolved
// against a non-synced cwd) → local pin. Conservative: only fires when (a) the
// verb is a hexa exec AND (b) a data flag is present AND (c) its value is NOT a
// synced workdir path. NON-hexa heavy compute is unaffected.
fn _has_local_data_input(toks: array) -> bool {
    if !_is_hexa_exec(toks) { return false }
    let n = len(toks)
    let mut i = 0
    while i < n {
        let t = toks[i]
        let eq = t.index_of("=")
        if eq > 0 {
            // attached form: --flag=value
            let name = t.substring(0, eq)
            if _is_data_input_flag(name) {
                let val = t.substring(eq + 1, len(t))
                if val != "" && !_is_synced_workdir_path(val) { return true }
            }
        } else if _is_data_input_flag(t) {
            // space form: --flag value (value is the next token)
            if i + 1 < n {
                let val = toks[i + 1]
                if val != "" && !_is_synced_workdir_path(val) { return true }
            } else {
                // dangling flag with no value — be conservative, pin local
                return true
            }
        }
        i = i + 1
    }
    return false
}

// `_basename` — strip directory prefix. `/Users/x/.hx/bin/hexa` → `hexa`.
fn _basename(path: string) -> string {
    let i = path.last_index_of("/")
    if i < 0 { return path }
    return path.substring(i + 1, len(path))
}

// emit the updatedInput rewrite — rebuild tool_input with command swapped.
fn _emit(ti: map, new_cmd: string, note: string) {
    let ks = keys(ti)
    let mut parts = []
    let mut i = 0
    while i < len(ks) {
        let k = ks[i]
        if k == "command" {
            parts.push(_json_str(k) + ":" + _json_str(new_cmd))
        } else {
            parts.push(_json_str(k) + ":" + json_stringify(ti[k]))
        }
        i = i + 1
    }
    let updated = "{" + parts.join(",") + "}"
    let final_note = if _ADVISORY != "" { _ADVISORY + "\n\n--- routing note ---\n" + note } else { note }
    let out = "{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"allow\",\"updatedInput\":" + updated + ",\"additionalContext\":" + _json_str(final_note) + "}}"
    println(out)
    exit(0)
}

// Event-name reader — hook payload carries `hook_event_name` (snake_case).
fn _event_of(payload: map) -> string {
    if has_key(payload, "hook_event_name") { return payload["hook_event_name"] }
    if has_key(payload, "hookEventName") { return payload["hookEventName"] }
    return ""
}

// Append a routing log entry — ~/.pool/route-log.jsonl, capped at 100 lines.
// Each line: {"t":"<iso>","host":"<name>","cmd":"<first 40 chars, sanitized>"}.
fn _log_route(host: string, cmd: string) {
    let home = _env("HOME")
    if home == "" { return }
    let path = home + "/.pool/route-log.jsonl"
    // sanitize: drop newlines/tabs, first 40 chars
    let mut head = cmd
    head = head.split("\n").join(" ")
    head = head.split("\t").join(" ")
    if len(head) > 40 { head = head.substring(0, 40) }
    let t = exec_with_status("date -u +%Y-%m-%dT%H:%M:%SZ")[0].trim()
    let line = "{\"t\":" + _json_str(t) + ",\"host\":" + _json_str(host) + ",\"cmd\":" + _json_str(head) + "}\n"
    // read existing, append, trim to last 100 lines
    let mut prior = ""
    try { prior = read_file(path) } catch e { prior = "" }
    let combined = prior + line
    let lines = combined.split("\n")
    let n = len(lines)
    let start = if n > 101 { n - 101 } else { 0 }
    let mut kept = []
    let mut i = start
    while i < n {
        if lines[i] != "" { kept.push(lines[i]) }
        i = i + 1
    }
    try { write_file(path, kept.join("\n") + "\n") } catch e { }
}

// SessionStart snapshot — emit recent routing log as additionalContext.
// Skips quietly when the log is empty or unreadable.
fn _emit_session_start() {
    let home = _env("HOME")
    if home == "" { exit(0) }

    // 0.9.2 — POLICY PREAMBLE: every session start now carries the pool-route
    // routing policy as ambient context, so any agent automatically knows
    // "hexa command → pool" without the user having to re-explain. The policy
    // mirrors the plugin.json description but trimmed to one screen.
    let policy = "# pool-route policy (default=POOL · 화이트리스트만 local · 0.9.0+ inversion):\n"
               + "  - ANY `hexa <verb>` → pool (0.8.0 POOL-DISPATCH; structural local-exemptions only: $CLAUDE_PLUGIN_ROOT/DATA · `hexa cloud` · `hexa atlas register` · /Users//home abs-path sign-gated)\n"
               + "  - non-hexa default also → pool (0.9.0 inversion); LOCAL-EXEC WHITELIST stays local: git/gh/pool · npm/pnpm/yarn · ~/. dotstate · host-introspection (ps/top/uptime/df/lsof/pgrep/kill/…)\n"
               + "  - whitelist 추가 = sign-gated (project.tape commons @D s13 · `! sidecar sign project`)\n"
               + "  - `! sidecar sign local` (30min TUI bang since 0.9.3 — build-covering) → 모든 명령 로컬 강제 (단일 force-local gate · agent 자가민팅 deny)\n"

    let path = home + "/.pool/route-log.jsonl"
    let mut raw = ""
    try { raw = read_file(path) } catch e { raw = "" }

    let mut tail = ""
    if raw != "" {
        let lines = raw.split("\n")
        let n = len(lines)
        let take = 5
        let start = if n > take + 1 { n - take - 1 } else { 0 }
        let mut bullets = []
        let mut i = start
        while i < n {
            let ln = lines[i].trim()
            if ln != "" {
                let mut obj = json_parse("{}")
                try { obj = json_parse(ln) } catch e { obj = json_parse("{}") }
                if type_of(obj) == "map" {
                    let mut t = ""
                    let mut host = ""
                    let mut cmd = ""
                    if has_key(obj, "t") { if type_of(obj["t"]) == "string" { t = obj["t"] } }
                    if has_key(obj, "host") { if type_of(obj["host"]) == "string" { host = obj["host"] } }
                    if has_key(obj, "cmd") { if type_of(obj["cmd"]) == "string" { cmd = obj["cmd"] } }
                    if host != "" {
                        bullets.push("- " + t + " → " + host + " : " + cmd)
                    }
                }
            }
            i = i + 1
        }
        if len(bullets) > 0 {
            tail = "\n# recent pool-route (~/.pool/route-log.jsonl · last " + to_string(len(bullets)) + ")\n" + bullets.join("\n") + "\n"
        }
    }

    let body = policy + tail
    let out = "{\"hookSpecificOutput\":{\"hookEventName\":\"SessionStart\",\"additionalContext\":" + _json_str(body) + "}}"
    println(out)
    exit(0)
}

fn main() {
    let raw = _read_stdin()
    let mut payload = json_parse("{}")
    try { payload = json_parse(raw) } catch e { _allow() }
    if type_of(payload) != "map" { _allow() }

    // SessionStart — emit recent routing log snapshot, then exit.
    let event = _event_of(payload)
    if event == "SessionStart" { _emit_session_start() }

    // Bash tool only — Read/Write/Edit operate on the local fs.
    if !has_key(payload, "tool_name") { _allow() }
    if payload["tool_name"] != "Bash" { _allow() }
    if !has_key(payload, "tool_input") { _allow() }
    let ti = payload["tool_input"]
    if type_of(ti) != "map" { _allow() }
    if !has_key(ti, "command") { _allow() }
    let cmd0 = ti["command"]
    if type_of(cmd0) != "string" { _allow() }
    let cmd = cmd0.trim()
    if cmd == "" { _allow() }

    // skip — already routed / heredoc / background / already ssh
    if cmd.contains(MARK) { _allow() }
    if cmd.contains("<<") { _allow() }
    if cmd.ends_with("&") { _allow() }
    if cmd.starts_with("ssh ") { _allow() }

    // 0.7.11 — useless env-prefix advisory (POOL-OFFLOAD m7 prep · agent
    // education). Scan POSIX env-var prefix at the head of the cmd for
    // SIDECAR_NO_POOL / SIDECAR_NO_POOL_ROUTE / POOL_DISABLE /
    // SIDECAR_POOL_DISABLE — all no-op since 0.7.3 (env-prefix is stripped
    // before classification, by design per s11). Set _ADVISORY so the
    // eventual exit fn emits an inline additionalContext explaining the
    // no-op + pointing to `! sidecar sign local` as the only legitimate
    // local-force path. Does NOT change routing behavior — purely educational.
    let early_toks = _tokens(cmd)
    if _has_useless_pool_env_prefix(early_toks) {
        _ADVISORY = _pool_advisory_text()
    }

    // single local-execution gate (0.7.2): a fresh `local` sign token forces
    // EVERY command to run HERE — the one deliberate, user-minted "run this on
    // the workstation, do NOT route" path (`! sidecar sign local`, 30min TTL).
    // Consolidates local-exec control to one sign-gated channel: when the router
    // mis-classifies a local-bound command (a diagnostic `ps`/`awk`, a local-fs
    // fix) and ships it to a peer host, the user signs ONCE and all routing is
    // suppressed for the window. A sanctioned, time-boxed, user-minted token —
    // NOT an env-var/config opt-out (s11). Subsumes the abs-path-heavy sign gate
    // below: when signed, this returns first; when unsigned, that gate still
    // bites (fork-storm protection), so unsigned behaviour is unchanged.
    if _local_signed() { _allow_count("local_bound") }

    // local-bound guard (pool-route 0.6.0): commands inherently tied to THIS
    // host's filesystem / repo state must NEVER route — they break on a remote
    // where the path / repo / binary doesn't exist. The recurring failure mode:
    // `git push` / `hexa run /Users/.../x.hexa` / a `/Users/`-absolute smoke
    // shipped to a Linux pool host where that path resolves to nothing.
    //   - git / gh : operate on the local working tree + remotes (cwd repo)
    //   - pool     : the dispatcher ITSELF (`pool on <host> <cmd>`). Routing a
    //                `pool` command to a pool host is nonsensical — the remote
    //                host has no `pool` binary (→ 127), and even if it did it
    //                would double-dispatch. The `pool` CLI is the local SSH
    //                wrapper; it must always run on THIS workstation. (0.7.1 —
    //                fixes load-balanced mis-route of `pool on …` to a peer host.)
    //   - sidecar  : the local marketplace CLI (sidecar-family, same class as
    //                `pool`). It manages LOCAL state only — `~/.sidecar/` (handoff
    //                registry · signs · local-paths whitelist · profiles) and
    //                `~/.claude/` (installed_plugins.json · enabledPlugins). A
    //                `sidecar handoff add …` / `sidecar sync` shipped to a pool
    //                host writes the WRONG machine's state (or 127s on a host with
    //                no `sidecar` binary). Mirrors the `pool` pin: always LOCAL.
    //                (0.14.0 — the bare `sidecar <verb>` CLI was NOT covered by
    //                the `$CLAUDE_PLUGIN_ROOT`/`~/.sidecar` literal pins below —
    //                a `sidecar handoff add <repo> <text>` carries neither token.)
    //   - /Users/ or /home/ literal : host-specific absolute path
    // These are read/version-control/local-fs ops, never the heavy compute the
    // pool exists for, so an early _allow() is always correct.
    if _has_word(cmd, "git") || _has_word(cmd, "gh") || _has_word(cmd, "pool") || _has_word(cmd, "sidecar") { _allow_count("local_bound") }
    // node-package installers (0.7.4): npm/pnpm/yarn read package.json + write
    // node_modules in CWD — they are inherently cwd-bound, so routing them to a
    // pool host (where the CWD usually doesn't exist) fails preflight with
    // 'workdir missing' on every host and DENIES the command. The classifier
    // counted these as heavy compute, but the install/build IS local to the
    // project's CWD — there's no remote work to dispatch.
    if _has_word(cmd, "npm") || _has_word(cmd, "pnpm") || _has_word(cmd, "yarn") { _allow_count("local_bound") }
    // sidecar plugin pin (0.6.8): `$CLAUDE_PLUGIN_ROOT` / `$CLAUDE_PLUGIN_DATA`
    // literals always resolve to the LOCAL plugin cache — routing them to a
    // pool host fails because the cache lives only on the workstation. Trusted
    // surface (sidecar slash commands), so no sign gate.
    if cmd.contains("$CLAUDE_PLUGIN_ROOT") || cmd.contains("$CLAUDE_PLUGIN_DATA") { _allow_count("local_bound") }
    // deck-gen pin (0.15.0 — structural LOCAL-EXECUTION exemption, sits BEFORE
    // the abs-path/dotstate sign gate below so it gives a CLEAN local allow):
    // the `/deck` command runs `hexa run $HOME/.hx/install/hexa-lang/stdlib/
    // deck/gen.hexa …`. Pre-s3 it carried a literal `/Users/…` substring, so it
    // matched the abs-path branch below — but as a HEAVY hexa interp on an
    // absolute host path it would have hit that branch's sign gate (DENY without
    // `! sidecar sign local`). The s3 portability fix rewrote it to `$HOME/.hx/…`
    // which still matches the `$HOME/.` arm of that same branch → same sign-gate
    // DENY. Either way the deck generator (sidecar's OWN trusted command surface,
    // like the $CLAUDE_PLUGIN_ROOT pin above) must run LOCAL without a sign gate:
    // it is a Mac-local hx install artifact (`~/.hx/install/...`) absent on every
    // pool peer, so routing it → `source not found` and deck BREAKS. Pin any cmd
    // referencing the deck generator to a clean local allow. Mirrors the cloud/
    // atlas pins. Unconditional · no opt-out env (@D s11).
    if cmd.contains("stdlib/deck/gen.hexa") { _allow_count("local_bound") }
    // home-dotstate pin (0.6.9): `~/.` and `$HOME/.` references point at
    // per-host HIDDEN state (`~/.zsh_history` · `~/.hexa-cache` · `~/.pool` ·
    // `~/.sidecar` · `~/.config` · …) that is NOT user-synced. Routing them to a
    // pool host reads the WRONG host's state — the recurring failure: a probe
    // like `grep ~/.zsh_history` or `cat ~/.hexa-cache/...` shipped to ubu-2
    // returned that host's history / dispatch cache instead of the Mac's. They
    // join the local-bound set alongside `/Users/`·`/home/`. SYNCED workdirs
    // (`~/core/...`) are deliberately excluded — they keep routing (the
    // documented `find ~/core/anima` big-tree pattern still dispatches).
    if cmd.contains("/Users/") || cmd.contains("/home/") || cmd.contains("~/.") || cmd.contains("$HOME/.") {
        // Sign gate (0.6.4): local-bound HEAVY invocations (hexa · python ·
        // bash/sh <script>) on absolute host paths are the canonical mac
        // fork-storm trigger — multiple sessions racing dispatch caches +
        // re-fork on every env-hash miss. Require a fresh user sign-off
        // (`! sidecar sign local`, 30min token since 0.9.3, mints freely from
        // the TUI bang) before honoring the absolute-path exemption. Bare reads
        // (ls/cat/grep/find/...) on absolute paths stay free — the gate
        // narrows to interpreters/compilers only.
        let toks = _tokens(cmd)
        if _local_heavy_interp(cmd, toks) {
            if !_local_signed() {
                _deny_count("local-bound heavy invocation (hexa · python · gcc/g++/clang/cc · sh <script>) on an absolute host path needs a fresh sign-off — the canonical mac fork-storm trigger. USER: run  `! sidecar sign local`  in the TUI prompt (30min token — covers a full build), then retry. Bare absolute-path reads (ls/cat/grep/find/...) are unaffected; this gate narrows to interpreters/compilers only.", "heavy_failed")
            }
        }
        _allow_count("local_bound")
    }

    // 0.9.0 — host-introspection whitelist. These commands measure THIS
    // host's state (CPU/load/processes/disk/network/kernel/users/files) —
    // routing them to a pool host returns the PEER's state, which is
    // incoherent for diagnostics (`ps -ax` of pool host != Mac's procs;
    // `uptime` of pool host != Mac load; `kill <pid>` targets a different
    // process namespace; `df` shows pool disk; `lsof` shows pool sockets).
    // Extends the dotstate principle (per-host hidden state stays local)
    // to host-introspection commands by semantic necessity, NOT convenience.
    // Sign-gated additions (extending this list) go via project.tape rule
    // edits (commons @D s13). Per user policy 0.9.0: "무조건 pool · 화이트
    // 리스트만 local 가능" — strict default-pool, semantic-coherent local
    // exceptions only.
    let intro_list = ["ps", "top", "htop", "uptime", "w", "who", "users", "df", "du", "free", "vmstat", "iostat", "uname", "sysctl", "launchctl", "systemctl", "pgrep", "pkill", "kill", "killall", "stat", "lsof", "netstat", "ifconfig", "ip", "arp", "route", "dscl", "scutil", "sw_vers"]
    if len(early_toks) >= 1 {
        let t0i = _basename(early_toks[0])
        let mut ii = 0
        while ii < len(intro_list) {
            if t0i == intro_list[ii] { _allow_count("local_bound") }
            ii = ii + 1
        }
    }

    // 0.10.0 — sidecar path-prefix whitelist (~/.sidecar/local-paths,
    // USER-managed via `sidecar paths {bare|add|rm}`). The PERMANENT
    // counterpart to the runtime `sign-local` token (which is one-shot
    // 30-min): a registered prefix forces LOCAL for any Bash cmd whose
    // argv contains a `/`-prefixed token starting with that prefix.
    // Closes the recurring fail mode where sidecar's own hexa hooks at
    // `$HOME/.claude/plugins/cache/sidecar/...` got bounced to the pool
    // (the cache only exists on the workstation). The whitelist itself
    // IS the opt-in — no env opt-out (project.tape @D s11). Sits
    // alongside the other STRUCTURAL local-exemptions (host-introspection,
    // dotstate, etc); the heavy classifier never sees these.
    let _wl_match = _whitelisted_path_match(early_toks)
    if _wl_match != "" {
        // 0.11.0 fork-storm cap: a whitelist-forced-local HEAVY hexa run is the
        // canonical Mac fork-storm source (N background agents each firing a
        // /tmp hexa at once -> multi-process CPU blowout). Cap concurrent local
        // hexa RUNS: if FORK_STORM_CAP or more USER hexa interpreters are already
        // live (sidecar's own hooks + claude excluded), DENY this one with a
        // runbook — locality is preserved (imports still resolve) while the storm
        // gets a ceiling. Fail-OPEN: a count error (-1) is < cap, so it never
        // blocks. Only fires for hexa execs; a plain `cat /tmp/x` is unaffected.
        if _is_hexa_exec(early_toks) {
            let _nrun = _local_hexa_count()
            if _nrun >= FORK_STORM_CAP {
                _deny_count("pool-route: fork-storm guard — " + to_string(_nrun) + " local hexa runs already in flight (cap " + to_string(FORK_STORM_CAP) + ").\n  This `hexa` is forced LOCAL by the sidecar path whitelist (prefix=" + _wl_match + "), so launching another now risks a Mac fork-storm.\n  Options: (a) wait for an in-flight run to finish, (b) run it on the pool (use a path NOT under a local-paths prefix), or (c) raise FORK_STORM_CAP in pool-route.\n  (counts USER hexa runs only — sidecar's own hooks + claude are excluded.)", "heavy_failed")
            }
        }
        println("pool-route: local (sidecar path whitelist · prefix=" + _wl_match + ")")
        _allow_count("local_bound")
    }

    let home = _env("HOME")

    // roster — the `pool` CLI's single source of truth, ~/.pool/pool.json
    // (schema: hosts[] of {name, ssh, enabled, sudo, os}).
    let dd = home + "/.pool"
    let mut cfg = json_parse("{}")
    try {
        let parsed = json_parse(read_file(dd + "/pool.json"))
        if type_of(parsed) == "map" { cfg = parsed }
    } catch e { _allow() }

    // ARM check — at least one enabled roster host.
    if !has_key(cfg, "hosts") { _allow() }
    let hosts = cfg["hosts"]
    if type_of(hosts) != "array" { _allow() }

    let mut h_name = []
    let mut h_plat = []
    let mut h_sudo = []
    let mut hi = 0
    while hi < len(hosts) {
        let h = hosts[hi]
        if type_of(h) == "map" {
            // host name — for the @D s8 akida governance check + ssh fallback
            let mut hname = ""
            if has_key(h, "name") { if type_of(h["name"]) == "string" { hname = h["name"] } }
            // ssh target — the `ssh` field, falling back to `name`
            let mut tgt = ""
            if has_key(h, "ssh") { if type_of(h["ssh"]) == "string" { tgt = h["ssh"] } }
            if tgt == "" { tgt = hname }
            let mut pl = "linux"
            if has_key(h, "os") { if type_of(h["os"]) == "string" { pl = h["os"] } }
            // 0.6.6 — macOS pool hosts are now eligible for macOS-ONLY
            // commands. The 0.6.1 blanket exclusion (`pl != "macos"`) was
            // too coarse: it left swift/xcodebuild stuck on the workstation
            // Mac even when an os: macos pool host (e.g. mini) was in the
            // roster. The capability filter below restricts mac hosts to
            // is_macos commands only, so the workstation is still protected
            // from general-heavy round-robin (linux-only there), but mini
            // DOES receive Swift/Xcode work as the user asked.
            //
            // @D s8 — pi5-akida is anima-only: NEVER an auto-dispatch
            // candidate (no route / load-balance / round-robin). Reached
            // ONLY via explicit `pool on pi5-akida` (the pool CLI, not this
            // hook). Match on name OR ssh so it never enters the elig set.
            // Roster hosts are otherwise always-on (no enable toggle as of
            // commons 0.12.0 / pool-route 0.10.0).
            let is_akida = hname.contains("akida") || tgt.contains("akida")
            if tgt != "" && !is_akida {
                h_name.push(tgt)
                h_plat.push(pl)
                let mut su = false
                if has_key(h, "sudo") { if type_of(h["sudo"]) == "bool" { su = h["sudo"] } }
                h_sudo.push(su)
            }
        }
        hi = hi + 1
    }
    if len(h_name) == 0 { _allow() }

    // pool.json is roster-only — workdir mirrors the local cwd by default.
    let workdir = "auto"

    let stripped = _strip_quotes(cmd)
    let toks = _tokens(stripped)   // classifier tokens are quote-stripped

    // cloud pin (0.6.10): `hexa cloud *` is ITSELF a remote-dispatch tool —
    // Mac-local-only (needs the local hexa build + stdlib/cloud/cloud_cli).
    // Its post-`--` remote argv routinely carries heavy words (nvidia-smi ·
    // train.log · make) that trip the classifier below, shipping the whole
    // `hexa cloud exec <pod> -- ...` to a Linux pool host where there is no
    // `cloud` subcommand (and no cloud_cli source) → it fails non-
    // deterministically depending on the argv. Double-routing a dispatcher
    // is incoherent: cloud already reaches the remote pod itself. Always run
    // local. Mirrors the heavy detector's adjacency + substring robustness so
    // a zsh-snapshot-wrapped `hexa cloud` is caught too. (INBOX hexa-lang
    // 2026-05-25T06:37Z — pool-route double-routes hexa cloud.)
    if _any_adjacent(toks, ["hexa", "cloud"]) || _any_pair_substring(stripped, ["hexa", "cloud"]) { _allow_count("local_bound") }

    // atlas-register pin (0.8.1 — 4th structural local-exemption to the 0.8.0
    // hexa whitelist): `hexa atlas register --from-verify/--from-drill/--auto-pr`
    // MUTATES the local SSOT `compiler/atlas/embedded.gen.hexa` in place, which is
    // then shared via a normal local `git commit`. Routing it to a peer host
    // writes the PEER's atlas and leaves the LOCAL file untouched → the following
    // local `git add embedded.gen.hexa` captures nothing (silently broken share).
    // Same local-mutation rationale as the git/gh exemption — a write to the cwd
    // repo's tracked SSOT must run where the commit happens. Narrow: only the
    // `register` WRITE subverb is pinned; read forms (atlas lookup/stats/hash/dump)
    // still route under the whitelist (read-only, peer staleness acceptable).
    if _any_adjacent(toks, ["atlas", "register"]) || _any_pair_substring(stripped, ["atlas", "register"]) { _allow_count("local_bound") }

    // data-locality pin (0.9.3 — anima PURE F-CURRICULA-1 · 5th structural
    // LOCAL-EXECUTION exemption to the 0.8.0 hexa POOL-DISPATCH): a hexa command
    // whose data-INPUT flag (`--corpus-path`·`--corpus`·`--data`·`--data-path`·
    // `--dataset`·`--input`·`--train-data`·`--eval-data`·`--weights`·`--ckpt`·
    // `--checkpoint`) points at a LOCAL-ONLY path (anything NOT under a synced
    // `~/core/` workdir) DEPENDS on data the pool peer does not hold. Routing it
    // anyway reproduced the anima PURE failure: `hexa run build_curriculum_corpus
    // .hexa --corpus-path /Users/.../c.jsonl` went to ubu-2, the jsonl was never
    // synced there, and the run died at compile-stage with `source not found` —
    // a DATA-ABSENCE error misread as a CODE error. Same data-locality necessity
    // as the host-introspection whitelist (you can't measure a host's procs from
    // a peer; you can't read Mac-local corpus from a peer). The value-IS-synced
    // case (`--data ~/core/anima/d/`) is EXCLUDED → keeps routing (the peer
    // mirrors `~/core`). Uses quote-stripped `toks` so a zsh-snapshot-wrapped
    // invocation tokenizes cleanly. Unconditional · no opt-out env (@D s11).
    if _has_local_data_input(toks) { _allow_count("local_bound") }

    // heavy classifier — build / test / package / train commands
    // 0.6.7 — `aprime_cc` added: hexa-lang's in-tree self-host native codegen
    // (build/aprime_cc, Mach-O arm64 ~1.2MB · invoked as `./build/aprime_cc <x>.hexa
    // --emit=asm`). User-reported workstation load 85%+ when invoked directly on
    // mac. Same workstation-protection rationale as swift build (0.6.6) — route
    // to a mac pool host (mini) where the binary can also execute.
    // 0.6.11 — C/C++ compiler drivers added: gcc · g++ · clang · clang++ · cc ·
    // c++. A C/C++ compile is heavy local compute — same workstation-protection
    // rationale as make/cmake/cargo. They carry NO macOS-capability marker, so
    // they land in the general-heavy bucket → Linux-only round-robin (the Mac
    // stays the workstation, per @D s12 zero-macOS-offload). Word-matched (not
    // first-token) so a zsh-snapshot-wrapped invocation is still caught; `cc` is
    // the only 2-char driver — bounded by non-word chars, and git/gh + absolute-
    // path commands already returned local above, so a coincidental bare `cc`
    // token in an unrelated command is unlikely to reach here.
    // 0.7.4 — npm/pnpm/yarn removed (now local-bound earlier in main: node-
    // package installers are cwd-dependent; routing them to a pool host fails
    // preflight with 'workdir missing').
    // 0.7.7 — Node 생태계 런타임 (POOL-OFFLOAD m2): `node`/`deno`/`bun`/`ts-node`
    // are JS/TS interpreters that fork the V8/Deno/Bun runtime locally per
    // invocation — same fork-storm pattern as python/hexa on multi-session.
    // 4-char+ words with word-boundary check survive `node_modules`/`node.js`
    // (`_`/`.` non-word boundaries reject those). `tsx` deliberately EXCLUDED
    // (3-char, file-extension collision: `cat foo.tsx` would match `_has_word`
    // due to `.` non-word prev boundary); a first-token-only classifier is
    // the right fix, deferred. npm/pnpm/yarn stay LOCAL (cwd-dependent, 0.7.4).
    // 0.7.8 — JVM 계열 컴파일러 (POOL-OFFLOAD m3): `javac`/`kotlinc`/`scalac` are
    // canonical Java/Kotlin/Scala compilers (5-7 char, specific). `java` and
    // `sbt` use PAIR-based matching only (4-char/3-char with frequent false-pos
    // risk: `cat /tmp/java-tools.txt`/`sbt-output.log` would substring-match);
    // pairs like `java -jar`/`sbt compile` are precise. mvn/gradle already in.
    // 0.7.9 — 미디어 도구 (POOL-OFFLOAD m4): `ffmpeg`/`magick` are 6-char
    // specific CPU-heavy media tools (video/audio encode · image transform).
    // `convert`(7-char, ImageMagick 6 legacy) and `sox`(3-char) ALSO heavy but
    // word-boundary substring risk is too high (`cat docs/convert.md` · path
    // false-pos); they're protected via abs-path first-token sign-gate ONLY.
    // `imagemagick` is the PACKAGE name (`magick` is the binary), skipped.
    let heavy_words = ["make", "cargo", "gradle", "mvn", "bazel", "cmake", "ctest", "tox", "pytest", "jest", "vitest", "webpack", "gcc", "g++", "clang", "clang++", "cc", "c++", "xcodebuild", "xcrun", "swiftc", "nvidia-smi", "train", "aprime_cc", "node", "deno", "bun", "ts-node", "javac", "kotlinc", "scalac", "ffmpeg", "magick"]
    // hexa-native heavy subverbs (kick-storm 2026-05-23 Mac kill: /kick = `hexa kick --seed`,
    // multi-agent local fire drove load 80+. drill = kick alias. loop = RFC 080 DFS+LLM cycle.
    // cc = full transpiler bootstrap.)
    // 0.6.5 — `hexa run`/`hexa build` added: dispatch-cache miss + re-fork on every
    // env-hash diff was the canonical mac fork-storm (measured load 130+ when
    // multi-session ran `hexa run <script>` on absolute host paths). Routing them
    // through the pool eliminates the fork loop on the workstation Mac entirely.
    // 0.7.6 — heavy hexa verb sweep (POOL-OFFLOAD m6): hexa CLI exposes 80+ verbs;
    // the canonical fork-storm sources beyond run/build/cc/kick/drill/loop are:
    //   (a) toolchain: `hexa test` (native @test runner — pytest/jest analog) ·
    //       `hexa bench` (wall/RSS/alloc benchmark — by definition CPU-bound)
    //   (b) math verifiers: `hexa absolute` (Mk.VIII Δ₀-absolute classifier) ·
    //       `hexa meta-closure` (Mk.IX self-ref fixpoint H1+H2+H3)
    //   (c) math discovery: `hexa smash` (9-phase singularity drill, ~414 candidates
    //       per --depth 3) · `hexa free` (DFS compose 5-module) ·
    //       `hexa hyperarithmetic` (Mk.IX Π₀² 5-system reverse-math classifier)
    //   (d) discovery extras: `hexa chain` (L3 cross-engine pipeline)
    //   (e) drill variants (11 — each composes drill with a different orchestration
    //       pattern, all fork-storm class): omega · surge · dream · swarm · reign ·
    //       molt · wake · forge · canon · debate · revive (kick is already covered)
    // Excluded (light read/lookup): atlas hash/stats/lookup/dump/verify · qrng status
    // · 29 annotation analyzers (pure-check/memo-check/catalog/…) · 16 data bridges
    // (wikipedia/oeis/arxiv/…, HTTP-only) · lattice verify · gpu lint/disasm.
    // Excluded (3-token pair — needs richer classifier, deferred): hexa gpu fire ·
    // hexa sim-universe <X> · hexa qmirror <X> · hexa atlas register --from-drill.
    let heavy_pairs = ["go", "test", "go", "build", "swift", "build", "swift", "test", "docker", "build",
                       "hexa", "kick", "hexa", "drill", "hexa", "loop", "hexa", "cc", "hexa", "run", "hexa", "build",
                       "hexa", "test", "hexa", "bench",
                       "hexa", "absolute", "hexa", "meta-closure",
                       "hexa", "smash", "hexa", "free", "hexa", "hyperarithmetic",
                       "hexa", "chain",
                       "hexa", "omega", "hexa", "surge", "hexa", "dream", "hexa", "swarm",
                       "hexa", "reign", "hexa", "molt", "hexa", "wake", "hexa", "forge",
                       "hexa", "canon", "hexa", "debate", "hexa", "revive",
                       "java", "-jar", "sbt", "compile", "sbt", "test", "sbt", "run"]
    // big-tree find substring — multi-session `find $HOME/core/<any>` is the
    // documented Mac-kill pattern (anima ~458GB tree drives 267% CPU from 3×
    // concurrent bfs; other dancinlab repos like hexa-lang are similarly large).
    // 0.7.10 generalizes from single `~/core/anima` to ALL `~/core/*` siblings,
    // matching BOTH the expanded `<HOME>/core/` prefix AND the tilde `~/core/`
    // form (commands typed by the user usually carry the tilde; commands
    // composed by tools usually expand $HOME). Preflight test -d still gates
    // each host — non-mirrored hosts fall through. Small repos (sidecar) pay a
    // marginal SSH overhead for short finds; that trade-off keeps the Mac clean.
    let mut heavy_find_subs = []
    if home != "" { heavy_find_subs.push("find " + home + "/core/") }
    heavy_find_subs.push("find ~/core/")
    // 0.8.0 — WHITELIST: ANY hexa execution routes (the heavy_words/pairs above
    // remain for NON-hexa heavy compute: make · cargo · gcc · node · java · …).
    // `_is_hexa_exec` makes the hexa-specific pairs (kick/run/verify/…) redundant
    // but they are kept harmless; the structural local-exemptions ($CLAUDE_PLUGIN_
    // ROOT · hexa cloud · abs-path sign-gate) already returned before this line.
    let heavy = _is_hexa_exec(toks) || _any_word(stripped, heavy_words) || _any_adjacent(toks, heavy_pairs) || _any_pair_substring(stripped, heavy_pairs) || _any_contains(cmd, heavy_find_subs)

    // NOTE (pool-route 0.6.0): the load-aware escalation gate (0.5.7 #96) was
    // REMOVED. It promoted any non-trivial cmd to "heavy" when non-claude CPU
    // summed > 150% — but on an 8-core Mac WindowServer + browser + build
    // daemons routinely exceed 150%, so nearly every git / hexa-run / smoke got
    // shipped to a Linux pool host and broke (Mac-local paths absent there).
    // "system busy" ≠ "this command should move" — that conflation was the bug.
    // Storm protection still holds: kick/drill/loop/cc + `find ~/core/anima` are
    // in the EXPLICIT classifier above, so the real meltdown patterns route on
    // their own merits, not on a noisy load signal.

    // root-needing commands — always routable, and `sudo`-prefixed on a
    // host tagged sudo:true.
    let sudo_words = ["apt", "apt-get", "dpkg", "dpkg-deb", "add-apt-repository", "yum", "dnf", "rpm", "pacman", "systemctl", "ldconfig", "setcap", "update-alternatives"]
    let needs_sudo = _any_word(cmd, sudo_words)

    // 0.9.0 — DEFAULT = POOL. The previous `light_allowed` fallthrough
    // (allow local if !heavy && !needs_sudo) is REMOVED. Per user policy:
    // "무조건 pool · 화이트리스트만 local 가능" — every command falls
    // through to host-selection + routing unless it hit a LOCAL-EXECUTION
    // WHITELIST entry above (sign-local · git/gh/pool · npm/pnpm/yarn ·
    // $CLAUDE_PLUGIN_ROOT · abs-path heavy sign-gate · ~/. dotstate ·
    // hexa cloud · hexa atlas register · host-introspection ps/top/uptime/…).
    // The `heavy` flag stays computed for downstream OS-capability hints
    // (is_macos / is_linux still gate which pool host) but no longer gates
    // routing itself. Whitelist additions are sign-gated via project.tape
    // (commons @D s13) — no env-var/config opt-out (commons @D s11).
    let _heavy_unused = heavy   // silence unused warning if any

    // capability filter — restrict to a platform when the command demands one
    // 0.6.7 — `aprime_cc` also added to macos_words: the in-tree binary is
    // built Mach-O arm64 only, so it must run on a mac pool host (mini).
    // Linux pool hosts (ubu) would refuse to exec the Mach-O binary.
    let macos_words = ["xcodebuild", "xcrun", "xcode-select", "codesign", "notarytool", "stapler", "pkgbuild", "productbuild", "hdiutil", "lipo", "otool", "install_name_tool", "vtool", "swiftc", "sw_vers", "osascript", "launchctl", "diskutil", "caffeinate", "sips", "plutil", "aprime_cc"]
    let macos_pairs = ["swift", "build", "swift", "test", "swift", "run", "swift", "package"]
    let macos_subs = ["apple-darwin", "apple-macos", "apple-ios", "Mach-O", ".dylib", ".dmg"]
    let is_macos = _any_word(stripped, macos_words) || _any_adjacent(toks, macos_pairs) || _any_contains(cmd, macos_subs)

    let linux_words = ["apt", "apt-get", "dpkg", "dpkg-deb", "add-apt-repository", "yum", "dnf", "rpm", "pacman", "systemctl", "journalctl", "ldconfig", "setcap", "update-alternatives"]
    let linux_subs = ["linux-gnu", "linux-musl", ".deb", ".rpm"]
    let is_linux = _any_word(cmd, linux_words) || _any_contains(cmd, linux_subs)

    let mut why = "load-balanced"
    let mut elig = []
    let mut ei = 0
    if is_macos {
        why = "macOS-only command"
        while ei < len(h_name) {
            if h_plat[ei] == "macos" { elig.push(ei) }
            ei = ei + 1
        }
    } else if is_linux {
        why = "Linux-only command"
        while ei < len(h_name) {
            if h_plat[ei] == "linux" { elig.push(ei) }
            ei = ei + 1
        }
    } else {
        // General-heavy round-robin is Linux-only (project.tape @D s12 —
        // zero-macOS-offload by default). The workstation Mac stays protected
        // from generic build/test fan-out; only an explicit macOS-capability
        // marker (swift build · xcodebuild · …) promotes the command into the
        // is_macos branch above (→ mini). 0.13.0 dropped the `mini-equal`
        // runtime toggle (`~/.pool/mini-equal` marker) — it was the only
        // remaining on/off-style surface and was rarely used; the default
        // behavior is now permanent. Explicit `pool on mini <cmd>` still
        // works for any command — that's the manual escape hatch.
        why = "load-balanced (Linux-only — Mac is the workstation)"
        while ei < len(h_name) {
            if h_plat[ei] != "macos" { elig.push(ei) }
            ei = ei + 1
        }
    }
    if len(elig) == 0 { _allow_count("heavy_failed") }

    // round-robin across the eligible hosts
    let rr_path = dd + "/.pool-route.rr"
    let mut n = 0
    try {
        let rr = read_file(rr_path).trim()
        if rr != "" { n = to_int(rr) }
    } catch e { n = 0 }
    if n < 0 { n = 0 }
    let start_pick = elig[n % len(elig)]
    try { write_file(rr_path, to_string((n + 1) % 1000000)) } catch e { }

    // ── workdir + transport (host-independent — pull above the host loop) ─

    // resolve the remote workdir — `auto` mirrors the local cwd under $HOME
    let mut wd_remote = workdir
    if wd_remote.to_lower() == "auto" {
        let mut cwd = ""
        if has_key(payload, "cwd") { if type_of(payload["cwd"]) == "string" { cwd = payload["cwd"] } }
        if cwd == "" { cwd = exec_with_status("pwd")[0].trim() }
        if cwd == home {
            wd_remote = "~"
        } else if cwd.starts_with(home + "/") {
            wd_remote = "~/" + cwd.substring(len(home) + 1, len(cwd))
        } else {
            // worktree → canonical-root fallback (0.6.10) — INBOX hexa-lang
            // 2026-05-25T08:10Z(a). A git LINKED worktree lives outside $HOME
            // (e.g. /tmp/wt-x), so its cwd can't be mirrored to a pool host.
            // But its MAIN checkout usually IS under ~/core (a synced workdir
            // the pool already routes). `git worktree list --porcelain` lists
            // the main worktree FIRST — mirror that root instead. This runs
            // ONLY in the branch that already DENIES, so it can never regress
            // a routing command; it strictly rescues the standard worktree-
            // isolation dispatch pattern (stdlib / SSCHA agents). The remote
            // runs against the canonical checkout, not the worktree's
            // uncommitted edits — for kick/drill/loop/cc (HEXA_LANG=canonical)
            // that is already the intended target; logged in `why` for audit.
            let mut rescued = 0
            if cwd != "" {
                let gr = exec_with_status("git -C " + _shq(cwd) + " worktree list --porcelain 2>/dev/null")
                if gr[1] == 0 {
                    let wl = _tokens(gr[0])   // first line: `worktree <abs-main-path>`
                    if len(wl) >= 2 && wl[0] == "worktree" {
                        let root = wl[1]
                        if root == home {
                            wd_remote = "~"
                            rescued = 1
                        } else if root.starts_with(home + "/") {
                            wd_remote = "~/" + root.substring(len(home) + 1, len(root))
                            rescued = 1
                        }
                    }
                }
            }
            if rescued == 1 {
                why = why + " · worktree→canonical-root"
            } else {
                _deny("pool-route: cwd outside $HOME cannot be mirrored to any pool host — heavy command refused (move into $HOME or rerun without the heavy-classifier trigger).")
            }
        }
    }
    if wd_remote == "" { _deny("pool-route: empty remote workdir — heavy command refused.") }
    let wd_sh = _cd_target(wd_remote)

    // transport — tailscale if a local daemon is up, else plain ssh
    let mut tx = "auto"
    if tx == "auto" {
        tx = "ssh"
        if _exec_rc("command -v tailscale >/dev/null 2>&1") == 0 {
            if _exec_rc("tailscale status --peers=false >/dev/null 2>&1") == 0 { tx = "tailscale" }
        }
    }

    // toolchain preflight (0.6.13) — pre-0.6.13 only kick/drill/loop/cc probed
    // the actual tool (`hexa <verb> --help`); `hexa run`/`build` + C compiles
    // checked only `test -d <wd>`, so a host with a broken/missing toolchain
    // (e.g. ubu-1 with a non-functional hexa) PASSED preflight then FAILED the
    // real run. Now every hexa verb + C/C++ compile contributes a tool probe
    // (existence `command -v` + interp `test -x` + a cheap real invocation
    // `<tool> --help`, all in one ssh); a host that fails it is SKIPPED so the
    // round-robin moves on, and if ALL fail the deny trailer names the gap.
    // hexa_subverb is still tracked separately — it drives HEXA_LANG below.
    // Known limit (@D d6): a binary that passes `--help` but segfaults at
    // RUNTIME is not caught (would need a full exec probe — heavier, deferred).
    let toks_pre = _tokens(cmd)
    let mut hexa_subverb = ""
    let mut tool_probe = ""
    let mut tool_label = ""
    if len(toks_pre) >= 1 {
        let t0b = _basename(toks_pre[0])
        if t0b == "hexa" {
            let mut hverb = ""
            if len(toks_pre) >= 2 { hverb = toks_pre[1] }
            if hverb == "kick" || hverb == "drill" || hverb == "loop" || hverb == "cc" { hexa_subverb = hverb }
            let mut help_cmd = "hexa --help"
            if hverb != "" && hverb.substring(0, 1) != "-" { help_cmd = "hexa " + hverb + " --help" }
            // 0.9.1 — ROLLED BACK 0.8.3 canon injection. Each host's hexa
            // binary has its OWN path-resolution semantics (ubu-1 = bash wrapper
            // exec'ing hexa_real; ubu-2 = ELF binary with argv[0]-relative
            // hexat search; Mac = yet another arrangement). HEXA_REAL_BIN /
            // canon stdlib injection works on some hosts and silently breaks
            // on others (qwen_bpe.hexa runs need self/native/hexat at a
            // host-specific path canon doesn't supply consistently). Reverted
            // to "host owns its hexa setup" — pool-route uses the host's
            // ~/core/hexa-lang for HEXA_LANG and the host's PATH-resolved hexa
            // binary. Hosts with stale stdlib are the host owner's problem
            // (anima session for stdlib drift on its workdir). `~/.hx/canon`
            // remains as scaffolding on hosts where canon-update.sh was run
            // but pool-route no longer routes through it. 0.8.4 sign-gated
            // additions to the LOCAL-EXECUTION WHITELIST still apply.
            tool_probe = "command -v hexa >/dev/null 2>&1 && PATH=\"$HOME/.hx/bin:$HOME/bin:$PATH\" HEXA_LANG=\"$HOME/core/hexa-lang\" " + help_cmd + " >/dev/null 2>&1"
            tool_label = help_cmd
        } else if t0b == "gcc" || t0b == "g++" || t0b == "clang" || t0b == "clang++" || t0b == "cc" || t0b == "c++" {
            tool_probe = "command -v " + t0b + " >/dev/null 2>&1"
            tool_label = t0b
        }
    }

    // ── iterate eligible hosts (round-robin start; wrap once) ────────────
    //
    // The user contract is "pool resources only" for heavy-classified cmds
    // — never silently fall back to local. So probe each eligible host in
    // turn; first one that passes (workdir present, hexa subverb works if
    // applicable) gets the route. If ALL fail, emit a `_deny` with a
    // per-host failure breakdown so the operator can fix the missing host.
    let mut tried = []
    let mut reasons = []
    let mut routed = false
    let mut li = 0
    while li < len(elig) {
        let pick = elig[(n + li) % len(elig)]
        let host_i = h_name[pick]

        // per-host rcmd (sudo prefix), hexa_env (HEXA_LANG choice), remote
        let mut rcmd = cmd
        let mut sudo_note = ""
        if h_sudo[pick] && needs_sudo && !rcmd.starts_with("sudo ") {
            rcmd = "sudo " + rcmd
            sudo_note = ", sudo-prefixed"
        }
        let mut hexa_env = ""
        if _has_word(rcmd, "hexa") || rcmd.contains("hexa ") {
            // 0.9.1 — ROLLED BACK 0.8.3 canon injection (canon path-resolution
            // is host-specific; see tool_probe comment). Use the host's
            // ~/core/hexa-lang as HEXA_LANG (stdlib resolution) and let the
            // host's hexa binary find its own self/native/hexat via its own
            // search paths. Stale stdlib on a host is the host owner's
            // responsibility (anima for its consciousness/atlas WIP on ubu-2).
            let mut hexa_lang = "$PWD"
            if hexa_subverb != "" { hexa_lang = "$HOME/core/hexa-lang" }
            hexa_env = "export PATH=\"$HOME/.hx/bin:$HOME/bin:$PATH\" HEXA_MODULE_LOADER=\"$PWD/build/hexa_module_loader\" HEXA_LANG=\"" + hexa_lang + "\" && "
        }
        let remote = "cd " + wd_sh + " && " + hexa_env + rcmd

        // preflight — workdir present + (0.6.13) the command's toolchain works
        let mut probe_inner = "test -d " + wd_sh
        if tool_probe != "" {
            probe_inner = probe_inner + " && " + tool_probe
        }
        let mut probe = ""
        if tx == "tailscale" {
            probe = "tailscale ssh " + _shq(host_i) + " " + _shq(probe_inner)
        } else {
            probe = "ssh -o BatchMode=yes -o ConnectTimeout=6 " + _shq(host_i) + " " + _shq(probe_inner)
        }
        let rc = _exec_rc(probe)
        if rc == 0 {
            // SUCCESS — emit the rewrite and finish
            let mut new_cmd = ""
            let sshc = "ssh"
            if tx == "tailscale" { let sshc2 = "tailscale ssh"; new_cmd = sshc2 + " " + _shq(host_i) + " " + _shq(_login_wrap(remote)) + "  # " + MARK }
            else { new_cmd = sshc + " " + _shq(host_i) + " " + _shq(_login_wrap(remote)) + "  # " + MARK }
            let mut note = "pool-route: routed to " + host_i + ":" + wd_remote + " via " + tx + " (workdir is user-synced)"
            note = note + " (" + why + sudo_note + "; " + to_string(len(h_name)) + "-host roster)."
            if li > 0 { note = note + " [skipped " + to_string(li) + " host(s) on preflight: " + tried.join(", ") + "]" }
            _log_route(host_i, cmd)
            _tally("routed")
            _emit(ti, new_cmd, note)
            routed = true
        }
        // record failure reason for the deny trailer
        tried.push(host_i)
        let mut why_fail = "preflight rc=" + to_string(rc) + " (workdir missing"
        if tool_label != "" { why_fail = why_fail + " or `" + tool_label + "` toolchain not runnable on this host" }
        why_fail = why_fail + ")"
        reasons.push(host_i + ": " + why_fail)
        li = li + 1
    }
    // exhausted — every eligible host failed preflight
    if !routed {
        let body = "pool-route: heavy command refused — no eligible pool host passed preflight.\n"
                 + "  cmd     : " + cmd + "\n"
                 + "  why     : " + why + " (heavy-classified, must use pool resources)\n"
                 + "  tried   : " + tried.join(", ") + "\n"
                 + "  failures:\n    " + reasons.join("\n    ") + "\n"
                 + "  fix     : for hexa, ensure each pool host has the hexa-lang repo at ~/core/hexa-lang "
                 + "+ a runnable compiled `hexa` on PATH (`command -v hexa` + `hexa --help` must succeed — "
                 + "hexa is compiled, the build/hexa_interp interpreter is DEPRECATED, do NOT probe for it). "
                 + "Stale stdlib on a host is the host owner's responsibility — anima session handles its own "
                 + "~/core/hexa-lang on ubu-2 (660 commits behind origin/main with untracked WIP that blocks ff-only pull). "
                 + "for C/C++, ensure the compiler (gcc/clang) is installed on a host; "
                 + "for any command, ensure the workdir (" + wd_remote + ") exists on at least one host."
        _deny_count(body, "heavy_failed")
    }
}
