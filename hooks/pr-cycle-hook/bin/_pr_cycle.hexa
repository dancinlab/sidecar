// _pr_cycle.hexa — PreToolUse(Bash) PR full-cycle router for `gh pr create`.
//
// commons @D g47 (PR ship discipline — no unmerged stacks): a PR is
// created → merged → its worktree+branch are cleaned in the same Bash
// invocation. The next PR therefore starts from a fresh main, never from
// a stacked branch waiting on N parents and never with dead worktrees.
//
// Detection: whitespace-tokenize the command and look for the 3-gram
// `gh pr create` anywhere — catches both bare `gh pr create …` and
// chained forms like `git push && gh pr create …` (the common case).
//
// Skip if: `--draft` flag present · `gh pr merge` already in the command.
//
// Rewrite tail (appended via the hook `updatedInput` field — emitted ALONGSIDE
// `permissionDecision: "allow"` in the same hookSpecificOutput; without that
// sibling field Claude Code IGNORES updatedInput and runs the original command,
// so the PR is created but never merged — the 0.3.5 fix):
//   1) ` && gh pr merge --squash --admin --delete-branch` (always —
//      `--admin` lets the create→merge cycle complete over branch
//      protection without a separate human approval step)
//   2) ` && (cd <main-wt> && git worktree remove <this-wt> --force …
//          && git branch -D <branch> …)` — ONLY when cwd is a linked
//      worktree (not the main one). The `(…)` subshell isolates the cd
//      and the `|| true` swallows residual errors so a missing branch /
//      already-pruned worktree never poisons the chain. The detection
//      runs at hook-time so it captures the exact worktree+branch that
//      `gh pr create` was issued from.
//
// Atomic — if any preceding step (including `gh pr create`) fails, the
// merge never runs; if the merge fails, the worktree never gets removed.
//
// DELETION-SANITY GATE (stale-base regression guard — anima #1105):
// before appending the auto-merge tail, probe `gh pr diff --name-status`
// for the PR's deletion count. A stale-base squash-merge can silently
// revert-delete the bulk of main (anima #1105 deleted 35190 files while
// the legit change was 3 files). When the diff shows a mass deletion —
// D-count over MAX_DELETIONS, OR deletions dwarf additions (>= 10x and
// > 20 abs) — the auto-merge is BLOCKED (permissionDecision: deny) with
// guidance to inspect for a stale base and merge by hand if intended.
// A normal PR (few deletions, or deletions < additions) passes through.
//
// No opt-out by design — no env var, no config file, no exception list.

let MARK = "__SIDECAR_PR_CYCLE__"
// 0.3.0 — explicit PR# capture via `gh pr view --json number -q .number` (run
// right after `gh pr create` succeeds, so the API sees the fresh PR). Bare
// `gh pr merge` infers from current-branch context; explicit PR# is robust
// when the branch is detached, when the worktree is being torn down, or when
// CI rerouting drops the head-ref. The same-repo tail captures from the cwd
// repo; the cross-repo branch (line ~376) captures via `--repo X` for both
// the view and the merge so the entire chain stays pinned to the target repo.
let MERGE_TAIL = " && gh pr merge \"$(gh pr view --json number -q .number)\" --squash --admin --delete-branch"

// Absolute deletion ceiling for an auto-merge. Above this the PR is a
// mass-deletion outlier — the 35190-file stale-base regression sits far
// above it; a real refactor rarely deletes this many files in one PR.
let MAX_DELETIONS = 50
// Asymmetry trip: deletions >= this multiple of additions (and over the
// abs floor below) is the silent-revert fingerprint even under the cap.
let DEL_RATIO = 10
let DEL_RATIO_FLOOR = 20

fn _read_stdin() -> string {
    return to_string(exec("cat"))
}

fn _allow() {
    exit(0)
}

// JSON-escape a string and wrap it in double quotes.
fn _json_str(s: string) -> string {
    let n = len(s)
    let mut i = 0
    let mut parts = []
    parts.push("\"")
    while i < n {
        let c = s[i]
        if c == "\"" { parts.push("\\\"") }
        else if c == "\\" { parts.push("\\\\") }
        else if c == "\n" { parts.push("\\n") }
        else if c == "\r" { parts.push("\\r") }
        else if c == "\t" { parts.push("\\t") }
        else {
            let k = char_code(c, 0)
            if k < 32 { parts.push(" ") }
            else { parts.push(c) }
        }
        i = i + 1
    }
    parts.push("\"")
    return parts.join("")
}

// Strip the contents of single- and double-quoted regions so trigger
// tokens that only appear INSIDE quoted shell args (e.g. JSON test
// payloads, heredoc-style strings echoed to a pipe) cannot fire the
// detector. The quote characters themselves are dropped too.  Backslash
// inside double-quotes escapes the next char.  Mismatched / unterminated
// quotes degrade gracefully — the remainder is consumed silently, which
// is the safe direction (we'd rather miss a trigger than rewrite a test
// payload as a real `gh pr merge` against the wrong branch).
fn _strip_quoted(s: string) -> string {
    let n = len(s)
    let mut out = ""
    let mut i = 0
    let mut in_sq = false
    let mut in_dq = false
    while i < n {
        let c = s[i]
        if in_sq {
            if c == "'" { in_sq = false }
        } else if in_dq {
            if c == "\\" && i + 1 < n { i = i + 1 }
            else if c == "\"" { in_dq = false }
        } else {
            if c == "'" { in_sq = true }
            else if c == "\"" { in_dq = true }
            else { out = out + c }
        }
        i = i + 1
    }
    return out
}

// whitespace-split into tokens
fn _tokens(s: string) -> array {
    let mut out = []
    let n = len(s)
    let mut i = 0
    let mut cur = ""
    while i < n {
        let c = s[i]
        if c == " " || c == "\t" || c == "\n" || c == "\r" {
            if len(cur) > 0 { out.push(cur); cur = "" }
        } else {
            cur = cur + c
        }
        i = i + 1
    }
    if len(cur) > 0 { out.push(cur) }
    return out
}

fn _trim(s: string) -> string { return s.trim() }

fn _starts_with(s: string, prefix: string) -> bool {
    if len(s) < len(prefix) { return false }
    return s.substring(0, len(prefix)) == prefix
}

// Wrap in single quotes; escape embedded singles as '\''.
fn _shell_sq(s: string) -> string {
    let n = len(s)
    let mut out = "'"
    let mut i = 0
    while i < n {
        let c = s[i]
        if c == "'" { out = out + "'\\''" } else { out = out + c }
        i = i + 1
    }
    return out + "'"
}

// sliding 3-gram scan for `gh pr create`
fn _has_gh_pr_create(toks: array) -> bool {
    let n = len(toks)
    if n < 3 { return false }
    let mut i = 0
    while i <= n - 3 {
        if toks[i] == "gh" && toks[i + 1] == "pr" && toks[i + 2] == "create" {
            return true
        }
        i = i + 1
    }
    return false
}

fn _current_branch() -> string {
    let r = exec_with_status("git rev-parse --abbrev-ref HEAD 2>/dev/null")
    if r[1] != 0 { return "" }
    return _trim(to_string(r[0]))
}

fn _cwd_toplevel() -> string {
    let r = exec_with_status("git rev-parse --show-toplevel 2>/dev/null")
    if r[1] != 0 { return "" }
    return _trim(to_string(r[0]))
}

// First `worktree <path>` line in `git worktree list --porcelain` is
// always the main worktree (git invariant). Returns "" on any failure.
fn _main_worktree() -> string {
    let r = exec_with_status("git worktree list --porcelain 2>/dev/null")
    if r[1] != 0 { return "" }
    let lines = to_string(r[0]).split("\n")
    let n = len(lines)
    let mut i = 0
    while i < n {
        let line = lines[i]
        if _starts_with(line, "worktree ") {
            return line.substring(9, len(line))
        }
        i = i + 1
    }
    return ""
}

// Empty string when cwd IS the main worktree or detection fails (no
// cleanup tail appended). Non-empty `&& (…)` chain otherwise.
fn _worktree_cleanup_tail() -> string {
    let cwd = _cwd_toplevel()
    let main = _main_worktree()
    if cwd == "" || main == "" || cwd == main { return "" }
    let br = _current_branch()
    if br == "" || br == "HEAD" { return "" }
    let p_main = _shell_sq(main)
    let p_wt = _shell_sq(cwd)
    let p_br = _shell_sq(br)
    return " && (cd " + p_main + " && git worktree remove " + p_wt + " --force 2>/dev/null && git branch -D " + p_br + " 2>/dev/null || true)"
}

// `--repo <X>` value if the create targets another repo (cross-repo PR).
// `--repo=X` not handled (gh's canonical form is space-separated). Used to
// route the appended merge to the SAME repo as the create (INBOX #4: a
// cross-repo create otherwise got a merge against the cwd repo).
fn _repo_flag(toks: array) -> string {
    let mut i = 0
    while i + 1 < len(toks) {
        if toks[i] == "--repo" { return toks[i + 1] }
        i = i + 1
    }
    return ""
}

// `--repo <X>` form for the deletion probe (mirrors _repo_flag) — empty
// when the create targets the cwd repo.
fn _repo_arg(toks: array) -> string {
    let repo = _repo_flag(toks)
    if repo == "" { return "" }
    return " --repo " + repo
}

// Tally D (deleted) and A (added/new) lines in name-status porcelain.
// Each line is `<status>\t<path>` (R/C carry a 3rd col); we key only off
// the leading status char. Returns [D, A].
fn _tally_name_status(out: string) -> array {
    let lines = out.split("\n")
    let n = len(lines)
    let mut d = 0
    let mut a = 0
    let mut i = 0
    while i < n {
        let line = lines[i].trim()
        if len(line) > 0 {
            let c0 = line[0]
            if c0 == "D" { d = d + 1 }
            else if c0 == "A" { a = a + 1 }
        }
        i = i + 1
    }
    return [d, a]
}

// Deletion / addition counts for the diff this merge will apply. Primary
// probe is `git diff --name-status <merge-base(origin/main,HEAD)>...HEAD`
// — works at create-time (BEFORE the PR exists, which is exactly when this
// hook fires) and reflects what a squash-merge into main lands. For a
// cross-repo create (repo_arg set) the local HEAD is unrelated to the PR,
// so we fall back to `gh pr diff --repo X`. On any probe failure returns
// [-1, -1] so the caller treats it as "unknown → do not block" (fail-open:
// a flaky probe must never wedge a legit merge).
fn _deletion_counts(repo_arg: string) -> array {
    if repo_arg == "" {
        // local same-repo branch: diff the squash payload against main
        let probe = "{ mb=$(git merge-base origin/main HEAD 2>/dev/null || git merge-base origin/master HEAD 2>/dev/null); [ -n \"$mb\" ] && git diff --name-status \"$mb\"...HEAD 2>/dev/null; }"
        let r = exec_with_status(probe)
        if r[1] != 0 { return [-1, -1] }
        let out = to_string(r[0])
        if out.trim() == "" { return [-1, -1] }
        return _tally_name_status(out)
    }
    // cross-repo: the open PR's own diff
    let r2 = exec_with_status("gh pr diff" + repo_arg + " --name-status 2>/dev/null")
    if r2[1] != 0 { return [-1, -1] }
    let out2 = to_string(r2[0])
    if out2.trim() == "" { return [-1, -1] }
    return _tally_name_status(out2)
}

// True when the deletion profile is a mass-deletion outlier (stale-base
// regression fingerprint). Counts of [-1,-1] (probe failed) are NOT a hit.
fn _is_mass_deletion(counts: array) -> bool {
    let d = counts[0]
    let a = counts[1]
    if d < 0 { return false }
    if d > MAX_DELETIONS { return true }
    if d > DEL_RATIO_FLOOR && d >= a * DEL_RATIO { return true }
    return false
}

// Block the auto-merge: deny the rewritten command (the PR is created, but
// the dangerous squash-merge is withheld for human inspection).
fn _deny(reason: string) {
    let out = "{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"deny\",\"permissionDecisionReason\":" + _json_str(reason) + "}}"
    println(out)
    exit(0)
}

// rebuild tool_input with command swapped, emit updatedInput JSON.
fn _emit(ti: map, new_cmd: string, note: string) {
    let ks = keys(ti)
    let mut parts = []
    let mut i = 0
    while i < len(ks) {
        let k = ks[i]
        if k == "command" {
            parts.push(_json_str(k) + ":" + _json_str(new_cmd))
        } else {
            parts.push(_json_str(k) + ":" + json_stringify(ti[k]))
        }
        i = i + 1
    }
    let updated = "{" + parts.join(",") + "}"
    let out = "{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"allow\",\"updatedInput\":" + updated + ",\"additionalContext\":" + _json_str(note) + "}}"
    println(out)
    exit(0)
}

fn main() {
    let raw = _read_stdin()
    let mut payload = json_parse("{}")
    try { payload = json_parse(raw) } catch e { _allow() }
    if type_of(payload) != "map" { _allow() }

    if !has_key(payload, "tool_name") { _allow() }
    if payload["tool_name"] != "Bash" { _allow() }
    if !has_key(payload, "tool_input") { _allow() }
    let ti = payload["tool_input"]
    if type_of(ti) != "map" { _allow() }
    if !has_key(ti, "command") { _allow() }
    let cmd0 = ti["command"]
    if type_of(cmd0) != "string" { _allow() }
    let cmd = cmd0.trim()
    if cmd == "" { _allow() }

    // idempotent — already rewritten
    if cmd.contains(MARK) { _allow() }

    // sliding-window 3-gram: `gh pr create` anywhere in the command,
    // but only OUTSIDE quoted regions (so a test payload like
    // `echo '{"command":"gh pr create …"}' | …` does not trigger).
    let toks = _tokens(_strip_quoted(cmd))
    if !_has_gh_pr_create(toks) { _allow() }

    // skip — already contains a merge
    if cmd.contains("gh pr merge") { _allow() }

    // skip — draft PR (user wants review, not immediate merge)
    if cmd.contains("--draft") { _allow() }

    // DELETION-SANITY GATE (anima #1105 stale-base regression guard): probe
    // the PR's name-status for a mass-deletion outlier BEFORE appending the
    // auto-merge. The probe targets the same repo as the create (--repo X if
    // cross-repo). Fail-open on probe failure ([-1,-1] → not a hit) so a
    // flaky `gh` never wedges a legit merge; a true 35190-style outlier is
    // a hard deny — the PR stays created, the squash-merge is withheld.
    let repo_arg = _repo_arg(toks)
    let counts = _deletion_counts(repo_arg)
    if _is_mass_deletion(counts) {
        let d = counts[0]
        let a = counts[1]
        _deny("PR_CYCLE_MASS_DELETION_BLOCK { D=" + to_string(d) + ", A=" + to_string(a) + " — 이 PR 머지가 대량 파일 삭제(D=" + to_string(d) + ", 추가 A=" + to_string(a) + ")를 일으킴. stale-base squash-merge 회귀(anima #1105: 35190 파일 삭제)일 수 있음. 자동 머지 BLOCK — 의도된 삭제가 맞으면 stale base 여부를 확인한 뒤 `gh pr merge` 를 직접 수동 실행하세요 (pr-cycle 자동-tail 우회). 아니면 origin/main 최신에서 fresh 분기해 다시 PR. }")
    }

    // cross-repo create (`--repo X`): merge THAT repo's PR, and do NOT touch
    // the local (cwd) worktree — it belongs to a different repo than the PR
    // (INBOX #4 from anima: a `--repo kosmos` create got ` && gh pr merge` run
    // against the cwd repo's main, fetching/merging the wrong repo).
    let repo = _repo_flag(toks)
    if repo != "" {
        // 0.3.0 — explicit PR# via `gh pr view --repo X --json number -q .number`
        // pinned to the same target repo as the create (vs inferring from the
        // cwd branch, which would resolve to the WRONG repo's PR — INBOX #4).
        let xcmd = cmd + " && gh pr merge \"$(gh pr view --repo " + repo + " --json number -q .number)\" --repo " + repo + " --squash --admin --delete-branch" + "  # " + MARK
        let xnote = "pr-cycle: cross-repo (--repo " + repo + ") — appended `gh pr merge <PR#> --repo " + repo + "` (PR# captured via `gh pr view --repo X`); no local worktree cleanup (cwd repo ≠ PR repo)."
        _emit(ti, xcmd, xnote)
    }

    let wt_tail = _worktree_cleanup_tail()
    let tail = MERGE_TAIL + wt_tail
    let new_cmd = cmd + tail + "  # " + MARK
    let mut note = "pr-cycle: appended ` && gh pr merge --squash --admin --delete-branch` per commons @D g47 (create→merge atomic)."
    if wt_tail != "" {
        note = "pr-cycle: appended merge + worktree cleanup (cwd is a linked worktree — cd main + `git worktree remove --force` + `git branch -D` after merge) per commons @D g47."
    }
    _emit(ti, new_cmd, note)
}
