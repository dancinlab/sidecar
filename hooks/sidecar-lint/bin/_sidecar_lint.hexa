// _sidecar_lint.hexa — PreToolUse(Bash) auto-lint on `git commit` for
// Claude Code marketplace plugin packs. Non-blocking — emits findings as
// additionalContext.
//
// Fires when tool_name == Bash, the command contains `git commit`, and the
// repo root holds `.claude-plugin/marketplace.json`.
//
// Checks:
//   1. staged diff added lines — stale-history patterns (commons @D g15)
//   2. staged diff added lines — hardcoded /Users//home/ paths (g13 / s3)
//   3. marketplace.json plugin entry vs each plugin.json — version drift
//   4. hooks/*/bin/*.sh missing user-exec bit
//   5. no CHANGELOG.md at repo root (commons @D g29)
//   6. plugin missing a profiles.json tier (sidecar @D s7) — only when the
//      repo has .claude-plugin/profiles.json (sidecar's multi-user profiles)
//   7. STDIO MCP-server plugin registered — mcps/ source or command-based mcpServers (HTTP/SSE url-based MCP is allowed)
//      (project.tape @D s15: no MCP-server plugins; hook · command · skill only)
//   8. unexpected top-level dir — ALLOWLIST (concept dir·plugin·.github·.claude-plugin);
//      tracked only · rename-proof (project.tape @D s16: co-locate by owner/domain)
//   9. skills/*/SKILL.md body violates s6 — >1 @D block · prose/heading/table/code
//      fence beyond do/dont · a @D key other than do/dont · a per-skill README.md
//      (project.tape @D s6: SKILL.md body = ONE @D do/dont block; no prose/tables/examples)
//
// Self-excludes hooks/sidecar-lint/ and CHANGELOG.md in the staged checks.
// NO opt-out by design — no env var, no config file, no exception
// list. A guard you can switch off is a guard you will switch off.

fn _read_stdin() -> string {
    return to_string(exec("cat"))
}

fn _read_file_safe(path: string) -> string {
    let mut out = ""
    try { out = to_string(read_file(path)) }
    catch e { out = "" }
    return out
}

fn _allow() {
    exit(0)
}

fn _json_escape(s: string) -> string {
    let n = len(s)
    let mut i = 0
    let mut parts = []
    parts.push("\"")
    while i < n {
        let c = s[i]
        if c == "\"" { parts.push("\\\"") }
        else if c == "\\" { parts.push("\\\\") }
        else if c == "\n" { parts.push("\\n") }
        else if c == "\r" { parts.push("\\r") }
        else if c == "\t" { parts.push("\\t") }
        else {
            let k = char_code(c, 0)
            if k < 32 { parts.push(" ") }
            else { parts.push(c) }
        }
        i = i + 1
    }
    parts.push("\"")
    return parts.join("")
}

fn _emit(text: string) {
    let payload = "{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"additionalContext\":" + _json_escape(text) + "}}"
    println(payload)
    exit(0)
}


fn _trim(s: string) -> string {
    let n = len(s)
    let mut a = 0
    while a < n {
        let c = s[a]
        if c != " " && c != "\t" && c != "\r" && c != "\n" { break }
        a = a + 1
    }
    let mut b = n
    while b > a {
        let c = s[b - 1]
        if c != " " && c != "\t" && c != "\r" && c != "\n" { break }
        b = b - 1
    }
    return s.substring(a, b)
}

fn _lstrip(s: string) -> string {
    let n = len(s)
    let mut a = 0
    while a < n {
        let c = s[a]
        if c != " " && c != "\t" { break }
        a = a + 1
    }
    return s.substring(a, n)
}

fn _starts_with(s: string, prefix: string) -> bool {
    if len(prefix) > len(s) { return false }
    return s.substring(0, len(prefix)) == prefix
}

fn _contains(s: string, needle: string) -> bool {
    let nl = len(needle)
    if nl == 0 { return true }
    let sl = len(s)
    if nl > sl { return false }
    let mut i = 0
    while i <= sl - nl {
        if s.substring(i, i + nl) == needle { return true }
        i = i + 1
    }
    return false
}

fn _tokens(s: string) -> array {
    let mut out = []
    let n = len(s)
    let mut i = 0
    let mut cur = ""
    while i < n {
        let c = s[i]
        if c == " " || c == "\t" || c == "\n" || c == "\r" {
            if len(cur) > 0 { out.push(cur); cur = "" }
        } else {
            cur = cur + c
        }
        i = i + 1
    }
    if len(cur) > 0 { out.push(cur) }
    return out
}

fn _is_digit(c: string) -> bool {
    let k = char_code(c, 0)
    return k >= 48 && k <= 57
}

fn _is_lower(c: string) -> bool {
    let k = char_code(c, 0)
    return k >= 97 && k <= 122
}

fn _is_alnum_lower(c: string) -> bool {
    if _is_digit(c) { return true }
    return _is_lower(c)
}

// `replaces ` argument char class — [@a-z0-9_/-]
fn _is_replaces_char(c: string) -> bool {
    if _is_alnum_lower(c) { return true }
    let k = char_code(c, 0)
    if k == 64 { return true }   // @
    if k == 95 { return true }   // _
    if k == 47 { return true }   // /
    if k == 45 { return true }   // -
    return false
}

// (8) version/generation marker in a name (commons @D g72 — minimal role name).
// Hand-rolled (no regex): stage0..2 · -new/-old/-final suffix · _vN/-vN/_mkN/-mkN/_cN (N=2..9).
fn _ver_marked(s: string) -> bool {
    if _contains(s, "stage0") || _contains(s, "stage1") || _contains(s, "stage2") { return true }
    if _contains(s, "-new") || _contains(s, "-old") || _contains(s, "-final") { return true }
    let mut d = 2
    while d <= 9 {
        let ds = to_string(d)
        if _contains(s, "_v" + ds) || _contains(s, "-v" + ds) { return true }
        if _contains(s, "_mk" + ds) || _contains(s, "-mk" + ds) { return true }
        if _contains(s, "_c" + ds) { return true }
        d = d + 1
    }
    return false
}

// `removed in ` + N+.N+ (semver-ish prefix)
fn _version_at(lo: string, idx: int) -> bool {
    let n = len(lo)
    let mut i = idx
    let mut d = 0
    while i < n && _is_digit(lo[i]) { i = i + 1; d = d + 1 }
    if d == 0 { return false }
    if i >= n || lo[i] != "." { return false }
    i = i + 1
    let mut d2 = 0
    while i < n && _is_digit(lo[i]) { i = i + 1; d2 = d2 + 1 }
    return d2 > 0
}

// `archived 20` + \d\d-\d\d-\d\d
fn _date_at(lo: string, idx: int) -> bool {
    let n = len(lo)
    if idx + 8 > n { return false }
    if !_is_digit(lo[idx]) { return false }
    if !_is_digit(lo[idx + 1]) { return false }
    if lo[idx + 2] != "-" { return false }
    if !_is_digit(lo[idx + 3]) { return false }
    if !_is_digit(lo[idx + 4]) { return false }
    if lo[idx + 5] != "-" { return false }
    if !_is_digit(lo[idx + 6]) { return false }
    if !_is_digit(lo[idx + 7]) { return false }
    return true
}

// phrase found, then char-after passes the class — `kind` selects the class.
fn _phrase_then(lo: string, phrase: string, kind: string) -> bool {
    let n = len(lo)
    let mut from = 0
    let mut guard = 0
    while guard < 100000 {
        let rest = lo.substring(from, n)
        let rel = rest.index_of(phrase)
        if rel < 0 { return false }
        let at = from + rel + len(phrase)
        if kind == "version" {
            if _version_at(lo, at) { return true }
        } else if kind == "date" {
            if _date_at(lo, at) { return true }
        } else if at < n {
            let c = lo[at]
            if kind == "replaces" {
                if _is_replaces_char(c) { return true }
            } else if kind == "lower" {
                if _is_lower(c) { return true }
            } else if kind == "alnum" {
                if _is_alnum_lower(c) { return true }
            }
        }
        from = from + rel + 1
        guard = guard + 1
    }
    return false
}

fn _stale_hist(body: string) -> bool {
    let lo = body.to_lower()
    if _phrase_then(lo, "removed in ", "version") { return true }
    if _phrase_then(lo, "replaces ", "replaces") { return true }
    if _phrase_then(lo, "migrated from ", "lower") { return true }
    if _phrase_then(lo, "archived 20", "date") { return true }
    if _phrase_then(lo, "deprecated as of ", "alnum") { return true }
    if _phrase_then(lo, "formerly known as ", "alnum") { return true }
    if _phrase_then(lo, "previously named ", "alnum") { return true }
    return false
}

fn _is_hardpath_char(c: string) -> bool {
    let k = char_code(c, 0)
    if k >= 48 && k <= 57 { return true }
    if k >= 65 && k <= 90 { return true }
    if k >= 97 && k <= 122 { return true }
    if k == 46 { return true }   // .
    if k == 95 { return true }   // _
    if k == 45 { return true }   // -
    return false
}

// (?:/Users|/home)/[A-Za-z0-9._-]+/
fn _hardpath_from(body: string, marker: string) -> bool {
    let n = len(body)
    let mut from = 0
    let mut guard = 0
    while guard < 100000 {
        let rest = body.substring(from, n)
        let rel = rest.index_of(marker)
        if rel < 0 { return false }
        let mut at = from + rel + len(marker)
        let mut cnt = 0
        while at < n && _is_hardpath_char(body[at]) { at = at + 1; cnt = cnt + 1 }
        if cnt > 0 && at < n && body[at] == "/" { return true }
        from = from + rel + 1
        guard = guard + 1
    }
    return false
}

fn _hardpath(body: string) -> bool {
    if _hardpath_from(body, "/Users/") { return true }
    if _hardpath_from(body, "/home/") { return true }
    return false
}

fn _repo_root() -> string {
    let r = exec_with_status("git rev-parse --show-toplevel 2>/dev/null")
    if r[1] != 0 { return "" }
    return _trim(to_string(r[0]))
}

// Parse `git diff --cached -U0` → array of "path\tbody" for added lines.
fn _staged_added(root: string) -> array {
    let r = exec_with_status("git -C '" + root + "' diff --cached --no-color -U0 2>/dev/null")
    let mut out = []
    if r[1] != 0 { return out }
    let lines = to_string(r[0]).split("\n")
    let n = len(lines)
    let mut cur = ""
    let mut i = 0
    while i < n {
        let line = lines[i]
        if _starts_with(line, "+++ b/") {
            cur = line.substring(6, len(line))
        } else if _starts_with(line, "+") && !_starts_with(line, "+++") {
            let body = line.substring(1, len(line))
            out.push(cur + "\t" + body)
        }
        i = i + 1
    }
    return out
}

fn _is_git_commit(cmd: string) -> bool {
    let toks = _tokens(cmd)
    let n = len(toks)
    let mut i = 0
    while i + 1 < n {
        if toks[i] == "git" && toks[i + 1] == "commit" { return true }
        i = i + 1
    }
    return false
}

// (9) skills/*/SKILL.md body s6 conformance (project.tape @D s6 — a SKILL.md
// body is exactly ONE `@D <name> :: skill` block of do/dont lines; no prose
// paragraphs / markdown headings / tables / code-fence examples; no @D key
// other than do/dont; and no per-skill README.md). The frontmatter (between
// the first two `---` lines) is skipped — only the body is judged.
//
// Returns an array of finding strings ("  <rel>: <reason>").
fn _skill_s6_findings(root: string) -> array {
    let mut out = []

    // enumerate skill dirs (tracked or not — the SKILL.md is the unit).
    let lr = exec_with_status("ls -1 '" + root + "/skills' 2>/dev/null")
    if lr[1] != 0 { return out }
    let dirs = to_string(lr[0]).split("\n")
    let dn = len(dirs)
    let mut di = 0
    while di < dn {
        let name = _trim(dirs[di])
        di = di + 1
        if name == "" { continue }
        let skdir = root + "/skills/" + name

        // a per-skill README.md is forbidden outright (s6 dont).
        if file_exists(skdir + "/README.md") && len(out) < 30 {
            out.push("  skills/" + name + "/README.md: per-skill README.md forbidden (s6 — SKILL.md is the only doc surface)")
        }

        let skpath = skdir + "/SKILL.md"
        if !file_exists(skpath) { continue }
        let raw = _read_file_safe(skpath)
        if raw == "" { continue }

        // strip frontmatter: skip everything up to and including the SECOND
        // line that is exactly "---" (the first one opens it).
        let lines = raw.split("\n")
        let ln = len(lines)
        let mut li = 0
        let mut dashes = 0
        if ln > 0 && _trim(lines[0]) == "---" {
            li = 1
            while li < ln {
                if _trim(lines[li]) == "---" { li = li + 1; break }
                li = li + 1
            }
        }

        // scan the body.
        let mut at_blocks = 0
        let mut in_fence = false
        let mut sawProse = false
        let mut sawTable = false
        let mut sawHeading = false
        let mut sawFence = false
        let mut sawBadKey = false
        let mut badKeys = ""
        while li < ln {
            let line = lines[li]
            li = li + 1
            let t = _trim(line)

            if _starts_with(t, "```") {
                in_fence = !in_fence
                sawFence = true
                continue
            }
            if in_fence { continue }
            if t == "" { continue }

            if _starts_with(t, "@D ") {
                at_blocks = at_blocks + 1
                continue
            }
            if _starts_with(t, "## ") || _starts_with(t, "# ") || _starts_with(t, "### ") {
                sawHeading = true
                continue
            }
            if _starts_with(t, "|") {
                sawTable = true
                continue
            }

            // indented `key =` inside a @D body: only do / dont allowed.
            let ls = _lstrip(line)
            let eq = ls.index_of("=")
            if eq > 0 && (line[0] == " " || line[0] == "\t") {
                let key = _trim(ls.substring(0, eq))
                if key == "do" || key == "dont" {
                    continue
                }
                // a bare lowercase identifier before '=' that isn't do/dont
                // is an extra @D key (e.g. why/tool/note/ref/ex).
                let mut isident = len(key) > 0
                let mut ki = 0
                while ki < len(key) {
                    let c = key[ki]
                    if !_is_alnum_lower(c) && c != "_" { isident = false; break }
                    ki = ki + 1
                }
                if isident {
                    sawBadKey = true
                    if !_contains(badKeys, key) {
                        if badKeys == "" { badKeys = key } else { badKeys = badKeys + " " + key }
                    }
                    continue
                }
            }

            // anything else that isn't a do/dont continuation is prose.
            // (do/dont values can wrap across lines; a wrapped value line is
            // indented and has no leading marker — treat a top-level,
            // non-indented, non-@D line as prose.)
            if line[0] != " " && line[0] != "\t" {
                sawProse = true
            }
        }

        let rel = "skills/" + name + "/SKILL.md"
        if at_blocks > 1 && len(out) < 30 {
            out.push("  " + rel + ": " + to_string(at_blocks) + " @D blocks (s6 — body = exactly ONE @D do/dont block)")
        }
        if sawHeading && len(out) < 30 {
            out.push("  " + rel + ": markdown heading(s) in body (s6 — no prose/tables/examples; do/dont only)")
        }
        if sawTable && len(out) < 30 {
            out.push("  " + rel + ": markdown table(s) in body (s6 — no prose/tables/examples; do/dont only)")
        }
        if sawFence && len(out) < 30 {
            out.push("  " + rel + ": code-fence example(s) in body (s6 — no prose/tables/examples; do/dont only)")
        }
        if sawProse && len(out) < 30 {
            out.push("  " + rel + ": prose paragraph(s) in body (s6 — do/dont lines only)")
        }
        if sawBadKey && len(out) < 30 {
            out.push("  " + rel + ": @D key(s) other than do/dont (" + badKeys + ") (s6 — do/dont only)")
        }
    }
    return out
}

fn main() {

    let raw = _read_stdin()
    let mut payload = json_parse("{}")
    try { payload = json_parse(raw) } catch e { _allow() }

    if type_of(payload) != "map" { _allow() }
    if !has_key(payload, "tool_name") { _allow() }
    if payload["tool_name"] != "Bash" { _allow() }
    if !has_key(payload, "tool_input") { _allow() }
    let ti = payload["tool_input"]
    if type_of(ti) != "map" { _allow() }
    if !has_key(ti, "command") { _allow() }
    let cmd = ti["command"]
    if cmd == "" { _allow() }
    if !_is_git_commit(cmd) { _allow() }

    let root = _repo_root()
    if root == "" { _allow() }
    if !file_exists(root + "/.claude-plugin/marketplace.json") { _allow() }

    // (1) + (2) staged diff scans
    let mut hist = []
    let mut paths = []
    let staged = _staged_added(root)
    let sn = len(staged)
    let mut i = 0
    while i < sn {
        let parts = staged[i].split("\t")
        let p = parts[0]
        let mut body = ""
        if len(parts) > 1 { body = parts[1] }
        let skip = _starts_with(p, "hooks/sidecar-lint/") || p == "CHANGELOG.md"
        if !skip {
            if len(hist) < 5 && _stale_hist(body) {
                hist.push("  " + p + ": " + _trim(body))
            }
            if len(paths) < 5 && _hardpath(body) {
                let st = _lstrip(body)
                let mut is_comment = false
                if len(st) > 0 {
                    if st[0] == "#" || st[0] == "*" { is_comment = true }
                    if _starts_with(st, "//") || _starts_with(st, "--") { is_comment = true }
                }
                if !is_comment {
                    paths.push("  " + p + ": " + _trim(body))
                }
            }
        }
        i = i + 1
    }

    // (3) marketplace.json <-> plugin.json version drift
    // (7) MCP-server plugin registered (project.tape @D s15) — shares this loop
    let mut drift = []
    let mut mcpban = []
    let mut verban = []
    let mraw = _read_file_safe(root + "/.claude-plugin/marketplace.json")
    if mraw != "" {
        try {
            let m = json_parse(mraw)
            if type_of(m) == "map" && has_key(m, "plugins") {
                let plugs = m["plugins"]
                if type_of(plugs) == "array" {
                    let pn = len(plugs)
                    let mut j = 0
                    while j < pn {
                        let entry = plugs[j]
                        if type_of(entry) == "map" {
                            let mut src = ""
                            if has_key(entry, "source") { src = entry["source"] }
                            if _starts_with(src, "./") { src = src.substring(2, len(src)) }
                            let mut name = src
                            if has_key(entry, "name") { name = entry["name"] }
                            if src != "" {
                                let pjpath = root + "/" + src + "/.claude-plugin/plugin.json"
                                let pjraw = _read_file_safe(pjpath)
                                // s15 (revised): STDIO MCP forbidden; HTTP/SSE-transport MCP permitted.
                                // mcps/ source dir = legacy/ambiguous → always flagged.
                                // mcpServers in plugin.json → flag ONLY when stdio (command-based):
                                // an HTTP/SSE server entry carries a "url" (or http/sse transport),
                                // a stdio entry carries "command". Allow when a url/http marker is present.
                                let mut is_mcp = _starts_with(src, "mcps/")
                                if !is_mcp && pjraw != "" {
                                    let pjm = json_parse(pjraw)
                                    if type_of(pjm) == "map" && has_key(pjm, "mcpServers") {
                                        let has_url = pjraw.contains("\"url\"") || pjraw.contains("\"sse\"") || pjraw.contains("\"http\"") || pjraw.contains("streamable")
                                        if !has_url { is_mcp = true }
                                    }
                                }
                                if is_mcp && len(mcpban) < 8 {
                                    mcpban.push("  " + name + " (" + src + "): STDIO MCP-server plugin — mcps/ source or command-based (stdio) mcpServers; use HTTP/SSE transport (url-based)")
                                }
                                if _ver_marked(name) && len(verban) < 8 {
                                    verban.push("  " + name + " (" + src + "): version/generation marker in plugin name — use a minimal role name (version = semver in plugin.json)")
                                }
                                if pjraw != "" {
                                    let pj = json_parse(pjraw)
                                    if type_of(pj) == "map" {
                                        let mut mv = ""
                                        if has_key(entry, "version") { mv = entry["version"] }
                                        let mut pv = ""
                                        if has_key(pj, "version") { pv = pj["version"] }
                                        if mv != "" && pv != "" && mv != pv && len(drift) < 8 {
                                            drift.push("  " + name + ": marketplace.json=" + mv + " vs plugin.json=" + pv + " (version drift)")
                                        }
                                    }
                                }
                            }
                        }
                        j = j + 1
                    }
                }
            }
        } catch e { drift = drift }
    }

    // (4) hooks/*/bin/*.sh missing user-exec bit
    let mut noexec = []
    let fr = exec_with_status("find '" + root + "/hooks' -path '*/bin/*.sh' 2>/dev/null")
    if fr[1] == 0 {
        let fl = to_string(fr[0]).split("\n")
        let fn_count = len(fl)
        let mut k = 0
        while k < fn_count && len(noexec) < 5 {
            let f = _trim(fl[k])
            if f != "" {
                let xr = exec_with_status("test -x '" + f + "'")
                if xr[1] != 0 {
                    let mut rel = f
                    if _starts_with(f, root + "/") {
                        rel = f.substring(len(root) + 1, len(f))
                    }
                    noexec.push("  " + rel + ": missing user-exec bit (chmod +x)")
                }
            }
            k = k + 1
        }
    }

    // (5) CHANGELOG.md at repo root (commons @D g29)
    let mut nochangelog = false
    if !file_exists(root + "/CHANGELOG.md") { nochangelog = true }

    // (6) profiles.json tier coverage (sidecar @D s7 — classification ships
    // with its enforcement). Only when the repo carries the multi-user profiles
    // file; an untagged plugin silently defaults to 'personal' (hidden from the
    // minimal / hexa profiles), so flag it for tagging in profiles.json.
    let mut untagged = []
    let profpath = root + "/.claude-plugin/profiles.json"
    if file_exists(profpath) && mraw != "" {
        try {
            let pc = json_parse(_read_file_safe(profpath))
            let m2 = json_parse(mraw)
            if type_of(pc) == "map" && has_key(pc, "tiers") && type_of(m2) == "map" && has_key(m2, "plugins") {
                let tmap = pc["tiers"]
                let plugs2 = m2["plugins"]
                if type_of(tmap) == "map" && type_of(plugs2) == "array" {
                    let pn2 = len(plugs2)
                    let mut q = 0
                    while q < pn2 && len(untagged) < 10 {
                        let e2 = plugs2[q]
                        if type_of(e2) == "map" && has_key(e2, "name") {
                            let nm = to_string(e2["name"])
                            if !has_key(tmap, nm) {
                                untagged.push("  " + nm + ": no tier in profiles.json (defaults to 'personal' → hidden from the minimal/hexa profiles)")
                            }
                        }
                        q = q + 1
                    }
                }
            }
        } catch e { untagged = untagged }
    }

    // (8) unexpected top-level directory (project.tape @D s16 — co-locate by
    // owner). ALLOWLIST, not a name-blocklist: any TRACKED top-level dir that
    // is NOT a concept dir / plugin-pack dir is flagged — so renaming a bucket
    // (docs→documentation, state→tmp) does NOT dodge it. Only tracked dirs
    // (git ls-files), so gitignored runtime/scratch (state/ · build/ · drafts/)
    // never false-fires. Allowed: hooks · commands · skills · agents · bin ·
    // .github · .claude-plugin.
    let mut kindfolders = []
    let kr = exec_with_status("git -C '" + root + "' ls-files 2>/dev/null | awk -F/ 'NF>1{print $1}' | sort -u")
    if kr[1] == 0 {
        let tops = to_string(kr[0]).split("\n")
        let mut ti = 0
        while ti < len(tops) {
            let d = _trim(tops[ti])
            let ok = d == "" || d == "hooks" || d == "commands" || d == "skills" || d == "agents" || d == "bin" || d == ".github" || d == ".claude-plugin"
            if !ok {
                kindfolders.push("  " + d + "/: 예상 밖 top-level 디렉터리 — 이 폴더 내용을 소속 도메인/플러그인 밑으로 옮기세요 (by-owner, s16). 새 top-level 은 concept dir(hooks·commands·skills)·plugin·루트 reference doc(.md)만 — 폴더명만 바꿔 재등록해도 걸립니다")
            }
            ti = ti + 1
        }
    }

    // (9) skills/*/SKILL.md s6 conformance (project.tape @D s6 — minimal
    // tape-style do/dont body; no prose/tables/examples/extra keys; no
    // per-skill README.md). Whole-tree scan (not staged-diff) so an existing
    // violation surfaces on the next commit, matching the marketplace/profiles
    // checks above.
    // (file_exists is regular-file-only in hexa — it returns false for a
    // directory; the function itself fail-opens when `ls skills` errors, so no
    // dir-existence guard is needed here.)
    let skills6 = _skill_s6_findings(root)

    let mut sections = []
    if nochangelog {
        sections.push("no CHANGELOG.md at repo root (commons @D g29 — create + maintain CHANGELOG.md as the chronological history surface)")
    }
    if len(hist) > 0 {
        sections.push("stale-history patterns in staged diff (commons @D g15 — write current-state only):\n" + hist.join("\n"))
    }
    if len(paths) > 0 {
        sections.push("hardcoded absolute paths in staged diff (commons @D g13 / sidecar @D s3 — use $HOME / ${CLAUDE_PLUGIN_ROOT} / $CLAUDE_PLUGIN_DATA):\n" + paths.join("\n"))
    }
    if len(drift) > 0 {
        sections.push("marketplace.json <-> plugin.json version drift (commons @D g22 — lockstep version surfaces):\n" + drift.join("\n"))
    }
    if len(noexec) > 0 {
        sections.push("hook .sh missing user-exec bit (PreToolUse / SessionStart fires die with Permission denied):\n" + noexec.join("\n"))
    }
    if len(untagged) > 0 {
        sections.push("plugins missing a profiles.json tier (sidecar @D s7 — tag a tier {core·hexa·personal} so the multi-user profiles can place it; untagged defaults to 'personal'):\n" + untagged.join("\n"))
    }
    if len(mcpban) > 0 {
        sections.push("STDIO MCP-server plugin(s) registered (project.tape @D s15 — STDIO MCP forbidden; use hook · command · skill + host CLI, OR an HTTP/SSE-transport MCP (url-based); stdio JSON-RPC handshake collides with hexa hook stdio + fake-stdin):\n" + mcpban.join("\n"))
    }
    if len(verban) > 0 {
        sections.push("version/generation marker in plugin name(s) (commons @D g72 — minimal role-name identifiers; the version lives in semver / git tag, never the name):\n" + verban.join("\n"))
    }
    if len(kindfolders) > 0 {
        sections.push("예상 밖 top-level 디렉터리 (project.tape @D s16 — 소속 도메인/플러그인 밑으로 co-locate; 허용 = concept dir(hook·command·skill)·plugin·루트 reference doc. 폴더명만 바꿔도 걸리는 allowlist 방식):\n" + kindfolders.join("\n"))
    }
    if len(skills6) > 0 {
        sections.push("SKILL.md s6 위반 (project.tape @D s6 — SKILL.md body = ONE `@D <name> :: skill` block · do/dont only; no prose/tables/examples/extra-keys; no per-skill README.md):\n" + skills6.join("\n"))
    }

    if len(sections) == 0 { _allow() }

    _emit("sidecar-lint findings (non-blocking):\n\n" + sections.join("\n\n"))
}
