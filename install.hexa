// install.hexa — sidecar one-shot bootstrap (hx build hook).
//
// `hx install sidecar` runs this automatically — hx's build-hook step
// looks for `bin/build.hexa` | `install.hexa` | `bin/build.sh` and runs
// the first it finds. So `hx install sidecar` ALONE sets everything up.
// Also re-runnable any time:  hexa run install.hexa
//
// What it does (idempotent — every JSON file is .bak'd, parsed, merged,
// re-emitted; re-running only updates what changed):
//   1. clone / pull the Claude Code marketplace at
//      ~/.claude/plugins/marketplaces/sidecar
//   2. register it in known_marketplaces.json
//   3. copy each plugin into the version cache + patch installed_plugins.json
//   4. ENABLE every sidecar plugin in ~/.claude/settings.json
//      (enabledPlugins) — the step plain `sidecar sync` used to skip,
//      which is why freshly-synced plugins never showed up.

fn _trim(s: string) -> string {
    let n = len(s)
    let mut a = 0
    while a < n {
        let c = s[a]
        if c != " " && c != "\t" && c != "\r" && c != "\n" { break }
        a = a + 1
    }
    let mut b = n
    while b > a {
        let c = s[b - 1]
        if c != " " && c != "\t" && c != "\r" && c != "\n" { break }
        b = b - 1
    }
    return s.substring(a, b)
}

fn _shq(s: string) -> string {
    let mut out = "'"
    let n = len(s)
    let mut i = 0
    while i < n {
        let c = s[i]
        if c == "'" { out = out + "'\\''" }
        else { out = out + c }
        i = i + 1
    }
    return out + "'"
}

fn _now() -> string {
    return _trim(to_string(exec("date -u +%Y-%m-%dT%H:%M:%S"))) + ".000Z"
}

fn _exists(path: string) -> bool {
    return exec_with_status("test -e " + _shq(path))[1] == 0
}

fn _is_dir(path: string) -> bool {
    return exec_with_status("test -d " + _shq(path))[1] == 0
}

fn _read_safe(path: string) -> string {
    let mut out = ""
    try { out = to_string(read_file(path)) }
    catch e { out = "" }
    return out
}

// parse a JSON file, falling back to `fallback` when missing / unreadable
fn _parse_or(path: string, fallback: string) -> map {
    let raw = _trim(_read_safe(path))
    if raw == "" { return json_parse(fallback) }
    let mut m = json_parse(fallback)
    let mut ok = true
    try { m = json_parse(raw) }
    catch e { ok = false }
    if !ok { return json_parse(fallback) }
    return m
}

// back up (.bak) then re-emit a JSON file.
// A macOS immutable flag (`uchg`) on the target blocks the write with
// EPERM — `~/.claude/settings.json` is commonly locked this way. Clear
// the flag (owner-clearable, no sudo), write, then restore it as found.
fn _write_json(path: string, value: map) {
    let mut relock = false
    if _exists(path) {
        let flags = to_string(exec("ls -lO " + _shq(path) + " 2>/dev/null"))
        if flags.index_of("uchg") >= 0 {
            relock = true
            let _u = exec("chflags nouchg " + _shq(path) + " 2>/dev/null")
        }
        let _b = exec("cp " + _shq(path) + " " + _shq(path + ".bak") + " 2>/dev/null")
    }
    write_file(path, json_stringify(value) + "\n")
    if relock {
        let _r = exec("chflags uchg " + _shq(path) + " 2>/dev/null")
    }
}

// active enable-profile name — ~/.sidecar/profile (one word), else the
// profiles.json "default" (full). Default `full` = enable everything = the
// pre-profiles behavior, so existing installs are unaffected.
fn _read_active_profile(home: string, def: string) -> string {
    let raw = _trim(_read_safe(home + "/.sidecar/profile"))
    if raw == "" { return def }
    return raw
}

fn _arr_has(arr: any, v: string) -> bool {
    if type_of(arr) != "array" { return false }
    let mut i = 0
    while i < len(arr) {
        if to_string(arr[i]) == v { return true }
        i = i + 1
    }
    return false
}

// is this installed/enabled key a sidecar one (ends in "@sidecar")?
fn _is_sidecar_key(k: string) -> bool {
    let suf = "@sidecar"
    let n = len(k)
    let m = len(suf)
    if n < m { return false }
    return k.substring(n - m, n) == suf
}

fn main() {
    let home = env_var("HOME")
    if home == "" {
        eprintln("sidecar install: $HOME not set — cannot locate Claude Code config")
        return
    }
    let plugins_dir = home + "/.claude/plugins"
    let mp = plugins_dir + "/marketplaces/sidecar"
    let cache = plugins_dir + "/cache/sidecar"
    let installed_path = plugins_dir + "/installed_plugins.json"
    let known_path = plugins_dir + "/known_marketplaces.json"
    let settings_path = home + "/.claude/settings.json"
    let repo = "https://github.com/dancinlab/sidecar"

    let _mk = exec("mkdir -p " + _shq(cache) + " " + _shq(plugins_dir + "/marketplaces"))

    // ── 1. marketplace clone / pull ──────────────────────────────────
    // Branch-guard (PR#104): if a prior session left the clone on a feature
    // branch (e.g. `fix/...`), force-checkout `main` (or recreate it tracking
    // origin/main) first.
    //
    // Force-sync (PR#9): then always `fetch + reset --hard origin/main`. The
    // previous `pull --ff-only ... 2>/dev/null` silently swallowed failure
    // modes (transient HTTP error, lock files, shallow-clone fetch limits) and
    // left the clone stuck at an old HEAD while reporting "pulled" — which is
    // exactly how the user's clone ended up frozen at 0.4.2 after 0.4.3 merged.
    // The marketplace clone has no local edits we ever want to preserve, so
    // reset --hard is safe and immune to silent-no-op.
    println("sidecar install: setting up the Claude Code marketplace…")
    if _is_dir(mp + "/.git") {
        let cur = _trim(to_string(exec("git -C " + _shq(mp) + " branch --show-current 2>/dev/null")))
        if cur != "main" {
            let _f  = exec("git -C " + _shq(mp) + " fetch origin main 2>/dev/null")
            let _co = exec("git -C " + _shq(mp) + " checkout main 2>/dev/null || git -C " + _shq(mp) + " checkout -B main origin/main 2>/dev/null")
            println("  marketplace · realigned " + cur + " → main")
        }
        let _f2 = exec("git -C " + _shq(mp) + " fetch origin main 2>/dev/null")
        let _r  = exec("git -C " + _shq(mp) + " reset --hard origin/main 2>/dev/null")
        println("  marketplace · synced to origin/main")
    } else {
        let cl = exec_with_status("git clone --depth 1 " + _shq(repo) + " " + _shq(mp) + " 2>&1")
        if cl[1] != 0 {
            eprintln("  marketplace clone failed: " + _trim(to_string(cl[0])))
            eprintln("sidecar install: cannot continue without the marketplace — CC plugin setup skipped")
            return
        }
        println("  marketplace · cloned")
    }
    let sha = _trim(to_string(exec("git -C " + _shq(mp) + " rev-parse HEAD 2>/dev/null")))
    let mut shortsha = sha
    if len(sha) >= 7 { shortsha = sha.substring(0, 7) }

    let manifest_raw = _trim(_read_safe(mp + "/.claude-plugin/marketplace.json"))
    if manifest_raw == "" {
        eprintln("sidecar install: marketplace.json not found at " + mp)
        return
    }
    let manifest = json_parse(manifest_raw)
    let plugins = manifest["plugins"]
    let now = _now()

    // ── multi-user enable profiles (.claude-plugin/profiles.json) ────
    // A plugin is enabled iff its tier is in the active profile's tier list,
    // unless ~/.sidecar/plugin-overrides.json names it explicitly (per-plugin
    // wins). Filtering applies ONLY for a non-`full` profile with a readable
    // config — `full` (the default) and any missing/broken config fall straight
    // back to enable-everything, so this is a no-op for existing installs and
    // can never silently disable the whole roster. This is plugin enable/disable
    // (Claude Code's own mechanism), NOT an in-guard opt-out — project.tape @D
    // s11 forbids the latter; a disabled plugin simply isn't loaded.
    let prof_cfg = _parse_or(mp + "/.claude-plugin/profiles.json", "{}")
    let prof_def = if has_key(prof_cfg, "default") { to_string(prof_cfg["default"]) } else { "full" }
    let active_profile = _read_active_profile(home, prof_def)
    let prof_map = if has_key(prof_cfg, "profiles") { prof_cfg["profiles"] } else { json_parse("{}") }
    let tier_map = if has_key(prof_cfg, "tiers") { prof_cfg["tiers"] } else { json_parse("{}") }
    let active_tiers = if has_key(prof_map, active_profile) { prof_map[active_profile] } else { json_parse("[]") }
    let prof_ok = has_key(prof_cfg, "profiles") && has_key(prof_cfg, "tiers") && len(active_tiers) > 0
    let filtering = prof_ok && active_profile != "full"
    let overrides = _parse_or(home + "/.sidecar/plugin-overrides.json", "{}")
    // master tier = CREATOR-ONLY: a `master`-tier plugin enables only when the
    // ~/.sidecar/master marker exists (force-disabled otherwise, even under the
    // no-filter `full`/`master` profile). Public installs never have the marker.
    let master_marker = _trim(_read_safe(home + "/.sidecar/master")) != ""

    // ── 2. register the marketplace in known_marketplaces.json ───────
    let known = _parse_or(known_path, "{}")
    let src = json_parse("{}")
    src["source"] = "github"
    src["repo"] = "dancinlab/sidecar"
    let mentry = json_parse("{}")
    mentry["source"] = src
    mentry["installLocation"] = mp
    mentry["lastUpdated"] = now
    known["sidecar"] = mentry
    _write_json(known_path, known)
    println("  known_marketplaces.json · sidecar registered")

    // ── 3. cache + installed_plugins.json · 4. settings.json enable ──
    let installed = _parse_or(installed_path, "{\"version\":2,\"plugins\":{}}")
    if !has_key(installed, "plugins") { installed["plugins"] = json_parse("{}") }
    let settings = _parse_or(settings_path, "{}")
    if !has_key(settings, "enabledPlugins") { settings["enabledPlugins"] = json_parse("{}") }

    let subs = ["hooks", "skills", "commands", "mcps"]
    let mut n = 0
    let mut ndis = 0
    // every `<name>@sidecar` key the CURRENT marketplace still vouches for —
    // built over ALL listed plugins (even ones whose srcdir is transiently
    // missing) so the prune below only drops genuinely-retired entries.
    let mut valid = json_parse("{}")
    let mut i = 0
    while i < len(plugins) {
        let p = plugins[i]
        let name = to_string(p["name"])
        let ver = to_string(p["version"])
        valid[name + "@sidecar"] = true

        // locate the plugin's source dir (hooks/ · skills/ · commands/)
        let mut srcdir = ""
        let mut si = 0
        while si < len(subs) {
            let cand = mp + "/" + subs[si] + "/" + name
            if _is_dir(cand) { srcdir = cand }
            si = si + 1
        }
        if srcdir == "" {
            i = i + 1
            continue
        }

        // copy into the version cache (only when that version is absent)
        let dest = cache + "/" + name + "/" + ver
        if !_is_dir(dest) {
            let _m = exec("mkdir -p " + _shq(dest))
            let _c = exec("cp -R " + _shq(srcdir) + "/. " + _shq(dest) + "/")
            // jq validate the freshly copied plugin.json — a corrupt manifest in
            // the cache silently breaks /doctor + plugin load. On parse fail, rm
            // the dest dir so the next sync re-copies (vs leaving a zombie cache
            // that survives forever once written). Advisory stderr — never fatal.
            let pj = dest + "/.claude-plugin/plugin.json"
            if exec_with_status("test -f " + _shq(pj))[1] == 0 {
                let probe = exec_with_status("jq -e . " + _shq(pj) + " >/dev/null 2>&1")
                if probe[1] != 0 {
                    let _rm = exec("rm -rf " + _shq(dest))
                    println("sidecar install: WARN — " + name + "@" + ver + " plugin.json invalid JSON, cache evicted (re-sync next run)")
                }
            }
        }

        let key = name + "@sidecar"
        // preserve the original installedAt when the entry already exists
        let mut installed_at = now
        if has_key(installed["plugins"], key) {
            let arr = installed["plugins"][key]
            if len(arr) > 0 && has_key(arr[0], "installedAt") {
                installed_at = to_string(arr[0]["installedAt"])
            }
        }
        let entry = json_parse("{}")
        entry["scope"] = "user"
        entry["installPath"] = dest
        entry["version"] = ver
        entry["installedAt"] = installed_at
        entry["lastUpdated"] = now
        entry["gitCommitSha"] = sha
        installed["plugins"][key] = [entry]

        // enable per the active profile (the step that also fixes "commands
        // don't show up"). Override wins; else tier∈active_tiers when filtering;
        // else true (full / legacy → enable everything).
        let tier = if has_key(tier_map, name) { to_string(tier_map[name]) } else { "personal" }
        let mut en = true
        if has_key(overrides, name) {
            en = overrides[name] == true
        } else if filtering {
            en = _arr_has(active_tiers, tier)
        }
        // master tier is creator-only — off unless ~/.sidecar/master exists
        // (applies even in the no-filter `full` profile). Explicit per-plugin
        // override still wins (the user's own escape hatch).
        if tier == "master" && !master_marker && !has_key(overrides, name) { en = false }
        settings["enabledPlugins"][key] = en
        if !en { ndis = ndis + 1 }

        n = n + 1
        i = i + 1
    }

    // ── prune retired plugins ────────────────────────────────────────
    // The loop above only ever ADDS / UPDATES entries, so a plugin dropped
    // from marketplace.json leaves a dangling `<name>@sidecar` in both
    // installed_plugins.json and settings.enabledPlugins — Claude Code then
    // reports "<n> error(s) during load" for the missing install path. Drop
    // every `@sidecar` key the current marketplace no longer vouches for
    // (non-sidecar keys + still-valid sidecar keys are copied through).
    let mut npruned = 0
    let inst_keys = keys(installed["plugins"])
    let mut new_inst = json_parse("{}")
    let mut pi = 0
    while pi < len(inst_keys) {
        let k = inst_keys[pi]
        if _is_sidecar_key(k) && !has_key(valid, k) {
            npruned = npruned + 1
        } else {
            new_inst[k] = installed["plugins"][k]
        }
        pi = pi + 1
    }
    installed["plugins"] = new_inst

    let en_keys = keys(settings["enabledPlugins"])
    let mut new_en = json_parse("{}")
    let mut ei = 0
    while ei < len(en_keys) {
        let k = en_keys[ei]
        if _is_sidecar_key(k) && !has_key(valid, k) {
            // pruned in lockstep with installed_plugins (counted above)
        } else {
            new_en[k] = settings["enabledPlugins"][k]
        }
        ei = ei + 1
    }
    settings["enabledPlugins"] = new_en

    _write_json(installed_path, installed)
    _write_json(settings_path, settings)

    let en_n = n - ndis
    let prof_note = if filtering { "  profile '" + active_profile + "' · " + to_string(en_n) + " enabled · " + to_string(ndis) + " disabled" }
        else { "  profile '" + active_profile + "' · all " + to_string(n) + " enabled" }
    println("sidecar install: " + to_string(n)
        + " plugin(s) cached · installed  (HEAD " + shortsha + ")")
    println(prof_note)
    if npruned > 0 {
        println("  pruned " + to_string(npruned) + " retired plugin(s) from installed_plugins.json + enabledPlugins")
    }
    println("  → run /reload-plugins in Claude Code (or restart) to load them now.")
}
