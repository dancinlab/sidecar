{
  "hooks": {
    "Stop": [
      { "hooks": [ { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/bin/checkpoint.sh hook" } ] }
    ],
    "PreCompact": [
      { "hooks": [ { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/bin/checkpoint.sh hook" } ] }
    ],
    "SessionEnd": [
      { "hooks": [ { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/bin/checkpoint.sh hook" } ] }
    ],
    "SessionStart": [
      { "hooks": [ { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/bin/checkpoint.sh hook" } ] }
    ]
  }
}
