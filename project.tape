@V := "tape" :: spec [active]
  version = "1.4"

@I := "sidecar" :: identity [active]
  kind   = "Claude Code marketplace plugin pack (concept-separated guardrails Â· commands Â· skills)"
  brief  = "Side-mounts onto Claude Code without modifying it. Carries the cross-project do/dont layer in hooks/commons/commons.tape."
  parent = "dancinlab"
  ssot   = "github.com/dancinlab/sidecar (`hx install sidecar`)"

@D s1 := "concept separation" :: governance [required active]
  do   = "1 plugin = exactly 1 of {hook Â· command Â· skill} Â· top-level dir matches the concept"
  dont = "mix concepts in one plugin (skill+command relax allowed when the command is the literal mechanism the skill orchestrates â€” e.g. inbox, all-bg-go, easy, brainstorm, domain, research)"

@D s2 := "structured carriers over prose" :: governance [required active]
  do   = "use structured carriers: `.tape` Â· `plugin.json` Â· `hooks.json` Â· `marketplace.json` Â· `lsp.json`"

@D s3 := "portable plugin scripts" :: governance [required active]
  dont = "hardcoded absolute paths in plugin scripts (use `${CLAUDE_PLUGIN_ROOT}` Â· `$HOME` Â· `$CLAUDE_PLUGIN_DATA` Â· PATH-resolved binaries)"

@D s4 := "commons carries cross-project rules" :: governance [active]
  do   = "the `commons` hook plugin carries cross-project hexa-native do/dont rules across all sessions (SessionStart + PreCompact + PostCompact re-inject)"

@D s5 := "project.tape carries project-level rules" :: governance [active]
  do   = "this file (`<project-root>/project.tape`, linked as CLAUDE.md) carries sidecar-specific identity + governance; project-tape hook re-injects on PreCompact + PostCompact"

@D ship := "ship cycle â€” sidecar plugin atomic commit + push + install-sync" :: governance [required active]
  do    = "the word `ship` refers to THIS REPO's plugin ship cycle (sidecar), NOT a cross-repo git push batch. atomic op: commit (stage explicit paths Â· credential scan first) â†’ push origin/<branch> â†’ marketplace clone pull â†’ cache copy to ~/.claude/plugins/cache/sidecar/<name>/<ver>/ â†’ patch installed_plugins.json (version Â· installPath Â· lastUpdated Â· gitCommitSha) â€” equivalent to `sidecar sync` after the push"
  dont  = "interpret `ship` as a cross-repo batch (sweeping git push across hexa-lang Â· demiurge Â· anima Â· etc. â€” those are other repos' own ship cycles) Â· unshipped diffs between user-facing pauses Â· `git add -A` / `-u` instead of explicit paths Â· defer install sync to `/plugin` after push Â· skip credential scan (rpa_ Â· sk-[A-Za-z0-9]{20} Â· hf_[A-Za-z0-9]{30} Â· AKIA)"
  tool  = "git + gh + sidecar sync (= marketplace pull + cache copy + installed_plugins.json patch)"
