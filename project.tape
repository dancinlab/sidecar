@V := "tape" :: spec [active]
  version = "1.4"

@I := "sidecar" :: identity [active]
  kind     = "Claude Code marketplace plugin pack â€” concept-separated guardrails Â· commands Â· skills"
  brief    = "Side-mounts onto Claude Code Â· carries the cross-project do/dont layer in hooks/commons/"
  parent   = "dancinlab"
  ssot     = "github.com/dancinlab/sidecar (`hx install sidecar`)"
  siblings = "hexa-lang Â· pool Â· secret"

@D s1 := "concept separation" :: governance [required active]
  do   = "1 plugin = exactly 1 of {hook Â· command Â· skill} Â· top-level dir matches the concept"
  dont = "mix concepts in one plugin (skill+command ok when the command IS the skill's mechanism)"

@D s2 := "structured carriers over prose" :: governance [required active]
  do   = "use structured carriers: `.tape` Â· `plugin.json` Â· `hooks.json` Â· `marketplace.json` Â· `.lsp.json`"

@D s3 := "portable plugin scripts" :: governance [required active]
  dont = "absolute paths in plugin scripts â€” use ${CLAUDE_PLUGIN_ROOT} Â· $HOME Â· $CLAUDE_PLUGIN_DATA Â· PATH"

@D s4 := "commons carries cross-project rules" :: governance [active]
  do   = "`commons` hook carries cross-project do/dont Â· re-injects SessionStart + PreCompact + PostCompact"

@D s5 := "project.tape carries project-level rules" :: governance [active]
  do   = "project.tape (= CLAUDE.md) carries sidecar identity + governance Â· re-injected on compact"

@D s6 := "skill SKILL.md â€” minimal tape-style do/dont body" :: governance [required active]
  do   = "SKILL.md body = one `@D <name> :: skill` block Â· do/dont only Â· project.tape lint standard"
  dont = "prose Â· tables Â· examples in a SKILL.md body Â· keys beyond do/dont Â· per-skill README.md"

@D s7 := "ship governance + its enforcement together" :: governance [required active]
  do   = "new governance rule / plugin â†’ ship its lint or guard hook in the same cycle"
  dont = "land a rule with no enforcement Â· defer the lint to later Â· rely on model self-discipline only"

@D ship := "ship cycle â€” atomic commit + push + sync (install + enable)" :: governance [required active]
  do   = "commit (explicit paths Â· g28 cred-scan) â†’ push â†’ `sidecar sync` (cache Â· install Â· enable)"
  dont = "`ship` as cross-repo batch Â· sync without enable Â· `git add -A`/`-u` Â· unshipped diffs at pauses"

@D s8 := "pi5-akida is anima-only â€” exclude from general pool dispatch" :: governance [required active]
  do   = "use pi5-akida ONLY for anima work Â· explicit `pool on pi5-akida <cmd>` only"
  dont = "include pi5-akida in `pool route` / load-balancing / round-robin / auto-dispatch candidates"

@D s9 := "claude sessions exempt from local load assessment" :: governance [required active]
  do   = "exclude `claude` PIDs from CPU/load attribution Â· attribute load to non-claude consumers only"
  dont = "count `claude` toward 'Mac overloaded â†’ pool' Â· suggest killing claude as load remedy unasked"

@D s10 := "pool-route routes on explicit classifier only â€” never on load" :: governance [required active]
  do   = "route to pool only on explicit heavy classifier Â· git/gh/abs-path/local-fs cmds stay local"
  dont = "route on high system load â€” 'busy' â‰  'portable'; local-bound cmds break on the wrong host"

@D s11 := "no opt-out / escape-hatch variables in guards or auto-hooks" :: governance [required active]
  do   = "guards + auto-hooks unconditional Â· gate only on real preconditions (binary Â· dirty-tree skip)"
  dont = "env var/config/exception that DISABLES a guard â€” gets auto-flipped to silence, defeats purpose"

@D s12 := "zero macOS offload by default Â· `pool mini-equal on` opts mini in" :: governance [required active]
  do   = "general-heavyâ†’Linux pool (default) Â· macOS-onlyâ†’mac host Â· mini joins via `pool mini-equal on`"
  dont = "Linux-only workâ†’mac host Â· route general-heavy to mini while mini-equal OFF (Mac=workstation)"

@D s13 := "governance SSOT files are sign-gated â€” user sign-off before agent edits" :: governance [required active]
  do   = "edit commons.tape Â· project.tape ONLY after the USER runs `sidecar sign <key>` Â· obey the deny"
  dont = "self-mint the sign Â· edit a sign-gated file without a fresh user token Â· add an opt-out"
