// _domain.hexa — UPPERCASE <DOMAIN>.md (snapshot) + <DOMAIN>.log.md
// (checkbox log). Project-name fallback: if NAME not given, uppercase the
// project-root basename. Auto-scaffolds both files when missing.
//
// usage: hexa run _domain.hexa [NAME | <task> | todo .. | done .. | new .. | show ..]

fn _trim(s: string) -> string {
    let n = len(s)
    let mut a = 0
    while a < n {
        let c = s[a]
        if c != " " && c != "\t" && c != "\r" && c != "\n" { break }
        a = a + 1
    }
    let mut b = n
    while b > a {
        let c = s[b - 1]
        if c != " " && c != "\t" && c != "\r" && c != "\n" { break }
        b = b - 1
    }
    return s.substring(a, b)
}

fn _read_file_safe(path: string) -> string {
    let mut out = ""
    try { out = to_string(read_file(path)) }
    catch e { out = "" }
    return out
}

fn _starts_with(s: string, prefix: string) -> bool {
    if len(prefix) > len(s) { return false }
    return s.substring(0, len(prefix)) == prefix
}

fn _basename(path: string) -> string {
    let i = path.last_index_of("/")
    if i < 0 { return path }
    return path.substring(i + 1, len(path))
}

fn _contains(hay: string, needle: string) -> bool {
    return hay.index_of(needle) >= 0
}

// Word-boundary char class — [A-Za-z0-9_]. A "word match" is one where the
// needle's neighbors are NOT word chars (so `M6` doesn't accidentally match
// inside `M16` or `M62`). Critical for `done <term>` disambiguation.
fn _is_word_char(c: string) -> bool {
    let k = char_code(c, 0)
    if k >= 48 && k <= 57 { return true }
    if k >= 65 && k <= 90 { return true }
    if k >= 97 && k <= 122 { return true }
    if k == 95 { return true }
    return false
}

fn _word_match(hay: string, needle: string) -> bool {
    let m = len(needle)
    if m == 0 { return false }
    let n = len(hay)
    let mut from = 0
    let mut guard = 0
    while guard < 100000 {
        let rest = hay.substring(from, n)
        let rel = rest.index_of(needle)
        if rel < 0 { return false }
        let at = from + rel
        let left_ok = at == 0 || !_is_word_char(hay[at - 1])
        let after = at + m
        let right_ok = after >= n || !_is_word_char(hay[after])
        if left_ok && right_ok { return true }
        from = at + 1
        guard = guard + 1
    }
    return false
}

// uppercase a-z, keep the rest (incl. `-`) — mirrors `tr 'a-z' 'A-Z'`.
// `-` is the canonical word-separator now (`_` is rejected by _is_name), so a
// project basename like `my-project` defaults to the domain `MY-PROJECT`.
fn _domain_name(s: string) -> string {
    let mut out = ""
    let n = len(s)
    let mut i = 0
    while i < n {
        let c = s[i]
        let k = char_code(c, 0)
        if k >= 97 && k <= 122 {
            out = out + chr(k - 32)
        } else {
            out = out + c
        }
        i = i + 1
    }
    return out
}

// A valid domain NAME starts with an UPPERCASE letter; subsequent chars are
// UPPERCASE / digit / `-` / `+`. The `+` enables meta-domain composition —
// e.g. `RTSC+HTS` writes RTSC+HTS.md + RTSC+HTS.log.md (a domain of domains).
// `-` is the sole word-separator (e.g. `TTR-LM`); `_` is REJECTED — one
// separator convention so `TTR-LM` and `TTR_LM` never split into two domains.
fn _is_name(s: string) -> bool {
    let n = len(s)
    if n == 0 { return false }
    let k0 = char_code(s[0], 0)
    if !(k0 >= 65 && k0 <= 90) { return false }
    let mut i = 1
    while i < n {
        let k = char_code(s[i], 0)
        let ok = (k >= 65 && k <= 90) || (k >= 48 && k <= 57) || (k == 45) || (k == 43)
        if !ok { return false }
        i = i + 1
    }
    return true
}

fn _join_from(arr: array, from: int) -> string {
    let mut out = ""
    let n = len(arr)
    let mut i = from
    while i < n {
        if i > from { out = out + " " }
        out = out + arr[i]
        i = i + 1
    }
    return out
}

fn _iso_ts() -> string {
    return _trim(to_string(exec("date -u +%Y-%m-%dT%H:%M")))
}

// ── global root + default name (set in main, passed explicitly) ──

// Domain path resolution: a domain pair lives EITHER at the repo root
// (`<NAME>.md` + `<NAME>.log.md`) OR in a self-contained folder
// (`<NAME>/<NAME>.md` + `<NAME>/<NAME>.log.md`). Resolve order:
//   (1) an existing root-level `<NAME>.md` wins
//   (2) else an existing folder-nested `<NAME>/<NAME>.md`
//   (3) else default to root (fresh scaffold)
// The log path follows the snapshot's directory so the pair never splits.
// Fixes the folder-nested regression where every verb regenerated an empty
// root scaffold for a domain that actually lives in `<NAME>/` (INBOX #120).

// A nested `<name>/<name>.md` counts as a domain snapshot ONLY if its first
// non-empty line is the domain header `# <name> …` (the scaffold convention).
// Guards the folder-nested fallback against false-matching an unrelated
// same-named file (e.g. a digest `<name>/<NAME>.md` that is not a domain) —
// critical on case-insensitive filesystems where `inbox/INBOX.md` collides
// with an `INBOX` domain lookup (0.8.0 → 0.8.1 fix).
fn _is_domain_snapshot(path: string, name: string) -> bool {
    let body = _read_file_safe(path)
    if body == "" { return false }
    let lines = body.split("\n")
    let mut i = 0
    while i < len(lines) {
        let t = _trim(lines[i])
        if t != "" { return _starts_with(t, "# " + name) }
        i = i + 1
    }
    return false
}

fn _domain_dir(root: string, name: string) -> string {
    if file_exists(root + "/" + name + ".md") { return root }
    let nested = root + "/" + name + "/" + name + ".md"
    if file_exists(nested) && _is_domain_snapshot(nested, name) { return root + "/" + name }
    return root
}

fn _snap_path(root: string, name: string) -> string {
    return _domain_dir(root, name) + "/" + name + ".md"
}

fn _log_path(root: string, name: string) -> string {
    return _domain_dir(root, name) + "/" + name + ".log.md"
}

fn _scaffold_snapshot(path: string, name: string) {
    write_file(path, "# " + name + " — current state\n\n(edit me — describe current state in completed-form; no history, no changelog inside this file)\n")
}

fn _scaffold_log(path: string, name: string) {
    write_file(path, "# " + name + " — log\n\nAppend-only history sister of `" + name + ".md`. Each entry starts with `## <ISO timestamp> — <header>` (newest on top); body = `- [x]` (done) / `- [ ]` (pending) checkbox tasks.\n\n")
}

fn _ensure_files(root: string, name: string) {
    let snap = _snap_path(root, name)
    let log = _log_path(root, name)
    if !file_exists(snap) { _scaffold_snapshot(snap, name) }
    if !file_exists(log) { _scaffold_log(log, name) }
}

// index of first line starting with "## ", or -1
fn _first_header(lines: array) -> int {
    let n = len(lines)
    let mut i = 0
    while i < n {
        if _starts_with(lines[i], "## ") { return i }
        i = i + 1
    }
    return -1
}

fn _append_task(root: string, name: string, mark: string, text: string) {
    _ensure_files(root, name)
    let log = _log_path(root, name)
    let ts = _iso_ts()
    let body = _read_file_safe(log)
    let lines = body.split("\n")
    let h = _first_header(lines)
    let task = "- [" + mark + "] " + text
    if h < 0 {
        write_file(log, body + "\n## " + ts + " — session\n\n" + task + "\n")
        return
    }
    let mut pos = h + 1
    if pos < len(lines) && lines[pos] == "" { pos = pos + 1 }
    let mut out = []
    let mut i = 0
    while i < len(lines) {
        if i == pos { out.push(task) }
        out.push(lines[i])
        i = i + 1
    }
    if pos >= len(lines) { out.push(task) }
    write_file(log, out.join("\n"))
}

// append a final-goal milestone `- [ ] <text>` to the SNAPSHOT (<NAME>.md) —
// this is what progress % counts against. `done <match>` flips it to `[x]`.
fn _append_goal(root: string, name: string, text: string) {
    _ensure_files(root, name)
    let snap = _snap_path(root, name)
    let body = _read_file_safe(snap)
    let mut sep = "\n"
    if len(body) > 0 && body.substring(len(body) - 1, len(body)) == "\n" { sep = "" }
    write_file(snap, body + sep + "- [ ] " + text + "\n")
}

// flip a snapshot goal `- [ ] *<term>*` -> `- [x]` (goal completion → progress)
//
// Match policy: word-boundary `term` (so `M6` does not bleed into `M16`/`M62`).
// Disambiguation:
//   * exactly 1 open match → flip + return true (caller stops)
//   * 2+ open matches      → print candidates + exit 1 (ambiguous, force user
//                            to use a more specific term — never silently flip
//                            the first hit when intent is unclear)
//   * 0 open + closed hit  → record the closed line(s) for the dispatcher to
//                            surface as a hint, return false
//   * 0 anywhere           → return false (caller falls back to _flip_done)
fn _flip_goal(root: string, name: string, term: string) -> bool {
    _ensure_files(root, name)
    let snap = _snap_path(root, name)
    let body = _read_file_safe(snap)
    let lines = body.split("\n")
    let mut opens = []
    let mut closes = []
    let mut i = 0
    while i < len(lines) {
        let ln = lines[i]
        if _starts_with(ln, "- [ ] ") && _word_match(ln, term) { opens.push(i) }
        else if _starts_with(ln, "- [x] ") && _word_match(ln, term) { closes.push(i) }
        i = i + 1
    }
    if len(opens) == 1 {
        let idx = opens[0]
        let old = lines[idx]
        lines[idx] = "- [x] " + old.substring(6, len(old))
        write_file(snap, lines.join("\n"))
        return true
    }
    if len(opens) >= 2 {
        eprintln("domain: ambiguous — '" + term + "' matches " + to_string(len(opens)) + " open milestones in " + name + ".md:")
        let mut j = 0
        while j < len(opens) {
            eprintln("  " + lines[opens[j]])
            j = j + 1
        }
        eprintln("hint: use a longer / more specific term")
        exit(1)
    }
    if len(closes) > 0 {
        eprintln("domain: '" + term + "' already closed in " + name + ".md:")
        let mut j = 0
        while j < len(closes) {
            eprintln("  " + lines[closes[j]])
            j = j + 1
        }
    }
    return false
}

fn _new_entry(root: string, name: string, header: string) {
    _ensure_files(root, name)
    let log = _log_path(root, name)
    let ts = _iso_ts()
    let body = _read_file_safe(log)
    let lines = body.split("\n")
    let h = _first_header(lines)
    if h < 0 {
        write_file(log, body + "\n## " + ts + " — " + header + "\n\n")
        return
    }
    let mut out = []
    let mut i = 0
    while i < len(lines) {
        if i == h {
            out.push("## " + ts + " — " + header)
            out.push("")
            out.push("")
        }
        out.push(lines[i])
        i = i + 1
    }
    write_file(log, out.join("\n"))
}

// Flip a log task `- [ ] <term>` -> `- [x]`. Same word-boundary +
// disambiguation policy as _flip_goal (see comment there). Called only when
// _flip_goal returned false (snapshot didn't match), so a closed-hint surfaced
// there has already been printed.
fn _flip_done(root: string, name: string, term: string) {
    _ensure_files(root, name)
    let log = _log_path(root, name)
    let body = _read_file_safe(log)
    let lines = body.split("\n")
    let mut opens = []
    let mut closes = []
    let mut i = 0
    while i < len(lines) {
        let ln = lines[i]
        if _starts_with(ln, "- [ ] ") && _word_match(ln, term) { opens.push(i) }
        else if _starts_with(ln, "- [x] ") && _word_match(ln, term) { closes.push(i) }
        i = i + 1
    }
    if len(opens) == 1 {
        let idx = opens[0]
        let old = lines[idx]
        lines[idx] = "- [x] " + old.substring(6, len(old))
        write_file(log, lines.join("\n"))
        println("flipped: " + term)
        return
    }
    if len(opens) >= 2 {
        eprintln("domain: ambiguous — '" + term + "' matches " + to_string(len(opens)) + " open tasks in " + name + ".log.md:")
        let mut j = 0
        while j < len(opens) {
            eprintln("  " + lines[opens[j]])
            j = j + 1
        }
        eprintln("hint: use a longer / more specific term")
        exit(1)
    }
    if len(closes) > 0 {
        eprintln("domain: '" + term + "' already closed in " + name + ".log.md:")
        let mut j = 0
        while j < len(closes) {
            eprintln("  " + lines[closes[j]])
            j = j + 1
        }
        exit(1)
    }
    eprintln("domain: no pending task matching '" + term + "' (checked snapshot + log)")
    exit(1)
}

fn _env(name: string) -> string {
    let r = exec_with_status("printenv " + name)
    if r[1] != 0 { return "" }
    return _trim(to_string(r[0]))
}

// active-domain pointer store: $HOME/.claude/domain-active.tsv
// One `<root>\t<sid>\t<NAME>` line per (project root × terminal session) — two
// claude sessions in the same repo each get an independent active domain.
//
// Cross-session persistence (0.8.3): a fresh session has a NEW <sid>, so the
// exact (root, sid) row never matches → pre-0.8.3 it fell straight back to the
// project-basename default, FORGETTING the repo's last-set domain every new
// session. `_get_active` now falls back to the most-recent ANY-session row for
// the same root when no exact (root, sid) row exists. Net effect: a session
// that explicitly `set`s a domain keeps its own (independence preserved), while
// a fresh session inherits the repo's last-set domain (persistence restored).
//
// `<sid>` fallback chain (most-specific → least):
//   1. CLAUDE_CODE_SESSION_ID env (UUID, per-Claude-Code-session — the dominant
//      case, since Claude Code's Bash tool runs commands without a tty)
//   2. `tty` command (controlling terminal path like `/dev/ttys003`, for direct
//      shell invocation outside Claude Code)
//   3. `NOTTY` (cron / non-interactive fallback — shared across such callers)
//
// Pre-0.7.7 lines used a 2-field key (`<root>\t<NAME>`) and are auto-cleaned
// on next `_set_active` for the same root (see below); `_get_active` ignores
// them naturally because its prefix is `<root>\t<sid>\t` (three fields).
fn _session_id() -> string {
    let cid = _env("CLAUDE_CODE_SESSION_ID")
    if cid != "" { return cid }
    let r = exec_with_status("tty 2>/dev/null")
    if r[1] == 0 {
        let t = _trim(to_string(r[0]))
        if t != "" { return t }
    }
    return "NOTTY"
}

fn _active_store() -> string {
    let home = _env("HOME")
    if home == "" { return ".domain-active.tsv" }
    return home + "/.claude/domain-active.tsv"
}

fn _active_key(root: string) -> string {
    return root + "\t" + _session_id()
}

// True iff `ln` is a pre-0.7.7 2-field row (`<root>\t<NAME>`, exactly one tab)
// for `root` — used to auto-clean legacy rows during `_set_active`.
fn _is_legacy_row_for(ln: string, root: string) -> bool {
    let pfx = root + "\t"
    if !_starts_with(ln, pfx) { return false }
    let rest = ln.substring(len(pfx), len(ln))
    // legacy row has NO further tab; new format has at least one more (sid\tname)
    return rest.index_of("\t") < 0
}

fn _set_active(root: string, name: string) {
    let path = _active_store()
    let home = _env("HOME")
    if home != "" { let _mk = exec_with_status("mkdir -p " + home + "/.claude") }
    let body = _read_file_safe(path)
    let lines = body.split("\n")
    let key = _active_key(root)
    let pfx = key + "\t"
    let mut out = []
    let mut i = 0
    while i < len(lines) {
        let ln = lines[i]
        if ln == "" { i = i + 1; continue }
        // drop the current (root, sid) slot — about to be rewritten
        if _starts_with(ln, pfx) { i = i + 1; continue }
        // drop pre-0.7.7 2-field rows for the same root (natural migration)
        if _is_legacy_row_for(ln, root) { i = i + 1; continue }
        out.push(ln)
        i = i + 1
    }
    out.push(pfx + name)
    try { write_file(path, out.join("\n") + "\n") } catch e { }
}

// Resolve the active domain for `root` with a two-tier policy:
//   1. exact (root, this-session) row → return it (this session's own choice).
//   2. else the most-recent ANY-session row for `root` → cross-session default
//      (later rows win; `_set_active` re-pushes the touched row to the end, so
//      the last `<root>\t…` line in the file is the most recently set).
// Legacy pre-0.7.7 2-field rows (`<root>\t<NAME>`, no second tab) are ignored
// by the fallback — `rest` has no tab to split, so they never set `fallback`.
// The trailing `\t` on both prefixes is a field boundary: `…/sidecar\t` does
// not match `…/sidecar-x\t…`, so a root that is a string-prefix of another
// root never bleeds across.
fn _get_active(root: string) -> string {
    let body = _read_file_safe(_active_store())
    let lines = body.split("\n")
    let exact = _active_key(root) + "\t"
    let rootpfx = root + "\t"
    let mut fallback = ""
    let mut i = 0
    while i < len(lines) {
        let ln = lines[i]
        if _starts_with(ln, exact) { return ln.substring(len(exact), len(ln)) }
        if _starts_with(ln, rootpfx) {
            let rest = ln.substring(len(rootpfx), len(ln))
            let tab = rest.index_of("\t")
            if tab >= 0 { fallback = rest.substring(tab + 1, len(rest)) }
        }
        i = i + 1
    }
    return fallback
}

// [done, todo] checkbox counts across the SNAPSHOT (<NAME>.md) — the final-goal
// board (RTSC.md pattern: milestones live in the snapshot, not the log). Progress
// = goal completion, so it doesn't drift as the append-only log grows.
fn _count_tasks(root: string, name: string) -> array {
    let body = _read_file_safe(_snap_path(root, name))
    let lines = body.split("\n")
    let mut done = 0
    let mut todo = 0
    let mut i = 0
    while i < len(lines) {
        let ln = lines[i]
        if _starts_with(ln, "- [x] ") { done = done + 1 }
        else if _starts_with(ln, "- [ ] ") { todo = todo + 1 }
        i = i + 1
    }
    return [done, todo]
}

// g56 progress bar: `▓▓▓░░ NN% · done/total` (10-cell)
fn _progress_bar(done: int, total: int) -> string {
    if total == 0 { return "░░░░░░░░░░ 0% · 0/0 (no tasks yet — /domain todo <text>)" }
    let pct = (done * 100) / total
    let filled = (done * 10) / total
    let mut bar = ""
    let mut i = 0
    while i < 10 {
        if i < filled { bar = bar + "▓" } else { bar = bar + "░" }
        i = i + 1
    }
    return bar + " " + to_string(pct) + "% · " + to_string(done) + "/" + to_string(total)
}

// the snapshot's final-goal declaration: a single `@goal: <text>` line (the
// domain's north star — distinct from `- [ ]` milestones, which are progress
// units). Empty string when none declared.
fn _get_goal(root: string, name: string) -> string {
    let body = _read_file_safe(_snap_path(root, name))
    let lines = body.split("\n")
    let mut i = 0
    while i < len(lines) {
        if _starts_with(lines[i], "@goal:") {
            return _trim(lines[i].substring(6, len(lines[i])))
        }
        i = i + 1
    }
    return ""
}

// set/replace the `@goal:` line — inserted right after the first `# ` heading.
fn _set_goal(root: string, name: string, text: string) {
    _ensure_files(root, name)
    let snap = _snap_path(root, name)
    let body = _read_file_safe(snap)
    let lines = body.split("\n")
    let mut out = []
    let mut placed = false
    let mut i = 0
    while i < len(lines) {
        let ln = lines[i]
        if _starts_with(ln, "@goal:") {
            if !placed { out.push("@goal: " + text); placed = true }
        } else {
            out.push(ln)
            if !placed && _starts_with(ln, "# ") {
                out.push("")
                out.push("@goal: " + text)
                placed = true
            }
        }
        i = i + 1
    }
    if !placed { out.push("@goal: " + text) }
    write_file(snap, out.join("\n"))
}

// lint a domain's snapshot: a final goal (`@goal:`) AND ≥1 milestone (`- [ ]`/
// `- [x]`) are both required. Warn-only (stderr), never blocks.
fn _lint(root: string, name: string) {
    if _get_goal(root, name) == "" {
        eprintln("⚠ lint: no `@goal:` in " + name + ".md — declare the final goal: /domain goal <text>")
    }
    let c = _count_tasks(root, name)
    if c[0] + c[1] == 0 {
        eprintln("⚠ lint: no milestones (`- [ ]`) in " + name + ".md — add: /domain milestone <text>")
    }
}

fn _show(root: string, name: string) {
    _ensure_files(root, name)
    let snap = _snap_path(root, name)
    let log = _log_path(root, name)
    let goal = _get_goal(root, name)
    let c = _count_tasks(root, name)
    // progress is reported ONLY when an `@goal:` is declared — the goal is
    // the frame of reference. No goal → no progress line (just the lint).
    if goal == "" {
        println("◆ active domain: " + name)
    } else {
        println("◆ active domain: " + name + "   🎯 " + goal)
        println("진행 " + _progress_bar(c[0], c[0] + c[1]))
    }
    _lint(root, name)
    println("═══ " + snap + " ═══")
    print(_read_file_safe(snap))
    println("")
    println("═══ " + log + " ═══")
    print(_read_file_safe(log))
}

fn _usage() {
    eprintln("usage:")
    eprintln("  domain                      Show active domain + @goal + progress bar (+ lint)")
    eprintln("  domain init <NAME>          Scaffold <NAME>.md + <NAME>.log.md (NAME = UPPERCASE-start + UPPERCASE/digits/`-`/`+`; `+` for meta-domain: RTSC+HTS)")
    eprintln("  domain set <NAME>           Select NAME as the session's active domain")
    eprintln("  domain <NAME>               (shortcut for `set <NAME>`)")
    eprintln("  domain goal <text>          Declare the FINAL goal — sets the snapshot's `@goal:` line")
    eprintln("  domain milestone <text>     Add a `- [ ]` progress milestone (alias: ms) — counts toward progress")
    eprintln("  domain done <match>         Flip a milestone `- [ ]` -> `- [x]`, else flip a log task")
    eprintln("  domain todo <task-text>     Append `- [ ] <task-text>` to the log")
    eprintln("  domain <task-text>          Append `- [x] <task-text>` to the log")
    eprintln("  domain new <header>         Start a new log entry")
}

fn main() {
    let rr = exec_with_status("git rev-parse --show-toplevel 2>/dev/null")
    let mut root = ""
    if rr[1] == 0 { root = _trim(to_string(rr[0])) }
    if root == "" { root = _trim(to_string(exec("pwd"))) }
    let def_name = _domain_name(_basename(root))
    let active = _get_active(root)
    let eff_name = if active != "" { active } else { def_name }

    let raw = argv()
    let mut args = []
    let mut ai = 1
    while ai < len(raw) { args.push(raw[ai]); ai = ai + 1 }
    let argc = len(args)

    if argc == 0 {
        _show(root, eff_name)
        return
    }
    let v = args[0]
    if v == "-h" || v == "--help" {
        _usage()
        return
    }

    // `init <NAME>` — scaffold <NAME>.md + <NAME>.log.md (does not change the
    // session's active domain). NAME uses `-` as the word-separator (`_` is
    // rejected) and `+` for meta-domain composition (e.g. `RTSC+HTS`).
    if v == "init" {
        if argc < 2 || !_is_name(args[1]) {
            eprintln("usage: domain init <NAME>   (NAME = UPPERCASE-start + UPPERCASE/digits/`-`/`+`; `+` for meta-domain, e.g. RTSC+HTS)")
            exit(1)
        }
        _ensure_files(root, args[1])
        println("✓ initialized · " + _snap_path(root, args[1]) + " + " + args[1] + ".log.md")
        return
    }

    // `set <NAME>` — select the session's active domain (subcommand form of
    // the bare `<NAME>` shortcut). Scaffolds files via show.
    if v == "set" {
        if argc < 2 || !_is_name(args[1]) {
            eprintln("usage: domain set <NAME>   (NAME = UPPERCASE-start + UPPERCASE/digits/`-`/`+`)")
            exit(1)
        }
        _set_active(root, args[1])
        _show(root, args[1])
        return
    }

    // `goal <text>` — declare the domain's FINAL goal: a single `@goal:` line
    // in the snapshot (replaces any existing). The north star — distinct from
    // `- [ ]` milestones, which are the progress units.
    if v == "goal" {
        if argc < 2 {
            eprintln("usage: domain goal <text>   (sets the @goal: final goal)")
            exit(1)
        }
        let g = _join_from(args, 1)
        _set_goal(root, eff_name, g)
        println("🎯 goal set · " + eff_name + ": " + g)
        return
    }

    // `milestone <text>` (alias `ms`) — add a `- [ ]` progress milestone to the
    // snapshot (counts toward the progress bar). `done <match>` flips it to [x].
    if v == "milestone" || v == "ms" {
        if argc < 2 {
            eprintln("usage: domain milestone <text>")
            exit(1)
        }
        _append_goal(root, eff_name, _join_from(args, 1))
        let c = _count_tasks(root, eff_name)
        println("milestone + · " + eff_name + "   진행 " + _progress_bar(c[0], c[0] + c[1]))
        return
    }

    if v == "todo" || v == "done" || v == "new" {
        if argc < 2 {
            _usage()
            exit(1)
        }
        let mut name = eff_name
        let mut from = 1
        if _is_name(args[1]) && argc >= 3 {
            name = args[1]
            from = 2
        }
        let text = _join_from(args, from)
        if v == "todo" { _append_task(root, name, " ", text) }
        else if v == "done" {
            // a goal (snapshot) completion takes priority over a log flip,
            // so `done <match>` advances the final-goal progress bar.
            if !_flip_goal(root, name, text) { _flip_done(root, name, text) }
        }
        else { _new_entry(root, name, text) }
        return
    }

    if v == "show" {
        let mut name = eff_name
        if argc >= 2 && _is_name(args[1]) { name = args[1] }
        _show(root, name)
        return
    }

    // `/domain <NAME>` alone → select that domain as the session's active
    // domain (subsequent todo/done/append default to it) + show with progress.
    if _is_name(args[0]) && argc == 1 {
        _set_active(root, args[0])
        _show(root, args[0])
        return
    }
    if _is_name(args[0]) && argc >= 2 {
        _append_task(root, args[0], "x", _join_from(args, 1))
        return
    }
    _append_task(root, eff_name, "x", _join_from(args, 0))
}
