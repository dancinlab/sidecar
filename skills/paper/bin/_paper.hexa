// _paper.hexa — arxiv-style LaTeX paper scaffolder (paper plugin).
//
// Verbs (0.10 PAPER.tape roster):
//   list [--sync] | set <slug> | show [<slug>]
//   goal <text> | title <text> | ms <text> | done <match> | todo <text>
//   new <slug> | sample <name> [<dest>] | samples (= old `list`)
//   fig <size> <prompt> <out.png> | compile [dir] | lint [dir]
//   companion {init|sync} | monograph-init <slug> [N] | fill <letter>
//   outline [dir] | pipeline ... | atoms <domain> | verify-block ...
//   bib add <id> | pr-roll <repo> <since> | arxiv-prep [<dir>] | help
//
// PAPER.tape (repo root) is the roster — `@paper <slug> := "<relpath>"` rows
// map a paper slug to its dir. Each paper dir carries a sister PAPER.md
// (snapshot = `@title:` · `@goal:` · `- [ ]` milestones) + PAPER.log.md
// (append-only log). Progress / title are read LIVE from PAPER.md — the
// roster never churns on a milestone flip. Mirrors the DOMAINS.tape pattern.
//
// usage: hexa run _paper.hexa --root <plugin-root> <verb> [args...]
//
// `--root` is supplied by the command; $CLAUDE_PLUGIN_ROOT is correct
// for paper's own invocation, but is passed explicitly so the script
// stays callable from any cwd.

fn _trim(s: string) -> string {
    let n = len(s)
    let mut a = 0
    while a < n {
        let c = s[a]
        if c != " " && c != "\t" && c != "\r" && c != "\n" { break }
        a = a + 1
    }
    let mut b = n
    while b > a {
        let c = s[b - 1]
        if c != " " && c != "\t" && c != "\r" && c != "\n" { break }
        b = b - 1
    }
    return s.substring(a, b)
}

fn _shq(s: string) -> string {
    let mut out = "'"
    let n = len(s)
    let mut i = 0
    while i < n {
        let c = s[i]
        if c == "'" { out = out + "'\\''" }
        else { out = out + c }
        i = i + 1
    }
    return out + "'"
}

fn _dirname(p: string) -> string {
    let i = p.last_index_of("/")
    if i < 0 { return "." }
    if i == 0 { return "/" }
    return p.substring(0, i)
}

fn _basename(p: string) -> string {
    let mut q = p
    if len(q) > 1 && q[len(q) - 1] == "/" { q = q.substring(0, len(q) - 1) }
    let i = q.last_index_of("/")
    if i < 0 { return q }
    return q.substring(i + 1, len(q))
}

fn _dir_exists(path: string) -> bool {
    let r = exec_with_status("test -d " + _shq(path))
    return r[1] == 0
}

fn _path_exists(path: string) -> bool {
    let r = exec_with_status("test -e " + _shq(path))
    return r[1] == 0
}

fn _has_cmd(name: string) -> bool {
    let r = exec_with_status("command -v " + _shq(name) + " >/dev/null 2>&1")
    return r[1] == 0
}

// reject a <slug> that is not a simple name (slash / leading dot / empty)
fn _bad_slug(slug: string) -> bool {
    if slug == "" { return true }
    if slug.index_of("/") >= 0 { return true }
    if slug[0] == "." { return true }
    return false
}

// ═══════════════════════════════════════════════════════════════════
// PAPER.tape roster — slug → dir map (mirrors DOMAINS.tape pattern).
// Progress / title stay DERIVED from each paper's PAPER.md so the
// checked-in roster never churns on a milestone flip.
// ═══════════════════════════════════════════════════════════════════

fn _starts_with(s: string, prefix: string) -> bool {
    if len(prefix) > len(s) { return false }
    return s.substring(0, len(prefix)) == prefix
}

fn _ends_with(s: string, suf: string) -> bool {
    if len(suf) > len(s) { return false }
    return s.substring(len(s) - len(suf), len(s)) == suf
}

fn _read_file_safe(path: string) -> string {
    let mut out = ""
    try { out = to_string(read_file(path)) }
    catch e { out = "" }
    return out
}

fn _git_root() -> string {
    let r = exec_with_status("git rev-parse --show-toplevel 2>/dev/null")
    if r[1] == 0 {
        let t = _trim(to_string(r[0]))
        if t != "" { return t }
    }
    return _trim(to_string(exec("pwd")))
}

fn _iso_ts() -> string {
    return _trim(to_string(exec("date -u +%Y-%m-%dT%H:%M")))
}

// resolve a roster relpath to absolute: leading `/` = absolute; strip `./`;
// otherwise prefix the repo root.
fn _abs(repo: string, p: string) -> string {
    if _starts_with(p, "/") { return p }
    let mut q = p
    if _starts_with(q, "./") { q = q.substring(2, len(q)) }
    return repo + "/" + q
}

// ─── roster I/O ──────────────────────────────────────────────────
fn _roster_path(repo: string) -> string {
    return repo + "/PAPER.tape"
}

// parse PAPER.tape into [[slug, relpath], ...]; `@paper <slug> := "<path>"`.
fn _roster_entries(repo: string) -> array {
    let body = _read_file_safe(_roster_path(repo))
    let mut out = []
    if body == "" { return out }
    let lines = body.split("\n")
    let mut i = 0
    while i < len(lines) {
        let ln = _trim(lines[i])
        i = i + 1
        if !_starts_with(ln, "@paper ") { continue }
        let rest = _trim(ln.substring(7, len(ln)))
        let sp = rest.index_of(" ")
        let slug = if sp < 0 { rest } else { rest.substring(0, sp) }
        let q1 = ln.index_of("\"")
        if q1 < 0 { continue }
        let after = ln.substring(q1 + 1, len(ln))
        let q2 = after.index_of("\"")
        if q2 < 0 { continue }
        let path = after.substring(0, q2)
        if slug != "" && path != "" { out.push([slug, path]) }
    }
    return out
}

fn _roster_lookup(repo: string, slug: string) -> string {
    let es = _roster_entries(repo)
    let mut i = 0
    while i < len(es) {
        if es[i][0] == slug { return es[i][1] }
        i = i + 1
    }
    return ""
}

fn _roster_has(repo: string, slug: string) -> bool {
    return _roster_lookup(repo, slug) != ""
}

fn _roster_append(repo: string, slug: string, relpath: string) {
    if _roster_has(repo, slug) { return }
    let rp = _roster_path(repo)
    let mut body = _read_file_safe(rp)
    if body == "" {
        body = "# PAPER.tape — paper roster (slug → dir; progress/title stay derived, not stored here)\n@V := \"papers\" :: index\n\n"
    } else {
        if body.substring(len(body) - 1, len(body)) != "\n" { body = body + "\n" }
    }
    write_file(rp, body + "@paper " + slug + " := \"" + relpath + "\"\n")
}

// ─── PAPER.md / PAPER.log.md path resolution ─────────────────────
// roster path wins (paper can live at any relpath); else fall back to
// `<repo>/<slug>/PAPER.md` so a slug just-scaffolded by `new`/`sample`
// resolves correctly before the roster row is written.
fn _paper_dir(repo: string, slug: string) -> string {
    let rp = _roster_lookup(repo, slug)
    if rp == "" { return repo + "/" + slug }
    return _abs(repo, rp)
}

fn _paper_md(repo: string, slug: string) -> string {
    return _paper_dir(repo, slug) + "/PAPER.md"
}

fn _paper_log(repo: string, slug: string) -> string {
    return _paper_dir(repo, slug) + "/PAPER.log.md"
}

fn _scaffold_paper_md(path: string, slug: string) {
    let body = "# " + slug + " — paper status\n"
        + "\n"
        + "@title: 📄 " + slug + "\n"
        + "@goal: TODO — declare paper goal in one line (one outcome, one sentence)\n"
        + "\n"
        + "- [ ] draft v1\n"
        + "- [ ] figures complete (≥1 fal.ai-generated)\n"
        + "- [ ] references ≥10 (`/paper bib add <doi-or-arxiv>`)\n"
        + "- [ ] lint pass (`/paper lint .`)\n"
        + "- [ ] compile clean (`/paper compile .`)\n"
        + "- [ ] arxiv submit ready (`/paper arxiv-prep .`)\n"
    write_file(path, body)
}

fn _scaffold_paper_log(path: string, slug: string) {
    let body = "# " + slug + " — paper log\n"
        + "\n"
        + "Append-only history sister of `PAPER.md`. Each entry starts with `## <ISO timestamp> — <header>` (newest on top); body = `- [x]` (done) / `- [ ]` (pending) checkbox tasks.\n"
        + "\n"
    write_file(path, body)
}

fn _ensure_paper_files(repo: string, slug: string) {
    let md = _paper_md(repo, slug)
    let lg = _paper_log(repo, slug)
    let _ = exec_with_status("mkdir -p " + _shq(_dirname(md)))
    if !_path_exists(md) { _scaffold_paper_md(md, slug) }
    if !_path_exists(lg) { _scaffold_paper_log(lg, slug) }
}

// register a freshly-scaffolded paper dir into PAPER.tape + drop PAPER.md/log.
// Called from `_cmd_new` / `_cmd_sample` / `_cmd_monograph_init` so every paper
// joins the roster automatically.
fn _register_paper(repo: string, slug: string) {
    _roster_append(repo, slug, "./" + slug)
    _ensure_paper_files(repo, slug)
}

// ─── active paper store (~/.claude/paper-active.tsv) ─────────────
// One `<repo>\t<sid>\t<slug>` line per (repo × session). New session
// inherits the repo's last-set paper (most-recent row for the repo).
fn _session_id() -> string {
    let cid = env_var("CLAUDE_CODE_SESSION_ID")
    if cid != "" { return cid }
    let r = exec_with_status("tty 2>/dev/null")
    if r[1] == 0 {
        let t = _trim(to_string(r[0]))
        if t != "" { return t }
    }
    return "NOTTY"
}

fn _active_store() -> string {
    let home = env_var("HOME")
    if home == "" { return ".paper-active.tsv" }
    return home + "/.claude/paper-active.tsv"
}

fn _active_key(repo: string) -> string {
    return repo + "\t" + _session_id()
}

fn _set_active(repo: string, slug: string) {
    let path = _active_store()
    let home = env_var("HOME")
    if home != "" { let _ = exec_with_status("mkdir -p " + _shq(home + "/.claude")) }
    let body = _read_file_safe(path)
    let lines = body.split("\n")
    let key = _active_key(repo)
    let pfx = key + "\t"
    let mut out = []
    let mut i = 0
    while i < len(lines) {
        let ln = lines[i]
        if ln == "" { i = i + 1; continue }
        if _starts_with(ln, pfx) { i = i + 1; continue }
        out.push(ln)
        i = i + 1
    }
    out.push(pfx + slug)
    try { write_file(path, out.join("\n") + "\n") } catch e { }
}

fn _get_active(repo: string) -> string {
    let body = _read_file_safe(_active_store())
    let lines = body.split("\n")
    let exact = _active_key(repo) + "\t"
    let rootpfx = repo + "\t"
    let mut fallback = ""
    let mut i = 0
    while i < len(lines) {
        let ln = lines[i]
        if _starts_with(ln, exact) { return ln.substring(len(exact), len(ln)) }
        if _starts_with(ln, rootpfx) {
            let rest = ln.substring(len(rootpfx), len(ln))
            let tab = rest.index_of("\t")
            if tab >= 0 { fallback = rest.substring(tab + 1, len(rest)) }
        }
        i = i + 1
    }
    return fallback
}

// ─── PAPER.md derived metrics + mutators ─────────────────────────
fn _count_tasks(repo: string, slug: string) -> array {
    let body = _read_file_safe(_paper_md(repo, slug))
    let lines = body.split("\n")
    let mut done = 0
    let mut todo = 0
    let mut i = 0
    while i < len(lines) {
        let ln = lines[i]
        if _starts_with(ln, "- [x] ") { done = done + 1 }
        else if _starts_with(ln, "- [ ] ") { todo = todo + 1 }
        i = i + 1
    }
    return [done, todo]
}

fn _progress_bar(done: int, total: int) -> string {
    if total == 0 { return "░░░░░░░░░░ 0% · 0/0 (no milestones yet — /paper ms <text>)" }
    let pct = (done * 100) / total
    let filled = (done * 10) / total
    let mut bar = ""
    let mut i = 0
    while i < 10 {
        if i < filled { bar = bar + "▓" } else { bar = bar + "░" }
        i = i + 1
    }
    return bar + " " + to_string(pct) + "% · " + to_string(done) + "/" + to_string(total)
}

fn _get_goal(repo: string, slug: string) -> string {
    let body = _read_file_safe(_paper_md(repo, slug))
    let lines = body.split("\n")
    let mut i = 0
    while i < len(lines) {
        if _starts_with(lines[i], "@goal:") {
            return _trim(lines[i].substring(6, len(lines[i])))
        }
        i = i + 1
    }
    return ""
}

fn _get_title(repo: string, slug: string) -> string {
    let body = _read_file_safe(_paper_md(repo, slug))
    let lines = body.split("\n")
    let mut i = 0
    while i < len(lines) {
        if _starts_with(lines[i], "@title:") {
            return _trim(lines[i].substring(7, len(lines[i])))
        }
        i = i + 1
    }
    return ""
}

fn _set_goal(repo: string, slug: string, text: string) {
    _ensure_paper_files(repo, slug)
    let md = _paper_md(repo, slug)
    let body = _read_file_safe(md)
    let lines = body.split("\n")
    let mut out = []
    let mut placed = false
    let mut i = 0
    while i < len(lines) {
        let ln = lines[i]
        if _starts_with(ln, "@goal:") {
            if !placed { out.push("@goal: " + text); placed = true }
        } else {
            out.push(ln)
            if !placed && _starts_with(ln, "# ") {
                out.push("")
                out.push("@goal: " + text)
                placed = true
            }
        }
        i = i + 1
    }
    if !placed { out.push("@goal: " + text) }
    write_file(md, out.join("\n"))
}

fn _set_title(repo: string, slug: string, text: string) {
    _ensure_paper_files(repo, slug)
    let md = _paper_md(repo, slug)
    let body = _read_file_safe(md)
    let lines = body.split("\n")
    let mut i = 0
    while i < len(lines) {
        if _starts_with(lines[i], "@title:") {
            lines[i] = "@title: " + text
            write_file(md, lines.join("\n"))
            return
        }
        i = i + 1
    }
    let mut out = []
    let mut placed = false
    i = 0
    while i < len(lines) {
        out.push(lines[i])
        if !placed && _starts_with(lines[i], "# ") {
            out.push("@title: " + text)
            placed = true
        }
        i = i + 1
    }
    if !placed { out.push("@title: " + text) }
    write_file(md, out.join("\n"))
}

fn _append_milestone(repo: string, slug: string, text: string) {
    _ensure_paper_files(repo, slug)
    let md = _paper_md(repo, slug)
    let body = _read_file_safe(md)
    let mut sep = "\n"
    if len(body) > 0 && body.substring(len(body) - 1, len(body)) == "\n" { sep = "" }
    write_file(md, body + sep + "- [ ] " + text + "\n")
}

// flip a snapshot milestone `- [ ] <term>` -> `- [x]`. Substring match;
// 2+ open hits → list candidates + exit 1 (force a more specific term).
fn _flip_done(repo: string, slug: string, term: string) -> bool {
    _ensure_paper_files(repo, slug)
    let md = _paper_md(repo, slug)
    let body = _read_file_safe(md)
    let lines = body.split("\n")
    let mut opens = []
    let mut closes = []
    let mut i = 0
    while i < len(lines) {
        let ln = lines[i]
        if _starts_with(ln, "- [ ] ") && ln.index_of(term) >= 0 { opens.push(i) }
        else if _starts_with(ln, "- [x] ") && ln.index_of(term) >= 0 { closes.push(i) }
        i = i + 1
    }
    if len(opens) == 1 {
        let idx = opens[0]
        let old = lines[idx]
        lines[idx] = "- [x] " + old.substring(6, len(old))
        write_file(md, lines.join("\n"))
        return true
    }
    if len(opens) >= 2 {
        eprintln("paper: ambiguous — '" + term + "' matches " + to_string(len(opens)) + " open milestones in PAPER.md:")
        let mut j = 0
        while j < len(opens) {
            eprintln("  " + lines[opens[j]])
            j = j + 1
        }
        eprintln("hint: use a longer / more specific term")
        exit(1)
    }
    if len(closes) > 0 {
        eprintln("paper: '" + term + "' already closed in PAPER.md:")
        let mut j = 0
        while j < len(closes) {
            eprintln("  " + lines[closes[j]])
            j = j + 1
        }
    }
    return false
}

fn _append_todo(repo: string, slug: string, text: string) {
    _ensure_paper_files(repo, slug)
    let lg = _paper_log(repo, slug)
    let ts = _iso_ts()
    let body = _read_file_safe(lg)
    write_file(lg, body + "\n## " + ts + " — log\n\n- [ ] " + text + "\n")
}

// ─── disk scan (for list --sync) ─────────────────────────────────
fn _disk_papers(repo: string) -> array {
    let raw = to_string(exec("find " + _shq(repo) + " -maxdepth 3 -name PAPER.md -not -path '*/node_modules/*' 2>/dev/null | sort"))
    let lines = raw.split("\n")
    let pfx = repo + "/"
    let mut out = []
    let mut i = 0
    while i < len(lines) {
        let p = _trim(lines[i])
        i = i + 1
        if p == "" { continue }
        let mut rel = p
        if _starts_with(p, pfx) { rel = p.substring(len(pfx), len(p)) }
        if _ends_with(rel, "/PAPER.md") {
            let dir = rel.substring(0, len(rel) - 9)
            let slug = _basename(dir)
            if slug != "" { out.push([slug, "./" + dir]) }
        }
    }
    return out
}

// ─── list rendering ──────────────────────────────────────────────
fn _rpad(s: string, w: int) -> string {
    let mut out = s
    while len(out) < w { out = out + " " }
    return out
}

fn _lpad3(n: int) -> string {
    let mut s = to_string(n)
    while len(s) < 3 { s = " " + s }
    return s
}

fn _bar_compact(done: int, total: int) -> string {
    let mut pct = 0
    let mut filled = 0
    if total > 0 {
        pct = (done * 100) / total
        filled = (done * 10) / total
    }
    let mut bar = ""
    let mut i = 0
    while i < 10 {
        if i < filled { bar = bar + "▓" } else { bar = bar + "░" }
        i = i + 1
    }
    return bar + " " + _lpad3(pct) + "%"
}

fn _truncate(s: string, max: int) -> string {
    if len(s) <= max { return s }
    let mut cut = max
    while cut > 0 {
        let b = char_code(s, cut)
        if b < 128 || b >= 192 { break }
        cut = cut - 1
    }
    return s.substring(0, cut) + "…"
}

fn _list_row(repo: string, slug: string, relpath: string, active: string) -> int {
    let mark = if slug == active { "★ " } else { "  " }
    let md = _abs(repo, relpath) + "/PAPER.md"
    if !_path_exists(md) {
        println(mark + _rpad(slug, 22) + "  👻 PAPER.md 없음 → " + relpath)
        return 1
    }
    let body = _read_file_safe(md)
    let lines = body.split("\n")
    let mut done = 0
    let mut todo = 0
    let mut title = ""
    let mut i = 0
    while i < len(lines) {
        let ln = lines[i]
        if _starts_with(ln, "- [x] ") { done = done + 1 }
        else if _starts_with(ln, "- [ ] ") { todo = todo + 1 }
        else if title == "" && _starts_with(ln, "@title:") { title = _trim(ln.substring(7, len(ln))) }
        i = i + 1
    }
    let tail = if title != "" { _truncate(title, 50) } else { "(no @title)" }
    println(mark + _rpad(slug, 22) + " " + _bar_compact(done, done + todo) + "  " + _rpad(relpath, 24) + " " + tail)
    return 0
}

fn _cmd_paper_list(repo: string) {
    let active = _get_active(repo)
    let es = _roster_entries(repo)
    let total = len(es)
    if total == 0 {
        let disk = _disk_papers(repo)
        if len(disk) == 0 {
            println("◆ paper roster 비어있음 — `/paper new <slug>` · `/paper sample <name>` · `/paper monograph-init <slug>` 로 시작")
            return
        }
        println("◆ PAPER.tape 없음 · 디스크엔 " + to_string(len(disk)) + "개 PAPER.md")
        eprintln("ℹ `/paper list --sync` 로 호적부 부트스트랩")
        return
    }
    println("◆ papers: " + to_string(total) + "개  (★ = 활성 · PAPER.tape)")
    println("")
    let mut ghosts = 0
    let mut j = 0
    while j < total {
        if es[j][0] == active { ghosts = ghosts + _list_row(repo, es[j][0], es[j][1], active) }
        j = j + 1
    }
    j = 0
    while j < total {
        if es[j][0] != active { ghosts = ghosts + _list_row(repo, es[j][0], es[j][1], active) }
        j = j + 1
    }
    let disk = _disk_papers(repo)
    let mut unreg = []
    let mut k = 0
    while k < len(disk) {
        if !_roster_has(repo, disk[k][0]) { unreg.push(disk[k][0]) }
        k = k + 1
    }
    if len(unreg) > 0 {
        eprintln("⚠ 미등록(disk엔 있으나 호적부에 없음): " + unreg.join(" · ") + "  → /paper list --sync")
    }
    if ghosts > 0 {
        eprintln("⚠ 유령 " + to_string(ghosts) + "건(호적부에 있으나 PAPER.md 없음) — 경로 수정 or 행 삭제")
    }
}

fn _cmd_paper_list_sync(repo: string) {
    let disk = _disk_papers(repo)
    let mut added = []
    let mut i = 0
    while i < len(disk) {
        let slug = disk[i][0]
        let rel = disk[i][1]
        if !_roster_has(repo, slug) {
            _roster_append(repo, slug, rel)
            added.push(slug)
        }
        i = i + 1
    }
    if len(added) == 0 {
        println("✓ PAPER.tape 이미 최신 (스캔된 PAPER.md 폴더 전부 등록됨)")
    } else {
        println("✓ PAPER.tape 동기화 · +" + to_string(len(added)) + ": " + added.join(" · "))
    }
    println("")
    _cmd_paper_list(repo)
}

// ─── show / set / verb handlers ──────────────────────────────────
fn _cmd_paper_show(repo: string, slug: string) {
    _ensure_paper_files(repo, slug)
    let md = _paper_md(repo, slug)
    let lg = _paper_log(repo, slug)
    let goal = _get_goal(repo, slug)
    let title = _get_title(repo, slug)
    let c = _count_tasks(repo, slug)
    let label = if title != "" { title } else { "active paper: " + slug }
    if goal == "" {
        println("◆ " + label)
    } else {
        println("◆ " + label + "   🎯 " + goal)
        println("진행 " + _progress_bar(c[0], c[0] + c[1]))
    }
    if goal == "" { eprintln("⚠ lint: `@goal:` 없음 — /paper goal <text>") }
    if c[0] + c[1] == 0 { eprintln("⚠ lint: 밀스톤(`- [ ]`) 없음 — /paper ms <text>") }
    println("═══ " + md + " ═══")
    print(_read_file_safe(md))
    println("")
    println("═══ " + lg + " ═══")
    print(_read_file_safe(lg))
}

fn _cmd_paper_set(repo: string, slug: string) {
    if _bad_slug(slug) {
        eprintln("paper set: <slug> must be a simple name (no slashes / no leading dot)")
        exit(1)
    }
    _set_active(repo, slug)
    // self-heal: register if dir already exists but roster missing
    if !_roster_has(repo, slug) && _dir_exists(repo + "/" + slug) {
        _roster_append(repo, slug, "./" + slug)
        eprintln("✓ roster: registered " + slug + " → ./" + slug + " in PAPER.tape")
    }
    _cmd_paper_show(repo, slug)
}

fn _require_active(repo: string, verb: string) -> string {
    let a = _get_active(repo)
    if a == "" {
        eprintln("paper " + verb + ": no active paper — run `/paper set <slug>` first (or `/paper list`)")
        exit(2)
    }
    return a
}

fn _usage() {
    println("paper — arxiv-style LaTeX paper scaffolder (v0.10 — PAPER.tape roster)")
    println("")
    println("usage — roster (PAPER.tape · slug → dir; progress derived from PAPER.md):")
    println("  /paper                                     show active paper (@title · @goal · progress)")
    println("  /paper list [--sync]                       repo-wide paper index (★ = active); --sync = reconcile roster with disk")
    println("  /paper set <slug>                          select session's active paper")
    println("  /paper show [<slug>]                       show one paper (defaults to active)")
    println("  /paper goal <text>                         set PAPER.md `@goal:` line on active paper")
    println("  /paper title <text>                        set PAPER.md `@title:` display header (icon · name · alias)")
    println("  /paper ms <text>                           add `- [ ]` milestone (alias: milestone)")
    println("  /paper done <match>                        flip a milestone `- [ ]` → `- [x]`")
    println("  /paper todo <text>                         append `- [ ] <text>` to PAPER.log.md")
    println("")
    println("usage — scaffold (auto-registers to PAPER.tape + drops PAPER.md/log.md):")
    println("  /paper new <slug>                          scaffold ./<slug>/ from template")
    println("  /paper sample [<name>] [<dest>]            copy a bundled sample (see `/paper samples`)")
    println("  /paper samples                             list bundled samples")
    println("  /paper monograph-init <slug> [N]           scaffold a monograph (main.tex \\appendix + N stubs + companion/)")
    println("")
    println("usage — build / extras:")
    println("  /paper fig <image_size> <prompt> <out.png> generate a figure (delegates to /imagine)")
    println("  /paper compile [dir]                       xelatex x 3 + bibtex")
    println("  /paper lint [dir]                          commons g51 lint (auto paper/monograph tier)")
    println("  /paper help                                this message")
    println("")
    println("v0.9 monograph verbs:")
    println("  /paper fill <appendix-letter>              print the fill runbook for one appendix")
    println("  /paper companion sync                      rebuild companion/{pr-roll,verify-ledger}.json")
    println("")
    println("v0.7 verbs:")
    println("  /paper companion init                      scaffold companion/ in cwd")
    println("  /paper outline [dir]                       print main.tex sections / figs / tables TOC")
    println("  /paper pipeline <stage1> <stage2> ...      emit §Full Pipeline LaTeX table skeleton")
    println("  /paper atoms <domain>                      scan hexa-lang atoms matching <domain>")
    println("  /paper verify-block <fn> <args...> <expected>  emit \\begin{lstlisting} verdict block")
    println("  /paper bib add <doi-or-arxiv>              fetch metadata + append bibtex entry")
    println("  /paper pr-roll <repo> <since-ref>          emit \\paragraph + companion/pr-roll.json")
    println("  /paper arxiv-prep [<dir>]                  produce out/<slug>-arxiv.tar.gz")
    println("")
    println("image_size: square_hd | landscape_16_9 | portrait_16_9 | square")
    println("")
    println("requirements:")
    println("  new / sample : cp · cwd writable · slug not already a directory")
    println("  fig          : sister `imagine` plugin installed + `secret` CLI + `fal.api_key`")
    println("  compile      : xelatex + bibtex (BasicTeX / TeX Live)")
    println("  bib add      : curl + (CrossRef DOI or arxiv API id)")
    println("  pr-roll      : gh CLI authenticated")
    println("  verify-block : hexa binary (/Users/ghost/.hx/bin/hexa or PATH)")
}

// locate the sister imagine plugin's dispatcher (source or installed layout)
fn _find_imagine(root: string) -> string {
    let parent = _dirname(root)
    let src = parent + "/imagine/bin/_imagine.hexa"
    if _path_exists(src) { return src }
    let grand = _dirname(parent)
    let listing = to_string(exec("ls -d " + _shq(grand)
        + "/imagine/*/bin/_imagine.hexa 2>/dev/null | sort -V | tail -1"))
    let cand = _trim(listing)
    if cand != "" && _path_exists(cand) { return cand }
    return ""
}

fn _cmd_new(root: string, slug: string) {
    if slug == "" {
        eprintln("paper new: missing <slug>")
        exit(2)
    }
    if _bad_slug(slug) {
        eprintln("paper new: <slug> must be a simple name (no slashes / no leading dot)")
        exit(2)
    }
    if _path_exists("./" + slug) {
        eprintln("paper new: ./" + slug + " already exists — refusing to overwrite")
        exit(2)
    }
    let template_dir = root + "/template"
    if !_dir_exists(template_dir) {
        eprintln("paper new: template/ missing at " + template_dir)
        exit(1)
    }
    let cp = exec_with_status("cp -R " + _shq(template_dir) + " " + _shq("./" + slug))
    if cp[1] != 0 {
        eprintln("paper new: copy failed — " + _trim(to_string(cp[0])))
        exit(1)
    }
    _register_paper(_git_root(), slug)
    println("[paper] scaffolded ./" + slug + "/ from template (+ PAPER.tape · PAPER.md · PAPER.log.md)")
    println("        edit main.tex (title · author · sections), references.bib, then `make`")
    println("        next: `/paper set " + slug + "` · `/paper goal <text>` · `/paper ms <text>`")
    print(to_string(exec("ls -1 " + _shq("./" + slug))))
}

// /paper sample [<sample-name>] [<dest-slug>] — copy a bundled sample.
//   1-arg : <sample-name>  → copy to ./<sample-name>/
//   2-arg : <sample-name> <dest-slug> → copy to ./<dest-slug>/
//   0-arg : default to sample-nb-bcs-absorbed
// Bundled (v0.8): sample-nb-bcs-absorbed · sample-fusion-7gate
//                 sample-cost-routing · sample-blue-max
fn _cmd_sample(root: string, args: array) {
    let mut name = "sample-nb-bcs-absorbed"
    let mut slug = ""
    if len(args) >= 1 && _trim(args[0]) != "" { name = args[0] }
    if len(args) >= 2 && _trim(args[1]) != "" { slug = args[1] }
    if slug == "" { slug = name }
    if _bad_slug(name) {
        eprintln("paper sample: <sample-name> must be a simple name (no slashes / no leading dot)")
        exit(2)
    }
    if _bad_slug(slug) {
        eprintln("paper sample: <dest-slug> must be a simple name (no slashes / no leading dot)")
        exit(2)
    }
    let src = root + "/samples/" + name
    if !_dir_exists(src) {
        eprintln("paper sample: bundled sample '" + name + "' not found at " + src)
        eprintln("  bundled samples:")
        print(to_string(exec("ls -1 " + _shq(root + "/samples") + " 2>/dev/null")))
        exit(1)
    }
    if _path_exists("./" + slug) {
        eprintln("paper sample: ./" + slug + " already exists — refusing to overwrite")
        exit(2)
    }
    let cp = exec_with_status("cp -R " + _shq(src) + " " + _shq("./" + slug))
    if cp[1] != 0 {
        eprintln("paper sample: copy failed — " + _trim(to_string(cp[0])))
        exit(1)
    }
    _register_paper(_git_root(), slug)
    println("[paper] copied bundled '" + name + "' → ./" + slug + "/ (+ PAPER.tape · PAPER.md · PAPER.log.md)")
    println("        next: `/paper set " + slug + "` · `/paper goal <text>` · `/paper ms <text>`")
    print(to_string(exec("ls -1 " + _shq("./" + slug))))
}

fn _cmd_fig(root: string, args: array) {
    if len(args) < 3 {
        eprintln("paper fig: usage: /paper fig <image_size> <prompt_file> <out.png>")
        exit(2)
    }
    let size = args[0]
    let prompt = args[1]
    let out = args[2]
    let imagine_hexa = _find_imagine(root)
    if imagine_hexa == "" {
        eprintln("paper fig: sister `imagine` plugin not found")
        eprintln("  install via: sidecar sync  (or /inject in Claude Code)")
        eprintln("  imagine plugin provides the image-generation backend (fal.ai · openai)")
        exit(1)
    }
    let imagine_root = _dirname(_dirname(imagine_hexa))
    // paper-fig argv: <size> <prompt> <out>; imagine argv: <prompt> <out> -s <size>
    let cmd = "hexa run " + _shq(imagine_hexa)
        + " --root " + _shq(imagine_root)
        + " " + _shq(prompt) + " " + _shq(out)
        + " -s " + _shq(size)
        + " 2>&1"
    let r = exec_with_status(cmd)
    print(to_string(r[0]))
    exit(r[1])
}

fn _cmd_compile(args: array) {
    let mut dir = "."
    if len(args) >= 1 && _trim(args[0]) != "" { dir = args[0] }
    if !_dir_exists(dir) {
        eprintln("paper compile: " + dir + " is not a directory")
        exit(2)
    }
    if !_path_exists(dir + "/main.tex") {
        eprintln("paper compile: " + dir + "/main.tex not found")
        exit(2)
    }
    if !_has_cmd("pdflatex") {
        eprintln("paper compile: pdflatex not on PATH (install BasicTeX / TeX Live)")
        exit(1)
    }
    if !_has_cmd("bibtex") {
        eprintln("paper compile: bibtex not on PATH")
        exit(1)
    }
    let pdf = "pdflatex -interaction=nonstopmode -halt-on-error main.tex"
    let seq = "cd " + _shq(dir) + " && " + pdf
        + " && (bibtex main || true)"
        + " && " + pdf + " && " + pdf
    let r = exec_with_status(seq + " 2>&1")
    print(to_string(r[0]))
    if r[1] != 0 {
        eprintln("paper compile: pdflatex/bibtex failed (exit " + to_string(r[1]) + ")")
        exit(r[1])
    }
    println("[paper] built " + dir + "/main.pdf")
}

fn _cmd_samples(root: string) {
    let samples_dir = root + "/samples"
    if !_dir_exists(samples_dir) {
        println("(no samples bundled)")
        return
    }
    println("[paper] bundled samples (under " + samples_dir + "):")
    let listing = to_string(exec("ls -1 " + _shq(samples_dir) + " 2>/dev/null"))
    let names = listing.split("\n")
    let mut i = 0
    while i < len(names) {
        let name = _trim(names[i])
        if name != "" && _dir_exists(samples_dir + "/" + name) {
            let mut first = ""
            let readme = samples_dir + "/" + name + "/README.md"
            if _path_exists(readme) {
                try {
                    let line1 = to_string(read_file(readme)).split("\n")[0]
                    if line1.substring(0, 2) == "# " { first = _trim(line1.substring(2, len(line1))) }
                    else { first = _trim(line1) }
                }
                catch e { first = "" }
            }
            println("  " + name + "\t" + first)
        }
        i = i + 1
    }
}

// Build the space-separated list of .tex files that contribute to the
// document body: main.tex PLUS every \input{...}/\include{...} target it
// references (resolving the conventional .tex extension), PLUS any
// appendix/*.tex present. Returns shell-quoted, space-joined paths.
//   The 58p monograph build proved lint MUST traverse \input'd appendix
//   files — counting \includegraphics in main.tex alone reported "4
//   figures" for a 16-figure doc (#1).
fn _lint_tex_files(dir: string, main_tex: string) -> string {
    let mut files = ""
    if _path_exists(main_tex) {
        files = _shq(main_tex)
        // extract \input{X} / \include{X} targets from main.tex
        let cmd = "grep -oE '\\\\(input|include)\\{[^}]+\\}' " + _shq(main_tex)
            + " 2>/dev/null | sed -E 's/\\\\(input|include)\\{//; s/\\}//'"
        let r = exec_with_status(cmd)
        if r[1] == 0 {
            let lines = _trim(to_string(r[0])).split("\n")
            let mut i = 0
            while i < len(lines) {
                let raw = _trim(lines[i])
                if raw != "" {
                    // resolve target relative to dir; add .tex if no extension file
                    let mut cand = dir + "/" + raw
                    if !_path_exists(cand) { cand = dir + "/" + raw + ".tex" }
                    if _path_exists(cand) && files.index_of(_shq(cand)) < 0 {
                        files = files + " " + _shq(cand)
                    }
                }
                i = i + 1
            }
        }
    }
    // also glob appendix/*.tex (monograph layout) in case it isn't \input'd yet
    if _dir_exists(dir + "/appendix") {
        let r2 = exec_with_status("ls -1 " + _shq(dir + "/appendix") + "/*.tex 2>/dev/null")
        if r2[1] == 0 {
            let lines = _trim(to_string(r2[0])).split("\n")
            let mut i = 0
            while i < len(lines) {
                let p = _trim(lines[i])
                if p != "" && files.index_of(_shq(p)) < 0 { files = files + " " + _shq(p) }
                i = i + 1
            }
        }
    }
    return files
}

// count \input appendix files wired in (monograph tier detection): requires
// \appendix present in main.tex AND >=1 appendix/*.tex (or \input{appendix/..}).
fn _lint_appendix_count(dir: string, main_tex: string) -> int {
    if !_path_exists(main_tex) { return 0 }
    let has_appendix = exec_with_status("grep -cE '^\\\\appendix' " + _shq(main_tex) + " 2>/dev/null")
    if has_appendix[1] != 0 || to_int(_trim(has_appendix[0])) < 1 { return 0 }
    let mut n = 0
    if _dir_exists(dir + "/appendix") {
        let r = exec_with_status("ls -1 " + _shq(dir + "/appendix") + "/*.tex 2>/dev/null | wc -l")
        if r[1] == 0 { n = to_int(_trim(r[0])) }
    }
    if n == 0 {
        let r2 = exec_with_status("grep -cE '\\\\(input|include)\\{appendix/' " + _shq(main_tex) + " 2>/dev/null")
        if r2[1] == 0 { n = to_int(_trim(r2[0])) }
    }
    return n
}

// "comparison ⇒ chart" heuristic (v0.7 profile): count body .tex files whose
// tabular content looks like a numeric comparison (contains "vs", an
// expected/computed pair, or a baseline/this-work pair). Heuristic — warn, not
// fail; false positives are an acceptable nudge.
fn _lint_comparison_tables(files: string) -> int {
    if files == "" { return 0 }
    let cmd = "grep -liE 'textbf\\{vs|[ &]vs\\.?[ &]|expected.*computed|computed.*expected|baseline.*this work|this work.*baseline' "
        + files + " 2>/dev/null | wc -l"
    let r = exec_with_status(cmd)
    if r[1] != 0 { return 0 }
    return to_int(_trim(r[0]))
}

// commons @D g51 — paper lint (extended 0.6.0; figure-traverse + monograph
// tier + comparison-chart heuristic added 0.9.0):
//   Base : >=10 pages AND >=1 fal.ai-generated figure
//   v0.6 : +§Full Pipeline / §Limitations / §Reproducibility headings
//          +>=1 \begin{table} (or `tabular`)
//          +>=2 \includegraphics (or TikZ fig)
//          +>=10 @-keyed bibtex entries
//          +no tier emoji in references.bib body (pdflatex fatal guard)
//          +all \cite{KEY} resolve to a bibtex KEY (warn-list, non-blocking)
//   v0.9 : figure + table counts traverse main.tex AND every \input'd /
//          appendix/*.tex file (#1 fix — was main.tex only).
//          monograph tier auto-detect: \appendix + >=6 \input appendix files
//          → expect >=30 pages, >=6 figures, >=1 companion/ dir; else the
//          existing >=10p / >=1fig paper tier.
//          "comparison ⇒ chart" heuristic warns on a comparison tabular w/ 0 figs.
// Exit 0 = pass, 1 = fail. Output is a per-condition checklist.
fn _cmd_lint(args: array) {
    let mut dir = "."
    if len(args) >= 1 && _trim(args[0]) != "" { dir = args[0] }
    if !_dir_exists(dir) {
        eprintln("paper lint: directory not found: " + dir)
        exit(2)
    }

    let pdf = dir + "/main.pdf"
    let mut pages = 0
    let mut pdf_present = false
    if _path_exists(pdf) {
        pdf_present = true
        let r = exec_with_status("pdfinfo " + _shq(pdf) + " 2>/dev/null | awk '/^Pages:/ {print $2}'")
        if r[1] == 0 {
            let v = _trim(r[0])
            if v != "" { pages = to_int(v) }
        }
    }
    // (A) figures/_prompts/ contains ≥1 .txt/.md file
    let prompts_dir = dir + "/figures/_prompts"
    let mut prompt_hits = 0
    if _dir_exists(prompts_dir) {
        let r = exec_with_status("ls -1 " + _shq(prompts_dir) + " 2>/dev/null | grep -Ec '\\.(txt|md)$'")
        if r[1] == 0 {
            let v = _trim(r[0])
            if v != "" { prompt_hits = to_int(v) }
        }
    }

    // (B) figures/_scripts/*.py greps for fal / imagine
    let scripts_dir = dir + "/figures/_scripts"
    let mut script_hits = 0
    if _dir_exists(scripts_dir) {
        let r = exec_with_status("grep -liE 'fal|imagine|/paper fig' " + _shq(scripts_dir) + "/*.py 2>/dev/null | wc -l")
        if r[1] == 0 {
            let v = _trim(r[0])
            if v != "" { script_hits = to_int(v) }
        }
    }
    let fal_ok = prompt_hits > 0 || script_hits > 0

    // --- extended (v0.6) checks ---
    let main_tex = dir + "/main.tex"
    let bib      = dir + "/references.bib"
    let main_present = _path_exists(main_tex)
    let bib_present  = _path_exists(bib)

    // body .tex fileset = main.tex + \input'd + appendix/*.tex  (v0.9 #1 fix)
    let tex_files = _lint_tex_files(dir, main_tex)
    let appendix_n = _lint_appendix_count(dir, main_tex)
    // monograph tier: \appendix + >=6 \input appendix files
    let monograph = appendix_n >= 6
    let companion_present = _dir_exists(dir + "/companion")
    // tier-scaled thresholds
    let mut min_pages = 10
    let mut min_figs  = 2
    if monograph { min_pages = 30; min_figs = 6 }
    let pages_ok = pages >= min_pages

    // §Full Pipeline / §Limitations / §Reproducibility headings (scan whole body)
    let mut sec_pipeline_ok = false
    let mut sec_limits_ok   = false
    let mut sec_repro_ok    = false
    let mut tables_n  = 0
    let mut figures_n = 0
    if main_present && tex_files != "" {
        let r1 = exec_with_status("grep -hcE '^\\\\section\\{Full Pipeline' " + tex_files + " 2>/dev/null | awk '{s+=$1} END{print s+0}'")
        if r1[1] == 0 { if to_int(_trim(r1[0])) >= 1 { sec_pipeline_ok = true } }
        let r2 = exec_with_status("grep -hcE '^\\\\section\\{Limitations' " + tex_files + " 2>/dev/null | awk '{s+=$1} END{print s+0}'")
        if r2[1] == 0 { if to_int(_trim(r2[0])) >= 1 { sec_limits_ok = true } }
        let r3 = exec_with_status("grep -hcE '^\\\\section\\*?\\{Reproducibility' " + tex_files + " 2>/dev/null | awk '{s+=$1} END{print s+0}'")
        if r3[1] == 0 { if to_int(_trim(r3[0])) >= 1 { sec_repro_ok = true } }
        // counts SUMMED across main.tex + every \input'd / appendix .tex (#1 fix)
        let rt = exec_with_status("grep -hcE '\\\\begin\\{tabular\\}|\\\\begin\\{table\\}' " + tex_files + " 2>/dev/null | awk '{s+=$1} END{print s+0}'")
        if rt[1] == 0 { tables_n = to_int(_trim(rt[0])) }
        let rf = exec_with_status("grep -hcE '\\\\includegraphics|\\\\begin\\{tikzpicture\\}' " + tex_files + " 2>/dev/null | awk '{s+=$1} END{print s+0}'")
        if rf[1] == 0 { figures_n = to_int(_trim(rf[0])) }
    }
    let tables_ok  = tables_n  >= 1
    let figures_ok = figures_n >= min_figs

    // "comparison ⇒ chart" heuristic — warn-only
    let comparison_n = _lint_comparison_tables(tex_files)

    // bib entry count + emoji guard
    let mut bib_entries = 0
    let mut bib_emoji_lines = 0
    if bib_present {
        let rb = exec_with_status("grep -cE '^@[A-Za-z]+\\{' " + _shq(bib) + " 2>/dev/null")
        if rb[1] == 0 { bib_entries = to_int(_trim(rb[0])) }
        // emoji guard — match tier emoji byte sequences (UTF-8 encoded):
        // U+1F535 blue / U+1F7E2 green / U+1F7E1 yellow / U+1F7E0 orange / U+1F534 red
        let re = exec_with_status("LC_ALL=C grep -cE $'\\xf0\\x9f\\x94\\xb5|\\xf0\\x9f\\x9f\\xa2|\\xf0\\x9f\\x9f\\xa1|\\xf0\\x9f\\x9f\\xa0|\\xf0\\x9f\\x94\\xb4' " + _shq(bib) + " 2>/dev/null")
        if re[1] == 0 { bib_emoji_lines = to_int(_trim(re[0])) }
    }
    let bib_count_ok = bib_entries >= 10
    let bib_emoji_ok = bib_emoji_lines == 0

    // unresolved \cite{KEY} — warn-list (does NOT fail the lint), scans body
    let mut unresolved = ""
    if main_present && bib_present {
        let cmd = "awk 'match($0, /\\\\cite[pt]?\\{[^}]+\\}/) { s=substr($0,RSTART,RLENGTH); sub(/\\\\cite[pt]?\\{/,\"\",s); sub(/\\}.*/,\"\",s); n=split(s,a,\",\"); for(i=1;i<=n;i++){gsub(/[ \\t]/,\"\",a[i]); print a[i]} }' "
            + tex_files
            + " | sort -u | while read k; do "
            + "  if [ -n \"$k\" ] && ! grep -qE \"^@[A-Za-z]+\\{$k,\" " + _shq(bib) + "; then echo \"$k\"; fi; "
            + "done"
        let ru = exec_with_status(cmd)
        if ru[1] == 0 { unresolved = _trim(ru[0]) }
    }

    let mut tier_name = "paper"
    if monograph { tier_name = "monograph" }
    println("paper lint (commons @D g51 — v0.9 · tier=" + tier_name + ") — " + dir)
    if monograph {
        println("  · monograph tier auto-detected (\\appendix + " + to_string(appendix_n) + " \\input appendix files; thresholds >=30p / >=6 figs / companion/)")
    }
    if main_present {
        println("  · body fileset traversed: main.tex + " + to_string(appendix_n) + " appendix/\\input file(s)")
    }
    if pdf_present {
        if pages_ok { println("  ✓ pages: " + to_string(pages) + " (>=" + to_string(min_pages) + ")") }
        else { println("  ✗ pages: " + to_string(pages) + " (<" + to_string(min_pages) + ", need >=" + to_string(min_pages) + ")") }
    } else {
        println("  ✗ pages: main.pdf not found — run `/paper compile " + dir + "` first")
    }
    if fal_ok {
        println("  ✓ fal.ai figure: " + to_string(prompt_hits) + " prompt(s) + " + to_string(script_hits) + " script(s) reference fal/imagine")
    } else {
        println("  ✗ fal.ai figure: no figures/_prompts/*.txt and no fal/imagine reference in figures/_scripts/*.py")
    }
    if main_present {
        if sec_pipeline_ok { println("  ✓ section: Full Pipeline present") }
        else { println("  ✗ section: \\section{Full Pipeline...} missing") }
        if sec_limits_ok { println("  ✓ section: Limitations present") }
        else { println("  ✗ section: \\section{Limitations...} missing") }
        if sec_repro_ok { println("  ✓ section: Reproducibility present") }
        else { println("  ✗ section: \\section{Reproducibility...} missing") }
        if tables_ok { println("  ✓ tables: " + to_string(tables_n) + " (>=1, body-wide)") }
        else { println("  ✗ tables: " + to_string(tables_n) + " (<1, need >=1 \\begin{tabular} or \\begin{table})") }
        if figures_ok { println("  ✓ figures: " + to_string(figures_n) + " (>=" + to_string(min_figs) + " includegraphics or tikz, body-wide)") }
        else { println("  ✗ figures: " + to_string(figures_n) + " (<" + to_string(min_figs) + ", need >=" + to_string(min_figs) + " \\includegraphics or \\begin{tikzpicture})") }
    } else {
        println("  ✗ main.tex not found at " + main_tex)
    }
    if monograph {
        if companion_present { println("  ✓ companion/: present") }
        else { println("  ✗ companion/: missing (monograph tier expects a companion/ data-record dir — `/paper companion init`)") }
    }
    // "comparison ⇒ chart" heuristic — warn-only nudge
    if comparison_n > 0 && figures_n == 0 {
        println("  ⚠ comparison ⇒ chart (warn-only): " + to_string(comparison_n)
            + " file(s) carry a comparison-style tabular but the doc has 0 figures —")
        println("      consider a chart (a comparison reads faster as a bar/line plot than a table).")
    }
    if bib_present {
        if bib_count_ok { println("  ✓ bibtex entries: " + to_string(bib_entries) + " (>=10)") }
        else { println("  ✗ bibtex entries: " + to_string(bib_entries) + " (<10, need >=10 @-keyed entries)") }
        if bib_emoji_ok { println("  ✓ bibtex emoji guard: no tier emoji in references.bib") }
        else { println("  ✗ bibtex emoji guard: " + to_string(bib_emoji_lines) + " emoji line(s) — strip tier emoji to avoid pdflatex fatal") }
    } else {
        println("  ✗ references.bib not found at " + bib)
    }
    if unresolved != "" {
        println("  ⚠ unresolved \\cite keys (warn-only, not blocking):")
        let lines = unresolved.split("\n")
        let mut i = 0
        while i < len(lines) {
            let k = _trim(lines[i])
            if k != "" { println("      - " + k) }
            i = i + 1
        }
    }

    let mut all_ok = pages_ok && fal_ok
        && main_present && sec_pipeline_ok && sec_limits_ok && sec_repro_ok
        && tables_ok && figures_ok
        && bib_present && bib_count_ok && bib_emoji_ok
    if monograph && !companion_present { all_ok = false }
    if all_ok { exit(0) }
    exit(1)
}

// =====================================================================
// v0.7 verbs
// =====================================================================

// /paper companion {init|sync} — scaffold or refresh companion/ in cwd.
fn _cmd_companion(root: string, args: array) {
    let mut sub = ""
    if len(args) >= 1 { sub = args[0] }
    if sub == "sync" {
        let mut rest = []
        let mut z = 1
        while z < len(args) { rest.push(args[z]); z = z + 1 }
        _cmd_companion_sync(rest)
        return
    }
    if sub != "init" {
        eprintln("paper companion: usage: /paper companion {init|sync}")
        exit(2)
    }
    let src = root + "/template/companion"
    if !_dir_exists(src) {
        eprintln("paper companion: template/companion/ missing at " + src)
        exit(1)
    }
    let dest = "./companion"
    if _path_exists(dest) {
        println("[paper] companion/ already exists in cwd — no changes (idempotent)")
        print(to_string(exec("ls -1 " + _shq(dest))))
        return
    }
    let cp = exec_with_status("cp -R " + _shq(src) + " " + _shq(dest))
    if cp[1] != 0 {
        eprintln("paper companion: copy failed — " + _trim(to_string(cp[0])))
        exit(1)
    }
    println("[paper] scaffolded ./companion/ from template")
    print(to_string(exec("ls -1 " + _shq(dest))))
}

// /paper outline [dir] — print main.tex sections / figures / tables TOC.
fn _cmd_outline(args: array) {
    let mut dir = "."
    if len(args) >= 1 && _trim(args[0]) != "" { dir = args[0] }
    let main_tex = dir + "/main.tex"
    if !_path_exists(main_tex) {
        eprintln("paper outline: main.tex not found at " + main_tex)
        exit(2)
    }
    println("[paper] outline of " + main_tex)
    println("")
    println("  sections:")
    let r1 = exec_with_status("grep -nE '^\\\\(section|subsection|paragraph)\\*?\\{' " + _shq(main_tex)
        + " | sed 's/:\\\\\\\\/  /' | sed 's/\\\\\\\\(section\\\\*\\?\\\\)/  §/' | sed 's/\\\\\\\\(subsection\\\\*\\?\\\\)/    §§/' | sed 's/\\\\\\\\(paragraph\\\\*\\?\\\\)/      ¶/'")
    print(to_string(r1[0]))
    // simpler fallback
    let r1b = exec_with_status("grep -nE '^\\\\section|^\\\\subsection|^\\\\paragraph' " + _shq(main_tex))
    print(to_string(r1b[0]))
    println("")
    println("  figures (\\includegraphics + \\begin{tikzpicture}):")
    let r2 = exec_with_status("grep -nE '\\\\includegraphics|\\\\begin\\{tikzpicture\\}' " + _shq(main_tex))
    print(to_string(r2[0]))
    println("")
    println("  tables (\\begin{table} + \\begin{tabular}):")
    let r3 = exec_with_status("grep -nE '\\\\begin\\{table\\}|\\\\begin\\{tabular\\}' " + _shq(main_tex))
    print(to_string(r3[0]))
}

// /paper pipeline <stage1> <stage2> ... — emit §Full Pipeline LaTeX table.
fn _cmd_pipeline(args: array) {
    if len(args) < 1 {
        eprintln("paper pipeline: usage: /paper pipeline <stage1> [<stage2> ...]")
        exit(2)
    }
    println("% --- emitted by /paper pipeline ---")
    println("\\section{Full Pipeline}")
    println("\\label{sec:pipeline}")
    println("")
    println("\\medskip")
    println("\\noindent\\fbox{\\parbox{0.97\\linewidth}{\\small\\textbf{Tier rubric.}")
    println("\\tierBlue\\ closed-form \\(\\cdot\\) \\tierGreen\\ numerical \\(\\cdot\\)")
    println("\\tierYellow\\ cited \\(\\cdot\\) \\tierOrange\\ wet-lab/install-gated \\(\\cdot\\)")
    println("\\tierRed\\ falsified.}}")
    println("")
    println("\\begin{table}[h]")
    println("\\centering")
    println("\\small")
    println("\\begin{tabular}{@{}clcl@{}}")
    println("\\toprule")
    println("\\textbf{\\#} & \\textbf{Stage} & \\textbf{Tier} & \\textbf{Backing atom} \\\\")
    println("\\midrule")
    let mut i = 0
    while i < len(args) {
        let n = i + 1
        // Use \textcircled for ⓵..⓻ glyphs (engine-portable)
        println("\\textcircled{\\scriptsize " + to_string(n) + "} & "
            + args[i] + " & \\tierOrange & \\texttt{atom:<id-" + to_string(n) + ">} \\\\")
        i = i + 1
    }
    println("\\bottomrule")
    println("\\end{tabular}")
    println("\\caption{Pipeline stages, each tier-tagged. Fill in the backing atom column with hexa-lang atom ids, companion ledger entries, or DOIs.}")
    println("\\label{tab:pipeline}")
    println("\\end{table}")
    println("% --- end pipeline ---")
}

// /paper atoms <domain> — scan hexa-lang verify_cli.hexa for atoms matching <domain>.
fn _cmd_atoms(args: array) {
    if len(args) < 1 {
        eprintln("paper atoms: usage: /paper atoms <domain>")
        exit(2)
    }
    let domain = args[0]
    let home = env_var("HOME")
    let verify_cli = home + "/core/hexa-lang/tool/verify_cli.hexa"
    if !_path_exists(verify_cli) {
        eprintln("paper atoms: hexa-lang verify_cli not found at " + verify_cli)
        eprintln("  this verb requires a local checkout of hexa-lang under ~/core/hexa-lang")
        exit(1)
    }
    // grep lines whose preceding comment OR same line contains <domain> (case-insensitive)
    let cmd = "awk 'BEGIN{IGNORECASE=1} /^[[:space:]]*\\/\\// { last=$0; next } /\"[A-Za-z0-9:_-]+\"/ { if (last ~ /" + domain + "/ || $0 ~ /" + domain + "/) print last \"\\n\" $0 \"\\n---\" } { last=\"\" }' " + _shq(verify_cli)
    let r = exec_with_status(cmd)
    let body = _trim(to_string(r[0]))
    if body == "" {
        println("[paper] no atoms matching '" + domain + "' in " + verify_cli)
        return
    }
    println("% --- emitted by /paper atoms " + domain + " ---")
    println("\\begin{table}[h]")
    println("\\centering")
    println("\\small")
    println("\\begin{tabular}{@{}ll@{}}")
    println("\\toprule")
    println("\\textbf{Atom} & \\textbf{Note} \\\\")
    println("\\midrule")
    let lines = body.split("\n")
    let mut i = 0
    while i < len(lines) {
        let l = _trim(lines[i])
        if l != "" && l != "---" {
            // best-effort: just emit the raw line as a tt cell
            println("\\texttt{" + l + "} & \\\\")
        }
        i = i + 1
    }
    println("\\bottomrule")
    println("\\end{tabular}")
    println("\\caption{Atoms matching `" + domain + "` (scanned from \\texttt{hexa-lang/tool/verify\\_cli.hexa}).}")
    println("\\end{table}")
    println("% --- end atoms ---")
}

// resolve the canonical hexa binary path (avoid the pool-route relative-hexa hook)
fn _hexa_bin() -> string {
    let local_pin = env_var("HOME") + "/.hx/bin/hexa"
    if _path_exists(local_pin) { return local_pin }
    // fall back to bare 'hexa' on PATH (may route)
    return "hexa"
}

// /paper verify-block <fn> <args...> <expected> — run hexa verify, emit lstlisting.
fn _cmd_verify_block(args: array) {
    if len(args) < 3 {
        eprintln("paper verify-block: usage: /paper verify-block <fn> <args...> <expected>")
        exit(2)
    }
    let hexabin = _hexa_bin()
    // Build hexa verify --expr <fn> <args...> <expected>
    let mut cmd = _shq(hexabin) + " verify --expr"
    let mut i = 0
    while i < len(args) {
        cmd = cmd + " " + _shq(args[i])
        i = i + 1
    }
    cmd = cmd + " 2>&1"
    let r = exec_with_status(cmd)
    let body = _trim(to_string(r[0]))
    println("% --- emitted by /paper verify-block ---")
    println("\\begin{lstlisting}[basicstyle=\\ttfamily\\small,frame=single,xleftmargin=0pt]")
    println("$ hexa verify --expr " + _join(args, " "))
    let bl = body.split("\n")
    let mut j = 0
    while j < len(bl) {
        println(bl[j])
        j = j + 1
    }
    println("\\end{lstlisting}")
    println("% --- end verify-block (exit=" + to_string(r[1]) + ") ---")
    // do NOT exit non-zero on non-blue/green; surface the raw output
    exit(0)
}

fn _join(arr: array, sep: string) -> string {
    let mut out = ""
    let mut i = 0
    while i < len(arr) {
        if i > 0 { out = out + sep }
        out = out + arr[i]
        i = i + 1
    }
    return out
}

// /paper bib add <doi-or-arxiv> — fetch metadata, append bibtex entry to references.bib.
fn _cmd_bib(args: array) {
    if len(args) < 2 || args[0] != "add" {
        eprintln("paper bib: usage: /paper bib add <doi-or-arxiv-id>")
        exit(2)
    }
    let id = args[1]
    if !_path_exists("./references.bib") {
        eprintln("paper bib: ./references.bib not found in cwd")
        exit(2)
    }
    if !_has_cmd("curl") {
        eprintln("paper bib: curl not on PATH")
        exit(1)
    }
    // arxiv id heuristic: 4digits.4-5digits OR arXiv:... ; DOI: contains '/'
    let mut is_arxiv = false
    if id.index_of("/") < 0 {
        // try arxiv format NNNN.NNNNN
        let mut digits_dot = false
        let n = len(id)
        let mut k = 0
        while k < n {
            let c = id[k]
            if c == "." { digits_dot = true }
            k = k + 1
        }
        if digits_dot { is_arxiv = true }
    }
    let mut bib_entry = ""
    if is_arxiv {
        // arxiv API: http://export.arxiv.org/api/query?id_list=<id>
        let cmd = "curl -s 'http://export.arxiv.org/api/query?id_list=" + id + "'"
        let r = exec_with_status(cmd)
        let body = to_string(r[0])
        if r[1] != 0 || body == "" {
            eprintln("paper bib: arxiv API fetch failed for " + id)
            exit(1)
        }
        // crude xml extraction
        let title_raw = exec_with_status("printf %s " + _shq(body) + " | sed -n 's:.*<entry>.*<title>\\([^<]*\\)</title>.*:\\1:p' | head -1")
        let auth_raw  = exec_with_status("printf %s " + _shq(body) + " | sed -n 's:.*<author><name>\\([^<]*\\)</name>.*:\\1:p' | head -1")
        let year_raw  = exec_with_status("printf %s " + _shq(body) + " | sed -n 's:.*<published>\\([0-9]\\{4\\}\\).*:\\1:p' | head -1")
        let title = _trim(to_string(title_raw[0]))
        let auth  = _trim(to_string(auth_raw[0]))
        let year  = _trim(to_string(year_raw[0]))
        if title == "" {
            eprintln("paper bib: arxiv API returned no parseable title for " + id)
            eprintln("  raw response head:")
            eprintln(body.substring(0, 400))
            exit(1)
        }
        let key = "arxiv" + id.split(".")[0] + id.split(".")[1]
        bib_entry = "@misc{" + key + ",\n"
            + "  author       = {" + auth + "},\n"
            + "  title        = {" + title + "},\n"
            + "  year         = {" + year + "},\n"
            + "  eprint       = {" + id + "},\n"
            + "  archivePrefix= {arXiv},\n"
            + "  url          = {https://arxiv.org/abs/" + id + "}\n"
            + "}\n"
    } else {
        // CrossRef DOI: https://api.crossref.org/works/<doi>
        let cmd = "curl -s 'https://api.crossref.org/works/" + id + "'"
        let r = exec_with_status(cmd)
        let body = to_string(r[0])
        if r[1] != 0 || body == "" {
            eprintln("paper bib: CrossRef DOI fetch failed for " + id)
            exit(1)
        }
        // jq if present, else crude python via sed (no python allowed); rely on jq
        if !_has_cmd("jq") {
            eprintln("paper bib: jq not on PATH — required for CrossRef parsing")
            exit(1)
        }
        let title_r = exec_with_status("printf %s " + _shq(body) + " | jq -r '.message.title[0] // empty'")
        let auth1_r = exec_with_status("printf %s " + _shq(body) + " | jq -r '.message.author[0] | (.family + \", \" + .given) // empty'")
        let year_r  = exec_with_status("printf %s " + _shq(body) + " | jq -r '.message.issued.\"date-parts\"[0][0] // empty'")
        let journ_r = exec_with_status("printf %s " + _shq(body) + " | jq -r '.message.\"container-title\"[0] // empty'")
        let title = _trim(to_string(title_r[0]))
        let auth  = _trim(to_string(auth1_r[0]))
        let year  = _trim(to_string(year_r[0]))
        let journ = _trim(to_string(journ_r[0]))
        if title == "" {
            eprintln("paper bib: CrossRef returned no parseable title for DOI " + id)
            exit(1)
        }
        // derive key from first author surname + year
        let mut surname = auth
        let cidx = surname.index_of(",")
        if cidx > 0 { surname = surname.substring(0, cidx) }
        // strip spaces from key
        let mut key = ""
        let mut kk = 0
        while kk < len(surname) {
            let cc = surname[kk]
            if cc != " " && cc != "." { key = key + cc }
            kk = kk + 1
        }
        key = key + year
        bib_entry = "@article{" + key + ",\n"
            + "  author       = {" + auth + "},\n"
            + "  title        = {" + title + "},\n"
            + "  journal      = {" + journ + "},\n"
            + "  year         = {" + year + "},\n"
            + "  doi          = {" + id + "},\n"
            + "  url          = {https://doi.org/" + id + "}\n"
            + "}\n"
    }
    // append
    let ap = exec_with_status("printf '\\n%s\\n' " + _shq(bib_entry) + " >> ./references.bib")
    if ap[1] != 0 {
        eprintln("paper bib: append failed")
        exit(1)
    }
    println("[paper] appended bibtex entry to ./references.bib:")
    println(bib_entry)
}

// /paper pr-roll <repo> <since-ref> — emit \paragraph + companion/pr-roll.json.
fn _cmd_pr_roll(args: array) {
    if len(args) < 2 {
        eprintln("paper pr-roll: usage: /paper pr-roll <repo> <since-ISO-date>")
        eprintln("  example: /paper pr-roll dancinlab/sidecar 2026-05-01")
        exit(2)
    }
    let repo = args[0]
    let since = args[1]
    if !_has_cmd("gh") {
        eprintln("paper pr-roll: gh CLI not on PATH")
        exit(1)
    }
    let cmd = "gh pr list --repo " + _shq(repo)
        + " --state merged"
        + " --search " + _shq("mergedAt:>=" + since)
        + " --json number,title,mergedAt --limit 200"
    let r = exec_with_status(cmd + " 2>&1")
    if r[1] != 0 {
        eprintln("paper pr-roll: gh fetch failed: " + _trim(to_string(r[0])))
        exit(1)
    }
    let json = _trim(to_string(r[0]))
    // companion/pr-roll.json overwrite
    if _dir_exists("./companion") {
        let w = exec_with_status("printf %s " + _shq(json) + " > ./companion/pr-roll.json")
        if w[1] == 0 {
            println("[paper] wrote ./companion/pr-roll.json (" + to_string(len(json)) + " bytes)")
        }
    } else {
        println("[paper] (no ./companion/ in cwd — skipped JSON write; run /paper companion init first)")
    }
    // LaTeX \paragraph stub — use jq if present, else raw
    println("")
    println("% --- emitted by /paper pr-roll " + repo + " " + since + " ---")
    println("\\paragraph{Merged PRs since " + since + " (" + repo + ").}")
    println("\\begin{itemize}\\itemsep0.1em")
    if _has_cmd("jq") {
        let jq = exec_with_status("printf %s " + _shq(json)
            + " | jq -r '.[] | \"\\\\item PR \\#\" + (.number|tostring) + \" --- \" + .title + \" (\" + .mergedAt + \")\"'")
        print(to_string(jq[0]))
    } else {
        println("\\item (jq not on PATH — see companion/pr-roll.json for the raw list)")
    }
    println("\\end{itemize}")
    println("% --- end pr-roll ---")
}

// /paper arxiv-prep [<dir>] — produce out/<slug>-arxiv.tar.gz with arxiv-mandatory files.
fn _cmd_arxiv_prep(args: array) {
    let mut dir = "."
    if len(args) >= 1 && _trim(args[0]) != "" { dir = args[0] }
    if !_dir_exists(dir) {
        eprintln("paper arxiv-prep: " + dir + " is not a directory")
        exit(2)
    }
    if !_path_exists(dir + "/main.tex") {
        eprintln("paper arxiv-prep: " + dir + "/main.tex not found")
        exit(2)
    }
    if !_path_exists(dir + "/main.bbl") {
        eprintln("paper arxiv-prep: " + dir + "/main.bbl not found — run `make` first (arxiv requires .bbl)")
        exit(2)
    }
    let basename_dir = _basename(_trim(to_string(exec("cd " + _shq(dir) + " && pwd"))))
    let slug = basename_dir
    let out = dir + "/out"
    let _ = exec("mkdir -p " + _shq(out))
    let tar = out + "/" + slug + "-arxiv.tar.gz"
    let cmd = "cd " + _shq(dir)
        + " && TMP=$(mktemp -d) && cp main.tex references.bib main.bbl \"$TMP\"/ "
        + " && mkdir -p \"$TMP\"/figures "
        + " && find figures -maxdepth 1 \\( -name '*.pdf' -o -name '*.png' -o -name '*.eps' \\) -exec cp {} \"$TMP\"/figures/ \\; "
        + " && (cd \"$TMP\" && tar -czf \"" + tar + "\" .) "
        + " && rm -rf \"$TMP\""
    let r = exec_with_status(cmd + " 2>&1")
    if r[1] != 0 {
        eprintln("paper arxiv-prep: bundle failed: " + _trim(to_string(r[0])))
        exit(1)
    }
    // validate: exactly 1 .tex + .bbl present
    let count = exec_with_status("tar -tzf " + _shq(tar) + " | grep -c '\\.tex$'")
    let n_tex = to_int(_trim(to_string(count[0])))
    if n_tex != 1 {
        eprintln("paper arxiv-prep: WARNING — bundle has " + to_string(n_tex) + " .tex files (arxiv expects exactly 1)")
    }
    let has_bbl = exec_with_status("tar -tzf " + _shq(tar) + " | grep -q '\\.bbl$'")
    if has_bbl[1] != 0 {
        eprintln("paper arxiv-prep: WARNING — bundle missing .bbl (arxiv won't rebuild references)")
    }
    println("[paper] arxiv bundle → " + tar)
    print(to_string(exec("tar -tzf " + _shq(tar))))
}

// =====================================================================
// v0.9 verbs — monograph mode
// =====================================================================

// appendix letter for index i (0->A, 1->B, ...). Wraps past Z with A1, B1, ...
fn _ap_letter(i: int) -> string {
    let alpha = "ABCDEFGHIJKLMNOPQRSTUVWXYZ"
    if i < 26 { return alpha.substring(i, i + 1) }
    let lead = alpha.substring(i % 26, i % 26 + 1)
    return lead + to_string(i / 26)
}

// /paper monograph-init <slug> [N] — scaffold a monograph from template/ plus
// an N-appendix \appendix spine + companion/ (the HEXA-FUSION 58p structure).
fn _cmd_monograph_init(root: string, args: array) {
    if len(args) < 1 || _trim(args[0]) == "" {
        eprintln("paper monograph-init: usage: /paper monograph-init <slug> [N]")
        eprintln("  N = number of appendix files to stub (default 12)")
        exit(2)
    }
    let slug = args[0]
    if _bad_slug(slug) {
        eprintln("paper monograph-init: <slug> must be a simple name (no slashes / no leading dot)")
        exit(2)
    }
    let mut n = 12
    if len(args) >= 2 && _trim(args[1]) != "" {
        let parsed = to_int(_trim(args[1]))
        if parsed >= 1 { n = parsed }
    }
    if _path_exists("./" + slug) {
        eprintln("paper monograph-init: ./" + slug + " already exists — refusing to overwrite")
        exit(2)
    }
    let template_dir = root + "/template"
    if !_dir_exists(template_dir) {
        eprintln("paper monograph-init: template/ missing at " + template_dir)
        exit(1)
    }
    // 1. seed from template (gets main.tex · Makefile · references.bib · figures/ · companion/)
    let cp = exec_with_status("cp -R " + _shq(template_dir) + " " + _shq("./" + slug))
    if cp[1] != 0 {
        eprintln("paper monograph-init: copy failed — " + _trim(to_string(cp[0])))
        exit(1)
    }
    // 2. appendix/ dir + N stub files
    let _ = exec("mkdir -p " + _shq("./" + slug + "/appendix"))
    let mut inputs = ""
    let mut k = 0
    while k < n {
        let L = _ap_letter(k)
        let fname = L + "_appendix_" + to_string(k + 1)
        let path = "./" + slug + "/appendix/" + fname + ".tex"
        let body = "% Appendix " + L + " — TODO: title this appendix.\n"
            + "% Filled standalone, then \\input'd by main.tex (see \\appendix block).\n"
            + "% Compile check: `make` (the Makefile's APPENDIX wildcard picks this up).\n"
            + "\\section{Appendix " + L + " --- TODO appendix title}\n"
            + "\\label{app:" + L + "}\n"
            + "\n"
            + "% TODO: appendix " + L + " body. Each appendix is a self-contained\n"
            + "% chapter — figures, tables, verify blocks. Cite atoms / DOIs inline.\n"
        let w = exec_with_status("cat > " + _shq(path) + " <<'PAPER_EOF'\n" + body + "PAPER_EOF")
        if w[1] != 0 {
            eprintln("paper monograph-init: failed to write " + path)
            exit(1)
        }
        if inputs != "" { inputs = inputs + "\n" }
        inputs = inputs + "\\input{appendix/" + fname + "}"
        k = k + 1
    }
    // 3. wire \appendix block into main.tex (before \end{document})
    let main_tex = "./" + slug + "/main.tex"
    let block = "\n% =========================================================================\n"
        + "% MONOGRAPH APPENDICES (scaffolded by /paper monograph-init).\n"
        + "% Each \\input target is a self-contained chapter under appendix/.\n"
        + "% Fill one at a time with `/paper fill <letter>`; recompile with `make`.\n"
        + "\\appendix\n"
        + inputs + "\n\n"
    // insert before the final \end{document}
    let ins = exec_with_status(
        "perl -0pi -e 's/\\\\end\\{document\\}/" + "PAPER_APX_MARKER" + "\\\\end{document}/' " + _shq(main_tex))
    if ins[1] != 0 {
        // fallback: append (perl missing) — still valid since block precedes nothing required
        eprintln("paper monograph-init: note — perl unavailable, appending appendix block (verify placement)")
        let _ = exec("printf '%s' " + _shq(block) + " >> " + _shq(main_tex))
    } else {
        // replace the marker with the real block (use a heredoc to a temp + sed-free swap)
        let tmp = "./" + slug + "/.apx_block"
        let _ = exec_with_status("cat > " + _shq(tmp) + " <<'PAPER_EOF'\n" + block + "PAPER_EOF")
        // python-free replacement: use awk to swap the marker line for the file contents
        let swap = "awk 'BEGIN{while((getline l < \"" + tmp + "\")>0) b=b l ORS} "
            + "{ if (index($0,\"PAPER_APX_MARKER\")>0) { sub(/PAPER_APX_MARKER/, \"\"); printf \"%s\", b } print }' "
            + _shq(main_tex) + " > " + _shq(main_tex + ".new") + " && mv " + _shq(main_tex + ".new") + " " + _shq(main_tex)
            + " && rm -f " + _shq(tmp)
        let sw = exec_with_status(swap)
        if sw[1] != 0 {
            eprintln("paper monograph-init: appendix wiring swap failed — appending instead")
            let _ = exec("printf '%s' " + _shq(block) + " >> " + _shq(main_tex))
            let _2 = exec("rm -f " + _shq(tmp))
        }
    }
    _register_paper(_git_root(), slug)
    println("[paper] scaffolded monograph ./" + slug + "/ (" + to_string(n) + " appendices A.." + _ap_letter(n - 1) + ") — + PAPER.tape · PAPER.md · PAPER.log.md")
    println("        · main.tex   — template spine + \\appendix block wiring " + to_string(n) + " \\input files")
    println("        · appendix/  — " + to_string(n) + " stub .tex (each \\section + \\label + % TODO)")
    println("        · companion/ — verify-ledger · pr-roll · adapter-defect-catalog · session-journal · README")
    println("        seed reference: `/paper sample sample-fusion-7gate` (the §Full Pipeline pattern)")
    println("        next: `/paper fill A` for the per-appendix runbook · `make` to compile · `/paper lint " + slug + "`")
    print(to_string(exec("ls -1 " + _shq("./" + slug) + " && echo '  appendix/:' && ls -1 " + _shq("./" + slug + "/appendix"))))
}

// /paper fill <appendix-letter> — print the fill runbook for one appendix.
fn _cmd_fill(args: array) {
    if len(args) < 1 || _trim(args[0]) == "" {
        eprintln("paper fill: usage: /paper fill <appendix-letter>   (e.g. /paper fill A)")
        exit(2)
    }
    let L = args[0]
    // locate the appendix file (cwd-relative; tolerate <L>_*.tex)
    let mut found = ""
    if _dir_exists("./appendix") {
        let r = exec_with_status("ls -1 ./appendix/" + L + "_*.tex 2>/dev/null | head -1")
        if r[1] == 0 { found = _trim(to_string(r[0])) }
        if found == "" {
            let r2 = exec_with_status("ls -1 ./appendix/" + L + ".tex 2>/dev/null | head -1")
            if r2[1] == 0 { found = _trim(to_string(r2[0])) }
        }
    }
    println("[paper] fill runbook — appendix " + L)
    println("")
    if found != "" {
        println("  1. SOURCE: edit " + found)
        let todo = exec_with_status("grep -nE '% TODO|TODO appendix title' " + _shq(found) + " 2>/dev/null")
        let tbody = _trim(to_string(todo[0]))
        if tbody != "" {
            println("     % TODO markers:")
            let lines = tbody.split("\n")
            let mut i = 0
            while i < len(lines) {
                let l = _trim(lines[i])
                if l != "" { println("       " + l) }
                i = i + 1
            }
        }
    } else {
        println("  1. SOURCE: appendix/" + L + "_*.tex not found in cwd")
        println("     (run from the monograph dir, or `/paper monograph-init <slug>` first)")
    }
    println("")
    println("  2. \\input WIRING CHECK — confirm main.tex \\input's this appendix:")
    if _path_exists("./main.tex") {
        let wired = exec_with_status("grep -nE '\\\\(input|include)\\{appendix/" + L + "_' ./main.tex 2>/dev/null")
        let wbody = _trim(to_string(wired[0]))
        if wbody != "" { println("     ✓ wired: " + wbody) }
        else { println("     ✗ NOT wired — add `\\input{appendix/" + L + "_<name>}` inside the \\appendix block of main.tex") }
    } else {
        println("     (no ./main.tex in cwd)")
    }
    println("")
    println("  3. RECOMPILE: `make` (the v0.9 Makefile lists appendix/*.tex + figures/*.pdf")
    println("     as $(DOC).pdf prerequisites — editing this appendix now triggers a rebuild,")
    println("     no `make distclean` needed). Then `/paper lint .` (monograph tier).")
    println("")
    println("  Per-appendix figs: drop figures/_scripts/figNN_<name>.{py,tex}; \\includegraphics")
    println("  the compiled figures/figNN.pdf (NOT \\input of a standalone-\\documentclass .tex).")
}

// /paper companion sync — best-effort rebuild of companion/{pr-roll,verify-ledger}.json
fn _cmd_companion_sync(args: array) {
    if !_dir_exists("./companion") {
        eprintln("paper companion sync: no ./companion/ in cwd — run `/paper companion init` first")
        exit(2)
    }
    let mut did_any = false
    // 1. pr-roll.json from gh pr list
    if _has_cmd("gh") {
        // best-effort repo inference from git remote; else leave a note
        let repo_r = exec_with_status("gh repo view --json nameWithOwner -q .nameWithOwner 2>/dev/null")
        let repo = _trim(to_string(repo_r[0]))
        if repo != "" {
            let cmd = "gh pr list --repo " + _shq(repo)
                + " --state merged --json number,title,mergedAt --limit 200 2>/dev/null"
            let r = exec_with_status(cmd)
            if r[1] == 0 && _trim(to_string(r[0])) != "" {
                let json = _trim(to_string(r[0]))
                let w = exec_with_status("printf %s " + _shq(json) + " > ./companion/pr-roll.json")
                if w[1] == 0 {
                    println("[paper] companion sync: pr-roll.json ← gh pr list (" + repo + ", " + to_string(len(json)) + " bytes)")
                    did_any = true
                }
            } else {
                println("[paper] companion sync: gh pr list returned nothing for " + repo + " — pr-roll.json unchanged")
            }
        } else {
            println("[paper] companion sync: could not infer repo (gh repo view) — pr-roll.json unchanged")
        }
    } else {
        println("[paper] companion sync: gh not on PATH — pr-roll.json unchanged")
    }
    // 2. verify-ledger.json from a hexa verify atom scan (best-effort)
    let hexabin = _hexa_bin()
    let scan = exec_with_status(_shq(hexabin) + " atlas stats --audit --format=json 2>/dev/null")
    if scan[1] == 0 && _trim(to_string(scan[0])) != "" {
        let json = _trim(to_string(scan[0]))
        let w = exec_with_status("printf %s " + _shq(json) + " > ./companion/verify-ledger.json")
        if w[1] == 0 {
            println("[paper] companion sync: verify-ledger.json ← hexa atlas stats --audit (" + to_string(len(json)) + " bytes)")
            did_any = true
        }
    } else {
        println("[paper] companion sync: hexa atlas scan unavailable — verify-ledger.json unchanged")
        println("        (populate manually from your `/paper verify-block` runs; this verb is best-effort)")
    }
    if did_any { println("[paper] companion sync: done.") }
    else { println("[paper] companion sync: nothing updated (no reachable data source).") }
}

fn main() {
    let raw = argv()
    let mut root = ""
    let mut args = []
    let mut i = 1
    while i < len(raw) {
        let a = raw[i]
        if a == "--root" && i + 1 < len(raw) {
            root = raw[i + 1]
            i = i + 2
            continue
        }
        args.push(a)
        i = i + 1
    }
    if root == "" { root = env_var("CLAUDE_PLUGIN_ROOT") }
    if root == "" {
        eprintln("paper: plugin root not resolved (no --root, no $CLAUDE_PLUGIN_ROOT)")
        exit(2)
    }

    let mut verb = "help"
    if len(args) >= 1 { verb = args[0] }
    let mut rest = []
    let mut j = 1
    while j < len(args) { rest.push(args[j]); j = j + 1 }

    if verb == "new" {
        let mut slug = ""
        if len(rest) >= 1 { slug = rest[0] }
        _cmd_new(root, slug)
    } else if verb == "sample" {
        _cmd_sample(root, rest)
    } else if verb == "fig" {
        _cmd_fig(root, rest)
    } else if verb == "compile" {
        _cmd_compile(rest)
    } else if verb == "lint" {
        _cmd_lint(rest)
    } else if verb == "list" || verb == "ls" {
        let repo = _git_root()
        if len(rest) >= 1 && rest[0] == "--sync" { _cmd_paper_list_sync(repo) }
        else { _cmd_paper_list(repo) }
    } else if verb == "samples" {
        _cmd_samples(root)
    } else if verb == "set" {
        if len(rest) < 1 { eprintln("paper set: usage: /paper set <slug>"); exit(2) }
        _cmd_paper_set(_git_root(), rest[0])
    } else if verb == "show" {
        let repo = _git_root()
        let slug = if len(rest) >= 1 { rest[0] } else { _require_active(repo, "show") }
        _cmd_paper_show(repo, slug)
    } else if verb == "goal" {
        let repo = _git_root()
        let slug = _require_active(repo, "goal")
        if len(rest) < 1 { eprintln("paper goal: usage: /paper goal <text>"); exit(2) }
        let text = _join(rest, " ")
        _set_goal(repo, slug, text)
        println("🎯 goal set · " + slug + ": " + text)
    } else if verb == "title" || verb == "subtitle" {
        let repo = _git_root()
        let slug = _require_active(repo, "title")
        if len(rest) < 1 { eprintln("paper title: usage: /paper title <text>"); exit(2) }
        let text = _join(rest, " ")
        _set_title(repo, slug, text)
        println("🏷  title set · " + slug + ": " + text)
    } else if verb == "ms" || verb == "milestone" {
        let repo = _git_root()
        let slug = _require_active(repo, "ms")
        if len(rest) < 1 { eprintln("paper ms: usage: /paper ms <text>"); exit(2) }
        _append_milestone(repo, slug, _join(rest, " "))
        let c = _count_tasks(repo, slug)
        println("milestone + · " + slug + "   진행 " + _progress_bar(c[0], c[0] + c[1]))
    } else if verb == "done" {
        let repo = _git_root()
        let slug = _require_active(repo, "done")
        if len(rest) < 1 { eprintln("paper done: usage: /paper done <match>"); exit(2) }
        let term = _join(rest, " ")
        if !_flip_done(repo, slug, term) {
            eprintln("paper done: no open milestone matching '" + term + "' in PAPER.md")
            exit(1)
        }
        let c = _count_tasks(repo, slug)
        println("flipped · " + slug + "   진행 " + _progress_bar(c[0], c[0] + c[1]))
    } else if verb == "todo" {
        let repo = _git_root()
        let slug = _require_active(repo, "todo")
        if len(rest) < 1 { eprintln("paper todo: usage: /paper todo <text>"); exit(2) }
        _append_todo(repo, slug, _join(rest, " "))
        println("todo + · " + slug)
    } else if verb == "companion" {
        _cmd_companion(root, rest)
    } else if verb == "monograph-init" {
        _cmd_monograph_init(root, rest)
    } else if verb == "fill" {
        _cmd_fill(rest)
    } else if verb == "outline" {
        _cmd_outline(rest)
    } else if verb == "pipeline" {
        _cmd_pipeline(rest)
    } else if verb == "atoms" {
        _cmd_atoms(rest)
    } else if verb == "verify-block" {
        _cmd_verify_block(rest)
    } else if verb == "bib" {
        _cmd_bib(rest)
    } else if verb == "pr-roll" {
        _cmd_pr_roll(rest)
    } else if verb == "arxiv-prep" {
        _cmd_arxiv_prep(rest)
    } else if verb == "help" || verb == "-h" || verb == "--help" {
        _usage()
    } else if verb == "" {
        // bare `/paper` — show active paper if one is set, else usage
        let repo = _git_root()
        let a = _get_active(repo)
        if a != "" { _cmd_paper_show(repo, a) }
        else { _usage() }
    } else {
        eprintln("paper: unknown verb '" + verb + "'")
        _usage()
        exit(2)
    }
}
